---
// /relay/ — Orionfold Relay, the free and open engine for AI agents and
// workflows (the npm package `orionfold-relay`, the former open ainative-business
// engine, renamed). The page states the free-vs-paid boundary plainly, shows the
// premium packs a license unlocks, then the buy block. Built dark (buy buttons
// gated by ORIONFOLD_RELAY_LIVE) while the live prices + fulfilment go live.
//
// Content source (relay later-10, 2026-06-30): mirrored from the peer's canonical
// README (~/orionfold/relay/README.md, commit 1b0b1720) — the constellation
// framing, the agency operating-model table, the five gaps, and the AWS
// personal-project disclaimer (verbatim, it's compliance). Substance + structure
// mirror the README; the voice is retuned to the site rule (grade 3-5, jargon
// explained, em-dashes stripped — the README's polished-pro voice has both). The
// free-vs-paid boundary is the one thing NOT in the README yet (it predates the
// licensing work), sourced to the actual owns_product() gate per the peer's
// later-10 §(a)(2) so page and package agree. Product screenshots for the in-page
// proof sections are pending a fresh DARK-theme Relay-branded set (relay later-14;
// the ones the README hotlinks are stale legacy "ainative" UI). Voice: grade 3-5,
// jargon explained, no em-dashes (website-copy-style).
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import RelayBox from '../components/product/RelayBox.astro';
import RelayProblem from '../components/product/RelayProblem.astro';
import RelaySolution from '../components/product/RelaySolution.astro';
import RelayUnderTheHood from '../components/product/RelayUnderTheHood.astro';
import RelayShowcase from '../components/product/RelayShowcase.astro';
import LandingStickyCta from '../components/product/LandingStickyCta.astro';
import LicenseBand from '../components/product/LicenseBand.astro';
import OfferSlot from '../components/ui/OfferSlot.astro';
import { ORIONFOLD_RELAY_LIVE } from '../data/launch';
import relayPoster from '../assets/projects/orionfold-relay-poster.jpeg';
import relayBoardShot from '../assets/relay/home-list.png';
import relayCostReceipt from '../assets/relay/customers-detail.png';
import { SITE, PERSON } from '../data/seo';
import { RELAY, formatUsd } from '../data/commerce';
import { ogMeta } from '../data/og';

const og = ogMeta('/relay/');
const relayUrl = `${SITE.url}/relay/`;
const ogImageAbs = `${SITE.url}${og.image}`;

// Merchant-listings completeness for the priced Offer below. Same honest values
// as ProductDetail.astro / ProofBox: Orionfold Relay is an instant digital
// license from a US LLC, so free "shipping" (nothing physical) + no returns (a
// delivered, signed license file can't be returned).
const digitalMerchantFields = {
  hasMerchantReturnPolicy: {
    '@type': 'MerchantReturnPolicy',
    applicableCountry: 'US',
    returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
  },
  shippingDetails: {
    '@type': 'OfferShippingDetails',
    shippingRate: { '@type': 'MonetaryAmount', value: '0', currency: 'USD' },
    shippingDestination: { '@type': 'DefinedRegion', addressCountry: 'US' },
  },
};

// SoftwareApplication + Offer so /relay/ reads as the buyable product for answer
// engines. Price = the standard $499 (the durable price after the founding seats
// sell out); the catalog SSOT is the source, never a hardcoded number.
const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Orionfold Relay',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux',
  description:
    'The free and open engine for AI agents and workflows. Install it with npm, run your agents from one place, and unlock premium packs you own with a license.',
  url: relayUrl,
  image: ogImageAbs,
  author: PERSON,
  brand: { '@type': 'Brand', name: 'Orionfold' },
  offers: {
    '@type': 'Offer',
    price: (RELAY.primary.amount / 100).toFixed(2),
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: relayUrl,
    category: 'Software license',
    ...digitalMerchantFields,
  },
};

// What you get free vs what a license unlocks. Stated plainly as a table so the
// boundary can't be overclaimed (same free-vs-paid discipline as Proof).
// Free-vs-paid, sourced to the real CLI gate (owns_product() → product:orionfold-relay,
// relay later-10 §(a)(2)) so the page and the package agree. The engine is a complete,
// free operations layer; a license adds premium packs + updates, not core function.
const freeVsPaid = [
  { free: 'The full engine and command-line tool, forever', paid: 'Premium packs you own' },
  { free: 'Run your own copy, your data stays on your machine', paid: 'One license unlocks every premium pack, not one at a time' },
  { free: 'All 21 agent profiles and 15 service templates', paid: 'The agency pack: real-estate and nonprofit profiles, blueprints, and a customer setup' },
  { free: 'Build apps, track per-client cost, add free and open packs', paid: 'New packs and pack updates for 12 months' },
];

// Proof-band stat tiles. Each carries its Lucide icon inner-paths TWICE: once as
// the small chip (removed in favour of the embossed treatment) and as the large
// faded watermark glyph placed top-right (peer field-notes ArticleCard technique:
// a big low-opacity mark behind a z-indexed body, so the card gains vibrancy +
// identity without gaining height). `accent` flags the emphasis tile.
const statTiles = [
  {
    label: 'AI spend, 30 days',
    value: '$0.05',
    sub: '6 runs · 32,150 tokens',
    icon: '<line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
    accent: false,
  },
  {
    label: 'Retainer (illustrative)',
    value: '~$500<span class="text-lg text-text-muted">/mo</span>',
    sub: 'Property-management client',
    icon: '<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>',
    accent: false,
  },
  {
    label: 'What you see',
    value: 'Real margin',
    sub: 'Tallied per client, per run',
    icon: '<path d="M16 7h6v6"/><path d="m22 7-8.5 8.5-5-5L2 17"/>',
    accent: true,
  },
];

// The own-it trust trio (Gap #4): Relay's most durable, repo-backed claim, said as
// three plain buyer benefits right under the proof band. This is the "rerun it,
// never trust us" brand applied to operations, and every line is backable to a
// docs/trust/ page (same canonical source the deeper trust Q&A links, no drift).
const trustTrio = [
  {
    title: 'Nothing leaves your machine',
    body: 'Relay runs on your own computer. No tracking, no usage reports, no check-ins home.',
    icon: '<rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/>',
    href: '/trust/data-flow/',
  },
  {
    title: 'You own it forever',
    body: 'The engine is open source and your license works offline. If we vanished tomorrow, your setup keeps running.',
    icon: '<path d="M12 2 4 5v6c0 5.5 3.8 9.5 8 11 4.2-1.5 8-5.5 8-11V5Z"/>',
    href: '/trust/continuity/',
  },
  {
    title: 'Verify every network call yourself',
    body: 'Anything that could leave your machine is listed in full, with an off switch. Check it before you run it.',
    icon: '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>',
    href: '/trust/supply-chain/',
  },
];

// The concrete premium pack that exists today plus the named roadmap packs, shown
// as breadth (Gap #6). Only the agency pack has SHIPPED (relay entry); the rest are
// honestly tagged "Planned" so the vertical-pack rail is visible without overclaiming.
const shippedPack = {
  name: 'Agency pack',
  job: 'Run a client agency',
  dek: 'A ready-made setup for agency work in real estate and nonprofits: 7 profiles, 8 blueprints, and a customer setup you drop in instead of wiring from scratch.',
};
const plannedPacks = [
  { name: 'Marketer pack', job: 'Run marketing work' },
  { name: 'Investor pack', job: 'Run investor updates' },
  { name: 'Operations pack', job: 'Run back-office ops' },
];

// The constellation framing (README): where Relay sits in the Orionfold line.
const constellation = [
  { name: 'Proof', q: 'Which AI can I trust?', href: '/proof/' },
  { name: 'Arena', q: 'Which build wins?', href: '/arena/' },
  { name: 'Relay', q: 'Now make the trusted AI do the real work.', href: null, self: true },
];

// The agency operating-model mapping (README "Built for an agency"): how the work
// you already do maps to a Relay building block. Rendered as transformation cards
// (your term -> arrow -> Relay block) with a per-row icon so the "maps straight
// onto Relay" claim is visible, not just stated. Icon = inner paths of a Lucide
// glyph; jargon spelled out in plain words.
const operatingModel = [
  { you: 'Clients', them: 'Projects', note: 'One workspace per client, with their own notes the agents read on their own.', icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { you: 'Kinds of work', them: 'Profiles', note: '21 ready-made agents, each tuned for a job like lease review or grant research.', icon: '<path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/>' },
  { you: 'Services', them: 'Blueprints', note: '15 templates. A packaged service you set up once and run for each client.', icon: '<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>' },
  { you: 'Deliverables', them: 'Schedules', note: 'Weekly digests, monthly statements, and deadline watches that run on their own.', icon: '<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>' },
  { you: 'Billing', them: 'Cost and usage', note: 'Per-client spend you can see, so the retainer maps to real cost.', icon: '<line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>' },
  { you: 'Sign-off', them: 'Inbox', note: 'Every client-facing result goes through your approval, with a full record.', icon: '<path d="M22 12h-6l-2 3h-4l-2-3H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>' },
];

// The five gaps every AI agency hits (README), retuned to plain voice.
const gaps = [
  { title: 'Many steps, one run', body: 'Real client work is a chain: take it in, do it, check it, send it. Relay runs the whole sequence with checkpoints, so you are not gluing steps together by hand.' },
  { title: 'Your words, the agent’s work', body: 'You think in clients, services, and deliverables. Agents think in prompts. Projects, profiles, and blueprints give both a shared language.' },
  { title: 'The whole life of a job', body: 'A deliverable needs scheduling, retries, a way to pick up where it left off, cost tracking, and a record. Relay carries all of it.' },
  { title: 'Trust and sign-off', body: 'Agents that read client files and draft client-facing work need guardrails. Relay routes every result through your approval and keeps the trail funders and stakeholders ask for.' },
  { title: 'One command to start', body: 'Standing up a workspace should not mean cloning a repo and wiring a database. Relay is one command, no setup, and your data stays on your machine.' },
];

// Security and trust (relay later-4 FYI + issue #17 / security-packet.md). Turns
// the four questions a security review asks into plain answers, each linking the
// on-site /trust/ page (which mirrors the canonical Relay repo doc; re-sync in
// src/data/trust-pages.ts when the repo docs change). Marketing-facing rewrite of
// the evaluator-facing source: grade 3-5, jargon spelled out, hard proof one
// click away. `href` is the on-site trust page that backs the claim.
const trust = [
  {
    q: 'Does Relay send our data to you?',
    a: 'No. Relay never sends your data to Orionfold. It runs on your own machine, with no tracking, no usage reporting, and no license check-ins. When it reaches out at all, it only reads public sources, like the one-time, checked download of the app itself from GitHub. Anything that can leave your machine, like the AI models you pick, is listed in full with an off switch.',
    label: 'See every network call',
    href: '/trust/data-flow/',
  },
  {
    q: 'What data do you hold about us?',
    a: 'Only your purchase record. Everything the product touches, your projects, tasks, documents, and history, lives in a file on your own machine. AI work runs through your own model accounts, not ours. We run no service in the middle, so there is nothing for us to hold and no data agreement to chase.',
    label: 'Read the security packet',
    href: '/trust/security-packet/',
  },
  {
    q: 'Can we trust what we install?',
    a: 'Yes, and you can check it before you run it. Every release is published straight from our build with a signed record of where it came from, and ships a full parts list of what is inside. The download is checked against a fingerprint before it opens. Nothing updates itself, so the version you reviewed stays the version you run.',
    label: 'See the supply chain',
    href: '/trust/supply-chain/',
  },
  {
    q: 'What if you disappear?',
    a: 'You keep everything. The engine is open source, your data is on your machine, and your license works offline forever. If Orionfold went away tomorrow, your setup keeps running. The honest edge cases are written down too.',
    label: 'Read the continuity note',
    href: '/trust/continuity/',
  },
];
---
<Layout
  title="Orionfold Relay · Run AI client work and see what each client costs"
  description="Orionfold Relay runs your AI agents for real client work, all on your own machine. Nothing leaves it. See what each client costs, approve every result before it ships, and own it forever. Free and open; own premium packs with a license."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={[
    softwareSchema,
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'Relay', item: relayUrl },
      ],
    },
  ]}
>
  <Nav />
  <main>
    <PageHeader
      eyebrow="Own it · Run it yourself"
      title="Run AI agents for real client work. See what each client costs."
      subtitle="Orionfold Relay runs on your own machine. Nothing leaves it. Point it at your client work, run it across local and cloud models, approve every result before it ships, and watch each client's cost add up on its own. Built for solo founders and small teams doing real work for real clients."
    >
      <!-- Above-fold primary action: Relay's OWN buy CTA, so a cold visitor's
           first action is toward this product, not a sibling. It's a live
           data-checkout button (ONE step straight to Stripe, wired by the page
           script when ORIONFOLD_RELAY_LIVE) rather than a scroll-to-buy-box
           anchor — shortest path from intent to checkout (CRO). When the flag is
           off it falls back to a scroll anchor so no one can pay pre-fulfilment.
           Secondary = the runnable install verb ("own it, run it yourself"). -->
      <div class="mb-4 mt-7 flex flex-col items-start gap-3 sm:flex-row sm:items-center">
        {ORIONFOLD_RELAY_LIVE ? (
          <button
            type="button"
            data-checkout={RELAY.founding.lookupKey}
            data-item="software:orionfold-relay"
            data-error-target="hero-cta-err"
            class="of-primary-action text-base font-semibold"
          >
            Get Orionfold Relay
            <span class="rounded-md bg-black/15 px-2 py-0.5 font-mono text-xs font-medium tracking-wide">{formatUsd(RELAY.founding.amount)} founding</span>
          </button>
        ) : (
          <a
            href="#get-relay"
            class="of-primary-action text-base font-semibold"
          >
            Get Orionfold Relay
            <span class="rounded-md bg-black/15 px-2 py-0.5 font-mono text-xs font-medium tracking-wide">{formatUsd(RELAY.founding.amount)} founding</span>
          </a>
        )}
        <div class="inline-flex items-center gap-2 rounded-xl border border-border/70 bg-surface/60 px-4 py-3">
          <span class="font-mono text-[0.65rem] uppercase tracking-wider text-text-dim">Install</span>
          <code class="font-mono text-sm text-primary">npx orionfold-relay</code>
        </div>
      </div>
      <p id="hero-cta-err" class="mt-3 hidden text-sm text-red-400" role="alert"></p>
    </PageHeader>
    <!-- Sticky-CTA sentinel: the bar fades in once this scrolls out of view.
         mt-10 gives the hero real breathing room before the proof band (the
         shared PageHeader closes with only pb-3). -->
    <div id="hero-cta-sentinel" class="mt-10" aria-hidden="true"></div>

    <!-- ============================================================
         THE PROOF BAND — the single most differentiated shipped asset,
         given its own full-width band so it doesn't get lost between
         sections. Blueprint-grid background (CSS gradient, theme-aware,
         no image), big infographic stat tiles, then the receipt shot
         framed inside (aspect-cropped to its meaningful top so the
         baked-in whitespace below the fold is clipped). This is Relay's
         analog of Proof's quantified receipt: a concrete number a buyer
         can trust, near the top, in the product's own boldest voice.
         ============================================================ -->
    <section class="relay-proof-band relative overflow-hidden border-y border-primary/20 px-6 py-16 sm:py-20">
      <!-- blueprint grid, drawn in CSS so it themes + costs nothing -->
      <div class="relay-blueprint-grid pointer-events-none absolute inset-0" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-primary/[0.04] via-transparent to-primary/[0.04]" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-5xl">
        <div class="mb-2 flex items-center gap-2">
          <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-primary/15 text-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          </span>
          <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">The proof, on one client</p>
        </div>
        <h2 class="max-w-3xl text-balance text-2xl leading-tight sm:text-3xl">
          <span class="font-semibold text-text">$0.05</span> of AI cost against a
          <span class="font-semibold text-text">~$500/mo</span> retainer.
          <span class="text-text-muted">Per-client margin you can <span class="whitespace-nowrap">actually see.</span></span>
        </h2>

        <!-- Infographic stat tiles. Each carries a LARGE faded embossed icon
             top-right (peer ArticleCard watermark technique) so the card reads
             vibrant + identifiable at a shorter height. The icon is absolutely
             positioned + clipped, so it adds zero layout height. -->
        <dl class="mt-8 grid gap-3 sm:grid-cols-3">
          {statTiles.map((t) => (
            <div class={`relative overflow-hidden rounded-2xl border p-5 backdrop-blur-sm ${t.accent ? 'border-primary/30 bg-primary/[0.07]' : 'border-border/60 bg-surface/50'}`}>
              <!-- Embossed watermark icon: big, faint, primary, top-right -->
              <svg
                class={`pointer-events-none absolute -right-4 -top-4 h-28 w-28 ${t.accent ? 'text-primary/[0.14]' : 'text-primary/[0.09]'}`}
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"
                aria-hidden="true" set:html={t.icon}
              />
              <div class="relative z-10">
                <dt class={`font-mono text-[0.65rem] uppercase tracking-wider ${t.accent ? 'text-primary/80' : 'text-text-dim'}`}>{t.label}</dt>
                <dd class={`mt-1.5 font-display text-3xl font-bold ${t.accent ? 'text-primary' : 'text-text'}`} set:html={t.value} />
                <dd class="mt-1 text-xs text-text-muted">{t.sub}</dd>
              </div>
            </div>
          ))}
        </dl>

        <!-- The receipt shot, framed + aspect-cropped to its meaningful top -->
        <figure class="mt-8 overflow-hidden rounded-2xl border border-primary/25 shadow-xl shadow-primary/10">
          <div class="aspect-[16/9] w-full overflow-hidden sm:aspect-[16/8]">
            <Image
              src={relayCostReceipt}
              alt="An Orionfold Relay customer page for Parkview Property Management: AI spend over 30 days reads $0.05 across 6 runs and 32,150 tokens, beside 1 linked project and an active status, with a note showing a roughly $500 a month retainer."
              widths={[720, 1080, 1440]}
              sizes="(min-width: 1024px) 64rem, 100vw"
              loading="lazy"
              decoding="async"
              data-no-zoom
              class="block w-full object-cover object-top"
            />
          </div>
          <figcaption class="border-t border-primary/15 bg-surface/40 px-5 py-3 text-center text-sm text-text-muted">
            Live per-client cost attribution, tallied from real runs. Not a hardcoded billing line.
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- ============================================================
         OWN-IT TRUST TRIO (Gap #4) — Relay's most durable claim as three
         plain buyer benefits, placed high (right under the proof band) so
         the "own it, nothing leaves your machine" axis reinforces the
         margin receipt before the reader scrolls. Each tile links the
         docs/trust/ page that backs it. The deeper 4-question trust
         section stays lower as the evaluator-facing detail.
         ============================================================ -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-5xl">
        <p class="mb-6 text-center font-mono text-[0.65rem] uppercase tracking-[0.24em] text-primary">Yours, not ours</p>
        <div class="grid gap-4 sm:grid-cols-3">
          {trustTrio.map((t) => (
            <a
              href={t.href}
              class="group of-surface flex flex-col rounded-2xl border border-border/70 p-6 transition-colors hover:border-primary/40"
            >
              <span class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={t.icon} />
              </span>
              <p class="text-base font-semibold text-text">{t.title}</p>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">{t.body}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 font-mono text-xs tracking-wider text-primary/80 transition-colors group-hover:text-primary">
                See how
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- The board overview: the "one board for every client" shot, now its own
         calmer moment after the proof band. -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-5xl">
        <div class="aspect-[16/9] overflow-hidden rounded-2xl border border-border/70 shadow-lg shadow-primary/5">
          <Image
            src={relayBoardShot}
            alt="The Orionfold Relay board: active work, tasks that need attention, a live agent activity stream, recent client projects, and today's cost, all on one screen."
            widths={[720, 1080, 1440]}
            sizes="(min-width: 1024px) 64rem, 100vw"
            loading="lazy"
            decoding="async"
            data-no-zoom
            class="block w-full object-cover object-top"
          />
        </div>
        <p class="mt-3 text-center font-mono text-[0.65rem] uppercase tracking-[0.2em] text-text-dim">
          One board for every client
        </p>
      </div>
    </section>

    <!-- Constellation: where Relay sits in the Orionfold line. Demoted below the
         proof band + shrunk to a quiet one-line row so it gives suite context and
         an internal link WITHOUT pulling cold traffic to a sibling product above
         the buy decision. -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-4xl">
        <p class="mb-3 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">The third product in the line</p>
        <div class="flex flex-col gap-2 rounded-2xl border border-border/60 bg-surface/40 p-2 sm:flex-row">
