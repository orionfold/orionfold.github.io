    <LandingStickyCta
      title="Orionfold Relay"
      lookupKey={RELAY.founding.lookupKey}
      priceLabel={formatUsd(RELAY.founding.amount)}
      itemId="software:orionfold-relay"
      live={ORIONFOLD_RELAY_LIVE}
      anchor="#get-relay"
    />
  </main>
  <Footer />
</Layout>

<style>
  /* Blueprint-grid backdrop for the proof band: two layered gradients (fine 24px
     cells + a heavier 120px major line) drawn from the theme's primary color via
     color-mix, so it themes light/dark for free and ships zero image weight.
     Masked to fade at the edges so it reads as texture, not a hard grid. */
  .relay-blueprint-grid {
    --bp-line: color-mix(in oklch, var(--color-primary) 12%, transparent);
    --bp-major: color-mix(in oklch, var(--color-primary) 20%, transparent);
    background-image:
      linear-gradient(to right, var(--bp-line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--bp-line) 1px, transparent 1px),
      linear-gradient(to right, var(--bp-major) 1px, transparent 1px),
      linear-gradient(to bottom, var(--bp-major) 1px, transparent 1px);
    background-size: 24px 24px, 24px 24px, 120px 120px, 120px 120px;
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 45%, black 40%, transparent 100%);
    mask-image: radial-gradient(ellipse 80% 70% at 50% 45%, black 40%, transparent 100%);
  }
</style>

