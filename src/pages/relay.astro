---
// /relay/ — Orionfold Relay, the free and open engine for AI agents and
// workflows (the npm package `orionfold-relay`, the former open ainative-business
// engine, renamed). The page states the free-vs-paid boundary plainly, shows the
// premium packs a license unlocks, then the buy block. Built dark (buy buttons
// gated by ORIONFOLD_RELAY_LIVE) while the live prices + fulfilment go live.
//
// Content source (relay later-10, 2026-06-30): mirrored from the peer's canonical
// README (~/orionfold/relay/README.md, commit 1b0b1720) — the constellation
// framing, the agency operating-model table, the five gaps, and the AWS
// personal-project disclaimer (verbatim, it's compliance). Substance + structure
// mirror the README; the voice is retuned to the site rule (grade 3-5, jargon
// explained, em-dashes stripped — the README's polished-pro voice has both). The
// free-vs-paid boundary is the one thing NOT in the README yet (it predates the
// licensing work), sourced to the actual owns_product() gate per the peer's
// later-10 §(a)(2) so page and package agree. Product screenshots for the in-page
// proof sections are pending a fresh DARK-theme Relay-branded set (relay later-14;
// the ones the README hotlinks are stale legacy "ainative" UI). Voice: grade 3-5,
// jargon explained, no em-dashes (website-copy-style).
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import RelayBox from '../components/product/RelayBox.astro';
import RelayProblem from '../components/product/RelayProblem.astro';
import RelaySolution from '../components/product/RelaySolution.astro';
import RelayUnderTheHood from '../components/product/RelayUnderTheHood.astro';
import RelayShowcase from '../components/product/RelayShowcase.astro';
import LandingStickyCta from '../components/product/LandingStickyCta.astro';
import LicenseBand from '../components/product/LicenseBand.astro';
import OfferSlot from '../components/ui/OfferSlot.astro';
import { ORIONFOLD_RELAY_LIVE } from '../data/launch';
import relayPoster from '../assets/projects/orionfold-relay-poster.jpeg';
import relayBoardShot from '../assets/relay/home-list.png';
import { SITE, PERSON } from '../data/seo';
import { RELAY, formatUsd } from '../data/commerce';
import { ogMeta } from '../data/og';

const og = ogMeta('/relay/');
const relayUrl = `${SITE.url}/relay/`;
const ogImageAbs = `${SITE.url}${og.image}`;

// Merchant-listings completeness for the priced Offer below. Same honest values
// as ProductDetail.astro / ProofBox: Orionfold Relay is an instant digital
// license from a US LLC, so free "shipping" (nothing physical) + no returns (a
// delivered, signed license file can't be returned).
const digitalMerchantFields = {
  hasMerchantReturnPolicy: {
    '@type': 'MerchantReturnPolicy',
    applicableCountry: 'US',
    returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
  },
  shippingDetails: {
    '@type': 'OfferShippingDetails',
    shippingRate: { '@type': 'MonetaryAmount', value: '0', currency: 'USD' },
    shippingDestination: { '@type': 'DefinedRegion', addressCountry: 'US' },
  },
};

// SoftwareApplication + Offer so /relay/ reads as the buyable product for answer
// engines. Price = the standard $499 (the durable price after the founding seats
// sell out); the catalog SSOT is the source, never a hardcoded number.
const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Orionfold Relay',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux',
  description:
    'The free and open engine for AI agents and workflows. Install it with npm, run your agents from one place, and unlock premium packs you own with a license.',
  url: relayUrl,
  image: ogImageAbs,
  author: PERSON,
  brand: { '@type': 'Brand', name: 'Orionfold' },
  offers: {
    '@type': 'Offer',
    price: (RELAY.primary.amount / 100).toFixed(2),
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: relayUrl,
    category: 'Software license',
    ...digitalMerchantFields,
  },
};

// What you get free vs what a license unlocks. Stated plainly as a table so the
// boundary can't be overclaimed (same free-vs-paid discipline as Proof).
// Free-vs-paid, sourced to the real CLI gate (owns_product() → product:orionfold-relay,
// relay later-10 §(a)(2)) so the page and the package agree. The engine is a complete,
// free operations layer; a license adds premium packs + updates, not core function.
const freeVsPaid = [
  { free: 'The full engine and command-line tool, forever', paid: 'Premium packs you own' },
  { free: 'Run your own copy, your data stays on your machine', paid: 'One license unlocks every premium pack, not one at a time' },
  { free: 'All 21 agent profiles and 15 service templates', paid: 'The agency pack: real-estate and nonprofit profiles, blueprints, and a customer setup' },
  { free: 'Build apps, track per-client cost, add free and open packs', paid: 'New packs and pack updates for 12 months' },
];

// The concrete premium pack that exists today (the relay-agency reference pack).
// Kept honest: only what the Relay relay entry says shipped.
const packs = [
  {
    name: 'Agency pack',
    dek: 'A ready-made setup for agency work in real estate and nonprofits: 7 profiles, 8 blueprints, and a customer setup you drop in instead of wiring from scratch.',
  },
];

// The constellation framing (README): where Relay sits in the Orionfold line.
const constellation = [
  { name: 'Proof', q: 'Which AI can I trust?', href: '/proof/' },
  { name: 'Arena', q: 'Which build wins?', href: '/arena/' },
  { name: 'Relay', q: 'Now make the trusted AI do the real work.', href: null, self: true },
];

// The agency operating-model mapping (README "Built for an agency"): how the work
// you already do maps to a Relay building block. Rendered as transformation cards
// (your term -> arrow -> Relay block) with a per-row icon so the "maps straight
// onto Relay" claim is visible, not just stated. Icon = inner paths of a Lucide
// glyph; jargon spelled out in plain words.
const operatingModel = [
  { you: 'Clients', them: 'Projects', note: 'One workspace per client, with their own notes the agents read on their own.', icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { you: 'Kinds of work', them: 'Profiles', note: '21 ready-made agents, each tuned for a job like lease review or grant research.', icon: '<path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/>' },
  { you: 'Services', them: 'Blueprints', note: '15 templates. A packaged service you set up once and run for each client.', icon: '<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>' },
  { you: 'Deliverables', them: 'Schedules', note: 'Weekly digests, monthly statements, and deadline watches that run on their own.', icon: '<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>' },
  { you: 'Billing', them: 'Cost and usage', note: 'Per-client spend you can see, so the retainer maps to real cost.', icon: '<line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>' },
  { you: 'Sign-off', them: 'Inbox', note: 'Every client-facing result goes through your approval, with a full record.', icon: '<path d="M22 12h-6l-2 3h-4l-2-3H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>' },
];

// The five gaps every AI agency hits (README), retuned to plain voice.
const gaps = [
  { title: 'Many steps, one run', body: 'Real client work is a chain: take it in, do it, check it, send it. Relay runs the whole sequence with checkpoints, so you are not gluing steps together by hand.' },
  { title: 'Your words, the agent’s work', body: 'You think in clients, services, and deliverables. Agents think in prompts. Projects, profiles, and blueprints give both a shared language.' },
  { title: 'The whole life of a job', body: 'A deliverable needs scheduling, retries, a way to pick up where it left off, cost tracking, and a record. Relay carries all of it.' },
  { title: 'Trust and sign-off', body: 'Agents that read client files and draft client-facing work need guardrails. Relay routes every result through your approval and keeps the trail funders and stakeholders ask for.' },
  { title: 'One command to start', body: 'Standing up a workspace should not mean cloning a repo and wiring a database. Relay is one command, no setup, and your data stays on your machine.' },
];

// Security and trust (relay later-4 FYI + issue #17 / security-packet.md). Turns
// the four questions a security review asks into plain answers, each linking the
// canonical trust doc in the Relay repo (link, do not mirror: one source, no
// drift, same rule as the license-terms link). Marketing-facing rewrite of the
// evaluator-facing source: grade 3-5, jargon spelled out, hard proof one click
// away. `href` is the repo doc that backs the claim.
const trust = [
  {
    q: 'Does it phone home?',
    a: 'No. Relay runs on your own machine. On a plain install the only call it makes is a one-time, checked download of the app itself from GitHub. There is no tracking, no usage reporting, and no calls back to us. Anything that can leave your machine, like the AI models you pick, is listed in full with an off switch.',
    label: 'See every network call',
    href: 'https://github.com/orionfold/relay/blob/main/docs/trust/data-flow.md',
  },
  {
    q: 'What data do you hold about us?',
    a: 'Only your purchase record. Everything the product touches, your projects, tasks, documents, and history, lives in a file on your own machine. AI work runs through your own model accounts, not ours. We run no service in the middle, so there is nothing for us to hold and no data agreement to chase.',
    label: 'Read the security packet',
    href: 'https://github.com/orionfold/relay/blob/main/docs/trust/security-packet.md',
  },
  {
    q: 'Can we trust what we install?',
    a: 'Yes, and you can check it before you run it. Every release is published straight from our build with a signed record of where it came from, and ships a full parts list of what is inside. The download is checked against a fingerprint before it opens. Nothing updates itself, so the version you reviewed stays the version you run.',
    label: 'See the supply chain',
    href: 'https://github.com/orionfold/relay/blob/main/docs/trust/supply-chain.md',
  },
  {
    q: 'What if you disappear?',
    a: 'You keep everything. The engine is open source, your data is on your machine, and your license works offline forever. If Orionfold went away tomorrow, your setup keeps running. The honest edge cases are written down too.',
    label: 'Read the continuity note',
    href: 'https://github.com/orionfold/relay/blob/main/docs/trust/continuity.md',
  },
];
---
<Layout
  title="Run your AI agents from one place · Orionfold Relay"
  description="Orionfold Relay is the free and open operations layer for AI agents and client work. Run one board for every client, route each result through your approval, and see per-client cost. Install with npm; own premium packs with a license."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={[
    softwareSchema,
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'Relay', item: relayUrl },
      ],
    },
  ]}
>
  <Nav />
  <main>
    <PageHeader
      eyebrow="Operating layer"
      title="Run your agents from one place."
      subtitle="Orionfold Relay is the operations layer for AI builders and small services teams. It is the missing piece between running one agent and running real work for a room full of clients. Point it at your client work, run it across local and cloud models, send every result through your approval, and watch each client's cost add up on its own."
    />
    <!-- Sticky-CTA sentinel: the bar fades in once this scrolls out of view. -->
    <div id="hero-cta-sentinel" aria-hidden="true"></div>

    <!-- Constellation: where Relay sits in the Orionfold line -->
    <section class="px-6 pt-4 pb-10">
      <div class="mx-auto max-w-4xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">The third product in the line</p>
        <p class="mb-6 max-w-2xl text-sm leading-relaxed text-text-muted">
          Proof and Arena help you pick the AI you can trust. Relay is where that trusted AI does the
          real work. It is the only one whose value grows after the testing stops.
        </p>
        <div class="grid gap-3 sm:grid-cols-3">
          {constellation.map((c) => (
            c.self ? (
              <div class="rounded-2xl border border-primary/40 bg-primary/5 p-5">
                <p class="font-display text-lg font-bold text-primary">{c.name}</p>
                <p class="mt-2 text-sm leading-relaxed text-text">{c.q}</p>
              </div>
            ) : (
              <a href={c.href} class="of-surface of-pressable group block rounded-2xl p-5">
                <p class="font-display text-lg font-bold text-text group-hover:text-primary">{c.name}</p>
                <p class="mt-2 text-sm leading-relaxed text-text-muted">{c.q}</p>
              </a>
            )
          ))}
        </div>
      </div>
    </section>

    <!-- The real product: one dark board shot so the visitor sees it early -->
    <section class="px-6 pb-6">
      <div class="mx-auto max-w-5xl">
        <div class="overflow-hidden rounded-2xl border border-border/70 shadow-lg shadow-primary/5">
          <Image
            src={relayBoardShot}
            alt="The Orionfold Relay board: active work, tasks that need attention, a live agent activity stream, recent client projects, and today's cost, all on one screen."
            widths={[720, 1080, 1440]}
            sizes="(min-width: 1024px) 64rem, 100vw"
            loading="lazy"
            decoding="async"
            data-no-zoom
            class="block w-full"
          />
        </div>
        <p class="mt-3 text-center font-mono text-[0.65rem] uppercase tracking-[0.2em] text-text-dim">
          One board for every client
        </p>
      </div>
    </section>

    <!-- The Problem: the gap Relay fills, sized with cited market stats -->
    <RelayProblem />

    <!-- The Solution: Relay in practice, two lanes + shipped platform chips -->
    <RelaySolution />

    <!-- Under the hood: shipped-software metrics + architecture at a glance -->
    <RelayUnderTheHood />

    <!-- See it running: capability beats + one-board proof, dark peer shots -->
    <RelayShowcase />

    <!-- Mid-page CTA: after the problem, solution, proof, and real screens, the
         reader who is already sold can convert here without scrolling to the
         bottom buy box. Same SSOT-priced, launch-flag-gated band. -->
    <LicenseBand
      family={RELAY}
      live={ORIONFOLD_RELAY_LIVE}
      itemId="software:orionfold-relay"
      errId="relay-band-err"
      fullBlockId="get-relay"
      eyebrow="Own the premium packs"
      heading="Skip the setup. Own the packs."
      body="One license unlocks every premium pack you own, starting with the agency pack. The engine stays free; the license is the key that adds a pack with one command."
      enquiryHref="/adoption/?item=software:orionfold-relay"
      image={relayPoster}
      imageAlt="Orionfold Relay poster: one operator at a wide command wall of glowing client panels, running a whole AI agency from one board."
    />

    <!-- What it is + install -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-3xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">Free and open</p>
        <p class="max-w-2xl text-base leading-relaxed text-text-muted">
          The engine is open source and free to use. You install it with npm and it gives you one
          place to run agents and workflows. Nothing is locked behind a paywall to get started.
        </p>
        <div class="mt-6 rounded-2xl border border-border/70 bg-surface/60 p-5">
          <p class="font-mono text-xs uppercase tracking-wider text-text-dim">Install</p>
          <pre class="mt-2 overflow-x-auto font-mono text-sm text-primary"><code>npm i -g orionfold-relay</code></pre>
          <p class="mt-3 text-sm text-text-muted">
            Or run it without installing: <span class="font-mono text-primary">npx orionfold-relay</span>.
            Then <span class="font-mono text-primary">relay</span> is your command.
          </p>
        </div>
      </div>
    </section>

    <!-- Built for an agency: the operating-model mapping as transformation cards.
         Each card reads "your term -> Relay block" with a per-row icon and a
         bridging arrow, so "maps straight onto Relay" is shown, not just told. -->
    <section class="px-6 py-14">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 text-center">
          <p class="mb-3 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-primary">Built for an agency</p>
          <h2 class="mb-4 text-3xl sm:text-4xl">Your way of working, mapped.</h2>
          <p class="mx-auto max-w-2xl text-sm leading-relaxed text-text-muted">
            The way you already run client work maps straight onto Relay. Each part of your day
            becomes a building block, so you are not bending your work to fit a tool.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {operatingModel.map((row) => (
            <div class="group of-surface relative overflow-hidden rounded-2xl border border-border/70 p-6 transition-colors hover:border-primary/40">
              <!-- Icon -->
              <div class="mb-5 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={row.icon} />
              </div>
              <!-- Mapping: your term -> Relay block -->
              <div class="flex items-center gap-2.5">
                <span class="text-base font-semibold text-text">{row.you}</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-primary/60 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
                <span class="rounded-full bg-primary/10 px-3 py-1 font-mono text-xs font-medium tracking-wide text-primary">{row.them}</span>
              </div>
              <p class="mt-3 text-sm leading-relaxed text-text-muted">{row.note}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- The five gaps every AI agency hits -->
    <section class="border-y border-border bg-surface-raised px-6 py-14">
      <div class="mx-auto max-w-3xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">The five gaps every AI agency hits</p>
        <p class="mb-8 max-w-2xl text-sm leading-relaxed text-text-muted">
          AI agents can already abstract a lease, research a grant, or sort a receipt. The hard part
          is everything around that. For an agency, every gap gets bigger with each client you serve.
          Relay is built to close all five.
        </p>
        <ol class="grid gap-4">
          {gaps.map((g, i) => (
            <li class="flex gap-4 rounded-2xl border border-border/70 bg-surface/60 p-5">
              <span class="font-display text-2xl font-bold text-primary/70">{i + 1}</span>
              <div>
                <p class="text-base font-medium text-text">{g.title}</p>
                <p class="mt-1.5 text-sm leading-relaxed text-text-muted">{g.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Free vs paid: two contrasting panels. Free (neutral, check icons) sits
         beside License-adds (primary-accented, plus icons), with a "+" bridge
         between them so the boundary reads as "everything free, and a license
         adds on top" rather than two disconnected columns. -->
    <section class="px-6 py-14">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 text-center">
          <p class="mb-3 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-primary">What is free, what a license adds</p>
          <h2 class="mb-4 text-3xl sm:text-4xl">Free forever, license optional.</h2>
          <p class="mx-auto max-w-2xl text-sm leading-relaxed text-text-muted">
            The engine is free forever. A license unlocks the premium packs you own. Here is the
            line, in plain terms.
          </p>
        </div>

        <div class="relative grid items-stretch gap-4 md:grid-cols-2 md:gap-6">
          <!-- Free panel -->
          <div class="rounded-2xl border border-border/70 bg-surface/60 p-6 sm:p-8">
            <div class="mb-6 flex items-center gap-3">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-text/5 text-text">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>
              </span>
              <div>
                <p class="text-lg font-semibold text-text">Free with the engine</p>
                <p class="font-mono text-[0.65rem] uppercase tracking-wider text-text-dim">Open source, forever</p>
              </div>
            </div>
            <ul class="space-y-4">
              {freeVsPaid.map((row) => (
                <li class="flex items-start gap-3">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-sm leading-relaxed text-text-muted">{row.free}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Bridge "+" (desktop only): sits on the seam between the panels -->
          <div class="pointer-events-none absolute left-1/2 top-1/2 z-10 hidden -translate-x-1/2 -translate-y-1/2 md:block" aria-hidden="true">
            <span class="flex h-11 w-11 items-center justify-center rounded-full border border-primary/30 bg-surface text-primary shadow-lg shadow-primary/10">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
            </span>
          </div>

          <!-- License panel (accented) -->
          <div class="rounded-2xl border border-primary/40 bg-primary/[0.06] p-6 shadow-lg shadow-primary/5 sm:p-8">
            <div class="mb-6 flex items-center gap-3">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-primary/15 text-primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.4 7.4H22l-6 4.6 2.3 7.4-6.3-4.6L5.7 21.4 8 14 2 9.4h7.6z"/></svg>
              </span>
              <div>
                <p class="text-lg font-semibold text-primary">A license adds</p>
                <p class="font-mono text-[0.65rem] uppercase tracking-wider text-primary/70">On top of everything free</p>
              </div>
            </div>
            <ul class="space-y-4">
              {freeVsPaid.map((row) => (
                <li class="flex items-start gap-3">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-primary" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                  <span class="text-sm leading-relaxed text-text">{row.paid}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <p class="mx-auto mt-8 max-w-2xl text-center text-sm leading-relaxed text-text-muted">
          The free engine is not a trial or a cut-down version. It is a complete operations layer you
          can run for real. A license adds premium packs and their updates. It does not unlock core
          features you would otherwise be missing. This is a promise we hold every product to: read
          <a href="/promise/" class="text-primary hover:text-primary/80 transition-colors">how our gating works</a>.
        </p>
      </div>
    </section>

    <!-- Premium packs a license unlocks -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-3xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">Packs you can own</p>
        <p class="mb-8 max-w-2xl text-sm leading-relaxed text-text-muted">
          A pack is a ready-made setup you drop in with one command instead of building it yourself.
          Your license adds it: run <span class="font-mono text-primary">relay pack add</span> with your
          own private link and it installs.
        </p>
        <ul class="grid gap-3">
          {packs.map((p) => (
            <li class="rounded-2xl border border-border/70 bg-surface/60 p-5">
              <p class="text-base font-medium text-text">{p.name}</p>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">{p.dek}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Security and trust: the last objection to clear before the price. Four
         plain answers to what a security review asks, each linking the canonical
         trust doc in the Relay repo. -->
    <section class="border-y border-border bg-surface-raised px-6 py-14">
      <div class="mx-auto max-w-3xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-primary">Security and trust</p>
        <h2 class="mb-4 text-3xl sm:text-4xl">Built to pass a security review.</h2>
        <p class="mb-8 max-w-2xl text-sm leading-relaxed text-text-muted">
          Relay runs on your own machine, holds none of your data, and keeps working even if we
          do not. Here are the four questions a careful buyer asks, answered in plain words, each
          backed by a page that links the code that proves it.
        </p>
        <ul class="grid gap-4">
          {trust.map((t) => (
            <li class="rounded-2xl border border-border/70 bg-surface/60 p-6">
              <p class="text-base font-semibold text-text">{t.q}</p>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">{t.a}</p>
              <a
                href={t.href}
                target="_blank"
                rel="noopener"
                class="mt-4 inline-flex items-center gap-1.5 font-mono text-xs tracking-wider text-primary transition-colors hover:text-primary/80"
              >
                {t.label}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </a>
            </li>
          ))}
        </ul>
        <p class="mt-6 max-w-2xl text-sm leading-relaxed text-text-muted">
          Found a security problem? Report it privately and we reply within three days:
          <a href="https://github.com/orionfold/relay/security/advisories/new" target="_blank" rel="noopener" class="text-primary hover:text-primary/80 transition-colors">open a private advisory</a>.
        </p>
      </div>
    </section>

    <!-- Own the premium packs: lead with the buy block -->
    <RelayBox />

    <!-- Soft opt-in below the buy: catch readers who aren't checkout-ready yet -->
    <OfferSlot
      offer="become-ai-native-business"
      source="relay-page"
      label="Not ready to buy?"
      heading="Start with the free book."
      dek="Get the AI Native Business book free, and a note when we ship a new Relay pack you can own."
      artifact="PDF + EPUB, plus new-pack notes"
      buttonText="Send it"
    />

    <!-- Persistent Buy bar: one tap away once the hero scrolls past. Same
         founding price + data-checkout wiring as RelayBox (SSOT-driven). -->
    <LandingStickyCta
      title="Orionfold Relay"
      lookupKey={RELAY.founding.lookupKey}
      priceLabel={formatUsd(RELAY.founding.amount)}
      itemId="software:orionfold-relay"
      live={ORIONFOLD_RELAY_LIVE}
      anchor="#get-relay"
    />
  </main>
  <Footer />
</Layout>

<script>
  // Wire the Relay purchase buttons (data-checkout → create-checkout-session →
  // Stripe). No-op when the buttons aren't rendered (ORIONFOLD_RELAY_LIVE off).
  import { wireCheckoutButtons } from '../lib/checkout';
  wireCheckoutButtons();
  document.addEventListener('astro:after-swap', () => wireCheckoutButtons());
</script>
