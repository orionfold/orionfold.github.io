---
// Models showcase (S8). Six open-weight models + one benchmark dataset, all
// live under huggingface.co/Orionfold, built from src/data/models.ts. Grouped
// by domain (spec §6): the Patent Strategist gets its own block (one model,
// two NeMo builds), the four single-domain models share a grid, and the dataset
// stands alone. A page-level BehindTheScenes holds the real benchmark detail so
// the cards stay grade 3–5 (spec §7 — Models is the second technical page).
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ModelCard from '../components/ui/ModelCard.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';
import BehindTheScenes from '../components/ui/BehindTheScenes.astro';
import { models } from '../data/models';
import { ogMeta } from '../data/og';
import { bentoSplit } from '../lib/bento';

const patent = models.filter((m) => m.group === 'patent');
const domain = models.filter((m) => m.group === 'domain');
const dataset = models.filter((m) => m.group === 'dataset');
// Odd 3+ sections lead with a full-width featured card (the shared bento rule).
// With today's counts (patent 2, domain 4) neither leads; wired for future growth.
const patentSplit = bentoSplit(patent);
const domainSplit = bentoSplit(domain);
const og = ogMeta('/models/');

// Resolve a model's curated comic cover (a path under src/assets/models/, e.g.
// "patent-strategist/cover.png") to ImageMetadata via a glob. Absent → the card
// falls back to its seeded constellation motif. Mirrors software.astro.
const modelImgs = import.meta.glob<{ default: ImageMetadata }>('../assets/models/**/*.{png,jpg,jpeg}', { eager: true });
function resolveCover(key?: string): ImageMetadata | undefined {
  if (!key) return undefined;
  const entry = Object.entries(modelImgs).find(([path]) => path.endsWith('/' + key));
  return entry?.[1]?.default;
}
---
<Layout
  title="Models · Orionfold"
  description="Open-weight AI models tuned for patents, security, law, finance, and medicine. Free to download and run offline, on huggingface.co/Orionfold."
  ogImage={og.image}
  ogImageAlt={og.alt}
>
  <Nav />
  <main>
    <!-- Page header -->
    <section class="px-6 pt-36 pb-4 text-center sm:pt-40">
      <div class="mx-auto max-w-3xl">
        <SectionLabel text="Models" />
        <h1 data-animate class="mb-5 mt-4">AI tuned for your field</h1>
        <p data-animate class="mx-auto max-w-2xl text-lg leading-relaxed text-text-muted" style="transition-delay: 80ms">
          Open AI models built for one job each, like patents, security, law, money, and health. All are free to download and run in private, right on your own computer.
        </p>
      </div>
    </section>

    <!-- Patent: one model, two NeMo builds -->
    <section class="px-6 pt-12">
      <div class="mx-auto max-w-5xl">
        <div class="mb-8 text-center">
          <h2 data-animate>Patent Strategist</h2>
          <p data-animate class="mx-auto mt-3 max-w-2xl leading-relaxed text-text-muted" style="transition-delay: 80ms">
            Our flagship model reads and reasons about patents fully offline. Built with the NeMo toolkit, it comes in two formats: ready-to-run files, or a small add-on patch for builders.
          </p>
        </div>
        {patentSplit.lead && <ModelCard {...patentSplit.lead} cover={resolveCover(patentSplit.lead.cover)} featured />}
        <div data-animate-stagger class:list={['grid gap-6 sm:grid-cols-2', patentSplit.lead && 'mt-6']}>
          {patentSplit.rest.map((m) => <ModelCard {...m} cover={resolveCover(m.cover)} />)}
        </div>
      </div>
    </section>

    <!-- One model per domain -->
    <section class="px-6 pt-20">
      <div class="mx-auto max-w-5xl">
        <div class="mb-8 text-center">
          <h2 data-animate>More domain models</h2>
          <p data-animate class="mx-auto mt-3 max-w-2xl leading-relaxed text-text-muted" style="transition-delay: 80ms">
            Each one is tuned for a single field, so it knows the words and rules of that work.
          </p>
        </div>
        {domainSplit.lead && <ModelCard {...domainSplit.lead} cover={resolveCover(domainSplit.lead.cover)} featured />}
        <div data-animate-stagger class:list={['grid gap-6 sm:grid-cols-2', domainSplit.lead && 'mt-6']}>
          {domainSplit.rest.map((m) => <ModelCard {...m} cover={resolveCover(m.cover)} />)}
        </div>
      </div>
    </section>

    <!-- Benchmark dataset -->
    <section class="px-6 pt-20">
      <div class="mx-auto max-w-5xl">
        <div class="mb-8 text-center">
          <h2 data-animate>Benchmark dataset</h2>
          <p data-animate class="mx-auto mt-3 max-w-2xl leading-relaxed text-text-muted" style="transition-delay: 80ms">
            The test set we use to check how well a model reasons about patents.
          </p>
        </div>
        <div class="mx-auto grid max-w-2xl gap-6">
          {dataset.map((m) => <ModelCard {...m} cover={resolveCover(m.cover)} />)}
        </div>
      </div>
    </section>

    <!-- Technical depth (held back from the cards per spec §7) -->
    <section class="px-6 pb-28 pt-16">
      <div data-animate>
        <BehindTheScenes summary="The technical details">
          All weights are open and free to run. The two Patent Strategist builds start from DeepSeek-R1-0528-Qwen3-8B, are made with the NeMo toolkit, and ship two ways: GGUF files (ready to run with llama.cpp) and LoRA adapters (small training patches in BF16). On Spark-class hardware (a small ~$3,000 AI desktop) the Q5_K_M GGUF runs around 32 to 35 tokens per second. SecurityLLM builds on ZySec-AI/SecurityLLM, Saul 7B on Equall/Saul-7B-Instruct-v1, Finance Chat on AdaptLLM/finance-chat, and II-Medical 8B on Intelligent-Internet/II-Medical-8B, each shipped as GGUF from Q4 through Q8 and F16, and scored on domain tests like CyberMetric, LegalBench, FinanceBench, and MedMCQA. The Patent Strategist Bench is 200 questions across seven shapes (claim drafting, prior-art ranking, MPEP-grounded reasoning, and more), released CC-BY-4.0.
        </BehindTheScenes>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
