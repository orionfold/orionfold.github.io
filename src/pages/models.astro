---
// Models showcase (S8). Six open-weight models + one benchmark dataset, all
// live under huggingface.co/Orionfold, built from src/data/models.ts. Grouped
// by domain (spec §6): the Patent Strategist gets its own block (one model,
// two NeMo builds), the four single-domain models share a grid, and the dataset
// stands alone. A page-level BehindTheScenes holds the real benchmark detail so
// the cards stay grade 3–5 (spec §7 — Models is the second technical page).
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ModelCard from '../components/ui/ModelCard.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import BehindTheScenes from '../components/ui/BehindTheScenes.astro';
import { models } from '../data/models';
import { ogMeta } from '../data/og';
import { bentoSplit } from '../lib/bento';
import { detailKeySet, slugify } from '../lib/product/detail';

// A model's join slug is slugify(title) (build variants collapse to one detail
// page); link a card inward when that slug has a detail entry (spec §3).
const detailKeys = await detailKeySet();
const detailHrefFor = (title: string) => {
  const slug = slugify(title);
  return detailKeys.has(`model:${slug}`) ? `/models/${slug}/` : undefined;
};

const patent = models.filter((m) => m.group === 'patent');
const domain = models.filter((m) => m.group === 'domain');
const dataset = models.filter((m) => m.group === 'dataset');
// Odd 3+ sections lead with a full-width featured card (the shared bento rule).
// With today's counts (patent 2, domain 4) neither leads; wired for future growth.
const patentSplit = bentoSplit(patent);
const domainSplit = bentoSplit(domain);
const og = ogMeta('/models/');

// Resolve a model's curated comic cover (a path under src/assets/models/, e.g.
// "patent-strategist/cover.png") to ImageMetadata via a glob. Absent → the card
// falls back to its seeded constellation motif. Mirrors software.astro.
const modelImgs = import.meta.glob<{ default: ImageMetadata }>('../assets/models/**/*.{png,jpg,jpeg}', { eager: true });
function resolveCover(key?: string): ImageMetadata | undefined {
  if (!key) return undefined;
  const entry = Object.entries(modelImgs).find(([path]) => path.endsWith('/' + key));
  return entry?.[1]?.default;
}
---
<Layout
  title="Models · Orionfold"
  description="Open-weight AI models tuned for patents, security, law, finance, and medicine. Download and run offline, on huggingface.co/Orionfold."
  ogImage={og.image}
  ogImageAlt={og.alt}
>
  <Nav />
  <main>
    <!-- Page header (slim masthead so the model covers rise above the fold) -->
    <PageHeader
      eyebrow="Models"
      title="AI tuned for your field"
      subtitle="Open AI models built for one job each, like patents, security, law, money, and health. Download and run them in private, right on your own computer."
    />

    <!-- Patent: one model, two NeMo builds -->
    <section class="px-6 pt-12">
      <div class="mx-auto max-w-6xl">
        <div class="mb-6">
          <SectionLabel text="Flagship Model" />
          <p class="mt-2 max-w-2xl leading-relaxed text-text-muted">
            This model reads and reasons about patents fully offline. Built with the NeMo toolkit, it comes in two formats: ready-to-run files, or a small add-on patch for builders.
          </p>
        </div>
        {patentSplit.lead && <ModelCard {...patentSplit.lead} cover={resolveCover(patentSplit.lead.cover)} detailHref={detailHrefFor(patentSplit.lead.title)} featured priority />}
        <div data-animate-stagger class:list={['grid gap-6 sm:grid-cols-2', patentSplit.lead && 'mt-6']}>
          {patentSplit.rest.map((m, index) => <ModelCard {...m} cover={resolveCover(m.cover)} detailHref={detailHrefFor(m.title)} priority={!patentSplit.lead && index === 0} />)}
        </div>
      </div>
    </section>

    <!-- One model per domain -->
    <section class="px-6 pt-20">
      <div class="mx-auto max-w-6xl">
        <div class="mb-6">
          <SectionLabel text="More domain models" />
          <p class="mt-2 max-w-2xl leading-relaxed text-text-muted">
            Each one is tuned for a single field, so it knows the words and rules of that work.
          </p>
        </div>
        {domainSplit.lead && <ModelCard {...domainSplit.lead} cover={resolveCover(domainSplit.lead.cover)} detailHref={detailHrefFor(domainSplit.lead.title)} featured />}
        <div data-animate-stagger class:list={['grid gap-6 sm:grid-cols-2', domainSplit.lead && 'mt-6']}>
          {domainSplit.rest.map((m) => <ModelCard {...m} cover={resolveCover(m.cover)} detailHref={detailHrefFor(m.title)} />)}
        </div>
      </div>
    </section>

    <!-- Benchmark dataset -->
    <section class="px-6 pt-20">
      <div class="mx-auto max-w-6xl">
        <div class="mb-6">
          <SectionLabel text="Benchmark dataset" />
          <p class="mt-2 max-w-2xl leading-relaxed text-text-muted">
            The test set we use to check how well a model reasons about patents.
          </p>
        </div>
        {dataset.map((m) => <ModelCard {...m} cover={resolveCover(m.cover)} detailHref={detailHrefFor(m.title)} featured />)}
      </div>
    </section>

    <!-- Technical depth (held back from the cards per spec §7) -->
    <section class="px-6 pb-28 pt-16">
      <div data-animate>
        <BehindTheScenes summary="The technical details">
          All weights are open. The two Patent Strategist builds start from DeepSeek-R1-0528-Qwen3-8B, are made with the NeMo toolkit, and ship two ways: GGUF files (ready to run with llama.cpp) and LoRA adapters (small training patches in BF16). On Spark-class hardware (a small ~$3,000 AI desktop) the Q5_K_M GGUF runs around 32 to 35 tokens per second. SecurityLLM builds on ZySec-AI/SecurityLLM, Saul 7B on Equall/Saul-7B-Instruct-v1, Finance Chat on AdaptLLM/finance-chat, and II-Medical 8B on Intelligent-Internet/II-Medical-8B, each shipped as GGUF from Q4 through Q8 and F16, and scored on domain tests like CyberMetric, LegalBench, FinanceBench, and MedMCQA. The Patent Strategist Bench is 200 questions across seven shapes (claim drafting, prior-art ranking, MPEP-grounded reasoning, and more), released CC-BY-4.0.
        </BehindTheScenes>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
