---
// Books showcase (S6). Two cards built from src/data/books.ts, each linking out
// to its canonical home on ainative.business. Reuses the homepage Highlight
// band (two-column, alternating sides) so the showcase keeps the homepage
// rhythm; covers are CSS-only placeholders (real artwork is a later spec).
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Highlight from '../components/ui/Highlight.astro';
import BookCover from '../components/ui/BookCover.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import { books } from '../data/books';
import aiNativeCover from '../assets/book/ai-native-business-book.jpg';
import aiResearchCover from '../assets/book/ai-research-dgx-spark-book.jpg';
import aiNativePlatformCover from '../assets/book/ai-native-platform-book.jpg';
import { ogMeta } from '../data/og';
import { getCatalogItem, formatUsd } from '../data/commerce';
import { detailKeySet } from '../lib/product/detail';

// Books with an on-site detail page link the band's secondary CTA inward (to the
// chapter list + buy box), keeping the Buy button; others keep the external
// "read free" link (spec §3).
const detailKeys = await detailKeySet();

// Buy-button label per book: "Buy PDF + EPUB · $20" (price from the catalog,
// which mirrors Stripe; the checkout fn resolves the real price by lookup key).
function buyText(lookupKey: string): string {
  const item = getCatalogItem(lookupKey);
  return item ? `Buy PDF + EPUB · ${formatUsd(item.amount)}` : 'Buy the bundle';
}

// Every book has real cover artwork (keyed by slug); any book without an
// entry here falls back to the CSS placeholder cover.
const covers: Record<string, ImageMetadata> = {
  'ai-native-business': aiNativeCover,
  'ai-research-on-nvidia-dgx-spark': aiResearchCover,
  'ai-native-platform': aiNativePlatformCover,
};
const og = ogMeta('/books/');
---
<Layout
  title="AI Native Business books · Orionfold"
  description="The AI Native Business book, AI Research Field Notes, and the AI Native Platform walkthrough. Open and grounded in real, working code."
  ogImage={og.image}
  ogImageAlt={og.alt}
>
  <Nav />
  <main>
    <!-- Page header (slim masthead so the book covers rise above the fold) -->
    <PageHeader
      eyebrow="Books"
      title="Playbooks for owning AI capability"
      subtitle="Three books on building with AI, written from working code. One on running a business with AI agents, one on doing AI research on a desktop you own, and one on the open platform that runs the agents. They are the playbooks behind every Orionfold offer."
    />

    {books.map((book, i) => {
      const hasDetail = detailKeys.has(`book:${book.slug}`);
      return (
      <Highlight
        eyebrow={book.eyebrow}
        title={book.title}
        body={book.body}
        pills={book.pills}
        href={hasDetail ? `/books/${book.slug}/` : book.href}
        ctaText={hasDetail ? 'Details' : book.ctaText}
        external={!hasDetail}
        reverse={i % 2 === 1}
        buyLookupKey={book.lookupKey}
        buyText={buyText(book.lookupKey)}
      >
        {hasDetail ? (
          <a slot="media" href={`/books/${book.slug}/`} aria-label={`See ${book.title} details`} class="block">
            <BookCover title={book.cover.title} subtitle={book.cover.subtitle} tag={book.cover.tag} image={covers[book.slug]} eager={i === 0} />
          </a>
        ) : (
          <BookCover slot="media" title={book.cover.title} subtitle={book.cover.subtitle} tag={book.cover.tag} image={covers[book.slug]} eager={i === 0} />
        )}
      </Highlight>
      );
    })}
  </main>
  <Footer />
</Layout>

<script>
  // Wire the "Buy PDF + EPUB" buttons to Stripe Checkout (C4). CORS-fails on
  // localhost (allowlist is orionfold.com); the live buy test is L1.
  import { wireCheckoutButtons } from '../lib/checkout';
  wireCheckoutButtons();
  document.addEventListener('astro:after-swap', () => wireCheckoutButtons());
</script>
