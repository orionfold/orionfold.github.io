---
// Story index (S9). Lists every post in the `story` collection, newest first.
// Cards are the shared StoryCard (also used by the homepage carousel) in a
// scroll-reveal grid. Posts are plain .md under src/content/story/.
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import StoryCard from '../../components/ui/StoryCard.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import { ogMeta } from '../../data/og';
import { bentoSplit } from '../../lib/bento';

const posts = (await getCollection('story')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
// Two per row; the shared bento rule leads with a full-width hero (image left,
// text right) when the count is odd (3+) so the grid below always pairs up.
const { lead, rest } = bentoSplit(posts);
const og = ogMeta('/story/');
---
<Layout
  title="Story · Orionfold"
  description="Building in public: short, honest notes on what we shipped, what broke, and what we learned along the way."
  ogImage={og.image}
  ogImageAlt={og.alt}
>
  <Nav />
  <main>
    <!-- Page header (slim masthead so the story comics rise above the fold) -->
    <PageHeader
      eyebrow="Story"
      title="From the build log"
      subtitle="We build in public. Each note is a short, honest look at what we shipped, what broke, and what we learned."
    />

    <!-- Post grid: optional full-width lead, then two per row -->
    <section class="px-6 pb-28 pt-8">
      <div class="mx-auto max-w-6xl">
        {lead && (
          <StoryCard
            href={`/story/${lead.id}/`}
            title={lead.data.title}
            date={lead.data.date}
            tag={lead.data.tags[0]}
            summary={lead.data.summary}
            seed={lead.data.accent}
            cover={lead.data.hero}
            coverAlt={lead.data.heroAlt}
            featured
            animate
          />
        )}
        <div data-animate-stagger class:list={['grid gap-6 sm:grid-cols-2', lead && 'mt-6']}>
          {rest.map((post) => (
            <StoryCard
              href={`/story/${post.id}/`}
              title={post.data.title}
              date={post.data.date}
              tag={post.data.tags[0]}
              summary={post.data.summary}
              seed={post.data.accent}
              cover={post.data.hero}
              coverAlt={post.data.heroAlt}
              animate
            />
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
