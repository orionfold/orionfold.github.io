---
// Story post (S9). One page per `story` collection entry. A light article
// layout (no reader-settings/TOC machinery from the donor — out of scope per
// spec §2): header with tag/date/title/summary, the rendered .md body in a
// .story-prose container, and a back link. trailingSlash:'always' → the route
// lives at /story/<slug>/.
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { ogPath, storyOgSlug } from '../../../data/og';

export async function getStaticPaths() {
  const posts = await getCollection('story');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, summary, tags, hero, heroAlt } = post.data;

// timeZone:'UTC' so a date-only frontmatter value (parsed as UTC midnight) shows
// the authored day, not the day before in a behind-UTC build/local timezone.
const dateFmt = new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'UTC' }).format(date);
const dateIso = date.toISOString().slice(0, 10);
---
<Layout
  title={`${title} · Orionfold`}
  description={summary}
  ogImage={ogPath(storyOgSlug(post.id))}
  ogImageAlt={`${title} · Orionfold story`}
  ogType="article"
  article={{
    datePublished: dateIso,
    dateModified: dateIso,
    author: 'Manav Sehgal',
    section: 'Story',
    tags,
  }}
>
  <Nav />
  <main class="px-6 pt-36 pb-28 sm:pt-40">
    <article class="mx-auto max-w-2xl">
      <a href="/story/" class="inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-[0.15em] text-text-muted transition-colors hover:text-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
        All stories
      </a>

      {hero && (
        <Image
          src={hero}
          alt={heroAlt ?? title}
          widths={[480, 768, 1024]}
          sizes="(min-width: 768px) 42rem, 100vw"
          loading="eager"
          decoding="async"
          data-no-zoom
          class="mt-8 aspect-[16/9] w-full rounded-xl border border-border object-cover"
        />
      )}

      <header class="mt-8">
        <div class="mb-4 flex flex-wrap items-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-text-muted">
          {tags[0] && <span class="text-primary">{tags[0]}</span>}
          <time datetime={dateIso}>{dateFmt}</time>
        </div>
        <h1 class="leading-tight" style="font-size: clamp(2rem, 5vw, 3rem);">{title}</h1>
        <p class="mt-5 text-lg leading-relaxed text-text-muted">{summary}</p>
      </header>

      <div class="story-prose mt-12 border-t border-border pt-10">
        <Content />
      </div>

      {tags.length > 0 && (
        <ul class="mt-12 flex flex-wrap gap-1.5" aria-label="Tags">
          {tags.map((tag) => (
            <li>
              <span class="rounded-full border border-primary/20 bg-primary/5 px-2.5 py-1 font-mono text-[10px] tracking-wider text-primary">
                {tag}
              </span>
            </li>
          ))}
        </ul>
      )}
    </article>
  </main>
  <Footer />
</Layout>
