---
// Story post (S9). One page per `story` collection entry. A light article
// layout (no reader-settings/TOC machinery from the donor — out of scope per
// spec §2): header with tag/date/title/summary, the rendered .md body in a
// .story-prose container, and a back link. trailingSlash:'always' → the route
// lives at /story/<slug>/.
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import StorySubscribe from '../../../components/sections/StorySubscribe.astro';
import StoryPrevNext from '../../../components/story/StoryPrevNext.astro';
import ProofCTA from '../../../components/story/ProofCTA.astro';
import { ogPath, storyOgSlug } from '../../../data/og';
import { SITE, PERSON, PUBLISHER } from '../../../data/seo';

// Mid-article CTA for the Orionfold Proof field-note cluster. Keyed by story
// slug: a story gets a CTA injected into the middle of its body (at the
// `::proof-cta` directive, see remark-proof-cta) only if it appears here.
// Copy + CTA text are chosen per story so the card matches the article it sits
// in. The thumbnail is the Orionfold Proof featured poster (landscape key art) —
// it grabs attention and stays undistorted in the narrow CTA panel, where the
// tall product screenshots squished. One poster across all three keeps the
// product's face consistent.
import proofPoster from '../../../assets/proof/orionfold-proof-poster.jpeg';

const POSTER_ALT = 'Orionfold Proof poster: a laptop on a desk emitting a long signed receipt under a star constellation, with the gold title Orionfold Proof.';

const PROOF_CTA = {
  'a-4b-model-scored-18-out-of-21-on-my-laptop': {
    thumb: proofPoster,
    thumbAlt: POSTER_ALT,
    title: 'Orionfold Proof',
    description: 'The tool that ran this bench. Point it at your own task, run any model local or cloud, and get a signed, rerunnable receipt that shows the failures too.',
    ctaText: 'Run your own bench',
  },
  'the-famous-model-lost': {
    thumb: proofPoster,
    thumbAlt: POSTER_ALT,
    title: 'Orionfold Proof',
    description: 'The cockpit behind this head-to-head. Put the famous model and a small local one on the same task and let the receipt decide, on your machine, for nothing.',
    ctaText: 'Compare your models',
  },
  'same-input-same-receipt': {
    thumb: proofPoster,
    thumbAlt: POSTER_ALT,
    title: 'Orionfold Proof',
    description: 'Every run writes a signed receipt with a config hash, so anyone can rerun it and confirm they ran the same thing. A benchmark you can hand over, not a screenshot.',
    ctaText: 'See the receipts',
  },
} as const;

export async function getStaticPaths() {
  const posts = await getCollection('story');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, summary, tags, hero, heroAlt } = post.data;

const proofCta = PROOF_CTA[post.id as keyof typeof PROOF_CTA];

// Ascending by date (oldest → newest) so a left-to-right walk in the index IS
// the founder-arc walk. StoryPrevNext picks neighbors by simple index math.
const allStories = (await getCollection('story')).sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime(),
);

// timeZone:'UTC' so a date-only frontmatter value (parsed as UTC midnight) shows
// the authored day, not the day before in a behind-UTC build/local timezone.
const dateFmt = new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'UTC' }).format(date);
const dateIso = date.toISOString().slice(0, 10);

// Page-specific JSON-LD (N10). Layout appends these after the global
// Organization node. BlogPosting makes each story eligible for article rich
// results + gives answer engines a clean author/date/headline triple; the
// author resolves to /about/ (a Person/ProfilePage) for E-E-A-T. The
// BreadcrumbList matches the Home → listing → page trail every other inner
// page (books/products/about) already ships.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogPath(storyOgSlug(post.id)), Astro.site).href;

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: summary,
  image: ogImageUrl,
  datePublished: dateIso,
  dateModified: dateIso,
  author: { ...PERSON, url: `${SITE.url}/about/` },
  publisher: PUBLISHER,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  url: canonical,
  inLanguage: 'en',
  articleSection: 'Story',
  ...(tags.length ? { keywords: tags.join(', ') } : {}),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Story', item: `${SITE.url}/story/` },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
};
---
<Layout
  title={`${title} · Orionfold`}
  description={summary}
  ogImage={ogPath(storyOgSlug(post.id))}
  ogImageAlt={`${title} · Orionfold story`}
  ogType="article"
  article={{
    datePublished: dateIso,
    dateModified: dateIso,
    author: 'Manav Sehgal',
    section: 'Story',
    tags,
  }}
  jsonLd={[blogPostingSchema, breadcrumbSchema]}
>
  <Nav />
  <main class="px-6 pt-36 pb-28 sm:pt-40">
    <article class="mx-auto max-w-2xl">
      <a href="/story/" class="inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-[0.15em] text-text-muted transition-colors hover:text-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
        All stories
      </a>

      {hero && (
        <Image
          src={hero}
          alt={heroAlt ?? title}
          widths={[480, 768, 1024]}
          sizes="(min-width: 768px) 42rem, 100vw"
          priority
          data-no-zoom
          class="mt-8 aspect-[16/9] w-full rounded-xl border border-border object-cover"
        />
      )}

      <header class="mt-8">
        <div class="mb-4 flex flex-wrap items-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-text-muted">
          {tags[0] && <span class="text-primary">{tags[0]}</span>}
          <time datetime={dateIso}>{dateFmt}</time>
        </div>
        <h1 class="leading-tight" style="font-size: clamp(2rem, 5vw, 3rem);">{title}</h1>
        <p class="mt-5 text-lg leading-relaxed text-text-muted">{summary}</p>
      </header>

      <div class="story-prose mt-12 border-t border-border pt-10">
        <Content />
      </div>

      {proofCta && (
        <>
          {/* Server-rendered once, hidden; the inline script below moves it into
              the `::proof-cta` slot inside the body so it sits mid-article. The
              thumbnail still flows through <Image> (it lives outside <Content/>,
              so the body's own inline images are untouched). Hidden-until-placed
              = no flash; if JS is off it stays appended right after the body,
              still a valid CTA. */}
          <div id="proof-cta-source" hidden>
            <ProofCTA
              thumb={proofCta.thumb}
              thumbAlt={proofCta.thumbAlt}
              title={proofCta.title}
              description={proofCta.description}
              ctaText={proofCta.ctaText}
            />
          </div>
          <script is:inline>
            (() => {
              const src = document.getElementById('proof-cta-source');
              const slot = document.querySelector('[data-proof-cta-slot]');
              if (!src) return;
              const card = src.firstElementChild;
              if (!card) { src.remove(); return; }
              if (slot) {
                slot.replaceWith(card);
              } else {
                // No midpoint marker in this body: drop the CTA right after the
                // article body as a graceful fallback.
                src.parentElement.insertBefore(card, src);
              }
              src.remove();
            })();
          </script>
        </>
      )}

      {tags.length > 0 && (
        <ul class="mt-12 flex flex-wrap gap-1.5" aria-label="Tags">
          {tags.map((tag) => (
            <li>
              <span class="rounded-full border border-primary/20 bg-primary/5 px-2.5 py-1 font-mono text-[10px] tracking-wider text-primary">
                {tag}
              </span>
            </li>
          ))}
        </ul>
      )}
    </article>
  </main>

  <!-- Read-next/prev within the arc; renders nothing at the ends if neither neighbor exists -->
  <StoryPrevNext current={post} posts={allStories} />

  <!-- Subscribe to stories (H3): same capture block as the story index -->
  <StorySubscribe class="border-t border-border" />
  <Footer />
</Layout>
