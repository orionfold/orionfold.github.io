---
// /arena/ — Orionfold Arena, the eval cockpit. The single canonical flagship
// landing + conversion surface, parallel to /proof/ + /relay/. Nav "Arena" points
// here (2026-07-01, repointed from /cockpit/). /cockpit/ stays live + footer-
// linked (SEO equity); the /software/arena/ detail page was retired the same day
// and 301s here (its Field Edition buy block now lives at #get-arena below).
//
// Content sourced from the ainative Arena corpus (products/orionfold-arena/
// product.md) + the FieldEditionBox positioning (capability/velocity-led). The
// paid Field Edition runs on an NVIDIA DGX Spark. Screenshots are the fresh dark
// Orionfold-Arena-branded cockpit shots (vendored to src/assets/arena/), cropped
// with object-top. Numbers use the newer counts (54 articles) and stay honest
// (receipt is verifiable, never "all gates green"). Prices come from the catalog
// SSOT (FIELD_EDITION) so they can't drift. Voice: grade 3-5, jargon explained,
// no em-dashes (website-copy-style).
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import ConstellationCover from '../components/ui/ConstellationCover.astro';
import ArenaBox from '../components/product/ArenaBox.astro';
import LandingStickyCta from '../components/product/LandingStickyCta.astro';
import LicenseBand from '../components/product/LicenseBand.astro';
import OfferSlot from '../components/ui/OfferSlot.astro';
import { ARENA_FIELD_EDITION_LIVE } from '../data/launch';
import arenaPoster from '../assets/projects/arena-poster.png';
import arenaCockpit from '../assets/arena/01-cockpit.png';
import arenaLeaderboard from '../assets/arena/02-leaderboard.png';
import arenaFrontier from '../assets/arena/03-efficiency-frontier.png';
import arenaCompare from '../assets/arena/07-compare.png';
import arenaEvalDrawer from '../assets/arena/08-eval-drawer.png';
import { SITE, PERSON } from '../data/seo';
import { FIELD_EDITION, formatUsd } from '../data/commerce';
import { ogMeta } from '../data/og';

const og = ogMeta('/arena/');
const arenaUrl = `${SITE.url}/arena/`;
const ogImageAbs = `${SITE.url}${og.image}`;

// Merchant-listings completeness for the priced Offer below (same honest values
// as ProofBox/RelayBox: an instant digital license from a US LLC, so free
// "shipping" and no returns).
const digitalMerchantFields = {
  hasMerchantReturnPolicy: {
    '@type': 'MerchantReturnPolicy',
    applicableCountry: 'US',
    returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
  },
  shippingDetails: {
    '@type': 'OfferShippingDetails',
    shippingRate: { '@type': 'MonetaryAmount', value: '0', currency: 'USD' },
    shippingDestination: { '@type': 'DefinedRegion', addressCountry: 'US' },
  },
};

// SoftwareApplication + Offer so /arena/ reads as the buyable product for answer
// engines. Price = the standard $499 (the durable price after the founding seats
// sell out); the catalog SSOT is the source, never a hardcoded number.
const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Orionfold Arena',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'NVIDIA DGX Spark',
  description:
    'One screen to run, compare, score, and train local AI models on one NVIDIA DGX Spark. Live GPU readouts, a cost-against-quality view, reference-based scoring, and a leak-proof leaderboard built from your own results.',
  url: arenaUrl,
  image: ogImageAbs,
  author: PERSON,
  brand: { '@type': 'Brand', name: 'Orionfold' },
  offers: {
    '@type': 'Offer',
    price: (FIELD_EDITION.primary.amount / 100).toFixed(2),
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: arenaUrl,
    category: 'Software license',
    ...digitalMerchantFields,
  },
};

// The constellation framing (shared with /relay/): where Arena sits in the line.
const constellation = [
  { name: 'Proof', q: 'Which AI can I trust?', href: '/proof/' },
  { name: 'Arena', q: 'Which build wins?', href: null, self: true },
  { name: 'Relay', q: 'Now make the trusted AI do the real work.', href: '/relay/' },
];

// What it does: the four core moves, sourced from product.md. Each is a real
// cockpit surface, not a claim.
const capabilities = [
  {
    verb: 'Run',
    line: 'Chat with a loaded model on your own box. Live GPU load, speed, and memory on one screen. Nothing you type leaves the machine.',
  },
  {
    verb: 'Compare',
    line: 'Put any two models side by side. Quality, speed, how fast the first word lands, and cost, each drawn over the run so you can see the difference, not guess it.',
  },
  {
    verb: 'Score',
    line: 'Pick a test, send a real prompt from the chat, and the right answer sits beside the model’s answer while a grader scores it. Testing becomes one button.',
  },
  {
    verb: 'Train',
    line: 'Queue tests and training runs overnight and wake up to a morning report. Start from where you left off, reward the good runs, and watch progress fill on one board.',
  },
];

// Own-it trust trio (reference-build gap D4-③c): Arena's two uncontested axes,
// own-it + private-on-your-own-hardware, said as three plain buyer benefits, each
// linking the docs/trust/ page that backs it (link, not mirror, so no drift).
// These claims are scattered through the prose today; the trio pulls them up.
const trustTrio = [
  {
    title: 'Nothing leaves the box',
    body: 'Arena runs on the Spark under your desk. Your prompts, your models, and your results stay there. No account, no uploads, no check-ins home.',
    icon: '<rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/>',
    href: '/trust/data-flow/',
  },
  {
    title: 'You own it forever',
    body: 'You buy the box you already own turned into a proven AI lab. Your license works offline. If we vanished tomorrow, your setup keeps running.',
    icon: '<path d="M12 2 4 5v6c0 5.5 3.8 9.5 8 11 4.2-1.5 8-5.5 8-11V5Z"/>',
    href: '/trust/continuity/',
  },
  {
    title: 'Verify it yourself',
    body: 'Every install writes a receipt you can read, and the leaderboard exports only scores, never your data. Check what the box did before you trust it.',
    icon: '<path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>',
    href: '/trust/supply-chain/',
  },
];

// Objection-as-header security block (reference-build gap D4-③c): the questions
// an Arena buyer (a hardware owner) asks before the price, each answered plainly
// and each linking the on-site /trust/ page that proves it. Same four-question
// pattern the shipped /relay/ page uses, adapted for the box owner. The
// publish-safety question is half-answered by the allowlist copy above; here it
// is promoted to a header.
const trust = [
  {
    q: 'Does Arena send our evals to you?',
    a: 'No. Arena runs on your own Spark. Your test prompts, your model answers, and your scores stay on the box. We run no service in the middle, so there is nothing for us to see and nothing for us to hold.',
    label: 'See every network call',
    href: '/trust/data-flow/',
  },
  {
    q: 'Can I publish the leaderboard safely?',
    a: 'Yes. The board exports only the scores and the totals, through a locked-down list. A prompt, an answer, or the model’s working never leaves with it. You can share the board and keep the data behind it.',
    label: 'Read the security packet',
    href: '/trust/security-packet/',
  },
  {
    q: 'What if you disappear?',
    a: 'You keep everything. The box is yours, your data is on it, and your license works offline. If Orionfold went away tomorrow, your lab keeps running. The honest edge cases are written down too.',
    label: 'Read the continuity note',
    href: '/trust/continuity/',
  },
  {
    q: 'Can I trust what gets installed?',
    a: 'Yes, and you can check it. Every release ships with a signed record of where it came from and a full parts list, and the install is checked against a fingerprint before it runs. The receipt on first boot reports the real state of the box.',
    label: 'See the supply chain',
    href: '/trust/supply-chain/',
  },
];

// The dark cockpit gallery (fresh Orionfold-Arena-branded shots).
const gallery = [
  { img: arenaLeaderboard, alt: 'The Arena leaderboard: your own models ranked by score, built from your own results.', label: 'Leaderboard', crop: 'aspect-[16/9] object-top' },
  { img: arenaFrontier, alt: 'Cost against quality, plotted, so you can see which smaller model earns its place.', label: 'Cost vs. quality', crop: 'aspect-[16/9] object-center' },
  { img: arenaCompare, alt: 'Compare: any model against any other, side by side, with metric cards over a session sparkline.', label: 'Compare, any vs any', crop: 'aspect-[16/9] object-top' },
  { img: arenaEvalDrawer, alt: 'The eval drawer: send a real eval prompt from the chat, gold answer beside the live one, graded instantly.', label: 'Eval drawer', crop: 'aspect-[16/9] object-top' },
];

// Credibility evidence band, same shape as the /relay/ proof band. Every number
// is a live count from the public ainative.business field-notes "At a glance"
// (verified 2026-07-03 against the live page + the source project-stats.json,
// which agree): a real, growing research log produced on this exact stack. The
// stat is a SHOWN artifact (D2: proof is never an adjective), cited openly to
// the source site, and rerunnable by the reader. `accent` flags the headline
// throughput tile. The starry backdrop is drawn by ConstellationCover (seeded,
// zero image weight), the site's signature motif.
const evidence = [
  { value: '56', sub: '+13 in the works', label: 'Field notes published' },
  { value: '176,597', sub: 'across the whole log', label: 'Words written' },
  { value: '63,840', sub: 'Python, CLI, tests', label: 'Lines of fieldkit code' },
  { value: '8', sub: 'run and scored locally', label: 'Open models' },
  { value: '11', sub: 'used across the notes', label: 'NVIDIA products' },
  { value: '100', unit: 'tok/s', sub: 'a local brain, on one Spark', label: 'Throughput', accent: true },
];
---
<Layout
  title="See which AI wins, on your own desk · Orionfold Arena"
  description="Orionfold Arena puts every move on one screen: run, compare, score, and train local AI models on one NVIDIA DGX Spark. Live readouts, a cost-against-quality view, and a leaderboard built from your own results. Nothing leaves the box."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={[
    softwareSchema,
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'Arena', item: arenaUrl },
      ],
    },
  ]}
>
  <Nav />
  <main>
    <PageHeader
      eyebrow="Run · Compare · Score · Train"
      title="See which AI wins, on your own desk."
      subtitle="Orionfold Arena puts every move on one screen: run, compare, score, and train local AI models on one NVIDIA DGX Spark. The model, the tests, the hardware, and the results all live in one place you control. Nothing leaves the box."
    >
      <!-- Above-fold hero action, same pattern as the shipped /relay/ hero:
           Arena's OWN buy CTA so a cold visitor's first action is toward this
           product. Live data-checkout button (ONE step to Stripe, wired by the
           page script when ARENA_FIELD_EDITION_LIVE) when the flag is on; falls
           back to a #get-arena scroll anchor when off, so no one can pay
           pre-fulfilment. Beside it, the runnable install verb as a single-line
           chip: `pip install fieldkit[arena]`. -->
      <div class="mb-4 mt-7 flex flex-col items-start gap-3 sm:flex-row sm:items-center">
        {ARENA_FIELD_EDITION_LIVE ? (
          <button
            type="button"
            data-checkout={FIELD_EDITION.founding.lookupKey}
            data-item="software:arena"
            data-error-target="hero-cta-err"
            class="of-primary-action text-base font-semibold"
          >
            Get Arena Field Edition
            <span class="rounded-md bg-black/15 px-2 py-0.5 font-mono text-xs font-medium tracking-wide">{formatUsd(FIELD_EDITION.founding.amount)} founding</span>
          </button>
        ) : (
          <a
            href="#get-arena"
            class="of-primary-action text-base font-semibold"
          >
            Get Arena Field Edition
            <span class="rounded-md bg-black/15 px-2 py-0.5 font-mono text-xs font-medium tracking-wide">{formatUsd(FIELD_EDITION.founding.amount)} founding</span>
          </a>
        )}
        <div class="inline-flex items-center gap-2 rounded-xl border border-border/70 bg-surface/60 px-4 py-3">
          <span class="font-mono text-[0.65rem] uppercase tracking-wider text-text-dim">Install</span>
          <code class="font-mono text-sm text-primary">pip install fieldkit[arena]</code>
        </div>
      </div>
      <p id="hero-cta-err" class="mt-3 hidden text-sm text-red-400" role="alert"></p>
    </PageHeader>
    <!-- Sticky-CTA sentinel: the bar fades in once this scrolls out of view. -->
    <div id="hero-cta-sentinel" aria-hidden="true"></div>

    <!-- Constellation: where Arena sits in the Orionfold line -->
    <section class="px-6 pt-4 pb-10">
      <div class="mx-auto max-w-4xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">The second product in the line</p>
        <p class="mb-6 max-w-2xl text-sm leading-relaxed text-text-muted">
          Proof tells you which AI to trust. Arena is where you drive the shelf of models you own and
          find the one that wins. Relay then puts the winner to work.
        </p>
        <div class="grid gap-3 sm:grid-cols-3">
          {constellation.map((c) => (
            c.self ? (
              <div class="rounded-2xl border border-primary/40 bg-primary/5 p-5">
                <p class="font-display text-lg font-bold text-primary">{c.name}</p>
                <p class="mt-2 text-sm leading-relaxed text-text">{c.q}</p>
              </div>
            ) : (
              <a href={c.href} class="of-surface of-pressable group block rounded-2xl p-5">
                <p class="font-display text-lg font-bold text-text group-hover:text-primary">{c.name}</p>
                <p class="mt-2 text-sm leading-relaxed text-text-muted">{c.q}</p>
              </a>
            )
          ))}
        </div>
      </div>
    </section>

    <!-- The real cockpit: one dark shot so the visitor sees it early -->
    <section class="px-6 pb-6">
      <div class="mx-auto max-w-5xl">
        <div class="overflow-hidden rounded-2xl border border-border/70 shadow-lg shadow-primary/5">
          <Image
            src={arenaCockpit}
            alt="The Orionfold Arena screen: live GPU readouts, your models, the tests, and a leaderboard built from your own results, all in one place."
            widths={[720, 1080, 1440]}
            sizes="(min-width: 1024px) 64rem, 100vw"
            loading="lazy"
            decoding="async"
            data-no-zoom
            class="block aspect-[16/11] w-full object-cover object-top"
          />
        </div>
        <p class="mt-3 text-center font-mono text-[0.65rem] uppercase tracking-[0.2em] text-text-dim">
          One screen over the whole loop
        </p>
      </div>
    </section>

    <!-- What it does: the four core moves -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-4xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">What it does</p>
        <p class="mb-8 max-w-2xl text-sm leading-relaxed text-text-muted">
          You have a shelf of local models and nowhere to drive them from. Arena is the instrument
          panel that turns that shelf into something you can fly. Four moves, one screen.
        </p>
        <div class="grid gap-4 sm:grid-cols-2">
          {capabilities.map((c) => (
            <div class="rounded-2xl border border-border/70 bg-surface/60 p-6">
              <p class="font-display text-xl font-bold text-primary">{c.verb}</p>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">{c.line}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         CREDIBILITY EVIDENCE BAND — same shape as the /relay/ proof band
         (mono eyebrow, headline, infographic stat tiles, honest caption,
         a real product shot framed inside), but the backdrop is a starry
         ConstellationCover (seeded, zero image weight) instead of the
         blueprint grid. Every number is a live count from the public
         ainative.business field-notes "At a glance" (verified 2026-07-03),
         cited openly and rerunnable by the reader — proof as a shown
         artifact, not an adjective. A dark overlay over the deep-blue cover
         keeps the tiles + text legible in both themes.
         ============================================================ -->
    <section class="relative overflow-hidden border-y border-primary/20 px-6 py-16 sm:py-20">
      <!-- Starry night backdrop: the site's signature constellation motif,
           seeded so it draws a distinct field. Dimmed by an overlay so the
           content reads on top. -->
      <ConstellationCover
        seed="arena-field-notes-evidence"
        rounded="rounded-none"
        class="!absolute inset-0 !aspect-auto h-full w-full"
      />
      <div class="pointer-events-none absolute inset-0 bg-bg/70" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-bg/30 via-transparent to-bg/60" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-5xl">
        <div class="mb-2 flex items-center gap-2">
          <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-primary/15 text-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          </span>
          <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">Proven on the same stack</p>
        </div>
        <h2 class="max-w-3xl text-balance text-2xl leading-tight sm:text-3xl">
          The field notes are the receipts.
          <span class="text-text-muted">One builder, one Spark, a public research log anyone can read and <span class="whitespace-nowrap">rerun.</span></span>
        </h2>

        <!-- Infographic stat tiles: the six "At a glance" KPIs. The throughput
             tile is accented as the headline performance number. -->
        <dl class="mt-8 grid gap-3 sm:grid-cols-3">
          {evidence.map((t) => (
            <div class={`relative overflow-hidden rounded-2xl border p-5 backdrop-blur-sm ${t.accent ? 'border-primary/40 bg-primary/[0.1]' : 'border-border/60 bg-surface/70'}`}>
              <dt class={`font-mono text-[0.65rem] uppercase tracking-wider ${t.accent ? 'text-primary/80' : 'text-text-dim'}`}>{t.label}</dt>
              <dd class={`mt-1.5 font-display text-3xl font-bold ${t.accent ? 'text-primary' : 'text-text'}`}>
                {t.value}{t.unit && <span class="ml-1 text-lg font-semibold text-text-muted">{t.unit}</span>}
              </dd>
              <dd class="mt-1 text-xs text-text-muted">{t.sub}</dd>
            </div>
          ))}
        </dl>

        <!-- The leaderboard shot, framed like /relay/ frames its receipt: real
             results, aspect-cropped to its meaningful top. -->
        <figure class="mt-8 overflow-hidden rounded-2xl border border-primary/25 shadow-xl shadow-primary/10">
          <div class="aspect-[16/9] w-full overflow-hidden sm:aspect-[16/8]">
            <Image
              src={arenaLeaderboard}
              alt="The Orionfold Arena leaderboard: local open models ranked by score, built from the builder's own runs on one DGX Spark."
              widths={[720, 1080, 1440]}
              sizes="(min-width: 1024px) 64rem, 100vw"
              loading="lazy"
              decoding="async"
              data-no-zoom
              class="block w-full object-cover object-top"
            />
          </div>
          <figcaption class="border-t border-primary/15 bg-surface/60 px-5 py-3 text-center text-sm text-text-muted">
            Real models, ranked from real runs on one Spark. Not a marketing chart.
          </figcaption>
        </figure>

        <p class="mx-auto mt-6 max-w-2xl text-center text-sm leading-relaxed text-text-muted">
          Every number is a live count from the public research log,
          <a href="https://ainative.business/field-notes/" target="_blank" rel="noopener" class="text-primary underline underline-offset-2 transition-colors hover:text-primary/80">the ainative field notes</a>.
          Read the notes, then rerun them yourself.
        </p>
      </div>
    </section>

    <!-- The leaderboard / efficiency-frontier mechanic: publishable, data stays yours -->
    <section class="border-y border-border bg-surface-raised px-6 py-14">
      <div class="mx-auto max-w-3xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">A board you can publish, data you keep</p>
        <p class="max-w-2xl text-base leading-relaxed text-text-muted">
          The leaderboard is built from your own results, and it is safe to share. A locked-down list
          exports only the scores and the totals, never a prompt, an answer, or the model's working.
          The board is something you can publish; the data behind it stays yours.
        </p>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-text-muted">
          Arena plots cost against quality, so you can read at a glance which smaller model earns its
          place. It is the full loop a rented AI service never gives you: the model, its test data,
          the hardware, and the results, all in one place you control.
        </p>
      </div>
    </section>

    <!-- Mid-page CTA: they now know what Arena is — catch the fast-decider -->
    <LicenseBand
      family={FIELD_EDITION}
      live={ARENA_FIELD_EDITION_LIVE}
      itemId="software:arena"
      errId="arena-band-err"
      fullBlockId="get-arena"
      eyebrow="Get an AI team without hiring one"
      heading="Own the proven box, not the parts."
      body="Arena Field Edition turns the Spark you own into a private AI lab, delivered turnkey. It installs in one pass, proves itself on first boot with a verifiable receipt, and stays proven for a year."
      enquiryHref="/adoption/?item=software:arena"
      image={arenaPoster}
      imageAlt="Orionfold Arena poster: the private AI lab you run on your own DGX Spark."
    />

    <!-- Gallery: a few dark cockpit views -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-5xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">Inside the screen</p>
        <p class="mb-8 max-w-2xl text-sm leading-relaxed text-text-muted">
          A few of the surfaces you drive, all on the machine under your desk.
        </p>
        <div class="grid gap-5 sm:grid-cols-2">
          {gallery.map((g) => (
            <figure class="overflow-hidden rounded-2xl border border-border/70 bg-surface/60">
              <Image
                src={g.img}
                alt={g.alt}
                widths={[480, 720]}
                sizes="(min-width: 640px) 30rem, 100vw"
                loading="lazy"
                decoding="async"
                data-no-zoom
                class:list={['block w-full object-cover', g.crop]}
              />
              <figcaption class="px-4 py-3 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-text-dim">
                {g.label}
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- Build-speed proof: honest, measured. This proves the BUILDER is prolific
         (what one person shipped with the stack); the buyer-outcome band below it
         proves what the BUYER gets (a small model they own beating a big one). -->
    <section class="border-y border-border bg-surface-raised px-6 py-14">
      <div class="mx-auto max-w-3xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">What one builder shipped on it</p>
        <p class="mb-6 max-w-2xl text-sm leading-relaxed text-text-muted">
          The proof is what one builder already did with this exact stack. Solo, on a single Spark
          running Arena: 14 software tools, 6 open models, 3 books, a 54-article research corpus, and
          2 production sites.
        </p>
        <div class="grid gap-4 sm:grid-cols-3">
          <div class="rounded-2xl border border-border/70 bg-surface/60 p-5">
            <p class="font-display text-2xl font-bold text-primary">~15 hours</p>
            <p class="mt-1 text-xs leading-relaxed text-text-muted">Arena itself, built in about fifteen hours across one day and an overnight.</p>
          </div>
          <div class="rounded-2xl border border-border/70 bg-surface/60 p-5">
            <p class="font-display text-2xl font-bold text-primary">125 tests</p>
            <p class="mt-1 text-xs leading-relaxed text-text-muted">Written alongside the features, over 12,733 lines of authored source.</p>
          </div>
