---
// Software showcase (S7; expanded V5). Fourteen products built from
// src/data/software.ts, grouped into five clusters (flagship, platform, apps,
// intel, devtools). The flagship cluster (Advisor, Arena, Cortex — the products
// we commercialize, operator 2026-06-11) leads the page, so its featured card
// is the LCP candidate. Each cluster is a SectionLabel + blurb over a
// unified-cover grid of ProductCards (sm:2 lg:3). Covers resolve here: the two donor screenshots are
// imported directly, the rest come from a glob over src/assets/projects/. A
// page-level BehindTheScenes still holds the technical depth (spec §7).
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ui/ProductCard.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import BehindTheScenes from '../components/ui/BehindTheScenes.astro';
import { software, softwareGroups } from '../data/software';
import platformImg from '../assets/platform/ai-native-platform.png';
import neosignalImg from '../assets/neosignal/neosignal-models.png';
import proofPoster from '../assets/proof/orionfold-proof-poster.jpeg';
import relayPoster from '../assets/projects/orionfold-relay-poster.jpeg';
import { ogMeta } from '../data/og';
import { bentoSplit } from '../lib/bento';
import { detailKeySet } from '../lib/product/detail';

const og = ogMeta('/software/');

// Which software slugs have an on-site detail page: those cards link inward
// (/software/<slug>/) instead of off-site (spec §3). Others keep their external link.
const detailKeys = await detailKeySet();
// The three flagships (Proof, Arena, Relay) have no /software/<slug>/ detail page
// — their canonical surface is a hand-built landing page. Their SSOT href is
// already the on-site landing (/proof/, /arena/, /relay/), so route them through
// the same inward-link path as a detail page (same-tab, no target=_blank).
const LANDING_HREF: Record<string, string> = {
  proof: '/proof/',
  arena: '/arena/',
  relay: '/relay/',
};
const detailHrefFor = (slug: string) =>
  LANDING_HREF[slug] ?? (detailKeys.has(`software:${slug}`) ? `/software/${slug}/` : undefined);

// Resolve a software entry's cover key to an ImageMetadata. Donor screenshots
// are imported directly; project covers come from a glob map keyed by filename.
const projectImgs = import.meta.glob<{ default: ImageMetadata }>('../assets/projects/*.png', { eager: true });
function resolveCover(key?: string): ImageMetadata | undefined {
  if (!key) return undefined;
  if (key === '@platform') return platformImg;
  if (key === '@neosignal') return neosignalImg;
  // Flagship posters that live outside src/assets/projects/*.png (the Proof
  // poster is under assets/proof/, and the Relay poster is a .jpeg), so the glob
  // below can't reach them — import them directly like the donor screenshots.
  if (key === '@proof') return proofPoster;
  if (key === '@relay') return relayPoster;
  const entry = Object.entries(projectImgs).find(([path]) => path.endsWith('/' + key));
  return entry?.[1]?.default;
}
---
<Layout
  title="Private AI software you control · Orionfold"
  description="Orionfold Proof, Arena, and Relay lead the catalog: prove which AI to trust, drive the models you own, and put the winner to work. Plus Advisor, Cortex, the API, and example apps, all open."
  ogImage={og.image}
  ogImageAlt={og.alt}
>
  <Nav />
  <main>
    <!-- Page header (slim masthead so the poster grid rises above the fold) -->
    <PageHeader
      eyebrow="Software"
      title="Private AI you can prove, run, and put to work"
      subtitle="Open software you control. Proof, Arena, and Relay lead: prove which AI to trust, drive the shelf of models you own, then put the winner to work. Advisor, Cortex, the API, and the apps carry the same rule: your data stays local."
    />

    <!-- Grouped product clusters -->
    {softwareGroups.map((group, groupIndex) => {
      const items = software.filter((p) => p.group === group.id);
      // Odd 3+ sections lead with a full-width featured card so the rest pair up.
      const { lead, rest } = bentoSplit(items);
      // The page's first card is the LCP candidate: load its poster eager +
      // fetchpriority=high and skip its reveal animation (max 1 eager/page).
      const isFirstGroup = groupIndex === 0;
      return (
        <section class="px-6 pt-12">
          <div class="mx-auto max-w-6xl">
            <div class="mb-6">
              <SectionLabel text={group.label} />
              <p class="mt-2 max-w-2xl leading-relaxed text-text-muted">
                {group.blurb}
              </p>
            </div>
            {lead && (
              <ProductCard
                eyebrow={lead.eyebrow}
                title={lead.title}
                body={lead.body}
                pills={lead.pills}
                href={lead.href}
                ctaText={lead.ctaText}
                detailHref={detailHrefFor(lead.slug)}
                cover={resolveCover(lead.cover)}
                coverType={lead.coverType}
                seed={lead.slug}
                featured
                priority={isFirstGroup}
              />
            )}
            <div data-animate-stagger class:list={['grid gap-6 sm:grid-cols-2', lead && 'mt-6']}>
              {rest.map((product, index) => (
                <ProductCard
                  eyebrow={product.eyebrow}
                  title={product.title}
                  body={product.body}
                  pills={product.pills}
                  href={product.href}
                  ctaText={product.ctaText}
                  detailHref={detailHrefFor(product.slug)}
                  cover={resolveCover(product.cover)}
                  coverType={product.coverType}
                  seed={product.slug}
                  priority={isFirstGroup && !lead && index === 0}
                />
              ))}
            </div>
          </div>
        </section>
      );
    })}

    <!-- Technical depth (held back from the cards per spec §7) -->
    <section class="px-6 pb-28 pt-16">
      <div data-animate>
        <BehindTheScenes summary="The technical details">
          The platform runs fully on your machine: task execution, workflows, agents, schedules, monitoring, a cost ledger, agent integration, and chat. neosignal compares models, accelerators (the chips that run AI), cloud providers, and frameworks with a scoring system and a compatibility matrix. fieldkit ships patterns we verified on Spark-class hardware: KV-cache, NIM, RAG (retrieval-augmented generation, where the model reads your own files before it answers), eval, training, lineage, quantization, HuggingFace publish, a CLI, charts, and notebooks. The AI Native API is a REST API with 27 endpoint groups across core, intelligence, content, platform, and operations. The personal apps (NeoCash, OpenVolo, Memo, Marketer) and research tools (Trends, Moments) follow the same local-first rule: they run on your own machine and call out to the AI provider you choose, so your data stays with you. Command is a terminal client across 7 providers and 15+ models, and Sentinel is a visual harness for testing agent behaviour.
        </BehindTheScenes>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
