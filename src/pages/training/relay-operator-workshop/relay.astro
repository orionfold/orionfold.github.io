---
import PrivateLayout from '../../../layouts/PrivateLayout.astro';
---

<PrivateLayout title="Connect Relay · Relay Operator Workshop" description="Check and open the learner's local Relay Workshop surface without losing lesson progress.">
  <main class="min-h-screen px-5 py-10 sm:px-8 sm:py-16">
    <div class="mx-auto max-w-5xl">
      <button class="font-mono text-xs uppercase tracking-[0.18em] text-text-dim hover:text-primary" type="button" data-return>← Return to the lesson</button>

      <div class="mt-8 grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <section>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-primary">Relay handoff · read-only check</p>
          <h1 class="mt-5 max-w-3xl text-balance text-4xl font-bold leading-tight sm:text-6xl">Open the workshop in your Relay.</h1>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-text-muted">The lesson stays here. Relay runs on your machine or at an address you control, and it alone records checkpoint and completion evidence.</p>

          <div class="mt-8 rounded-2xl border border-border bg-surface-raised p-6">
            <p class="font-mono text-xs uppercase tracking-[0.18em] text-text-dim">Why this check exists</p>
            <ul class="mt-4 grid gap-3 text-sm leading-relaxed text-text-muted">
              <li>• It avoids sending you to a dead browser tab when Relay is stopped.</li>
              <li>• It supports a different local port or your own Relay Host address.</li>
              <li>• It does not install the starter, call a model, or change your workspace.</li>
            </ul>
          </div>
        </section>

        <section class="rounded-3xl border border-primary/25 bg-surface-raised p-6 shadow-2xl shadow-primary/[0.08] sm:p-8">
          <div id="relay-status" class="rounded-2xl border border-border bg-surface p-5" role="status" aria-live="polite" data-state="checking">
            <div class="flex items-start gap-4">
              <span class="mt-1 h-3 w-3 shrink-0 rounded-full bg-text-dim" data-status-dot aria-hidden="true"></span>
              <div>
                <p class="font-semibold text-text" data-status-title>Checking your Relay address…</p>
                <p class="mt-2 text-sm leading-relaxed text-text-muted" data-status-detail>This normally takes less than three seconds.</p>
              </div>
            </div>
          </div>

          <form id="relay-address-form" class="mt-7">
            <label class="text-sm font-medium text-text" for="relay-address">Relay address</label>
            <div class="mt-2 grid gap-3 sm:grid-cols-[1fr_auto]">
              <input class="min-w-0 rounded-lg border border-border-strong bg-surface px-4 py-3 font-mono text-sm text-text outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" id="relay-address" name="address" type="url" inputmode="url" spellcheck="false" autocomplete="url" required />
              <button class="rounded-lg border border-primary/40 px-5 py-3 font-semibold text-primary hover:bg-primary/[0.07] disabled:opacity-50" type="submit">Check Relay</button>
            </div>
            <p class="mt-3 text-xs leading-relaxed text-text-dim">Relay defaults to <code class="font-mono">http://127.0.0.1:3000</code>. Change this only if your local port or Host address is different.</p>
          </form>

          <div class="mt-7 flex flex-wrap gap-3">
            <a id="open-relay" class="inline-flex rounded-lg bg-primary px-5 py-3 font-semibold text-accent-text" href="#" target="_blank" rel="noreferrer">Open Relay Workshop</a>
            <button class="inline-flex rounded-lg border border-border-strong px-5 py-3 text-text-muted hover:text-text" type="button" data-return>Return to lesson</button>
          </div>

          <details class="mt-8 rounded-2xl border border-border bg-surface p-5" data-start-help>
            <summary class="cursor-pointer font-semibold text-text">Relay is not running yet</summary>
            <p class="mt-4 text-sm leading-relaxed text-text-muted">Open Terminal, run the one-command local release, and keep that Terminal window open while you work.</p>
            <div class="mt-4 flex items-center justify-between gap-4 rounded-lg border border-border bg-surface-raised px-4 py-3">
              <code class="min-w-0 overflow-x-auto font-mono text-sm text-primary">npx orionfold-relay</code>
              <button class="shrink-0 text-xs font-semibold text-text-muted hover:text-primary" type="button" data-copy-command>Copy</button>
            </div>
            <ol class="mt-5 grid gap-2 text-sm leading-relaxed text-text-muted">
              <li>1. Wait until Terminal says Relay is ready.</li>
              <li>2. Return here and choose <strong class="text-text">Check Relay</strong>.</li>
              <li>3. If Relay selected another port, copy that address into the field above.</li>
            </ol>
            <a class="mt-5 inline-flex text-sm font-semibold text-primary hover:underline" href="/relay/docs/get-started-with-relay/" target="_blank" rel="noreferrer">Read the Relay setup guide →</a>
          </details>

          <p class="mt-5 text-xs leading-relaxed text-text-dim">Some browsers restrict local availability checks from a public page. If Relay is visibly running but the check remains unavailable, verify the address and use “Open Relay Workshop”; returning here preserves your lesson step.</p>
        </section>
      </div>
    </div>
  </main>
</PrivateLayout>

<script>
  import {
    DEFAULT_RELAY_RUNTIME,
    normalizeRelayRuntime,
    relayHealthTarget,
    relayWorkshopTarget,
  } from '../../../lib/training/relay-handoff.mjs';

  const form = document.getElementById('relay-address-form') as HTMLFormElement | null;
  const input = document.getElementById('relay-address') as HTMLInputElement | null;
  const status = document.getElementById('relay-status');
  const openRelay = document.getElementById('open-relay') as HTMLAnchorElement | null;
  const startHelp = document.querySelector<HTMLDetailsElement>('[data-start-help]');
  const title = status?.querySelector<HTMLElement>('[data-status-title]');
  const detail = status?.querySelector<HTMLElement>('[data-status-detail]');
  const dot = status?.querySelector<HTMLElement>('[data-status-dot]');
  const storageKey = 'of-relay-workshop-runtime';
  const requestedStage = new URLSearchParams(location.search).get('stage');
  if (openRelay && requestedStage === 'finish') openRelay.textContent = 'Open Relay to export';

  function setStatus(state: 'checking' | 'ready' | 'unavailable' | 'invalid', heading: string, body: string) {
    if (status) status.dataset.state = state;
    if (title) title.textContent = heading;
    if (detail) detail.textContent = body;
    if (dot) dot.className = `mt-1 h-3 w-3 shrink-0 rounded-full ${state === 'ready' ? 'bg-green-500' : state === 'checking' ? 'bg-primary' : 'bg-amber-500'}`;
  }

  function currentAddress() {
    return normalizeRelayRuntime(input?.value || DEFAULT_RELAY_RUNTIME);
  }

  function updateOpenTarget(runtime: string) {
    if (!openRelay) return;
    openRelay.href = relayWorkshopTarget(runtime);
    openRelay.removeAttribute('aria-disabled');
  }

  function disableOpenTarget() {
    if (!openRelay) return;
    openRelay.href = '#';
    openRelay.setAttribute('aria-disabled', 'true');
  }

  async function checkRelay() {
    let runtime;
    try {
      runtime = currentAddress();
      if (input) input.value = runtime;
      localStorage.setItem(storageKey, runtime);
      updateOpenTarget(runtime);
    } catch (error) {
      disableOpenTarget();
      setStatus('invalid', 'Check the Relay address.', error instanceof Error ? error.message : 'Enter a valid Relay address.');
      return;
    }

    setStatus('checking', 'Checking your Relay address…', 'This normally takes less than three seconds.');
    form?.querySelectorAll('button').forEach((button) => { button.disabled = true; });
    const controller = new AbortController();
    const timeout = window.setTimeout(() => controller.abort(), 2800);
    try {
      await fetch(relayHealthTarget(runtime), {
        method: 'GET',
        mode: 'no-cors',
        credentials: 'omit',
        cache: 'no-store',
        signal: controller.signal,
      });
      setStatus('ready', 'Relay answered at this address.', 'Open the Workshop in a new tab, complete the Relay action, then return to this lesson.');
      if (startHelp) startHelp.open = false;
    } catch {
      setStatus('unavailable', 'Relay did not answer yet.', 'Start Relay, confirm its address, and retry. Your lesson progress is preserved.');
      if (startHelp) startHelp.open = true;
    } finally {
      window.clearTimeout(timeout);
      form?.querySelectorAll('button').forEach((button) => { button.disabled = false; });
    }
  }

  document.querySelectorAll<HTMLButtonElement>('[data-return]').forEach((button) => button.addEventListener('click', () => {
    if (history.length > 1) history.back();
    else location.href = '/training/relay-operator-workshop/access/';
  }));

  document.querySelector<HTMLButtonElement>('[data-copy-command]')?.addEventListener('click', async (event) => {
    const button = event.currentTarget as HTMLButtonElement;
    try {
      await navigator.clipboard.writeText('npx orionfold-relay');
      button.textContent = 'Copied';
    } catch {
      button.textContent = 'Select command';
    }
  });

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    void checkRelay();
  });

  try {
    if (input) input.value = localStorage.getItem(storageKey) || DEFAULT_RELAY_RUNTIME;
  } catch {
    if (input) input.value = DEFAULT_RELAY_RUNTIME;
  }
  updateOpenTarget(input?.value || DEFAULT_RELAY_RUNTIME);
  void checkRelay();
</script>

<style>
  #relay-status[data-state='ready'] { border-color: color-mix(in srgb, #22c55e 45%, var(--color-border)); }
  #relay-status[data-state='unavailable'], #relay-status[data-state='invalid'] { border-color: color-mix(in srgb, #f59e0b 45%, var(--color-border)); }
</style>
