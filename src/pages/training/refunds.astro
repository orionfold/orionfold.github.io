---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { SITE } from '../../data/seo';

const pageUrl = `${SITE.url}/training/refunds/`;
const faq = [
  {
    question: 'How long is the refund window?',
    answer: 'You may request a full, no-judgment refund within 14 calendar days of successful payment.',
  },
  {
    question: 'What happens to workshop access?',
    answer: 'Access remains active while Stripe processes the request. A successful full refund closes future private playback and re-download.',
  },
  {
    question: 'Do I lose work I already made?',
    answer: 'No. Files you already downloaded and work you created in Relay remain yours.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  url: pageUrl,
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<Layout
  title="Training workshop refunds · Orionfold"
  description="Read the Orionfold training workshop refund policy and request a refund using your purchase email."
  jsonLd={faqSchema}
>
  <Nav />
  <main class="px-6 pb-28 pt-36 sm:pt-44">
    <header class="mx-auto max-w-4xl">
      <a class="font-mono text-xs uppercase tracking-[0.2em] text-primary hover:underline" href="/training/">Orionfold Training</a>
      <h1 class="mt-5 max-w-3xl text-balance text-5xl font-bold leading-[0.98] sm:text-7xl">Workshop refunds, without a maze.</h1>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-text-muted">Every paid Orionfold training workshop includes a 14-day full, no-judgment refund window. Use the purchase email below and confirm the private link we send you.</p>
    </header>

    <section class="mx-auto mt-14 grid max-w-4xl gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="rounded-2xl border border-border bg-surface-raised p-6 sm:p-8">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-primary">The policy</p>
        <dl class="mt-6 grid gap-6 text-sm leading-relaxed">
          <div><dt class="font-semibold text-text">14 calendar days</dt><dd class="mt-2 text-text-muted">The window begins when payment succeeds. Requests inside it receive a full refund to the original payment method.</dd></div>
          <div><dt class="font-semibold text-text">Access stays open while pending</dt><dd class="mt-2 text-text-muted">Only a successful Stripe refund closes future private playback and re-download.</dd></div>
          <div><dt class="font-semibold text-text">Your work remains yours</dt><dd class="mt-2 text-text-muted">Downloaded files and the workflows, outputs, and receipts you created in Relay are not removed.</dd></div>
          <div><dt class="font-semibold text-text">Private by default</dt><dd class="mt-2 text-text-muted">The form always returns the same message, so it does not reveal whether an email owns a purchase.</dd></div>
        </dl>
      </div>

      <form id="refund-request-form" class="rounded-2xl border border-primary/30 bg-primary/[0.05] p-6 sm:p-8">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-primary">Request a refund</p>
        <h2 class="mt-3 text-2xl font-semibold">Relay Operator Workshop</h2>
        <p class="mt-3 text-sm leading-relaxed text-text-muted">Enter the email used at checkout. If it owns an eligible purchase, we will send a one-hour confirmation link. Refund timing after confirmation depends on Stripe and your bank.</p>
        <label class="mt-6 block text-sm font-medium" for="refund-email">Purchase email</label>
        <input class="mt-2 w-full rounded-lg border border-border-strong bg-surface px-4 py-3 text-text outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" id="refund-email" name="email" type="email" autocomplete="email" required maxlength="254" />
        <input class="hidden" name="company" tabindex="-1" autocomplete="off" />
        <button class="mt-5 rounded-lg bg-primary px-5 py-3 font-semibold text-accent-text disabled:opacity-50" type="submit">Email my confirmation link</button>
        <p id="refund-request-status" class="mt-4 text-sm leading-relaxed text-text-muted" role="status" aria-live="polite"></p>
        <p class="mt-5 text-xs leading-relaxed text-text-dim">Outside the automatic window or unable to use the form? Email <a class="text-primary hover:underline" href="mailto:manav@orionfold.com">manav@orionfold.com</a>.</p>
      </form>
    </section>

    <section class="mx-auto mt-16 max-w-4xl border-t border-border pt-12" aria-labelledby="refund-questions">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-text-dim">Clear before you ask</p>
      <h2 id="refund-questions" class="mt-3 text-3xl font-bold">Refund questions</h2>
      <div class="mt-7 grid gap-4">
        {faq.map((item) => (
          <details class="rounded-xl border border-border bg-surface-raised p-5">
            <summary class="cursor-pointer font-semibold text-text">{item.question}</summary>
            <p class="mt-3 max-w-3xl text-sm leading-relaxed text-text-muted">{item.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import { requestWorkshopLink } from '../../lib/workshop';

  const form = document.getElementById('refund-request-form') as HTMLFormElement | null;
  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const status = document.getElementById('refund-request-status');
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (data.get('company')) return;
    if (button) button.disabled = true;
    if (status) status.textContent = 'Sending a private confirmation link…';
    const result = await requestWorkshopLink('refund', String(data.get('email') || ''));
    if (status) status.textContent = String(result.data.message || 'If that inbox owns an eligible workshop, the confirmation link is on its way.');
    if (button) button.disabled = false;
  });
</script>
