---
// Homepage (S4 + S5). Hero + narrative (Why → What → How) + lead form,
// then the Book/Software/Model highlights and the stories carousel.
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import CapabilitySystemMap from '../components/sections/CapabilitySystemMap.astro';
import Highlights from '../components/sections/Highlights.astro';
import SparkTeaser from '../components/sections/SparkTeaser.astro';
import StoriesCarousel from '../components/sections/StoriesCarousel.astro';
import FlagshipChooser from '../components/sections/FlagshipChooser.astro';
import CapabilityProof from '../components/sections/CapabilityProof.astro';
import Footer from '../components/Footer.astro';
import ConfirmBanner from '../components/ui/ConfirmBanner.astro';
import { ogMeta } from '../data/og';

const og = ogMeta('/');
---
<Layout ogImage={og.image} ogImageAlt={og.alt}>
  <Nav />
  <!-- Surfaces the ?confirmed= state the confirm-email funnel redirects here with (H3) -->
  <ConfirmBanner />
  <main>
    <Hero />
    <CapabilitySystemMap />
    <FlagshipChooser />
    <CapabilityProof />
    <SparkTeaser />
    <Highlights />
    <StoriesCarousel />
  </main>
  <Footer />
</Layout>
