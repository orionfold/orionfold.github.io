---
// Homepage (S4 + S5). Hero + narrative (Why → What → How) + lead form,
// then the Book/Software/Model highlights and the stories carousel.
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import FieldEditionBand from '../components/sections/FieldEditionBand.astro';
import RelayBand from '../components/sections/RelayBand.astro';
import RelayHostBox from '../components/product/RelayHostBox.astro';
import CapabilitySystemMap from '../components/sections/CapabilitySystemMap.astro';
import CompanyTrustTrio from '../components/sections/CompanyTrustTrio.astro';
import Highlights from '../components/sections/Highlights.astro';
import StoriesCarousel from '../components/sections/StoriesCarousel.astro';
import FromTheFounder from '../components/sections/FromTheFounder.astro';
import CatalogShelf from '../components/sections/CatalogShelf.astro';
import Footer from '../components/Footer.astro';
import ConfirmBanner from '../components/ui/ConfirmBanner.astro';
import { ogMeta } from '../data/og';

const og = ogMeta('/');
---
<Layout
  title="Orionfold · Proven AI-native business in a box"
  description="Orionfold gives you open or frontier AI models, local or cloud delivery, single- or multi-user operation, optimized for cost or intelligence."
  ogImage={og.image}
  ogImageAlt={og.alt}
>
  <Nav />
  <!-- Surfaces the ?confirmed= state the confirm-email funnel redirects here with (H3) -->
  <ConfirmBanner />
  <!-- Relay-led suite router (homepage CRO rebuild, 2026-07-03). The page routes
       to the product that matches each visitor's question rather than selling
       Proof: hero sets the company promise, the thesis diagram is the suite
       thesis, the trust trio sets the ethos, then the product bands lead with
       Relay (the $10K paid-test target) then Arena. Founder letter demoted below
       the routing; book/catalog/stories are the credibility tail. -->
  <main>
    <Hero />
    <CapabilitySystemMap />
    <CompanyTrustTrio />
    <RelayBand />
    <RelayHostBox placement="home" />
    <FieldEditionBand />
    <FromTheFounder />
    <Highlights />
    <StoriesCarousel />
    <CatalogShelf />
  </main>
  <Footer />
</Layout>
