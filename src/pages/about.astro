---
// About — the founder behind Orionfold (N-series, refreshed 2026-05-27 into a narrative,
// mission-first landing page: avatar + two story-style comics + public-product wordmark cards.
// Voice: first person, grade 3-5, no em-dashes (website-copy-style). No revenue figures;
// focus on the real public products. Person/ProfilePage JSON-LD ties it to the founder entity.
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';
import { SITE, PERSON } from '../data/seo';
import { ogMeta } from '../data/og';
import avatar from '../assets/about/manav.jpg';
import arc from '../assets/about/arc.jpeg';
import mission from '../assets/about/mission.jpeg';

const og = ogMeta('/about/');

// Real, public products and the rooms they were built in, on a timeline. No revenue figures.
const milestones = [
  {
    year: 'Late 1990s',
    mark: 'Xerox PARC',
    line: 'Helped build one of India’s first systems for storing and sharing documents across distance.',
  },
  {
    year: '2017',
    mark: 'AWS, India',
    line: 'Brought cloud computing to businesses across India, and helped stand up the tech behind the country’s pandemic response that reached 100 million people in 40 days.',
  },
  {
    year: '2021',
    mark: 'Alexa Conversations',
    line: 'Led product for Alexa’s conversational AI and grew it from 1 language to 9.',
  },
  {
    year: '2024',
    mark: 'Amazon Nova',
    line: 'Worked inside Amazon AGI on the foundation models that ship today as Amazon Nova.',
  },
  {
    year: '2024',
    mark: 'Generative AI for the store',
    line: 'Helped bring generative AI to the Amazon shopping experience that millions use every day.',
  },
  {
    year: '2025',
    mark: 'AWS Frontier AI',
    line: 'Led the solutions work helping frontier AI labs build on AWS, with partners like Anthropic and NVIDIA.',
  },
  {
    year: '2026',
    mark: 'Orionfold',
    line: 'Open AI software, custom models, and books you can run, all from one small desk.',
    now: true,
  },
];

const beliefs = [
  {
    title: 'Local and private by default',
    body: 'The best place for your AI to run is your own computer, not someone else’s cloud. Your work stays in the room.',
  },
  {
    title: 'Skill beats staff',
    body: 'One person with AI helpers can now do what used to take a whole team. I build the tools that make that real.',
  },
  {
    title: 'Open, not locked in',
    body: 'Open AI has caught up to the paid kind. I ship open software, open models, and books you can read and run.',
  },
];
---
<Layout
  title="About Manav Sehgal · Orionfold"
  description="I am Manav Sehgal, the builder behind Orionfold. Twenty-five years building AI, from Xerox PARC to Alexa Conversations and Amazon Nova, now folded into one studio for the solo builder."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'ProfilePage',
      url: `${SITE.url}/about/`,
      mainEntity: {
        ...PERSON,
        jobTitle: 'Founder, Orionfold',
        description:
          'Founder of Orionfold, an AI studio that builds open AI software, custom models, and the playbooks to run them locally and privately. Twenty-five years building AI, from Xerox PARC to Alexa Conversations and Amazon Nova. Author of the AI Native Business book.',
        worksFor: { '@type': 'Organization', name: 'Orionfold LLC', url: SITE.url },
        alumniOf: [
          { '@type': 'CollegeOrUniversity', name: 'Harvard Business School' },
          { '@type': 'CollegeOrUniversity', name: 'MIT Sloan School of Management' },
          { '@type': 'CollegeOrUniversity', name: 'University of California, Berkeley, Haas School of Business' },
        ],
        knowsAbout: ['Artificial Intelligence', 'Open-weight models', 'Local-first AI', 'AI agents', 'Cloud computing'],
      },
    },
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'About', item: `${SITE.url}/about/` },
      ],
    },
  ]}
>
  <Nav />
  <main>
    <!-- Hero: avatar + mission-first headline -->
    <section class="relative overflow-hidden px-6 pt-32 pb-12">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute left-1/2 top-10 h-[28rem] w-[28rem] -translate-x-1/2 rounded-full bg-primary/[0.12] blur-[150px]"></div>
      </div>
      <div class="relative z-10 mx-auto max-w-5xl">
        <div data-animate>
          <SectionLabel text="About" />
        </div>
        <div data-animate class="mt-6 flex items-center gap-5" style="transition-delay: 60ms">
          <div class="relative shrink-0">
            <div class="absolute -inset-1.5 rounded-full bg-primary/30 blur-md"></div>
            <Image
              src={avatar}
              alt="Manav Sehgal, a stylized space-explorer portrait of the founder of Orionfold."
              width={132}
              height={132}
              loading="eager"
              class="relative h-[88px] w-[88px] rounded-full border-2 border-primary/40 object-cover sm:h-[132px] sm:w-[132px]"
            />
          </div>
          <div>
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.24em] text-primary">Manav Sehgal</p>
            <p class="mt-1 text-sm text-text-muted">Founder, Orionfold · builder for twenty-five years</p>
          </div>
        </div>
        <h1 class="mt-7 font-display text-[clamp(2.2rem,6vw,4.5rem)] leading-[1.04]">
          I fold the frontier<br class="hidden sm:block" /> down to one desk.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-text-muted">
          Hi, I’m Manav. For twenty-five years I helped the biggest companies in the world put powerful
          technology in front of millions of people. Now I do the opposite of big. I put that same
          frontier in the hands of one person at a time, starting with you.
        </p>
      </div>
    </section>

    <!-- The mission, as a comic -->
    <section class="px-6 pb-4">
      <div class="mx-auto max-w-5xl">
        <figure data-animate class="overflow-hidden rounded-3xl border border-border bg-surface-raised">
          <Image
            src={mission}
            alt="A glowing tower of clouds and servers sends a bright star of light across a sunset sky into the open hands of a builder at a small desk, where a gold computer glows. A banner reads: Put the frontier in your hands."
            class="w-full"
            widths={[640, 960, 1280, 1600]}
            sizes="(min-width: 1024px) 64rem, 100vw"
          />
        </figure>
        <p data-animate class="mx-auto mt-5 max-w-2xl text-center text-base leading-relaxed text-text-muted">
          That is the whole mission. The frontier of AI should not live only in giant clouds rented by
          giant companies. It should fit on your desk, run on your terms, and answer to you.
        </p>
      </div>
    </section>

    <!-- The why, in plain words -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-2xl">
        <p class="mb-5 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">Why I do this</p>
        <p class="text-base leading-relaxed text-text-muted">
          For most of my life, the rule was simple. The best technology was big, expensive, and lived
          far away in someone else’s data center. You could use it, but you could not own it. I spent
          years on the inside of that world, and I kept noticing the same gap. The tech got more
          amazing every year, and yet it reached real people slowly, if at all.
        </p>
        <p class="mt-5 text-base leading-relaxed text-text-muted">
          Then something changed. Open AI models caught up to the locked, paid ones. A computer small
          enough to sit on a desk got powerful enough to run them. For the first time, one person with
          the right tools could do what used to take a whole team and a cloud bill. I could not unsee
          it. So I left to build for that person.
        </p>
      </div>
    </section>

    <!-- The 25-year arc, as a comic -->
    <section class="px-6 pb-2">
      <div class="mx-auto max-w-5xl">
        <figure data-animate class="overflow-hidden rounded-3xl border border-border bg-surface-raised">
          <Image
            src={arc}
            alt="Four-panel comic of a 25-year journey: a 1990s computer lab, a 2010s cloud city, a 2020s glowing voice assistant with a constellation of AI models, and today a builder at a home desk with a small glowing gold computer. A banner reads: Twenty-five years, folded into one desk."
            class="w-full"
            widths={[640, 960, 1280, 1600]}
            sizes="(min-width: 1024px) 64rem, 100vw"
          />
        </figure>
      </div>
    </section>

    <!-- The journey, story style -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-2xl">
        <p class="mb-5 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">The path here</p>
        <p class="text-base leading-relaxed text-text-muted">
          My path was not a straight line. It was the same idea told in very different rooms. It
          started at Xerox PARC in the late 1990s, where I helped build one of India’s first systems
          for storing and sharing documents across distance.
        </p>
        <p class="mt-5 text-base leading-relaxed text-text-muted">
          At AWS I helped bring the cloud to businesses across India, and helped stand up the tech
          behind the country’s pandemic response. At Amazon I led product for Alexa’s conversational
          AI, then worked on the foundation models that ship today as Amazon Nova, then helped bring
          generative AI to the store millions of people shop in every day. After that I led the team
          helping frontier AI labs like Anthropic and chipmakers like NVIDIA build on AWS.
        </p>
        <p class="mt-5 text-base leading-relaxed text-text-muted">
          Every step taught me the same lesson, a little louder each time. The most powerful technology
          in the world is worth almost nothing until it reaches the person who needs it. In June 2026,
          after nearly nine years at Amazon, I left to do the one thing all of it pointed at.
        </p>
      </div>
    </section>

    <!-- Things I've helped bring into the world, as a timeline -->
    <section class="border-y border-border bg-surface-raised px-6 py-16">
      <div class="mx-auto max-w-3xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">Things I’ve helped bring into the world</p>
        <p class="mb-10 max-w-2xl text-sm leading-relaxed text-text-muted">
          Not a resume. A timeline of the real, public things I had a hand in shipping, and the one I am building now.
        </p>
        <ol class="relative" data-animate-stagger>
          {milestones.map((m, i) => (
            <li data-animate class="relative flex gap-5 sm:gap-7">
              <div class="flex flex-col items-center">
                <span class={`relative mt-1 flex h-4 w-4 shrink-0 items-center justify-center rounded-full ring-4 ${m.now ? 'bg-primary ring-primary/25' : 'bg-primary/85 ring-primary/10'}`}>
                  {m.now && <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary/50"></span>}
                </span>
                {i < milestones.length - 1 && <span class="mt-1.5 w-px flex-1 bg-gradient-to-b from-primary/35 to-primary/10"></span>}
              </div>
              <div class={i === milestones.length - 1 ? 'pb-0' : 'pb-10'}>
                <p class="font-mono text-[0.62rem] uppercase tracking-[0.24em] text-primary">{m.year}</p>
                <p class="mt-1 font-display text-xl leading-tight text-text">{m.mark}</p>
                <p class="mt-2 max-w-xl text-sm leading-relaxed text-text-muted">{m.line}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- What I believe -->
    <section class="px-6 py-14">
      <div class="mx-auto max-w-6xl">
        <p class="mb-6 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">What I believe</p>
        <div class="grid gap-4 md:grid-cols-3" data-animate-stagger>
          {beliefs.map((b) => (
            <article data-animate class="rounded-2xl border border-border/70 bg-surface-raised/70 p-6">
              <p class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-primary">{b.title}</p>
              <p class="mt-4 text-sm leading-relaxed text-text-muted">{b.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Close + CTA -->
    <section class="px-6 pb-24">
      <div class="mx-auto max-w-2xl rounded-3xl border border-border bg-surface-raised/70 p-8 text-center">
        <p class="font-display text-2xl leading-snug">The frontier is finally small enough to hold. Let’s put it in your hands.</p>
        <p class="mt-4 text-base leading-relaxed text-text-muted">
          The full story of why I left, and what the name Orionfold means, is in
          <a class="text-primary underline underline-offset-2 hover:text-primary/80" href="/story/why-i-folded-orionfold/">Why I folded Orionfold</a>.
          Or follow the whole journey from the start in <a class="text-primary underline underline-offset-2 hover:text-primary/80" href="/story/">the Story log</a>.
        </p>
        <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
          <a href="/roadmap/" class="rounded-full bg-primary px-6 py-3 text-sm font-medium text-white transition hover:bg-primary/90">See what I’m building</a>
          <a href="/story/" class="rounded-full border border-border px-6 py-3 text-sm font-medium text-text transition hover:border-primary/50">Read the story</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
