---
// /proof/ — "Receipts." The standing, falsifiable evidence wall: the interactive
// capability matrix is the hero, then the headline receipts, then the contrarian
// takes. Built for the builder who reruns your tests and the buyer they refer.
// Voice: grade 3-5, jargon explained, no em-dashes (website-copy-style). Numbers
// are repurposed from the field notes; the honest caveats stay in (receipt-honesty).
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import CapabilityMatrix from '../components/sections/CapabilityMatrix.astro';
import ProofProduct from '../components/sections/ProofProduct.astro';
import ProofBox from '../components/product/ProofBox.astro';
import LandingStickyCta from '../components/product/LandingStickyCta.astro';
import LicenseBand from '../components/product/LicenseBand.astro';
import OfferSlot from '../components/ui/OfferSlot.astro';
import proofPoster from '../assets/proof/orionfold-proof-poster.jpeg';
import { getCollection } from 'astro:content';
import { receipts, myths, receiptHref } from '../data/proof';
import { SITE, PERSON } from '../data/seo';
import { PROOF, formatUsd } from '../data/commerce';
import { ORIONFOLD_PROOF_LIVE } from '../data/launch';
import { ogMeta } from '../data/og';

const og = ogMeta('/proof/');
const proofUrl = `${SITE.url}/proof/`;
const ogImageAbs = `${SITE.url}${og.image}`;

// Merchant-listings completeness for the priced Offer below. Same honest values
// as ProductDetail.astro: Orionfold Proof is an instant digital license from a
// US LLC, so free "shipping" (nothing physical) + no returns (a delivered,
// signed license file can't be returned). Without these GSC flags the Offer.
const digitalMerchantFields = {
  hasMerchantReturnPolicy: {
    '@type': 'MerchantReturnPolicy',
    applicableCountry: 'US',
    returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
  },
  shippingDetails: {
    '@type': 'OfferShippingDetails',
    shippingRate: { '@type': 'MonetaryAmount', value: '0', currency: 'USD' },
    shippingDestination: { '@type': 'DefinedRegion', addressCountry: 'US' },
  },
};

// A9 (relay): SoftwareApplication + Offer so /proof/ reads as the buyable
// product behind the receipts for answer engines, plus a HowTo for the
// configure -> run -> decide reproduction loop (the rerunnable claim is the
// whole pitch). Price = the standard $499 (the durable price after the founding
// seats sell out); the catalog SSOT is the source, never a hardcoded number.
const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Orionfold Proof',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, NVIDIA DGX Spark',
  description:
    'Lock a test before you train, run it on models you own, and publish a receipt anyone can rerun. The cockpit behind the receipts on this page.',
  url: proofUrl,
  image: ogImageAbs,
  author: PERSON,
  brand: { '@type': 'Brand', name: 'Orionfold' },
  offers: {
    '@type': 'Offer',
    price: (PROOF.primary.amount / 100).toFixed(2),
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: proofUrl,
    category: 'Software license',
    ...digitalMerchantFields,
  },
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Rerun an Orionfold Proof receipt',
  description:
    'How Orionfold Proof turns a claim into a receipt you can rerun: configure the test, run it on the models you are weighing, then decide from the scored result.',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Configure',
      text: 'Point Proof at your own task. Pick the models or setups you are weighing, local or cloud, and the rubric to score them by.',
      url: `${proofUrl}#what-it-does`,
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Run',
      text: 'Proof runs every candidate against the same locked test and records the result so the run is repeatable.',
      url: `${proofUrl}#what-it-does`,
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Decide',
      text: 'Read the scored receipt: which model passed, which refused, which missed. The receipt is the proof you can hand to anyone to rerun.',
      url: `${proofUrl}#what-it-does`,
    },
  ],
};

// Proof topic hub (relay ask A8): cluster the Proof-tagged build-log stories
// here so /proof/ is the pillar page that links its supporting field notes
// (topical authority for a young domain). Data-driven off the `Proof` tag so a
// new Proof story joins this hub the moment it ships, no edit here.
const proofStories = (await getCollection('story'))
  .filter((s) => s.data.tags.includes('Proof'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// The constellation framing (shared with /arena/ + /relay/ for consistent
// product-line navigation): where Proof sits in the line. Text-only cards, so
// the three pages' constellation sections stay identical.
const constellation = [
  { name: 'Relay', q: 'Now make the trusted AI do the real work.', href: '/relay/' },
  { name: 'Proof', q: 'Which AI can I trust?', href: null, self: true },
  { name: 'Arena', q: 'Which build wins?', href: '/arena/' },
];

// Dual-ICP columns (reference-build gap D4-②a): Proof serves two buyers with one
// tool. The builder wants a fast local benchmark; the regulated-enterprise buyer
// wants an audit-ready receipt their risk team can rerun. Same hero, two paths.
// Voice: grade 3-5, no jargon, the outcome in the buyer's own words.
const icps = [
  {
    who: 'For builders',
    lead: 'Benchmark the models on your own desk, offline, in minutes.',
    icon: '<path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/>',
    points: [
      'Run local and cloud models against the same locked test.',
      'Read one scored receipt: which passed, which refused, which made things up.',
      'No account, no per-word bill. It runs on the machine in front of you.',
    ],
    accent: false,
  },
  {
    who: 'For regulated teams',
    lead: 'Produce an audit-ready receipt your risk team can rerun.',
    icon: '<path d="M16 22h2a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v3"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M5 17a3 3 0 1 0-6 0"/><circle cx="8" cy="14" r="3"/>',
    points: [
      'Every run writes a signed receipt with the exact test, the models, and the scores.',
      'The same config hash reproduces the same result, so a reviewer can check it independently.',
      'Nothing leaves your machine. Prompts and data never reach us or any vendor you did not choose.',
    ],
    accent: true,
  },
];

// Own-it buyer-benefit trio (reference-build gap D4-②c): reframe "open source"
// as three plain buyer benefits, each backed by a docs/trust/ page (link, don't
// mirror, so the page can't drift from the canonical trust doc). Proof's two
// uncontested axes are local/offline + reproducible; the trio says them plainly.
const trustTrio = [
  {
    title: 'No lock-in, ever',
    body: 'The tool is open and installs with one command. Your receipts are plain files you keep. If we vanished tomorrow, everything you ran still verifies.',
    icon: '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/>',
    href: '/trust/continuity/',
  },
  {
    title: 'Auditable end to end',
    body: 'Every release ships with a signed record of where it came from and a full parts list. Check what you install before you run it.',
    icon: '<path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>',
    href: '/trust/supply-chain/',
  },
  {
    title: 'Run it yourself',
    body: 'Proof runs on your own machine, offline if you want. Nothing you test is uploaded. Anything that could leave the box is listed in full, with an off switch.',
    icon: '<rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/>',
    href: '/trust/data-flow/',
  },
];

// Objection-as-header security block (reference-build gap D4-②d): the four
// questions a careful buyer (and a regulated-vertical risk team) asks about Proof
// itself, each answered plainly and each linking the on-site /trust/ page that
// proves it. Same four-question pattern the shipped /relay/ page uses.
const trust = [
  {
    q: 'Does Proof send our prompts or data to you?',
    a: 'No. Proof runs on your own machine. Your prompts, your test data, and your results stay there. AI work runs through your own model accounts, not ours. We run no service in the middle, so there is nothing for us to see and nothing for us to hold.',
    label: 'See every network call',
    href: '/trust/data-flow/',
  },
  {
    q: 'Can I run it fully offline, air-gapped?',
    a: 'Yes. Point Proof at local models and it never needs the internet to run a test. The one time it reaches out is the checked, one-time download of the tool itself. After that, you can pull the plug and it keeps working.',
    label: 'Read the security packet',
    href: '/trust/security-packet/',
  },
  {
    q: 'What if you disappear? Do my receipts still verify?',
    a: 'Yes. The tool is open source and your receipts are plain files with the test, the config hash, and the scores baked in. Anyone can rerun the same config and reach the same result, with or without us. The honest edge cases are written down too.',
    label: 'Read the continuity note',
    href: '/trust/continuity/',
  },
  {
    q: 'Can my risk team rerun this independently?',
    a: 'That is the whole point. A receipt names the exact test and the models it ran. Hand it to a reviewer, they install Proof, run the same config, and get the same numbers. A benchmark you cannot rerun is a rumor. This one you can.',
    label: 'See the supply chain',
    href: '/trust/supply-chain/',
  },
];

// Taster map for the capability matrix's hover panel: receipt slug -> the
// metric + one-line claim shown in the right-side taster. Read here from the
// receipts collection so CapabilityMatrix stays decoupled from the content
// layer (it gets a plain map prop, no getCollection inside the component).
const receiptTasters = Object.fromEntries(
  (await getCollection('receipts')).map((r) => [
    r.id,
    { metric: r.data.metric, claim: r.data.claim },
  ]),
);
---
<Layout
  title="AI you can verify yourself · Orionfold"
  description="The proof, not the pitch. Frozen tests you can rerun, a small model that out-trusts a big one, and an AI lab that runs overnight for 2 cents, all on one desk."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={[
    softwareSchema,
    howToSchema,
    {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: myths.map((m) => ({
        '@type': 'Question',
        name: m.claim,
        acceptedAnswer: { '@type': 'Answer', text: m.bust },
      })),
    },
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'Receipts', item: `${SITE.url}/proof/` },
      ],
    },
  ]}
>
  <Nav />
  <main>
    <PageHeader
      eyebrow="Receipts"
      title="The proof, not the pitch."
      subtitle="We do not ask you to trust us. We lock the test before we train, publish the receipts, and let you rerun them. Here is what one desk can prove. Open source, offline, and it runs on the machine in front of you. Rerun anything on this page yourself."
    >
      <!-- Runnable install command on the hero (gap D4-②b): the brand is "rerun
           it, never trust us," so the single most on-brand move is to SHOW the
           real command above the fold, not assert "one command to install" 800px
           down. Real, verified verb: `pip install orionfold-proof` then
           `orionfold up` (PyPI package orionfold-proof, CLI command `orionfold`).
           Same install-chip shape as the shipped /relay/ hero. -->
      <div class="mt-7 flex flex-col items-start gap-3 sm:flex-row sm:items-center">
        {ORIONFOLD_PROOF_LIVE ? (
          <button
            type="button"
            data-checkout={PROOF.founding.lookupKey}
            data-item="software:orionfold-proof"
            data-error-target="hero-cta-err"
            class="of-primary-action text-base font-semibold"
          >
            Get Orionfold Proof
            <span class="rounded-md bg-black/15 px-2 py-0.5 font-mono text-xs font-medium tracking-wide">{formatUsd(PROOF.founding.amount)} founding</span>
          </button>
        ) : (
          <a href="#get-proof" class="of-primary-action text-base font-semibold">
            Get Orionfold Proof
            <span class="rounded-md bg-black/15 px-2 py-0.5 font-mono text-xs font-medium tracking-wide">{formatUsd(PROOF.founding.amount)} founding</span>
          </a>
        )}
        <div class="inline-flex flex-wrap items-center gap-x-3 gap-y-1 rounded-xl border border-border/70 bg-surface/60 px-4 py-3">
          <span class="font-mono text-[0.65rem] uppercase tracking-wider text-text-dim">Install</span>
          <code class="font-mono text-sm text-primary">pip install orionfold-proof</code>
          <span class="text-text-dim">then</span>
          <code class="font-mono text-sm text-primary">orionfold up</code>
        </div>
      </div>
      <p id="hero-cta-err" class="mt-3 hidden text-sm text-red-400" role="alert"></p>
    </PageHeader>
    <!-- Sticky-CTA sentinel: the bar fades in once this scrolls out of view. -->
    <div id="hero-cta-sentinel" aria-hidden="true"></div>

    <!-- The signature WOW: the capability matrix + speed -->
    <CapabilityMatrix tasters={receiptTasters} />

    <!-- The Orionfold line: the compact one-row strip (same as /relay/), so all
         three product pages carry an identical, equal-height suite-context row.
         Sequence is fixed Relay -> Proof -> Arena to match the top nav; the page
         self-highlights its own cell. Placed right before "What Orionfold Proof
         does" so the product-line context frames the product intro. -->
    <section class="px-6 pt-4 pb-10">
      <div class="mx-auto max-w-4xl">
        <p class="mb-3 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">The Orionfold line · Relay leads</p>
        <div class="flex flex-col gap-2 rounded-2xl border border-border/60 bg-surface/40 p-2 sm:flex-row">
          {constellation.map((c) => (
            c.self ? (
              <div class="flex flex-1 items-center gap-3 rounded-xl bg-primary/5 px-4 py-3">
                <span class="font-display text-sm font-bold text-primary">{c.name}</span>
                <span class="text-sm text-text-muted">{c.q}</span>
              </div>
            ) : (
              <a href={c.href} class="group flex flex-1 items-center gap-3 rounded-xl px-4 py-3 transition-colors hover:bg-surface">
                <span class="font-display text-sm font-bold text-text group-hover:text-primary">{c.name}</span>
                <span class="text-sm text-text-muted">{c.q}</span>
              </a>
            )
          ))}
        </div>
      </div>
    </section>

    <!-- What Orionfold Proof is: the product behind the receipts -->
    <ProofProduct />

    <!-- ============================================================
         DUAL-ICP COLUMNS (gap D4-②a) — one tool, two buyers. The builder
         wants a fast local benchmark; the regulated-enterprise buyer wants
         an audit-ready receipt a risk team can rerun. Placed after "What Proof
         does" so the reader knows the product before choosing their path.
         ============================================================ -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-5xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-primary">One tool, two jobs</p>
        <p class="mb-8 max-w-2xl text-sm leading-relaxed text-text-muted">
          The same locked-test-and-receipt loop serves the builder proving a model on their desk
          and the regulated team that has to hand a reviewer something they can check. Pick your path.
        </p>
        <div class="grid items-stretch gap-4 md:grid-cols-2 md:gap-6">
          {icps.map((p) => (
            <div class={`flex flex-col rounded-2xl border p-6 sm:p-8 ${p.accent ? 'border-primary/40 bg-primary/[0.06] shadow-lg shadow-primary/5' : 'border-border/70 bg-surface/60'}`}>
              <span class={`mb-5 inline-flex h-11 w-11 items-center justify-center rounded-xl ${p.accent ? 'bg-primary/15 text-primary' : 'bg-primary/10 text-primary'}`}>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={p.icon} />
              </span>
              <p class="font-mono text-[0.65rem] uppercase tracking-wider text-text-dim">{p.who}</p>
              <p class={`mt-1.5 text-lg font-semibold ${p.accent ? 'text-primary' : 'text-text'}`}>{p.lead}</p>
              <ul class="mt-5 space-y-3">
                {p.points.map((pt) => (
                  <li class="flex items-start gap-3">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class={`mt-0.5 shrink-0 ${p.accent ? 'text-primary' : 'text-text-muted'}`} aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="text-sm leading-relaxed text-text-muted">{pt}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Mid-page CTA: they now know what Proof is — catch the fast-decider -->
    <LicenseBand
      family={PROOF}
      live={ORIONFOLD_PROOF_LIVE}
      itemId="software:orionfold-proof"
      errId="proof-band-err"
      fullBlockId="get-proof"
      eyebrow="Prove it on your own machine"
      heading="Own the tool behind these receipts."
      body="Orionfold Proof runs on your own machine and hands back a signed receipt you can rerun. Owning it unlocks every pack it ships with, starting with the Advisor governance pack."
      enquiryHref="/adoption/?item=software:orionfold-proof"
      image={proofPoster}
      imageAlt="Orionfold Proof poster: an art-deco receipt rising from a laptop into the Orion stars, the tool that proves which AI to trust."
    />

    <!-- Headline receipts: our number next to the world it beats -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-6xl">
        <p class="mb-6 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">The numbers that pop</p>
        <div class="grid gap-4 sm:grid-cols-2" data-animate-stagger>
          {receipts.map((r) => (
            <a href={receiptHref(r.receipt) ?? r.href} data-animate class="of-surface of-pressable group flex flex-col rounded-2xl p-6">
              <div class="flex items-baseline justify-between gap-3">
                <span class="font-display text-3xl leading-none text-primary">{r.metric}</span>
                <span class="font-mono text-[0.6rem] uppercase tracking-[0.18em] text-text-dim">{r.label}</span>
              </div>
              <p class="mt-4 text-sm leading-relaxed text-text-muted">{r.body}</p>
              <span class="mt-4 text-sm text-primary transition-colors group-hover:text-primary/80">See the work &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Contrarian takes: what people assume, next to the receipt that breaks it -->
    <section class="border-y border-border bg-surface-raised px-6 py-14">
      <div class="mx-auto max-w-3xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">We proved these wrong</p>
        <p class="mb-8 max-w-2xl text-sm leading-relaxed text-text-muted">
          Six things almost everyone assumes about AI. Each one, next to the receipt from our own desk that breaks it.
        </p>
        <ul class="grid gap-3" data-animate-stagger>
          {myths.map((m) => (
            <li data-animate class="rounded-2xl border border-border/70 bg-surface/60 p-5">
              <p class="text-sm font-medium text-text-dim line-through decoration-text-dim/40">{m.claim}</p>
              <p class="mt-2 text-base leading-relaxed text-text">{m.bust}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Proof in the field: the build-log notes that carry each receipt's story -->
    {proofStories.length > 0 && (
      <section class="px-6 py-12">
        <div class="mx-auto max-w-3xl">
          <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">Proof in the field</p>
          <p class="mb-8 max-w-2xl text-sm leading-relaxed text-text-muted">
            Every receipt above has a story behind it: the test we locked, the run, and what we found.
            Here are the field notes, each one a thing you can rerun yourself.
          </p>
          <ul class="grid gap-3" data-animate-stagger>
            {proofStories.map((s) => (
              <li data-animate>
                <a href={`/story/${s.id}/`} class="of-surface of-pressable group block rounded-2xl p-5">
                  <p class="text-base font-medium leading-snug text-text group-hover:text-primary">{s.data.title}</p>
                  <p class="mt-2 text-sm leading-relaxed text-text-muted">{s.data.summary}</p>
                  <span class="mt-3 inline-block text-sm text-primary transition-colors group-hover:text-primary/80">Read the note &rarr;</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- ============================================================
         OWN-IT TRUST TRIO (gap D4-②c) — open source reframed as three plain
         buyer benefits, each linking the docs/trust/ page that backs it
         (link, not mirror, so no drift). Placed low, right before the
         objection block + buy box, so the own-it reassurance lands just as
         the reader nears the price. Proof's axes are local/offline +
         reproducible; the trio says them without jargon.
         ============================================================ -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-5xl">
        <p class="mb-6 text-center font-mono text-[0.65rem] uppercase tracking-[0.24em] text-primary">Yours, not ours</p>
        <div class="grid gap-4 sm:grid-cols-3">
          {trustTrio.map((t) => (
            <a
              href={t.href}
              class="group of-surface flex flex-col rounded-2xl border border-border/70 p-6 transition-colors hover:border-primary/40"
            >
              <span class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={t.icon} />
              </span>
              <p class="text-base font-semibold text-text">{t.title}</p>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">{t.body}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 font-mono text-xs tracking-wider text-primary/80 transition-colors group-hover:text-primary">
                See how
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         OBJECTION-AS-HEADER SECURITY BLOCK (gap D4-②d) — the last gate to
         clear before the price, and the deepest one for the regulated ICP.
         The "WE PROVED THESE WRONG" block busts AI-industry myths; this one
         answers buyer objections about Proof itself. Four questions a careful
         buyer (and a risk team) asks, each answered plainly, each linking the
         on-site /trust/ page that proves it. Same pattern as shipped /relay/.
         ============================================================ -->
    <section class="border-y border-border bg-surface-raised px-6 py-14">
      <div class="mx-auto max-w-3xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-primary">Before you buy</p>
        <h2 class="mb-4 text-3xl sm:text-4xl">The questions your risk team asks.</h2>
        <p class="mb-8 max-w-2xl text-sm leading-relaxed text-text-muted">
          Proof runs on your own machine, holds none of your data, and keeps working even if we do
          not. Here are the four questions a careful buyer asks, answered in plain words, each backed
          by a page that links the code that proves it.
        </p>
        <ul class="grid gap-4">
          {trust.map((t) => (
            <li class="rounded-2xl border border-border/70 bg-surface/60 p-6">
              <p class="text-base font-semibold text-text">{t.q}</p>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">{t.a}</p>
              <a
                href={t.href}
                class="mt-4 inline-flex items-center gap-1.5 font-mono text-xs tracking-wider text-primary transition-colors hover:text-primary/80"
              >
                {t.label}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Own the tool behind the receipts: lead with the buy block -->
    <ProofBox />

    <!-- Soft opt-in below the buy: catch receipt-readers who aren't checkout-ready yet -->
    <OfferSlot
      offer="proof-playbook"
      source="proof-page"
      label="Not ready to buy?"
      heading="Get the proof playbook."
      dek="The one-page guide to locking a test, running it on your own desk, and reading the receipts. Plus a note when we publish new proof."
      artifact="One-page PDF + new-proof notes"
      buttonText="Send it"
    />

    <!-- Close: hand the reader to the story and the catalog -->
    <section class="px-6 py-16">
      <div class="mx-auto max-w-2xl rounded-3xl border border-border bg-surface-raised/70 p-8 text-center">
        <p class="font-display text-2xl leading-snug">Proof you can rerun. An AI team you can own.</p>
        <p class="mt-4 text-base leading-relaxed text-text-muted">
          The receipts are the reason to believe. The payoff is what they earn: a private AI team
          that runs on the Spark you already own, with no cloud account and no per-word bills. The
          full story of why is in the
          <a class="text-primary underline underline-offset-2 hover:text-primary/80" href="/letter/">letter from the founder</a>.
        </p>
        <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
          <a href="/cockpit/" class="of-primary-action">Get an AI team you own</a>
          <a href="/letter/" class="of-secondary-action">Read the letter</a>
        </div>
      </div>
    </section>

    <!-- Persistent Buy bar: one tap away once the hero scrolls past. Same
         founding price + data-checkout wiring as ProofBox (SSOT-driven). -->
    <LandingStickyCta
      title="Orionfold Proof"
      lookupKey={PROOF.founding.lookupKey}
      priceLabel={formatUsd(PROOF.founding.amount)}
      itemId="software:orionfold-proof"
      live={ORIONFOLD_PROOF_LIVE}
      anchor="#get-proof"
    />
  </main>
  <Footer />
</Layout>

<script>
  // Wire the Proof purchase buttons (data-checkout → create-checkout-session →
  // Stripe). No-op when the buttons aren't rendered (ORIONFOLD_PROOF_LIVE off).
  import { wireCheckoutButtons } from '../lib/checkout';
  wireCheckoutButtons();
  document.addEventListener('astro:after-swap', () => wireCheckoutButtons());
</script>
