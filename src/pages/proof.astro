---
// /proof/ — "Receipts." The standing, falsifiable evidence wall: the interactive
// capability matrix is the hero, then the headline receipts, then the contrarian
// takes. Built for the builder who reruns your tests and the buyer they refer.
// Voice: grade 3-5, jargon explained, no em-dashes (website-copy-style). Numbers
// are repurposed from the field notes; the honest caveats stay in (receipt-honesty).
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import CapabilityMatrix from '../components/sections/CapabilityMatrix.astro';
import ProofProduct from '../components/sections/ProofProduct.astro';
import ProofBox from '../components/product/ProofBox.astro';
import LicenseBand from '../components/product/LicenseBand.astro';
import OfferSlot from '../components/ui/OfferSlot.astro';
import proofPoster from '../assets/proof/orionfold-proof-poster.jpeg';
import { getCollection } from 'astro:content';
import { receipts, myths, receiptHref } from '../data/proof';
import { SITE, PERSON } from '../data/seo';
import { PROOF } from '../data/commerce';
import { ORIONFOLD_PROOF_LIVE } from '../data/launch';
import { ogMeta } from '../data/og';

const og = ogMeta('/proof/');
const proofUrl = `${SITE.url}/proof/`;
const ogImageAbs = `${SITE.url}${og.image}`;

// Merchant-listings completeness for the priced Offer below. Same honest values
// as ProductDetail.astro: Orionfold Proof is an instant digital license from a
// US LLC, so free "shipping" (nothing physical) + no returns (a delivered,
// signed license file can't be returned). Without these GSC flags the Offer.
const digitalMerchantFields = {
  hasMerchantReturnPolicy: {
    '@type': 'MerchantReturnPolicy',
    applicableCountry: 'US',
    returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
  },
  shippingDetails: {
    '@type': 'OfferShippingDetails',
    shippingRate: { '@type': 'MonetaryAmount', value: '0', currency: 'USD' },
    shippingDestination: { '@type': 'DefinedRegion', addressCountry: 'US' },
  },
};

// A9 (relay): SoftwareApplication + Offer so /proof/ reads as the buyable
// product behind the receipts for answer engines, plus a HowTo for the
// configure -> run -> decide reproduction loop (the rerunnable claim is the
// whole pitch). Price = the standard $499 (the durable price after the founding
// seats sell out); the catalog SSOT is the source, never a hardcoded number.
const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Orionfold Proof',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, NVIDIA DGX Spark',
  description:
    'Lock a test before you train, run it on models you own, and publish a receipt anyone can rerun. The cockpit behind the receipts on this page.',
  url: proofUrl,
  image: ogImageAbs,
  author: PERSON,
  brand: { '@type': 'Brand', name: 'Orionfold' },
  offers: {
    '@type': 'Offer',
    price: (PROOF.primary.amount / 100).toFixed(2),
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: proofUrl,
    category: 'Software license',
    ...digitalMerchantFields,
  },
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Rerun an Orionfold Proof receipt',
  description:
    'How Orionfold Proof turns a claim into a receipt you can rerun: configure the test, run it on the models you are weighing, then decide from the scored result.',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Configure',
      text: 'Point Proof at your own task. Pick the models or setups you are weighing, local or cloud, and the rubric to score them by.',
      url: `${proofUrl}#what-it-does`,
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Run',
      text: 'Proof runs every candidate against the same locked test and records the result so the run is repeatable.',
      url: `${proofUrl}#what-it-does`,
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Decide',
      text: 'Read the scored receipt: which model passed, which refused, which missed. The receipt is the proof you can hand to anyone to rerun.',
      url: `${proofUrl}#what-it-does`,
    },
  ],
};

// Proof topic hub (relay ask A8): cluster the Proof-tagged build-log stories
// here so /proof/ is the pillar page that links its supporting field notes
// (topical authority for a young domain). Data-driven off the `Proof` tag so a
// new Proof story joins this hub the moment it ships, no edit here.
const proofStories = (await getCollection('story'))
  .filter((s) => s.data.tags.includes('Proof'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Taster map for the capability matrix's hover panel: receipt slug -> the
// metric + one-line claim shown in the right-side taster. Read here from the
// receipts collection so CapabilityMatrix stays decoupled from the content
// layer (it gets a plain map prop, no getCollection inside the component).
const receiptTasters = Object.fromEntries(
  (await getCollection('receipts')).map((r) => [
    r.id,
    { metric: r.data.metric, claim: r.data.claim },
  ]),
);
---
<Layout
  title="AI you can verify yourself · Orionfold"
  description="The proof, not the pitch. Frozen tests you can rerun, a small model that out-trusts a big one, and an AI lab that runs overnight for 2 cents, all on one desk."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={[
    softwareSchema,
    howToSchema,
    {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: myths.map((m) => ({
        '@type': 'Question',
        name: m.claim,
        acceptedAnswer: { '@type': 'Answer', text: m.bust },
      })),
    },
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'Receipts', item: `${SITE.url}/proof/` },
      ],
    },
  ]}
>
  <Nav />
  <main>
    <PageHeader
      eyebrow="Receipts"
      title="The proof, not the pitch."
      subtitle="We do not ask you to trust us. We lock the test before we train, publish the receipts, and let you rerun them. Here is what one desk can prove."
    />

    <!-- The signature WOW: the capability matrix + speed -->
    <CapabilityMatrix tasters={receiptTasters} />

    <!-- What Orionfold Proof is: the product behind the receipts -->
    <ProofProduct />

    <!-- Mid-page CTA: they now know what Proof is — catch the fast-decider -->
    <LicenseBand
      family={PROOF}
      live={ORIONFOLD_PROOF_LIVE}
      itemId="software:orionfold-proof"
      errId="proof-band-err"
      fullBlockId="get-proof"
      eyebrow="Prove it on your own machine"
      heading="Own the tool behind these receipts."
      body="Orionfold Proof runs on your own machine and hands back a signed receipt you can rerun. Owning it unlocks every pack it ships with, starting with the Advisor governance pack."
      enquiryHref="/adoption/?item=software:orionfold-proof"
      image={proofPoster}
      imageAlt="Orionfold Proof poster: an art-deco receipt rising from a laptop into the Orion stars, the tool that proves which AI to trust."
    />

    <!-- Headline receipts: our number next to the world it beats -->
    <section class="px-6 py-12">
      <div class="mx-auto max-w-6xl">
        <p class="mb-6 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">The numbers that pop</p>
        <div class="grid gap-4 sm:grid-cols-2" data-animate-stagger>
          {receipts.map((r) => (
            <a href={receiptHref(r.receipt) ?? r.href} data-animate class="of-surface of-pressable group flex flex-col rounded-2xl p-6">
              <div class="flex items-baseline justify-between gap-3">
                <span class="font-display text-3xl leading-none text-primary">{r.metric}</span>
                <span class="font-mono text-[0.6rem] uppercase tracking-[0.18em] text-text-dim">{r.label}</span>
              </div>
              <p class="mt-4 text-sm leading-relaxed text-text-muted">{r.body}</p>
              <span class="mt-4 text-sm text-primary transition-colors group-hover:text-primary/80">See the work &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Contrarian takes: what people assume, next to the receipt that breaks it -->
    <section class="border-y border-border bg-surface-raised px-6 py-14">
      <div class="mx-auto max-w-3xl">
        <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">We proved these wrong</p>
        <p class="mb-8 max-w-2xl text-sm leading-relaxed text-text-muted">
          Six things almost everyone assumes about AI. Each one, next to the receipt from our own desk that breaks it.
        </p>
        <ul class="grid gap-3" data-animate-stagger>
          {myths.map((m) => (
            <li data-animate class="rounded-2xl border border-border/70 bg-surface/60 p-5">
              <p class="text-sm font-medium text-text-dim line-through decoration-text-dim/40">{m.claim}</p>
              <p class="mt-2 text-base leading-relaxed text-text">{m.bust}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Proof in the field: the build-log notes that carry each receipt's story -->
    {proofStories.length > 0 && (
      <section class="px-6 py-12">
        <div class="mx-auto max-w-3xl">
          <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">Proof in the field</p>
          <p class="mb-8 max-w-2xl text-sm leading-relaxed text-text-muted">
            Every receipt above has a story behind it: the test we locked, the run, and what we found.
            Here are the field notes, each one a thing you can rerun yourself.
          </p>
          <ul class="grid gap-3" data-animate-stagger>
            {proofStories.map((s) => (
              <li data-animate>
                <a href={`/story/${s.id}/`} class="of-surface of-pressable group block rounded-2xl p-5">
                  <p class="text-base font-medium leading-snug text-text group-hover:text-primary">{s.data.title}</p>
                  <p class="mt-2 text-sm leading-relaxed text-text-muted">{s.data.summary}</p>
                  <span class="mt-3 inline-block text-sm text-primary transition-colors group-hover:text-primary/80">Read the note &rarr;</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- Own the tool behind the receipts: lead with the buy block -->
    <ProofBox />

    <!-- Soft opt-in below the buy: catch receipt-readers who aren't checkout-ready yet -->
    <OfferSlot
      offer="proof-playbook"
      source="proof-page"
      label="Not ready to buy?"
      heading="Get the proof playbook."
      dek="The one-page guide to locking a test, running it on your own desk, and reading the receipts. Plus a note when we publish new proof."
      artifact="One-page PDF + new-proof notes"
      buttonText="Send it"
    />

    <!-- Close: hand the reader to the story and the catalog -->
    <section class="px-6 py-16">
      <div class="mx-auto max-w-2xl rounded-3xl border border-border bg-surface-raised/70 p-8 text-center">
        <p class="font-display text-2xl leading-snug">Proof you can rerun. An AI team you can own.</p>
        <p class="mt-4 text-base leading-relaxed text-text-muted">
          The receipts are the reason to believe. The payoff is what they earn: a private AI team
          that runs on the Spark you already own, with no cloud account and no per-word bills. The
          full story of why is in the
          <a class="text-primary underline underline-offset-2 hover:text-primary/80" href="/letter/">letter from the founder</a>.
        </p>
        <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
          <a href="/cockpit/" class="of-primary-action">Get an AI team you own</a>
          <a href="/letter/" class="of-secondary-action">Read the letter</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  // Wire the Proof purchase buttons (data-checkout → create-checkout-session →
  // Stripe). No-op when the buttons aren't rendered (ORIONFOLD_PROOF_LIVE off).
  import { wireCheckoutButtons } from '../lib/checkout';
  wireCheckoutButtons();
  document.addEventListener('astro:after-swap', () => wireCheckoutButtons());
</script>
