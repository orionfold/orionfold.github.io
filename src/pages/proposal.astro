---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BrandMark from '../components/ui/BrandMark.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';
import { SITE } from '../data/seo';
import { ogMeta } from '../data/og';
import { RELAY_OPERATOR_WORKSHOP_CHECKOUT_ENABLED } from '../data/launch';
import {
  MAX_PROPOSAL_QUANTITY,
  PROPOSAL_TERMS_VERSION,
  formatUsd,
  getConsultingOffers,
} from '../../supabase/functions/_shared/consulting-proposal';
import { ORIONFOLD_LEGAL_IDENTITY } from '../../supabase/functions/_shared/legal-identity';

const publishedWorkshopKeys = RELAY_OPERATOR_WORKSHOP_CHECKOUT_ENABLED
  ? ['workshop_relay_operator_founding']
  : [];
const offers = getConsultingOffers(publishedWorkshopKeys);
const families = ['Prove', 'Operate', 'Learn', 'Train'] as const;
const og = ogMeta('/proposal/');
const localPreview = import.meta.env.DEV;
const endpoint = 'https://orionfold.supabase.co/functions/v1/consulting-request';

const proposalSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Build a non-binding Orionfold product proposal',
  description: 'Select Orionfold products, choose license or seat quantities, and print an itemized non-binding proposal request.',
  url: `${SITE.url}/proposal/`,
  mainEntity: {
    '@type': 'OfferCatalog',
    name: 'Orionfold product catalog',
    itemListElement: offers.map((offer, index) => ({
      '@type': 'Offer',
      position: index + 1,
      name: offer.label,
      priceCurrency: 'USD',
      price: (offer.amountCents / 100).toFixed(2),
      url: `${SITE.url}${offer.href}`,
      description: offer.includes,
    })),
  },
};
---
<Layout
  title="Build a non-binding Orionfold product proposal"
  description="Choose Orionfold products, set license or seat quantities, and print an itemized non-binding proposal request."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={proposalSchema}
>
  <Nav />
  <main id="proposal-builder" data-local-preview={localPreview ? 'true' : 'false'} data-endpoint={endpoint} data-published-workshops={JSON.stringify(publishedWorkshopKeys)}>
    <section class="proposal-hero relative overflow-hidden px-6 pb-20 pt-32">
      <div class="proposal-grid absolute inset-0 pointer-events-none"></div>
      <div class="absolute left-[12%] top-20 h-80 w-80 rounded-full bg-primary/[0.12] blur-[140px] pointer-events-none"></div>
      <div class="relative mx-auto max-w-6xl">
        <div data-animate><SectionLabel text="Product proposal · self-serve" /></div>
        <div class="mt-6 grid gap-10 lg:grid-cols-[minmax(0,1.18fr)_23rem] lg:items-end">
          <div>
            <p class="inline-flex rounded-full border border-primary/35 bg-primary/[0.08] px-3 py-1.5 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-primary">
              Non-binding proposal request
            </p>
            <h1 class="mt-6 max-w-4xl font-display text-[clamp(2.7rem,7vw,5.8rem)] leading-[0.97] tracking-[-0.045em] text-text" data-animate>
              Build the Orionfold system your business needs.
            </h1>
            <p class="mt-7 max-w-3xl text-lg leading-relaxed text-text-muted sm:text-xl" data-animate>
              Need to procure through an invoice or purchase order? Select the products and quantities you need, generate a formal proposal, and send it to Orionfold for review.
            </p>
          </div>
          <aside class="rounded-2xl border border-border bg-surface-raised/85 p-6 shadow-of-pop backdrop-blur" data-animate>
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.2em] text-text-dim">Product-only proposal</p>
            <p class="mt-3 text-3xl font-semibold text-text">Catalog price × quantity</p>
            <ul class="mt-5 space-y-3 text-sm leading-relaxed text-text-muted">
              <li>Select individual Orionfold products</li>
              <li>Set the required licenses or workshop seats</li>
              <li>Review list price and estimated bank-transfer savings</li>
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <section class="border-y border-border bg-surface-raised px-6 py-12">
      <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-3">
        <article class="rounded-2xl border border-border bg-surface p-5">
          <p class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-primary">1 · Build</p>
          <h2 class="mt-3 text-xl">Choose by job, not by bundle</h2>
          <p class="mt-2 text-sm leading-relaxed text-text-muted">Every product row explains when it fits, what it contributes, and when another choice is better.</p>
        </article>
        <article class="rounded-2xl border border-border bg-surface p-5">
          <p class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-primary">2 · Review</p>
          <h2 class="mt-3 text-xl">See one itemized estimate</h2>
          <p class="mt-2 text-sm leading-relaxed text-text-muted">Unit price, quantity, line total, and estimated domestic bank-transfer savings remain visible and separate.</p>
        </article>
        <article class="rounded-2xl border border-border bg-surface p-5">
          <p class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-primary">3 · Request</p>
          <h2 class="mt-3 text-xl">Orionfold reviews fit</h2>
          <p class="mt-2 text-sm leading-relaxed text-text-muted">Submission is not acceptance. Product availability, final quantities, invoice, and cleared payment come later.</p>
        </article>
      </div>
    </section>

    <form id="proposal-form" novalidate>
      <section class="border-y border-border bg-surface-raised px-6 py-20" aria-labelledby="matrix-heading">
        <div class="mx-auto max-w-6xl">
          <div class="max-w-4xl">
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-primary">Product decision matrix</p>
            <h2 id="matrix-heading" class="mt-4 text-4xl font-semibold tracking-tight sm:text-5xl">Choose the capability, not an upsell.</h2>
            <p class="mt-5 text-lg leading-relaxed text-text-muted">No product is preselected. Each has one distinct job; combinations are useful only when one product's output strengthens another.</p>
          </div>

          {families.map((family) => {
            const familyOffers = offers.filter((offer) => offer.family === family);
            if (!familyOffers.length) return null;
            return (
              <section class="mt-12" aria-labelledby={`family-${family.toLowerCase()}`}>
                <h3 id={`family-${family.toLowerCase()}`} class="font-mono text-sm uppercase tracking-[0.2em] text-text-dim">{family}</h3>
                <div class="mt-4 grid gap-5 xl:grid-cols-2">
                  {familyOffers.map((offer) => (
                    <article class="offer-card relative rounded-2xl border border-border bg-surface p-6 shadow-of transition hover:border-primary/60" data-offer-card={offer.id}>
                      <input
                        id={`offer-${offer.id}`}
                        type="checkbox"
                        name="selectedOffers"
                        value={offer.id}
                        class="offer-checkbox peer sr-only"
                        aria-label={`Add ${offer.label} to proposal`}
                      />
                      <label
                        for={`offer-${offer.id}`}
                        class="offer-hit-area absolute inset-0 z-10 cursor-pointer rounded-2xl"
                        aria-hidden="true"
                      ></label>
                      <div class="pointer-events-none relative z-20 flex items-start justify-between gap-5">
                        <div>
                          <p class="font-mono text-[0.6rem] uppercase tracking-[0.16em] text-primary">{offer.term}</p>
                          <h4 class="mt-2 text-2xl font-semibold text-text">{offer.label}</h4>
                        </div>
                        <label for={`offer-${offer.id}`} class="offer-select pointer-events-auto inline-flex shrink-0 cursor-pointer items-center gap-2 rounded-full border border-border bg-surface-raised px-3 py-2 text-sm font-medium text-text transition hover:border-primary/60">
                          <span class="offer-check inline-grid h-4 w-4 place-items-center rounded border border-border bg-surface text-[0.65rem] font-bold text-white" aria-hidden="true"></span>
                          <span class="offer-select-copy">Add</span>
                          <span class="offer-selected-copy hidden">Selected</span>
                        </label>
                      </div>
                      <dl class="mt-6 grid gap-4 text-sm leading-relaxed sm:grid-cols-2">
                        <div><dt>Job</dt><dd>{offer.job}</dd></div>
                        <div><dt>Choose it when</dt><dd>{offer.chooseWhen}</dd></div>
                        <div><dt>What it contributes</dt><dd>{offer.contributes}</dd></div>
                        <div><dt>Works with</dt><dd>{offer.worksWith}</dd></div>
                        <div><dt>Do not choose it for</dt><dd>{offer.notFor}</dd></div>
                        <div><dt>Included</dt><dd>{offer.includes}</dd></div>
                      </dl>
                      {offer.freeBoundary && <p class="mt-5 rounded-xl border border-primary/20 bg-primary/[0.06] p-3 text-sm leading-relaxed text-text-muted">{offer.freeBoundary}</p>}
                      <div class="relative z-20 mt-6 grid gap-4 border-t border-border pt-5 sm:grid-cols-[1fr_auto] sm:items-end">
                        <a class="relative z-20 text-sm text-primary hover:underline" href={offer.href}>Review product details</a>
                        <div class="flex flex-wrap items-end justify-between gap-4 sm:justify-end">
                          <label class="quantity-control">
                            <span>Quantity · {offer.unitLabel}</span>
                            <input
                              type="number"
                              name={`quantity-${offer.id}`}
                              data-offer-quantity={offer.id}
                              value="1"
                              min="1"
                              max={MAX_PROPOSAL_QUANTITY}
                              step="1"
                              inputmode="numeric"
                              disabled
                              aria-label={`Number of ${offer.unitLabel} for ${offer.label}`}
                            />
                          </label>
                          <p class="min-w-28 text-right text-xl font-semibold text-text">
                            {formatUsd(offer.amountCents)}
                            <span class="block text-xs font-normal text-text-muted">each{offer.mode === 'subscription' ? ' · per year' : ''}</span>
                          </p>
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              </section>
            );
          })}
          {!offers.some((offer) => offer.family === 'Train') && (
            <div class="mt-10 rounded-2xl border border-dashed border-border p-5 text-sm leading-relaxed text-text-muted">
              Published training workshops will appear here automatically. The current workshop remains excluded until its public checkout is enabled.
            </div>
          )}
        </div>
      </section>

      <section class="px-6 py-20" aria-labelledby="summary-heading">
        <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[minmax(0,1fr)_25rem] lg:items-start">
          <div>
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-primary">Your request</p>
            <h2 id="summary-heading" class="mt-4 text-4xl font-semibold tracking-tight sm:text-5xl">Tell us who the products are for.</h2>
            <p class="mt-5 max-w-3xl text-lg leading-relaxed text-text-muted">Your selections, quantities, and business contact are enough for Orionfold to review. We respond within 24 hours; that response may ask questions, decline, or issue a written product proposal.</p>

            <div class="mt-9 grid gap-5 sm:grid-cols-2">
              <label class="field-label">Full name<input name="fullName" autocomplete="name" maxlength="160" required /></label>
              <label class="field-label">Business email<input name="businessEmail" type="email" autocomplete="email" maxlength="320" required /></label>
              <label class="field-label sm:col-span-2">Company name<input name="companyName" autocomplete="organization" maxlength="200" required /></label>
              <label class="field-label sm:col-span-2">Purchase note or PO reference <span class="normal-case tracking-normal text-text-dim">(optional)</span><textarea name="purchaseNote" rows="3" maxlength="500" placeholder="Add a PO reference or a short invoicing or fulfillment note, if needed."></textarea></label>
              <label class="honeypot" aria-hidden="true">Site<input name="website" tabindex="-1" autocomplete="off" /></label>
            </div>
            <div id="form-message" class="mt-5 hidden rounded-xl border p-4 text-sm leading-relaxed" role="status" aria-live="polite"></div>
            <div class="mt-6 flex flex-wrap items-center gap-4">
              <button id="submit-proposal" class="rounded-full bg-primary px-6 py-3.5 font-semibold text-accent-text transition hover:bg-primary/90 disabled:cursor-not-allowed disabled:opacity-50" type="submit">Submit proposal request</button>
              <button id="print-proposal" class="rounded-full border border-border bg-surface-raised px-6 py-3.5 font-semibold text-text transition hover:border-primary/60" type="button">Print proposal</button>
            </div>
            <p class="mt-5 max-w-3xl text-xs leading-relaxed text-text-dim">By submitting, you ask Orionfold to review a non-binding product proposal request. No product order is accepted, invoiced, due, paid, or fulfilled. See the <a href="/terms/" class="text-primary hover:underline">Terms</a> and <a href="/privacy/" class="text-primary hover:underline">Privacy Policy</a>.</p>
          </div>

          <aside class="proposal-summary rounded-2xl border border-border bg-surface-raised p-6 shadow-of-pop lg:sticky lg:top-28" aria-label="Proposal estimate">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-primary">Non-binding proposal request</p>
            <p id="summary-state" class="mt-2 font-mono text-[0.6rem] uppercase tracking-[0.14em] text-text-dim">Draft · not submitted</p>
            <div id="summary-lines" class="mt-6 space-y-4"><p class="text-sm text-text-muted">Choose at least one product to begin.</p></div>
            <dl class="mt-6 space-y-3 border-t border-border pt-5 text-sm">
              <div class="flex justify-between gap-4"><dt class="text-text-muted">List subtotal</dt><dd id="summary-subtotal" class="font-medium text-text">—</dd></div>
              <div class="flex justify-between gap-4"><dt class="text-text-muted">Bank-transfer savings <span id="summary-rate"></span></dt><dd id="summary-savings" class="font-medium text-success">—</dd></div>
              <div class="flex justify-between gap-4 border-t border-border pt-3"><dt class="font-medium text-text">Estimated final subtotal</dt><dd id="summary-final" class="text-xl font-semibold text-text">—</dd></div>
            </dl>
            <p class="mt-5 text-xs leading-relaxed text-text-dim">Estimate for domestic USD ACH/wire. Based on avoided 2.9% + $0.30 card processing; no bank instructions appear here. Final written proposal and invoice control.</p>
          </aside>
        </div>
      </section>
    </form>

    <section class="proposal-preview-wrap border-t border-border bg-surface-raised px-6 py-20" aria-labelledby="formal-preview-heading">
      <div class="mx-auto max-w-5xl">
        <div class="proposal-preview-intro mb-8 print:hidden">
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-primary">Formal HTML proposal</p>
          <h2 id="formal-preview-heading" class="mt-4 text-3xl font-semibold tracking-tight">Print or save this document as PDF.</h2>
          <p class="mt-3 max-w-3xl text-text-muted">Before submission it is a draft. After submission, the same-session receipt is rebuilt from the server's immutable calculation.</p>
        </div>
        <article id="proposal-document" class="proposal-document" aria-label="Formal non-binding proposal document">
          <header class="document-header">
            <div class="flex items-center gap-3">
              <BrandMark size={32} />
              <div><p class="text-lg font-semibold"><span class="text-text">Orion</span><span class="text-primary">fold</span></p><p class="text-xs text-text-muted">{ORIONFOLD_LEGAL_IDENTITY.name}</p></div>
            </div>
            <div class="text-right text-xs leading-relaxed text-text-muted"><p>{ORIONFOLD_LEGAL_IDENTITY.postalAddress}</p><p>{ORIONFOLD_LEGAL_IDENTITY.email}</p></div>
          </header>
          <div class="document-status">
            <p>Non-binding proposal request</p>
            <p id="document-state">Draft · not submitted</p>
          </div>
          <div class="document-title">
            <p class="font-mono text-xs uppercase tracking-[0.16em] text-text-dim">Proposal <span id="document-number">Not assigned</span> · version <span id="document-version">Draft</span></p>
            <h2>Orionfold product proposal</h2>
            <p>Prepared <span id="document-date"></span> for <strong id="document-customer">Customer details pending</strong></p>
          </div>
          <section>
            <h3>Purchase note or PO reference</h3>
            <p id="document-purchase-note">None provided.</p>
          </section>
          <section>
            <h3>Itemized estimate</h3>
            <div id="document-lines"><p>Choose at least one product to build the estimate.</p></div>
            <dl class="document-totals">
              <div><dt>List subtotal</dt><dd id="document-subtotal">—</dd></div>
              <div><dt>Estimated domestic bank-transfer savings <span id="document-rate"></span></dt><dd id="document-savings">—</dd></div>
              <div><dt>Estimated final subtotal</dt><dd id="document-final">—</dd></div>
            </dl>
          </section>
          <section class="document-terms">
            <h3>Proposal terms and boundaries</h3>
            <ul>
              <li>This is a non-binding product proposal request, not acceptance, an order, an invoice, payment instructions, or a promise of availability or fulfillment.</li>
              <li>Every line is catalog unit price multiplied by the requested license or seat quantity. Prices, availability, and product terms may change before written acceptance.</li>
              <li>Each selected quantity is a request only. Orionfold may confirm, decline, or propose different quantities and fulfillment terms in writing.</li>
              <li>Hosting, cloud/model usage, deployment, consulting, and other third-party costs are excluded unless itemized in a later written agreement.</li>
              <li>Estimated savings applies to the eligible subtotal for domestic USD ACH/wire and uses the avoided-card-cost formula shown above. The final written proposal and invoice control.</li>
            </ul>
            <p class="mt-4 text-xs">Terms version: {PROPOSAL_TERMS_VERSION} · <span class="document-url">orionfold.com/terms/</span> · <span class="document-url">orionfold.com/privacy/</span></p>
          </section>
          <footer class="document-footer"><span>{ORIONFOLD_LEGAL_IDENTITY.name} · {ORIONFOLD_LEGAL_IDENTITY.email}</span><span>Non-binding proposal request</span></footer>
        </article>
      </div>
    </section>

    <aside
      id="proposal-sticky-summary"
      class="fixed inset-x-0 bottom-0 z-40 translate-y-full border-t border-border bg-surface/95 backdrop-blur transition-transform duration-300 [&.is-visible]:translate-y-0 motion-reduce:transition-none"
      aria-label="Current proposal selections and estimate"
      role="status"
      aria-live="polite"
    >
      <div class="mx-auto grid max-w-6xl grid-cols-[minmax(0,1fr)_auto_auto] items-center gap-3 px-4 py-3 sm:gap-6 sm:px-6">
        <div class="min-w-0">
          <p class="font-mono text-[0.56rem] uppercase tracking-[0.15em] text-primary sm:text-[0.62rem]">Your proposal</p>
          <p id="sticky-selection-summary" class="mt-0.5 truncate text-xs font-medium text-text sm:text-sm">Select a product</p>
        </div>
        <div class="text-right">
          <p class="font-mono text-[0.5rem] uppercase tracking-[0.1em] text-text-dim sm:text-[0.58rem]">You save</p>
          <p id="sticky-savings" class="mt-0.5 text-xs font-semibold text-success sm:text-sm">—</p>
        </div>
        <div class="text-right">
          <p class="font-mono text-[0.5rem] uppercase tracking-[0.1em] text-text-dim sm:text-[0.58rem]">Est. total</p>
          <p id="sticky-final" class="mt-0.5 text-sm font-semibold text-text sm:text-lg">—</p>
        </div>
      </div>
    </aside>
  </main>
  <Footer />
</Layout>

<script>
  import {
    buildProposalEstimate,
    buildProposalSnapshot,
    formatEffectiveSavings,
    formatUsd,
  } from '../../supabase/functions/_shared/consulting-proposal';

  const root = document.getElementById('proposal-builder') as HTMLElement;
  const form = document.getElementById('proposal-form') as HTMLFormElement;
  const publishedWorkshopKeys: string[] = JSON.parse(root.dataset.publishedWorkshops || '[]');
  let submittedReceipt: any = null;
  let submittedPayload: any = null;
  let requestId = crypto.randomUUID();

  const text = (id: string, value: string) => { const node = document.getElementById(id); if (node) node.textContent = value; };
  const selectedOffers = () => Array.from(form.querySelectorAll<HTMLInputElement>('input[name="selectedOffers"]:checked')).map((input) => ({
    id: input.value,
    quantity: Number(form.querySelector<HTMLInputElement>(`[data-offer-quantity="${CSS.escape(input.value)}"]`)?.value || 1),
  }));
  const customerData = () => {
    const data = new FormData(form);
    return {
      fullName: String(data.get('fullName') || '').trim(),
      businessEmail: String(data.get('businessEmail') || '').trim(),
      companyName: String(data.get('companyName') || '').trim(),
      purchaseNote: String(data.get('purchaseNote') || '').trim(),
      website: String(data.get('website') || ''),
    };
  };

  function render(snapshot?: any) {
    const linesHost = document.getElementById('summary-lines')!;
    const documentLines = document.getElementById('document-lines')!;
    const stickyBar = document.getElementById('proposal-sticky-summary')!;
    const customer = customerData();
    text('document-date', new Intl.DateTimeFormat('en-US', { dateStyle: 'long' }).format(new Date()));
    text('document-customer', customer.fullName
      ? `${customer.fullName}${customer.companyName ? ` · ${customer.companyName}` : ''}${customer.businessEmail ? ` · ${customer.businessEmail}` : ''}`
      : 'Customer details pending');
    text('document-purchase-note', customer.purchaseNote || 'None provided.');
    if (!snapshot) {
      stickyBar.classList.add('is-visible');
      text('sticky-selection-summary', 'Select a product');
      text('sticky-savings', '$0.00');
      text('sticky-final', '$0.00');
      linesHost.innerHTML = '<p class="text-sm text-text-muted">Choose at least one product to begin.</p>';
      documentLines.innerHTML = '<p>Choose at least one product to build the estimate.</p>';
      for (const id of ['summary-subtotal','summary-savings','summary-final','document-subtotal','document-savings','document-final']) text(id, '$0.00');
      text('summary-rate', ''); text('document-rate', '');
      return;
    }
    linesHost.replaceChildren(...snapshot.lines.map((line: any) => {
      const row = document.createElement('div'); row.className = 'flex justify-between gap-4 text-sm';
      const label = document.createElement('span'); label.className = 'text-text-muted'; label.textContent = `${line.label} · ${line.quantity} ${line.unitLabel}`;
      const amount = document.createElement('strong'); amount.className = 'shrink-0 text-text'; amount.textContent = formatUsd(line.amountCents);
      row.append(label, amount); return row;
    }));
    documentLines.replaceChildren(...snapshot.lines.map((line: any) => {
      const row = document.createElement('div'); row.className = 'document-line';
      const copy = document.createElement('div');
      const title = document.createElement('h4'); title.textContent = line.label;
      const quantity = document.createElement('p'); quantity.textContent = `${line.quantity} ${line.unitLabel} × ${formatUsd(line.unitAmountCents)} each`;
      const term = document.createElement('p'); term.textContent = line.term;
      const include = document.createElement('p'); include.textContent = line.includes;
      copy.append(title, quantity, term, include);
      const amount = document.createElement('strong'); amount.textContent = formatUsd(line.amountCents);
      row.append(copy, amount); return row;
    }));
    const rate = formatEffectiveSavings(snapshot.effectiveSavingsBasisPoints);
    const selectionSummary = snapshot.lines.map((line: any) => `${line.label} × ${line.quantity}`).join(' + ');
    text('sticky-selection-summary', selectionSummary);
    document.getElementById('sticky-selection-summary')?.setAttribute('title', selectionSummary);
    text('sticky-savings', `−${formatUsd(snapshot.savingsCents)}`);
    text('sticky-final', formatUsd(snapshot.estimatedFinalSubtotalCents));
    stickyBar.classList.add('is-visible');
    text('summary-subtotal', formatUsd(snapshot.listSubtotalCents));
    text('summary-savings', `−${formatUsd(snapshot.savingsCents)}`);
    text('summary-final', formatUsd(snapshot.estimatedFinalSubtotalCents));
    text('summary-rate', `(${rate})`);
    text('document-subtotal', formatUsd(snapshot.listSubtotalCents));
    text('document-savings', `−${formatUsd(snapshot.savingsCents)}`);
    text('document-final', formatUsd(snapshot.estimatedFinalSubtotalCents));
    text('document-rate', `(${rate})`);
  }

  function currentSnapshot() {
    if (submittedReceipt) return submittedReceipt.snapshot;
    const selections = selectedOffers();
    if (!selections.length) return undefined;
    try {
      return buildProposalEstimate({ selectedOffers: selections }, publishedWorkshopKeys);
    }
    catch { return undefined; }
  }

  form.addEventListener('input', (event) => {
    if (submittedReceipt) return;
    const target = event.target as HTMLInputElement;
    if (target.matches('input[name="selectedOffers"]')) {
      const quantity = form.querySelector<HTMLInputElement>(`[data-offer-quantity="${CSS.escape(target.value)}"]`);
      if (quantity) {
        quantity.disabled = !target.checked;
        if (target.checked && (!quantity.value || Number(quantity.value) < 1)) quantity.value = '1';
      }
    }
    render(currentSnapshot());
  });

  document.getElementById('print-proposal')?.addEventListener('click', () => {
    render(currentSnapshot());
    window.print();
  });

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    const message = document.getElementById('form-message')!;
    const submit = document.getElementById('submit-proposal') as HTMLButtonElement;
    const retryingConfirmation = Boolean(submittedReceipt && submittedPayload);
    if (!retryingConfirmation && !selectedOffers().length) {
      message.className = 'mt-5 rounded-xl border border-danger/40 bg-danger/10 p-4 text-sm text-danger';
      message.textContent = 'Choose at least one Orionfold product.';
      form.querySelector<HTMLInputElement>('input[name="selectedOffers"]')?.focus();
      return;
    }
    if (!retryingConfirmation && !form.reportValidity()) return;
    const customer = retryingConfirmation
      ? {
          fullName: submittedPayload.fullName,
          businessEmail: submittedPayload.businessEmail,
          companyName: submittedPayload.companyName,
          purchaseNote: submittedPayload.purchaseNote,
          website: submittedPayload.website,
        }
      : customerData();
    const payload = submittedPayload ?? {
      requestId,
      ...customer,
      selectedOffers: selectedOffers(),
    };
    submit.disabled = true;
    submit.textContent = 'Saving request…';
    message.className = 'mt-5 rounded-xl border border-border bg-surface-raised p-4 text-sm text-text-muted';
    message.textContent = 'Saving the server-verified proposal before notifying Orionfold…';
    try {
      let result: any;
      if (root.dataset.localPreview === 'true') {
        result = {
          success: true,
          localPreview: true,
          proposalNumber: `LOCAL-${new Date().toISOString().slice(0, 10)}`,
          proposalVersion: 1,
          requestState: 'pending_review',
          bindingStatus: 'non_binding_request',
          snapshot: buildProposalSnapshot({ selectedOffers: selectedOffers() }, publishedWorkshopKeys),
        };
      } else {
        const response = await fetch(root.dataset.endpoint!, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        result = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(result.error || 'We could not save the proposal request.');
      }
      submittedPayload = payload;
      submittedReceipt = result;
      render(result.snapshot);
      text('summary-state', result.localPreview ? 'Preview · not submitted' : 'Submitted · pending Orionfold review');
      text('document-state', result.localPreview ? 'Preview · not submitted' : 'Submitted · pending Orionfold review');
      text('document-number', result.proposalNumber);
      text('document-version', String(result.proposalVersion));
      form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea').forEach((control) => { control.disabled = true; });
      message.className = 'mt-5 rounded-xl border border-success/40 bg-success/10 p-4 text-sm leading-relaxed text-text';
      const customerConfirmationDelayed = result.customerConfirmationStatus === 'delayed';
      message.textContent = result.localPreview
        ? 'Preview only: no data or email was sent. The formal document below shows the server-calculated receipt shape for review.'
        : customerConfirmationDelayed
          ? `Proposal ${result.proposalNumber} was stored, but your confirmation email was delayed. Keep or print the proposal below, then retry the email. This does not mean the product request is accepted or fulfilled.`
        : result.notificationStatus === 'delayed'
          ? `Proposal ${result.proposalNumber} was stored and your confirmation copy was emailed to ${customer.businessEmail}. Orionfold's internal notification was delayed; if you do not hear within 24 hours, reply to that email. This does not mean the product request is accepted or fulfilled.`
          : `Proposal ${result.proposalNumber} was stored and a confirmation copy was emailed to ${customer.businessEmail}. Orionfold will respond within 24 hours. This does not mean the product request is accepted or fulfilled.`;
      submit.disabled = !customerConfirmationDelayed;
      submit.textContent = customerConfirmationDelayed ? 'Retry confirmation email' : 'Request stored';
      document.getElementById('print-proposal')?.focus();
    } catch (error) {
      message.className = 'mt-5 rounded-xl border border-danger/40 bg-danger/10 p-4 text-sm text-danger';
      message.textContent = error instanceof Error ? error.message : 'We could not save the proposal request. Try again.';
      submit.disabled = false;
      submit.textContent = 'Submit proposal request';
    }
  });

  render();
</script>

