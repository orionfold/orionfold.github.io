---
// Software detail route (P-series, spec §5.2). Emits /software/<slug>/ only for
// slugs that have a productDetail entry (getProductPaths gates the set). Joins
// the software.ts SSOT record to the entry, resolves the hero from the listing
// poster, and hands everything to the adaptive ProductDetail engine. Coexists
// with /software/ (src/pages/software.astro) — no collision (exact vs nested).
import { render } from 'astro:content';
import ProductDetail from '../../../layouts/ProductDetail.astro';
import { getProductPaths, toProductView, resolveRelated, coverKey } from '../../../lib/product/detail';
import { trust, buildTrustStats } from '../../../data/trust';

export async function getStaticPaths() {
  return getProductPaths('software');
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const view = toProductView('software', entry);
const related = await resolveRelated(entry);
const trustStats = buildTrustStats(trust, 'software', entry.data.slug);

// Hero reuses the listing poster (src/assets/projects/<slug>-poster.png) unless
// the entry overrides it with its own `hero`.
const projectImgs = import.meta.glob<{ default: ImageMetadata }>('../../../assets/projects/*.png', { eager: true });
const { key } = coverKey('software', entry.data.slug);
const ssotHero = key ? Object.entries(projectImgs).find(([p]) => p.endsWith('/' + key))?.[1]?.default : undefined;
const hero = entry.data.hero ?? ssotHero;
const hasBody = Boolean(entry.body && entry.body.trim());
---
<ProductDetail view={view} detail={entry.data} hero={hero} related={related} trustStats={trustStats} hasBody={hasBody}>
  <Content />
</ProductDetail>
