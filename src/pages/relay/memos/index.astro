---
// /relay/memos/ — source-ordered Relay editorial series. Articles and signature
// SVGs come from _ASSETS; grouping, status labels and conversion chrome belong
// to Website. Each series keeps its own pillar and reading arc.
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import PageHeader from '../../../components/ui/PageHeader.astro';
import RelaySubNav from '../../../components/relay/RelaySubNav.astro';
import RelayCtaBand from '../../../components/relay/RelayCtaBand.astro';
import { ogMeta } from '../../../data/og';
import { SITE } from '../../../data/seo';
import { groupedMemos, memoSignatureHtml } from '../../../lib/relay/memos.mjs';

const groups = groupedMemos(await getCollection('memos'));
const memos = groups.flatMap((group) => group.memos);
const og = ogMeta('/relay/');

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Relay field memos · Orionfold',
  description:
    'Source-verified essays about Relay Packs and the Host and Cell operating model.',
  url: `${SITE.url}/relay/memos/`,
  blogPost: memos.map((memo) => ({
    '@type': 'BlogPosting',
    headline: memo.data.title,
    description: memo.data.summary,
    url: `${SITE.url}/relay/memos/${memo.id}/`,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Relay', item: `${SITE.url}/relay/` },
    { '@type': 'ListItem', position: 3, name: 'Memos', item: `${SITE.url}/relay/memos/` },
  ],
};

const statusLabel = (memo) => memo.data.status === 'published' ? null : memo.data.status;
---
<Layout
  title="Relay field memos · Orionfold"
  description="Two source-verified Relay memo series: how Packs become owned operating systems, and how Hosts and Cells create honest operating boundaries."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={[collectionSchema, breadcrumbSchema]}
>
  <Nav />
  <RelaySubNav active="memos" />
  <main class="-mt-20 sm:-mt-24">
    <PageHeader
      eyebrow="Relay · Field memos"
      title="The architecture behind Relay."
      subtitle="Two reading arcs explain the product from the inside. Relay Packs covers the operating system you install for a domain. Relay Host & Cells covers the boundaries that keep managed customer instances honest, recoverable, and legible."
    />

    <div class="px-6 pt-8 pb-6">
      <div class="mx-auto max-w-5xl space-y-20">
        {groups.map((group) => {
          const [pillar, ...rest] = group.memos;
          return (
            <section aria-labelledby={`series-${group.slugs[0]}`}>
              <div class="mb-7 max-w-3xl">
                <p class="font-mono text-[0.65rem] uppercase tracking-[0.22em] text-primary">{group.label}</p>
                <h2 id={`series-${group.slugs[0]}`} class="mt-2 text-2xl sm:text-3xl">{group.name}</h2>
                <p class="mt-3 leading-relaxed text-text-muted">{group.description}</p>
              </div>

              {pillar && (
                <a
                  href={`/relay/memos/${pillar.id}/`}
                  class="group grid items-center gap-8 rounded-2xl border border-border/70 bg-surface/30 p-6 shadow-lg shadow-primary/5 transition-shadow hover:shadow-primary/15 sm:p-8 lg:grid-cols-2 lg:gap-10"
                  aria-label={`Start the ${group.name} series: ${pillar.data.title}`}
                >
                  {memoSignatureHtml(pillar) && (
                    <div class="memo-card-hero overflow-hidden rounded-xl border border-border/60 bg-surface/40 lg:order-2" set:html={memoSignatureHtml(pillar)} />
                  )}
                  <div class="lg:order-1">
                    <div class="flex flex-wrap items-center gap-2 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-primary">
                      <span>Start here · Pillar</span>
                      {statusLabel(pillar) && <span class="rounded-full border border-border px-2 py-0.5 text-text-dim">{statusLabel(pillar)}</span>}
                    </div>
                    <h3 class="mt-3 text-2xl leading-tight sm:text-3xl">{pillar.data.title}</h3>
                    <p class="mt-4 text-base leading-relaxed text-text-muted">{pillar.data.summary}</p>
                    <span class="mt-5 inline-flex items-center gap-1.5 font-mono text-sm text-primary">
                      Start the series <span class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">&rarr;</span>
                    </span>
                  </div>
                </a>
              )}

              {rest.length > 0 && (
                <div class="mt-8 grid gap-6 sm:grid-cols-2" data-animate-stagger>
                  {rest.map((memo, index) => (
                    <a
                      href={`/relay/memos/${memo.id}/`}
                      class="group flex flex-col overflow-hidden rounded-2xl border border-border/70 bg-surface/30 transition-shadow hover:shadow-lg hover:shadow-primary/10"
                      data-animate
                      aria-label={`Read memo: ${memo.data.title}`}
                    >
                      {memoSignatureHtml(memo) && (
                        <div class="memo-card-hero border-b border-border/60 bg-surface/40" set:html={memoSignatureHtml(memo)} />
                      )}
                      <div class="flex flex-1 flex-col p-6">
                        <div class="flex flex-wrap items-center gap-2 font-mono text-[0.6rem] uppercase tracking-[0.18em] text-primary">
                          <span>Memo {String(index + 2).padStart(2, '0')}</span>
                          {statusLabel(memo) && <span class="rounded-full border border-border px-2 py-0.5 text-text-dim">{statusLabel(memo)}</span>}
                        </div>
                        <h3 class="mt-2 text-lg leading-snug sm:text-xl">{memo.data.title}</h3>
                        <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">{memo.data.summary}</p>
                        <span class="mt-4 inline-flex items-center gap-1.5 font-mono text-sm text-primary">
                          Read <span class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">&rarr;</span>
                        </span>
                      </div>
                    </a>
                  ))}
                </div>
              )}
            </section>
          );
        })}
      </div>
    </div>

    <RelayCtaBand
      variant="footer"
      kicker="Choose the Relay boundary your work needs."
      line="Explore Relay Core, premium Packs, and the launch-dark Host path from one product overview."
      class="mt-10"
    />
  </main>
  <Footer />
</Layout>

<style>
  .memo-card-hero :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
