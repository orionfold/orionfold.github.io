---
// /relay/memos/ — the Relay Packs memo series index (Rail B publish, _RELAY #17).
// A long-form editorial series (one pillar + four domain memos) on the pack
// architecture. Presented as an editorial reading list, pillar-first: the pillar
// memo leads as a full-width feature, then the four domain memos in a grid.
// Each card leads with that memo's inlined signature.svg hero (theme-reactive
// via the global --svg-* tokens). Memos are copied verbatim from the strategy
// _ASSETS corpus; this page owns the chrome. Mirrors the /relay/docs/ index
// idiom + reuses the Rail-B footer CTA. Drafts render (operator preview, _RELAY
// #17); a Draft chip marks editorial-review-pending memos honestly.
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import PageHeader from '../../../components/ui/PageHeader.astro';
import RelaySubNav from '../../../components/relay/RelaySubNav.astro';
import RelayDocsCta from '../../../components/relay/RelayDocsCta.astro';
import { ogMeta } from '../../../data/og';
import { SITE } from '../../../data/seo';
import { orderedMemos, memoSignatureHtml } from '../../../lib/relay/memos.mjs';

const memos = orderedMemos(await getCollection('memos'));
const seriesName = memos[0]?.data.series ?? 'Relay Packs';
const [pillar, ...rest] = memos;
const og = ogMeta('/relay/');

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `${seriesName} · Orionfold Relay`,
  description:
    'The Relay Packs series: a long-form argument for the pack, the unit that turns a generic workspace into a domain operating system you own. One pillar essay plus four domain memos.',
  url: `${SITE.url}/relay/memos/`,
  blogPost: memos.map((m) => ({
    '@type': 'BlogPosting',
    headline: m.data.title,
    description: m.data.summary,
    url: `${SITE.url}/relay/memos/${m.id}/`,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Relay', item: `${SITE.url}/relay/` },
    { '@type': 'ListItem', position: 3, name: 'Memos', item: `${SITE.url}/relay/memos/` },
  ],
};

// A card body used for both the pillar feature and the grid cards.
const cardMeta = (m) => ({
  href: `/relay/memos/${m.id}/`,
  hero: memoSignatureHtml(m),
  isDraft: m.data.status !== 'published',
});
---
<Layout
  title={`${seriesName} · Relay · Orionfold`}
  description="The Relay Packs series: why a pack is a different category from a skill, an MCP server, or a plugin, and what one does inside a real domain. One pillar essay plus four domain memos."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={[collectionSchema, breadcrumbSchema]}
>
  <Nav />
  <RelaySubNav active="memos" />
  <main class="-mt-20 sm:-mt-24">
    <PageHeader
      eyebrow={`Relay · ${seriesName}`}
      title="A pack is a different category."
      subtitle="Skills teach one agent. MCP connects a model to a tool. Plugins extend someone else's app. A Relay Pack is the installable operating system for a domain, one you own and run offline. This series makes that argument in full, then walks it into one real domain at a time."
    />

    <section class="px-6 pt-8 pb-4">
      <div class="mx-auto max-w-5xl space-y-14">
        {pillar && (() => {
          const c = cardMeta(pillar);
          return (
            <a
              href={c.href}
              class="group grid items-center gap-8 rounded-2xl border border-border/70 bg-surface/30 p-6 shadow-lg shadow-primary/5 transition-shadow hover:shadow-primary/15 sm:p-8 lg:grid-cols-2 lg:gap-10"
              aria-label={`Read the pillar memo: ${pillar.data.title}`}
            >
              {c.hero && (
                <div class="memo-card-hero overflow-hidden rounded-xl border border-border/60 bg-surface/40 lg:order-2" set:html={c.hero} />
              )}
              <div class="lg:order-1">
                <div class="flex flex-wrap items-center gap-3">
                  <p class="font-mono text-[0.65rem] uppercase tracking-[0.22em] text-primary">Start here · Pillar</p>
                  {c.isDraft && (
                    <span class="rounded border border-border px-2 py-0.5 font-mono text-[0.55rem] uppercase tracking-[0.16em] text-text-dim">Draft</span>
                  )}
                </div>
                <h2 class="mt-3 text-2xl leading-tight sm:text-3xl">{pillar.data.title}</h2>
                <p class="mt-4 text-base leading-relaxed text-text-muted">{pillar.data.summary}</p>
                <span class="mt-5 inline-flex items-center gap-1.5 font-mono text-sm text-primary">
                  Read the pillar
                  <span class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">&rarr;</span>
                </span>
              </div>
            </a>
          );
        })()}

        {rest.length > 0 && (
          <div>
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.22em] text-text-dim">The domain memos</p>
            <div class="mt-6 grid gap-6 sm:grid-cols-2" data-animate-stagger>
              {rest.map((m, i) => {
                const c = cardMeta(m);
                return (
                  <a
                    href={c.href}
                    class="group flex flex-col overflow-hidden rounded-2xl border border-border/70 bg-surface/30 transition-shadow hover:shadow-lg hover:shadow-primary/10"
                    data-animate
                    aria-label={`Read memo: ${m.data.title}`}
                  >
                    {c.hero && (
                      <div class="memo-card-hero border-b border-border/60 bg-surface/40" set:html={c.hero} />
                    )}
                    <div class="flex flex-1 flex-col p-6">
                      <div class="flex flex-wrap items-center gap-2">
                        <p class="font-mono text-[0.6rem] uppercase tracking-[0.2em] text-primary">Memo {String(i + 2).padStart(2, '0')}</p>
                        {c.isDraft && (
                          <span class="rounded border border-border px-1.5 py-0.5 font-mono text-[0.5rem] uppercase tracking-[0.16em] text-text-dim">Draft</span>
                        )}
                      </div>
                      <h3 class="mt-2 text-lg leading-snug sm:text-xl">{m.data.title}</h3>
                      <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">{m.data.summary}</p>
                      <span class="mt-4 inline-flex items-center gap-1.5 font-mono text-sm text-primary">
                        Read
                        <span class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">&rarr;</span>
                      </span>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}
      </div>
    </section>

    <RelayDocsCta kicker="Own the packs in this series." class="mt-10" />
  </main>
  <Footer />
</Layout>

<style>
  /* Inlined hero SVGs scale to the card width, keeping their 16:9 box. */
  .memo-card-hero :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
