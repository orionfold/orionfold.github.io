---
// /relay/host/ is the dedicated decision surface for the paid Host right.
// It deliberately does not duplicate /relay/'s Core and premium-Pack sales job.
// Content authority, reconciled 2026-07-20:
// - Relay _ASSETS/docs guide 09 (Host/Cell boundary and seven-step journey)
// - Relay screenshots captured 2026-07-19 (boundary, deployment, license)
// - Relay docs: relay-host-{fulfillment,supervisor,access}.md
// - first five review-stage Relay Host & Cells memos
// - accepted Relay G-104/G-105 DigitalOcean guided-beta receipt on Relay 0.44.9
// Keep the provider claim bounded to that one manual customer-owned topology.
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import RelaySubNav from '../../components/relay/RelaySubNav.astro';
import ThemedShot from '../../components/relay/ThemedShot.astro';
import RelayHostOffer from '../../components/product/RelayHostOffer.astro';
import { RELAY_HOST, formatUsd } from '../../data/commerce';
import { RELAY_HOST_LIVE } from '../../data/launch';
import { SITE } from '../../data/seo';
import { ogMeta } from '../../data/og';

const og = ogMeta('/relay/host/');
const hostUrl = `${SITE.url}/relay/host/`;
const price = formatUsd(RELAY_HOST.amount);

const proofFacts = [
  { value: '1', label: 'customer-owned Host', note: 'One machine or VM under the operator’s control' },
  { value: '10', label: 'managed Relay Cells', note: 'Running, stopped and retained Cells count' },
  { value: '0.44.9', label: 'public accepted release', note: 'npm Host and signed multi-architecture Cell image' },
];

const boundaries = [
  {
    title: 'A Cell is not a folder',
    body: 'Each managed Cell is a complete Relay instance with its own database, files, identity, secrets, logs, limits and recovery lineage. Projects and customer records organize work inside a Cell. They do not isolate it.',
  },
  {
    title: 'The Host administrator is trusted',
    body: 'Cells on one Host have separate application state, but they share the machine and its administrator. Put a customer on a separate VM or machine when that administrator must not have access.',
  },
  {
    title: 'The supervisor stays local',
    body: 'One Host Supervisor controls only the Cells on its own machine. It is not a Fleet Controller and it does not reach into remote Hosts.',
  },
];

const proofs = [
  {
    n: '01',
    title: 'Commercial license',
    q: 'May this operator use managed Host actions?',
    a: 'A signed offline license carries the Host grant, term, owner and capacity. It is not a login session or a Docker password.',
  },
  {
    n: '02',
    title: 'Cell image authenticity',
    q: 'Did Orionfold build these exact bytes?',
    a: 'The Host pulls the public Cell image by immutable digest and verifies the signed release identity, attestation and software inventory.',
  },
  {
    n: '03',
    title: 'Registry access',
    q: 'May this machine download the image?',
    a: 'The primary GHCR image is public, so it needs no purchase token. A customer mirror can use its own scoped registry credential.',
  },
];

const journey = [
  ['Choose placement', 'Run locally or follow the manual DigitalOcean guided beta on a customer-owned Ubuntu server. Relay never asks for your provider token.'],
  ['Configure the Host', 'Set Host identity, machine shape, managed Cell count, exposure, model runtime and recovery posture.'],
  ['Review the estimate', 'Relay calculates a dated resource and provider range. Any material change clears stale approval.'],
  ['Authorize the exact plan', 'A signed Host license and explicit operator confirmation are required before a managed mutation.'],
  ['Install and verify', 'npm supplies Relay and Host control. The Host pulls and verifies the compatible public Cell image by digest.'],
  ['Create customer Cells', 'Each opaque Cell id gets its own data root, private network, loopback port, limits and lifecycle receipts.'],
  ['Handoff and recover', 'Keep encrypted recovery outside the Host. Export, verify and restore without depending on Orionfold infrastructure.'],
];

const faq = [
  ['Is Relay Host hosted by Orionfold?', 'No. The Host runs on infrastructure you or your customer controls. Orionfold sells the signed managed-use right and Host updates, not a hosted service or uptime promise.'],
  ['Do I pay to download Relay or the Cell image?', 'No. Relay Core, direct use and the public signed Cell image remain free. The paid right is managed Host lifecycle within signed capacity.'],
  ['Are ten Cells ten hostile tenants?', 'No. Each Cell has independent application state and lifecycle, but same-Host Cells still trust the Host administrator and share the machine failure boundary.'],
  ['What happens when the annual term ends?', 'Existing Cells keep running and remain startable, stoppable, exportable, recoverable and purgeable. New managed capacity and forward paid updates stop. Compatible critical-security fixes remain included.'],
  ['Are premium Packs included?', 'No. Packs are maintained application content and remain a separate license. Relay Host covers Host authority and managed Cell capacity.'],
  ['Is DigitalOcean deployment available now?', 'Yes, as a guided manual beta on a customer-owned Ubuntu server. You create and administer the server, firewall, DNS, TLS, backups, recovery keys and bill. Relay does not provision or operate it for you.'],
];

type AccessFaq = {
  question: string;
  paragraphs: string[];
  bullets?: string[];
  afterBullets?: string[];
  links?: { href: string; label: string }[];
};

const accessFaq: AccessFaq[] = [
  {
    question: 'Can I give each of my customers their own Relay workspace?',
    paragraphs: [
      'Yes. Create a separate managed Relay Cell for each customer. A Cell is a complete Relay instance with its own database, files, identity, secrets, settings, logs, limits, authenticated browser access, backups and recovery lineage. It is more than a customer record or folder inside a shared Relay application.',
    ],
  },
  {
    question: 'How does my customer open their Cell?',
    paragraphs: [
      'Give the Cell a dedicated HTTPS address, such as customer-name.relay.example.com, or an equivalently isolated path configured by the Host administrator. The public route must map only to that Cell’s loopback-only service port through an authenticated TLS ingress. Cell ports, Docker, databases and model-runtime ports must not be exposed directly.',
      'The current DigitalOcean guided beta leaves hostname, DNS, TLS, firewall and reverse-proxy configuration with the Host operator. Relay does not ask for your provider token or create those resources for you.',
    ],
  },
  {
    question: 'How does the customer create their login?',
    paragraphs: [
      'The Host operator generates a single-use bootstrap credential for that Cell. It is valid for 15 minutes and should be transferred to the intended customer through a separate trusted channel. The customer opens the Cell’s HTTPS address, enters the credential, creates the first administrator password and saves the eight recovery codes shown once.',
      'Relay stores digests rather than the clear bootstrap credential, password, session tokens or recovery codes.',
    ],
  },
  {
    question: 'Does the customer need to install Relay?',
    paragraphs: [
      'No. A customer using a managed Cell normally opens it in a web browser. The Relay Host operator installs, updates, monitors, backs up and recovers the Host and its resident Cells.',
    ],
  },
  {
    question: 'Can more than one person use the same customer Cell?',
    paragraphs: [
      'The current access model has one built-in administrator credential per Cell. That administrator can sign in from multiple named browser sessions. Sessions last 12 hours, are independently visible and can be revoked.',
      'Relay does not yet provide separate named users, role-based permissions, customer invitations, SSO or organization membership inside one Cell. Multiple browser sessions are not multiple user accounts.',
    ],
  },
  {
    question: 'Can one customer see another customer’s Cell?',
    paragraphs: [
      'Not through Relay’s normal application or ingress routing. Each managed Cell has its own application state, data root, secret root, private network, loopback port, identity, authentication store and recovery chain. Relay also rejects browser-supplied customer, Cell, session and forwarded-identity headers; a caller cannot select another Cell by changing a header or URL.',
      'This is operational isolation, not protection from the Host administrator or the shared machine’s failure boundary.',
    ],
  },
  {
    question: 'Can I, as the Host administrator, access a customer’s Cell?',
    paragraphs: [
      'Yes. The Host administrator remains trusted. They control the machine and runtime, can inspect resident Cell storage, create the initial first-administrator bootstrap credential before access is configured and operate infrastructure recovery. Containers do not make the Host administrator unable to access customer data. Relay refuses a second bootstrap after the Cell administrator has been configured.',
      'Make this trust relationship clear before onboarding a customer. Relay Host is customer-owned managed infrastructure, not a hostile-tenant SaaS boundary.',
    ],
  },
  {
    question: 'When should a customer receive a separate Host instead of a Cell on mine?',
    paragraphs: [
      'Use a separate Host, VM or customer-controlled server when the customer:',
    ],
    bullets: [
      'must not trust your Host administrator;',
      'requires a separate infrastructure or legal-administration boundary;',
      'cannot share the physical failure domain with another customer; or',
      'needs a security or compliance promise beyond the supported same-Host model.',
    ],
    afterBullets: [
      'Changing folders, ports or container labels does not solve an administrator-trust requirement. Change the Host boundary.',
    ],
  },
  {
    question: 'Is customer onboarding automatic?',
    paragraphs: [
      'Not yet. In the guided beta, onboarding is a guided manual setup. The Host operator:',
    ],
    bullets: [
      'creates and starts the managed Cell;',
      'assigns a stable HTTPS hostname or path;',
      'configures the TLS reverse proxy to map that route only to the Cell’s loopback port;',
      'generates the Cell’s short-lived first-administrator credential;',
      'hands the credential to the customer through a trusted channel; and',
      'confirms login, recovery-code custody, session visibility and backup policy.',
    ],
    afterBullets: [
      'Relay’s current Settings and Host Supervisor manage Cell lifecycle and capacity, but they do not yet automate DNS, TLS routes, invitation delivery or the complete customer-access handoff.',
    ],
  },
  {
    question: 'What happens if a customer loses their password?',
    paragraphs: [
      'The customer can use one of the Cell’s recovery codes. Recovery changes the password, rotates all remaining recovery codes and revokes every existing browser session. If the customer loses every recovery code, Relay does not allow the Host administrator to issue another first-administrator bootstrap credential over the configured account. Recovery must instead use the customer-owned encrypted Cell recovery material or a separately supported operator recovery procedure; do not delete or edit the authentication database to bypass this boundary.',
      'Browser recovery codes are not Cell disaster-recovery keys. The operator must separately configure encrypted Cell backup and Host-loss recovery.',
    ],
  },
  {
    question: 'What happens when I stop managing a customer?',
    paragraphs: [
      'Stopping or retaining a managed Cell does not release its licensed capacity. Before ending service, create and verify an encrypted recovery export. Then either:',
    ],
    bullets: [
      'export and release the Cell, preserving the verified recovery artifact and freeing the managed-Cell slot; or',
      'permanently purge the Cell after explicit confirmation when retention is no longer required.',
    ],
    afterBullets: [
      'Existing Cells and recovery remain available if a Host license lapses, but the operator cannot create additional managed Cells without valid capacity.',
    ],
  },
  {
    question: 'How many customers can one Relay Host serve?',
    paragraphs: [
      'The launch Relay Host entitlement covers one Host with up to ten managed Cells. Running, stopped and retained managed Cells count toward that limit. Exported-and-released and permanently purged Cells do not. A Cell should map to one customer organization unless that organization intentionally shares one administrator and operational boundary.',
    ],
  },
  {
    question: 'Is this the same as Orionfold hosting Relay for my customers?',
    paragraphs: [
      'No. Relay Host runs on infrastructure owned or controlled by you or your customer. You own the server account, infrastructure bill, DNS, TLS, firewall, model credentials, backups, recovery keys and administration. Orionfold supplies Relay software, the signed Cell image, the licensed managed-Host authority, updates and support within the documented topology.',
    ],
  },
  {
    question: 'Where can I find the setup instructions?',
    paragraphs: [
      'Use the guide that matches your installed Relay release. For the current guided-beta release, use these version-matched Relay 0.44.9 guides. Do not substitute an unversioned or third-party routing recipe for the release-matched trust and ingress contract.',
    ],
    links: [
      { href: 'https://github.com/orionfold/relay/blob/v0.44.9/docs/digitalocean-relay-host.md', label: 'Run a Relay Host on DigitalOcean' },
      { href: 'https://github.com/orionfold/relay/blob/v0.44.9/docs/relay-host-access.md', label: 'Relay Host ingress and administrator access' },
    ],
  },
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Orionfold Relay Host',
  description: 'The annual offline-verifiable right to operate one customer-owned Relay Host with up to ten managed Relay Cells. Premium Packs are separate.',
  url: hostUrl,
  brand: { '@type': 'Brand', name: 'Orionfold' },
  offers: {
    '@type': 'Offer',
    price: (RELAY_HOST.amount / 100).toFixed(2),
    priceCurrency: 'USD',
    availability: RELAY_HOST_LIVE ? 'https://schema.org/InStock' : 'https://schema.org/PreOrder',
    url: `${hostUrl}#get-relay-host`,
    category: 'Annual software license',
    hasMerchantReturnPolicy: {
      '@type': 'MerchantReturnPolicy',
      applicableCountry: 'US',
      returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
      merchantReturnDays: RELAY_HOST.refundDays,
      returnMethod: 'https://schema.org/KeepProduct',
      returnFees: 'https://schema.org/FreeReturn',
      refundType: 'https://schema.org/FullRefund',
    },
    shippingDetails: {
      '@type': 'OfferShippingDetails',
      shippingRate: { '@type': 'MonetaryAmount', value: '0', currency: 'USD' },
      shippingDestination: { '@type': 'DefinedRegion', addressCountry: 'US' },
    },
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    ...accessFaq.map(({ question, paragraphs, bullets = [], afterBullets = [] }) => ({
      '@type': 'Question',
      name: question,
      acceptedAnswer: { '@type': 'Answer', text: [...paragraphs, ...bullets, ...afterBullets].join(' ') },
    })),
    ...faq.map(([question, answer]) => ({
      '@type': 'Question',
      name: question,
      acceptedAnswer: { '@type': 'Answer', text: answer },
    })),
  ],
};
---

<Layout
  title="Relay Host · One Host, a clean Relay Cell for every customer"
  description="Run one customer-owned Relay Host with up to ten managed Relay Cells. Signed offline licensing, public verified Cell images, explicit recovery, and honest same-Host trust boundaries."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={[
    productSchema,
    faqSchema,
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'Relay', item: `${SITE.url}/relay/` },
        { '@type': 'ListItem', position: 3, name: 'Host', item: hostUrl },
      ],
    },
  ]}
>
  <Nav />
  <RelaySubNav active="host" />
  <main class="-mt-20 sm:-mt-24">
    <PageHeader
      eyebrow="Relay Host · Customer-owned infrastructure"
      title="One Host. A clean Relay Cell for every customer."
      subtitle="Operate up to ten complete Relay instances on one machine you control. Each Cell keeps its own state and recovery lineage. You keep the infrastructure, data, keys and bill."
    >
      <div class="mb-4 mt-7 flex flex-col items-start gap-3 sm:flex-row sm:items-center">
        {RELAY_HOST_LIVE ? (
          <button
            type="button"
            data-checkout={RELAY_HOST.primary.lookupKey}
            data-item="software:orionfold-relay-host"
            data-error-target="relay-host-hero-error"
            class="of-primary-action text-base font-semibold"
          >Buy Relay Host <span class="rounded-md bg-black/15 px-2 py-0.5 font-mono text-xs">{price}/yr</span></button>
        ) : (
          <span class="inline-flex min-h-11 items-center rounded-full border border-primary/30 bg-primary/[0.07] px-5 py-3 font-mono text-xs font-semibold uppercase tracking-wider text-primary">
            Relay Host launch is being prepared
          </span>
        )}
        <a href="#proof" class="of-secondary-action">See what is already proven</a>
      </div>
      <p id="relay-host-hero-error" role="alert" hidden class="mt-2 text-sm text-red-500"></p>
    </PageHeader>

    <section class="px-6 pb-12 pt-8 sm:pt-12">
      <div class="mx-auto grid max-w-5xl gap-3 sm:grid-cols-3">
        {proofFacts.map((fact) => (
          <div class="of-surface overflow-hidden rounded-2xl p-5">
            <p class="font-display text-4xl font-bold text-primary">{fact.value}</p>
            <p class="mt-1 text-sm font-semibold text-text">{fact.label}</p>
            <p class="mt-2 text-xs leading-relaxed text-text-muted">{fact.note}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="proof" class="managed-proof relative overflow-hidden border-y border-primary/20 px-6 py-16 sm:py-20">
      <div class="managed-grid pointer-events-none absolute inset-0" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-6xl">
        <div class="grid gap-10 lg:grid-cols-[0.72fr_1.28fr] lg:items-center">
          <div>
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-primary">The managed journey</p>
            <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">Placement to handoff, with every gate visible.</h2>
            <p class="mt-5 leading-relaxed text-text-muted">
              Relay turns managed deployment into seven named steps: placement, configuration, estimate,
              authorization, install, verification and handoff. The local path and one customer-owned DigitalOcean
              guided beta are proven. Relay's in-app Cloud Server Preview remains a planning simulation, not provisioning.
            </p>
            <a href="/relay/docs/set-trust-runtime-and-local-controls/" class="of-text-action mt-5">Read the operator guide →</a>
          </div>
          <figure class="overflow-hidden rounded-2xl border border-primary/25 bg-surface shadow-2xl shadow-primary/10">
            <ThemedShot
              id="settings-host-deployment"
              alt="Relay Settings showing the seven-step Host deployment journey, local device placement, cloud server preview, Host administrator trust warning, license gate and Host configuration fields."
              class="managed-shot"
            />
            <figcaption class="border-t border-border/70 px-5 py-3 text-center text-xs leading-relaxed text-text-muted">
              Host deployment capture from the accepted beta train · current public release: Relay 0.44.9
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section class="px-6 py-16 sm:py-20">
      <div class="mx-auto max-w-5xl">
        <p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-primary">The boundary you are buying</p>
        <h2 class="mt-3 max-w-3xl text-balance text-3xl font-bold sm:text-4xl">A folder organizes work. A Cell carries its own operational life.</h2>
        <div class="mt-9 grid gap-4 lg:grid-cols-3">
          {boundaries.map((boundary, index) => (
            <article class="of-surface rounded-2xl p-6">
              <span class="font-mono text-xs text-primary">0{index + 1}</span>
              <h3 class="mt-4 text-xl font-semibold">{boundary.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-text-muted">{boundary.body}</p>
            </article>
          ))}
        </div>
        <figure class="mt-9 overflow-hidden rounded-2xl border border-border/70 bg-surface shadow-lg">
          <ThemedShot
            id="settings-cell-boundary"
            alt="Relay Settings showing that one Cell has its own identity, data directory, database and workspace, with a clear Host administrator trust boundary."
            class="managed-boundary-shot"
          />
          <figcaption class="border-t border-border/70 px-5 py-3 text-center text-xs text-text-muted">
            Relay reports the Cell id, data root, database and Host-administrator boundary as facts, not marketing labels.
          </figcaption>
        </figure>
      </div>
    </section>

    <section class="border-y border-border/70 bg-surface/35 px-6 py-16 sm:py-20">
      <div class="mx-auto max-w-5xl">
        <p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-primary">Three proofs, never conflated</p>
        <h2 class="mt-3 max-w-3xl text-balance text-3xl font-bold sm:text-4xl">Paying, downloading and trusting the bytes are separate decisions.</h2>
        <div class="mt-9 grid gap-4 lg:grid-cols-3">
          {proofs.map((proof) => (
            <article class="rounded-2xl border border-border/70 bg-surface p-6">
              <span class="font-mono text-xs text-primary">{proof.n}</span>
              <h3 class="mt-4 text-xl font-semibold">{proof.title}</h3>
              <p class="mt-2 font-mono text-[0.68rem] uppercase tracking-wider text-text-dim">{proof.q}</p>
              <p class="mt-4 text-sm leading-relaxed text-text-muted">{proof.a}</p>
            </article>
          ))}
        </div>
        <p class="mt-7 max-w-3xl text-sm leading-relaxed text-text-muted">
          Relay Core and the public Cell image remain free. Relay Host is the signed authority to create and operate Cells through the Host Supervisor within the limits you bought. Premium Packs remain a separate right.
        </p>
      </div>
    </section>

    <section id="customer-cell-access" class="scroll-mt-36 border-y border-border/70 bg-surface/35 px-6 py-16 sm:py-20">
      <div class="mx-auto max-w-5xl">
        <div class="max-w-3xl">
          <p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-primary">Customer Cell access · Guided beta</p>
          <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">Give every customer a separate Cell—with the trust boundary stated plainly.</h2>
          <p class="mt-5 leading-relaxed text-text-muted">
            Per-customer authenticated browser access is available now through operator-configured access. One-click invitations,
            automatic DNS or reverse-proxy setup, multiple user roles and SSO are not. Same-Host Cells trust the Host administrator.
          </p>
        </div>
        <div class="mt-9 divide-y divide-border/70 rounded-2xl border border-border/70 bg-surface/70 px-5 sm:px-7">
          {accessFaq.map(({ question, paragraphs, bullets, afterBullets, links }) => (
            <details class="group py-5">
              <summary class="cursor-pointer list-none pr-10 text-lg font-semibold text-text marker:hidden">
                {question}
                <span aria-hidden="true" class="float-right -mr-7 font-mono text-primary transition-transform group-open:rotate-45">+</span>
              </summary>
              <div class="mt-4 max-w-4xl space-y-3 text-sm leading-relaxed text-text-muted">
                {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                {bullets && (
                  <ul class="list-disc space-y-2 pl-5">
                    {bullets.map((bullet) => <li>{bullet}</li>)}
                  </ul>
                )}
                {afterBullets?.map((paragraph) => <p>{paragraph}</p>)}
                {links && (
                  <div class="flex flex-col items-start gap-2 pt-1">
                    {links.map((link) => <a href={link.href} class="of-text-action">{link.label} →</a>)}
                  </div>
                )}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 py-16 sm:py-20">
      <div class="mx-auto max-w-5xl">
        <div class="grid gap-10 lg:grid-cols-[0.72fr_1.28fr]">
          <div>
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-primary">The operator path</p>
            <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">From one machine to ten named customer Cells.</h2>
            <p class="mt-5 text-sm leading-relaxed text-text-muted">
              Admission happens before Relay allocates a port, path, volume, network or customer state. At capacity, the eleventh Cell is refused without disturbing the first ten.
            </p>
          </div>
          <ol class="space-y-3">
            {journey.map(([title, body], index) => (
              <li class="grid gap-3 rounded-2xl border border-border/70 bg-surface/60 p-5 sm:grid-cols-[2.5rem_1fr]">
                <span class="font-mono text-sm font-semibold text-primary">{String(index + 1).padStart(2, '0')}</span>
                <div>
                  <h3 class="font-semibold text-text">{title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-text-muted">{body}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <section class="px-6 py-16 sm:py-20">
      <div class="mx-auto max-w-5xl rounded-3xl border border-primary/30 bg-primary/[0.055] p-7 sm:p-10">
        <p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-primary">Accepted customer-owned cloud proof</p>
        <div class="mt-4 grid gap-8 lg:grid-cols-[1fr_0.9fr]">
          <div>
            <h2 class="text-balance text-3xl font-bold sm:text-4xl">One DigitalOcean Host is proven. The claim stays that narrow.</h2>
            <p class="mt-5 leading-relaxed text-text-muted">
              Relay 0.44.9 passed a fresh guided-beta run on one customer-owned Ubuntu 24.04 x64 SFO3 Droplet with
              2 vCPU, 4 GiB RAM and 80 GiB disk. Authenticated HTTPS, first-admin setup, ten managed Cells, eleventh-Cell
              refusal, same-Host isolation, a private model runtime, encrypted recovery, restart, rollback and export all passed.
            </p>
            <p class="mt-4 text-sm leading-relaxed text-text-muted">
              The run lasted about 18 minutes at a $0.03571/hour compute rate and remained conservatively below $0.05,
              subject to provider billing lag. Cleanup removed the Droplet, volume, reserved IP, firewall, disposable SSH
              key, provider token and local credentials; final provider inventory was empty. This is a proof-run cost, not
              a monthly sizing or operating-cost promise.
            </p>
