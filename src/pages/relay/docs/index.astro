---
// /relay/docs/ — the Relay user guide index (Rail B publish, _RELAY #15). Lists
// the 9 green SMB chapters copied verbatim from the strategy-owned _ASSETS docs
// corpus, in `order`. A child of the /relay/ hub (the sub-nav marks Docs
// active); the footer CTA is the website's, hardcoded (contract: task-focused,
// footer CTA only). Mirrors the /receipts/ index idiom.
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import PageHeader from '../../../components/ui/PageHeader.astro';
import RelaySubNav from '../../../components/relay/RelaySubNav.astro';
import RelayDocsCta from '../../../components/relay/RelayDocsCta.astro';
import { ogMeta } from '../../../data/og';
import { SITE } from '../../../data/seo';

const chapters = (await getCollection('relayDocs')).sort((a, b) => a.data.order - b.data.order);
const og = ogMeta('/relay/');

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Relay User Guide',
  description:
    'The Orionfold Relay user guide: run your AI team from one local cockpit. Nine chapters, from first launch to workflows, tables, and trust controls.',
  url: `${SITE.url}/relay/docs/`,
  hasPart: chapters.map((c) => ({
    '@type': 'TechArticle',
    headline: c.data.title,
    description: c.data.summary,
    url: `${SITE.url}/relay/docs/${c.id}/`,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Relay', item: `${SITE.url}/relay/` },
    { '@type': 'ListItem', position: 3, name: 'Docs', item: `${SITE.url}/relay/docs/` },
  ],
};
---
<Layout
  title="Relay User Guide · Orionfold"
  description="The Orionfold Relay user guide: run your AI team from one local cockpit. Nine chapters, from first launch to workflows, tables, and trust controls."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={[collectionSchema, breadcrumbSchema]}
>
  <Nav />
  <RelaySubNav active="docs" />
  {/* The sub-nav already clears the fixed Nav; pull the PageHeader's own
      nav-clearance (pt-28) back up so the masthead sits just under the rail. */}
  <main class="-mt-20 sm:-mt-24">
    <PageHeader
      eyebrow="Relay · User guide"
      title="Run Relay like an operator."
      subtitle="Nine short chapters, written for a small-business operator. Start it, read the first screen, then work through packs, customers, workflows, tables, and trust controls."
    />

    <section class="px-6 py-12">
      <div class="mx-auto max-w-3xl">
        <ol class="grid gap-3" data-animate-stagger>
          {chapters.map((c) => (
            <li data-animate>
              <a href={`/relay/docs/${c.id}/`} class="of-surface of-pressable group block rounded-2xl p-6">
                <div class="flex items-baseline gap-3">
                  <span class="font-mono text-sm text-primary">{String(c.data.order).padStart(2, '0')}</span>
                  <span class="font-mono text-[0.6rem] uppercase tracking-[0.18em] text-text-dim">Chapter</span>
                </div>
                <p class="mt-3 text-lg font-medium leading-snug text-text group-hover:text-primary">{c.data.title}</p>
                <p class="mt-2 text-sm leading-relaxed text-text-muted">{c.data.summary}</p>
                <span class="mt-4 inline-block text-sm text-primary transition-colors group-hover:text-primary/80">Read the chapter &rarr;</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <RelayDocsCta kicker="Ready to run it yourself?" />
  </main>
  <Footer />
</Layout>
