---
// /relay/docs/<slug>/ — one Relay user-guide chapter (Rail B publish, _RELAY
// #15). Renders the verbatim markdown body; inline ![alt](relay-shot:<id>)
// markers are rewritten to themed shots by the global rehype bridge. Prev/next
// walk the `order`. Footer CTA is the website's edge-to-edge RelayCtaBand
// (contract: footer-only, don't interrupt), matching the Memos + API surfaces.
// Mirrors the /receipts/<slug>/ idiom.
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';
import Footer from '../../../../components/Footer.astro';
import RelaySubNav from '../../../../components/relay/RelaySubNav.astro';
import RelayCtaBand from '../../../../components/relay/RelayCtaBand.astro';
import { ogMeta } from '../../../../data/og';
import { SITE, PERSON, PUBLISHER } from '../../../../data/seo';

export async function getStaticPaths() {
  const chapters = (await getCollection('relayDocs')).sort((a, b) => a.data.order - b.data.order);
  return chapters.map((chapter, i) => ({
    params: { slug: chapter.id },
    props: {
      chapter,
      prev: i > 0 ? chapters[i - 1] : null,
      next: i < chapters.length - 1 ? chapters[i + 1] : null,
    },
  }));
}

type Entry = CollectionEntry<'relayDocs'>;
const { chapter, prev, next } = Astro.props as { chapter: Entry; prev: Entry | null; next: Entry | null };
const { Content } = await render(chapter);
const { title, order, summary } = chapter.data;

const og = ogMeta('/relay/');
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const techArticleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description: summary,
  author: { ...PERSON, url: `${SITE.url}/about/` },
  publisher: PUBLISHER,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  url: canonical,
  inLanguage: 'en',
  articleSection: 'Relay User Guide',
  isPartOf: { '@type': 'CollectionPage', name: 'Relay User Guide', url: `${SITE.url}/relay/docs/` },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Relay', item: `${SITE.url}/relay/` },
    { '@type': 'ListItem', position: 3, name: 'Docs', item: `${SITE.url}/relay/docs/` },
    { '@type': 'ListItem', position: 4, name: title, item: canonical },
  ],
};
---
<Layout
  title={`${title} · Relay User Guide · Orionfold`}
  description={summary}
  ogImage={og.image}
  ogImageAlt={`${title} · Orionfold Relay user guide`}
  jsonLd={[techArticleSchema, breadcrumbSchema]}
>
  <Nav />
  <RelaySubNav active="docs" />
  <main class="px-6 pt-10 pb-24">
    <div class="mx-auto max-w-2xl">
      <a href="/relay/docs/" class="inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-[0.15em] text-text-muted transition-colors hover:text-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
        User guide
      </a>

      <p class="mt-8 font-mono text-sm text-primary">Chapter {String(order).padStart(2, '0')}</p>
      <h1 class="mt-2 text-3xl leading-tight sm:text-4xl">{title}</h1>

      <article class="story-prose mt-10 border-t border-border pt-10">
        <Content />
      </article>

      <nav class="mt-16 flex flex-col gap-3 border-t border-border pt-8 sm:flex-row sm:justify-between" aria-label="Chapter navigation">
        {prev ? (
          <a href={`/relay/docs/${prev.id}/`} class="group max-w-[48%] text-sm text-text-muted transition-colors hover:text-primary">
            <span class="block font-mono text-[0.6rem] uppercase tracking-[0.16em] text-text-dim">&larr; Previous</span>
            <span class="mt-1 block leading-snug group-hover:text-primary">{prev.data.title}</span>
          </a>
        ) : <span />}
        {next ? (
          <a href={`/relay/docs/${next.id}/`} class="group max-w-[48%] text-right text-sm text-text-muted transition-colors hover:text-primary sm:ml-auto">
            <span class="block font-mono text-[0.6rem] uppercase tracking-[0.16em] text-text-dim">Next &rarr;</span>
            <span class="mt-1 block leading-snug group-hover:text-primary">{next.data.title}</span>
          </a>
        ) : <span />}
      </nav>
    </div>
  </main>

  <RelayCtaBand variant="footer" />
  <Footer />
</Layout>
