---
// Roadmap (R1, spec §5) — the hook page. Every offering (books, software,
// models) classified into three status lanes (Shipped / Building now / Planned),
// built from src/data/roadmap.ts: the F1 status tags merged with the live GitHub
// signals (F2), so the active items expand into real, current features (fieldkit
// modules, field-notes research areas). Each card carries a select checkbox (for
// the R2 enquiry drawer) and a Buy/Sponsor CTA. A momentum strip up top reads the
// live signals so the page feels alive. Covers resolve here via globs, mirroring
// software.astro / models.astro. Reuses RoadmapCard + ConstellationCover idioms.
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import RoadmapCard from '../components/ui/RoadmapCard.astro';
import { roadmap, roadmapLanes, roadmapSignals } from '../data/roadmap';
import { ogMeta } from '../data/og';
import { SITE } from '../data/seo';
import aiNativeCover from '../assets/book/ai-native-business-book.jpg';
import aiResearchCover from '../assets/book/ai-research-dgx-spark-book.jpg';

const og = ogMeta('/roadmap/');

// Books have no flat cover key in the roadmap data, but their real cover art
// lives in src/assets/book/. Map by roadmap item id so book cards show the
// actual cover (contained + centered in RoadmapCard) instead of the constellation.
const bookCovers: Record<string, ImageMetadata> = {
  'book:ai-native-business': aiNativeCover,
  'book:field-notes': aiResearchCover,
};

// Resolve an item's cover key to ImageMetadata. Software posters live flat under
// assets/projects/; model covers nest under assets/models/<slug>/cover.png.
// Books have no cover (RoadmapCard falls back to the constellation motif).
const projectImgs = import.meta.glob<{ default: ImageMetadata }>('../assets/projects/*.png', { eager: true });
const modelImgs = import.meta.glob<{ default: ImageMetadata }>('../assets/models/**/*.{png,jpg,jpeg}', { eager: true });
function resolveCover(assetBase?: string, key?: string): ImageMetadata | undefined {
  if (!assetBase || !key) return undefined;
  const map = assetBase === 'projects' ? projectImgs : assetBase === 'models' ? modelImgs : {};
  const entry = Object.entries(map).find(([path]) => path.endsWith('/' + key));
  return entry?.[1]?.default;
}

// Momentum strip — live signals (F2) make the page read as a working studio.
const stats = [
  { value: String(roadmap.length), label: 'offerings' },
  { value: String(roadmapLanes.active.length), label: 'building now' },
  { value: `v${roadmapSignals.fieldkit.version}`, label: 'fieldkit' },
  { value: `${roadmapSignals.fieldNotes.articlesPublished}`, label: `field notes (+${roadmapSignals.fieldNotes.articlesUpcoming} coming)` },
];

const lanes = [
  { key: 'active' as const, title: 'Building now', blurb: 'Active work you can sponsor to move faster. Open a card to back a single feature.', dot: 'bg-primary animate-pulse', items: roadmapLanes.active },
  { key: 'released' as const, title: 'Shipped', blurb: 'Out now, open, and free to use.', dot: 'bg-text-muted/50', items: roadmapLanes.released },
  { key: 'planned' as const, title: 'Planned', blurb: 'On the horizon. Sponsor the work to help pick what ships next.', dot: 'bg-text-muted/30 ring-1 ring-text-muted/40', items: roadmapLanes.planned },
];

// ItemList JSON-LD: lists every offering for answer engines (AEO).
const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Orionfold roadmap',
  description: 'Orionfold offerings by status: books, software, and models, with ways to sponsor each line of work.',
  numberOfItems: roadmap.length,
  itemListElement: roadmap
    .filter((i) => i.href)
    .map((i, idx) => ({ '@type': 'ListItem', position: idx + 1, name: i.title, url: i.href })),
};
---
<Layout
  title="Roadmap · Orionfold"
  description="Every Orionfold offering by status: what is shipped, what we are building now, and what is planned. Sponsor any line of work or send a custom enquiry."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={itemListLd}
>
  <Nav />
  <main>
    <!-- Page header + momentum strip (slim masthead so the lanes rise up) -->
    <PageHeader
      eyebrow="Roadmap"
      title="What we build, ship, and plan next"
      subtitle="One place for everything Orionfold makes, sorted by where it stands. Back an offering or a single feature to move it up the list, or send us a custom enquiry."
    >
      <dl data-animate class="mt-7 flex flex-wrap items-center gap-x-8 gap-y-4" style="transition-delay: 140ms">
        {stats.map((s) => (
          <div class="flex flex-col">
            <dt class="font-display text-2xl font-bold text-primary">{s.value}</dt>
            <dd class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted">{s.label}</dd>
          </div>
        ))}
      </dl>
    </PageHeader>

    <!-- Status lanes -->
    {lanes.map((lane) => (
      <section id={lane.key} class="scroll-mt-24 px-6 pt-14">
        <div class="mx-auto max-w-6xl">
          <div class="mb-6 flex items-baseline gap-3 border-b border-border pb-3">
            <span class:list={['inline-block h-2.5 w-2.5 shrink-0 translate-y-px rounded-full', lane.dot]}></span>
            <h2 data-animate class="text-2xl">{lane.title}</h2>
            <span class="font-mono text-sm text-text-muted">{lane.items.length}</span>
            <p data-animate class="ml-auto hidden max-w-md text-right text-sm leading-relaxed text-text-muted sm:block" style="transition-delay: 60ms">{lane.blurb}</p>
          </div>
          <p data-animate class="mb-6 text-sm leading-relaxed text-text-muted sm:hidden">{lane.blurb}</p>

          {lane.items.length > 0 ? (
            <div data-animate-stagger class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {lane.items.map((item) => (
                <RoadmapCard item={item} cover={resolveCover(item.assetBase, item.cover) ?? bookCovers[item.id]} />
              ))}
            </div>
          ) : (
            <div data-animate class="rounded-2xl border border-dashed border-border bg-surface-raised p-10 text-center">
              <p class="mx-auto max-w-md leading-relaxed text-text-muted">
                Nothing here yet. The next builds are shaped by what people back.
                <a href="/sponsor/" class="font-medium text-primary hover:underline"> Sponsor the work</a> to help pick what ships next.
              </p>
            </div>
          )}
        </div>
      </section>
    ))}

    <div class="h-20"></div>
  </main>

  <!-- Selection tray. R1 ships working multi-select + a count/clear; R2 turns
       this into the "Enquiry (n)" trigger that opens the enquiry drawer, reading
       the same window.roadmapSelection store. -->
  <div
    id="roadmap-tray"
    hidden
    class="fixed bottom-5 left-1/2 z-40 flex -translate-x-1/2 items-center gap-3 rounded-full border border-border bg-surface-raised/95 px-5 py-2.5 shadow-lg backdrop-blur"
  >
    <span class="flex items-center gap-2 font-mono text-sm">
      <span class="inline-block h-2 w-2 rounded-full bg-primary"></span>
      <span id="roadmap-tray-count" aria-live="polite">0 selected</span>
    </span>
    <button id="roadmap-tray-clear" type="button" class="font-mono text-xs uppercase tracking-wider text-text-muted hover:text-primary">
      Clear
    </button>
  </div>

  <Footer />
</Layout>

<script>
  // Roadmap selection store (R1). Tracks which items/features the visitor ticked
  // for an enquiry. R2's enquiry drawer consumes window.roadmapSelection — this is
  // the seam, so R1 keeps the store + tray and R2 adds the panel + submit.
  type Selection = { items: Map<string, string>; subscribe: (fn: () => void) => void };

  function initRoadmapSelection() {
    const boxes = Array.from(
      document.querySelectorAll<HTMLInputElement>('input[data-roadmap-select]'),
    );
    if (boxes.length === 0) return;

    const items = new Map<string, string>(); // id -> human label
    const listeners: Array<() => void> = [];
    const notify = () => listeners.forEach((fn) => fn());

    const store: Selection = { items, subscribe: (fn) => listeners.push(fn) };
    (window as unknown as { roadmapSelection: Selection }).roadmapSelection = store;

    const tray = document.getElementById('roadmap-tray');
    const count = document.getElementById('roadmap-tray-count');
    const clear = document.getElementById('roadmap-tray-clear');

    const render = () => {
      const n = items.size;
      if (tray) tray.hidden = n === 0;
      if (count) count.textContent = `${n} selected`;
    };

    boxes.forEach((box) => {
      box.addEventListener('change', () => {
        const id = box.value;
        const label = box.dataset.label ?? id;
        if (box.checked) items.set(id, label);
        else items.delete(id);
        render();
        notify();
      });
    });

    clear?.addEventListener('click', () => {
      boxes.forEach((b) => (b.checked = false));
      items.clear();
      render();
      notify();
    });

    render();
  }

  initRoadmapSelection();
  document.addEventListener('astro:after-swap', initRoadmapSelection);
</script>

<script>
  // Wire the Buy (book) + Sponsor-tier buttons to Stripe Checkout (C4). CORS-fails
  // on localhost (allowlist is orionfold.com); the live buy/sponsor test is L1.
  import { wireCheckoutButtons } from '../lib/checkout';
  wireCheckoutButtons();
  document.addEventListener('astro:after-swap', () => wireCheckoutButtons());
</script>
