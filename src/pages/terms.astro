---
// Terms of Use (S10). Ported from the donor terms.astro, structure + section
// headings kept; legal entity swapped to Orionfold LLC, product framing widened
// to the studio (website, software, models, newsletter, services), and the
// contact/domain swapped to manav@orionfold.com. The page-level JSON-LD uses the
// shared PUBLISHER from src/data/seo.ts (S11 DRYed it out of an S10 inline copy).
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';
import { SITE, PUBLISHER } from '../data/seo';
import { ogMeta } from '../data/og';

const og = ogMeta('/terms/');

const lastUpdated = 'May 24, 2026';

const summaryCards = [
  {
    title: 'Open Source',
    body: 'Orionfold software is offered under the Apache 2.0 license unless a file, repository, dependency, or model card says otherwise. These Terms cover the website, downloads, models, branding, and related services.',
  },
  {
    title: 'Use With Review',
    body: 'AI output can be wrong, incomplete, or unsafe. You are responsible for reviewing agent actions, outputs, and tool use before relying on them in production or customer work.',
  },
  {
    title: 'No High-Risk Use',
    body: 'Do not use Orionfold software or models where failure could cause death, bodily injury, legal noncompliance, or major financial harm without independent safeguards and human oversight.',
  },
];

const sections = [
  {
    title: '1. Acceptance and Scope',
    paragraphs: [
      'These Terms of Use govern your access to the Orionfold website, documentation, newsletter, downloadable software, models, and related services made available by Orionfold LLC. We call all of these “Orionfold.” By accessing or using Orionfold, you agree to these Terms.',
      'If you use Orionfold for an organization, you represent that you have authority to bind that organization. If you do not agree, do not use the website or software.',
    ],
  },
  {
    title: '2. Eligibility',
    paragraphs: [
      'You must be legally able to enter into a binding agreement to use Orionfold. You may not use Orionfold if you are prohibited from doing so under applicable law, export controls, or sanctions rules.',
    ],
  },
  {
    title: '3. Open-Source Software and Separate Licenses',
    paragraphs: [
      'Orionfold software is open source. Source code is generally made available under the Apache License 2.0 unless a repository file, dependency, model card, or bundled component states a different license.',
      'These Terms do not replace or narrow any rights that apply under the open-source licenses for the code or models themselves. Instead, they cover the surrounding service relationship, including the website, downloads, branding, updates, support communications, and any hosted or email-based features.',
    ],
  },
  {
    title: '4. Permitted Use',
    paragraphs: [
      'You may use Orionfold only in compliance with applicable law and these Terms. You may not use Orionfold to violate another person’s rights, distribute malware, interfere with systems, evade security controls, abuse third-party APIs, or process unlawful content.',
      'You are responsible for your own configurations, prompts, policies, workflows, connected model providers, API keys, and downstream actions taken by your agents or operators.',
    ],
  },
  {
    title: '5. AI Output and Human Responsibility',
    paragraphs: [
      'Orionfold builds AI software and models that help operators coordinate AI agents, but it does not guarantee that any model output, recommendation, classification, automation, or tool request is accurate, complete, lawful, or fit for your use case.',
      'You are solely responsible for reviewing outputs, verifying decisions, setting appropriate permissions, maintaining backups, and keeping a human in the loop wherever the consequences matter.',
    ],
    bullets: [
      'Do not rely on Orionfold for medical, legal, tax, employment, credit, insurance, or other professional advice.',
      'Do not rely on Orionfold as the sole basis for safety-critical, emergency-response, or regulated decisions.',
      'You are responsible for notices, consents, retention, and compliance obligations triggered by your own use of AI systems.',
    ],
  },
  {
    title: '6. Third-Party Services',
    paragraphs: [
      'Orionfold may link to or interoperate with third-party services such as model providers, code hosts, model hubs, email providers, or other APIs. Those services are controlled by their own operators and subject to their own terms and privacy notices.',
      'Orionfold LLC is not responsible for third-party services, outages, pricing, policy changes, or the way those providers collect, use, store, or secure data that you send to them.',
    ],
  },
  {
    title: '7. Beta Features, Updates, and Availability',
    paragraphs: [
      'Orionfold is an actively evolving set of open-source products. Features may change, be added, be removed, or remain experimental. Downloads, release cadence, documentation, models, and compatibility can change at any time.',
      'Orionfold LLC has no obligation to continue any feature, provide support, maintain backwards compatibility, or release updates on a particular schedule.',
    ],
  },
  {
    title: '8. Intellectual Property, Brand, and Feedback',
    paragraphs: [
      'Except where open-source licenses apply, the Orionfold name, logos, site content, design, and other brand assets remain the property of Orionfold LLC or its licensors. You may not imply endorsement, sponsorship, or affiliation without permission.',
      'If you submit feedback, ideas, issue reports, or suggestions, Orionfold LLC may use them without restriction or compensation unless applicable law requires otherwise.',
    ],
  },
  {
    title: '9. Disclaimer of Warranties',
    paragraphs: [
      'To the fullest extent permitted by law, Orionfold is provided “as is” and “as available,” without warranties of any kind, express or implied. This includes implied warranties of merchantability, fitness for a particular purpose, title, non-infringement, availability, accuracy, quiet enjoyment, and results.',
      'Orionfold LLC does not warrant that Orionfold will be uninterrupted, secure, error-free, compatible with your environment, or free from harmful components.',
    ],
  },
  {
    title: '10. Limitation of Liability',
    paragraphs: [
      'To the fullest extent permitted by law, Orionfold LLC will not be liable for any indirect, incidental, special, consequential, exemplary, or punitive damages, or for any loss of profits, revenue, goodwill, data, business interruption, or replacement costs arising from or related to Orionfold.',
      'To the fullest extent permitted by law, the total aggregate liability of Orionfold LLC for all claims arising out of or relating to Orionfold will not exceed the greater of one hundred U.S. dollars (USD $100) or the amount you paid directly to Orionfold LLC in the twelve months before the event giving rise to the claim.',
    ],
  },
  {
    title: '11. Indemnity',
    paragraphs: [
      'You agree to defend, indemnify, and hold harmless Orionfold LLC from claims, liabilities, damages, losses, and expenses arising from your misuse of Orionfold, your content, your connected services, your violation of law, or your violation of these Terms.',
    ],
  },
  {
    title: '12. Suspension and Termination',
    paragraphs: [
      'Orionfold LLC may suspend or terminate access to the website, newsletter, or related services if necessary to address abuse, legal risk, security issues, or violations of these Terms. Sections that by their nature should survive termination will survive.',
    ],
  },
  {
    title: '13. Governing Law and Disputes',
    paragraphs: [
      'These Terms are governed by the laws of the jurisdiction in which Orionfold LLC is established, excluding conflict-of-law rules. Unless mandatory consumer protection law requires otherwise, disputes arising from these Terms must be brought in the courts located in that jurisdiction.',
      'Before filing a claim, you agree to first contact Orionfold LLC at manav@orionfold.com and try in good faith to resolve the dispute informally.',
    ],
  },
  {
    title: '14. Changes to These Terms',
    paragraphs: [
      'Orionfold LLC may update these Terms from time to time. The updated version will be posted on this page with a revised “Last updated” date. Your continued use of Orionfold after changes take effect means you accept the revised Terms.',
    ],
  },
  {
    title: '15. Contact',
    paragraphs: [
      'Questions about these Terms can be sent to manav@orionfold.com.',
    ],
  },
];
---
<Layout
  title="Terms of Use · Orionfold"
  description="Terms of Use for the Orionfold website, software, downloads, and related services."
  ogImage={og.image}
  ogImageAlt={og.alt}
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'TermsOfService',
      name: 'Terms of Use · Orionfold',
      url: `${SITE.url}/terms/`,
      inLanguage: 'en',
      publisher: PUBLISHER,
      dateModified: '2026-05-24',
    },
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'Terms', item: `${SITE.url}/terms/` },
      ],
    },
  ]}
>
  <Nav />
  <main>
    <section class="relative overflow-hidden px-6 pt-32 pb-18">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute left-1/2 top-14 h-[26rem] w-[26rem] -translate-x-1/2 rounded-full bg-primary/[0.10] blur-[150px]"></div>
        <div class="absolute inset-x-0 bottom-0 h-40" style="background: linear-gradient(to bottom, transparent, var(--color-surface-raised));"></div>
      </div>

      <div class="relative z-10 mx-auto max-w-5xl">
        <div data-animate>
          <SectionLabel text="Legal" />
        </div>
        <div class="mt-5 grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_18rem] lg:items-end">
          <div>
            <h1 data-animate class="font-display text-[clamp(2.2rem,6vw,4.5rem)] leading-[1.02]" style="transition-delay: 80ms">
              Terms of Use
            </h1>
            <p data-animate class="mt-5 max-w-3xl text-lg leading-relaxed text-text-muted" style="transition-delay: 160ms">
              Practical rules for using Orionfold's open AI software, models, and services. This version is written to reduce ambiguity, set clear responsibility boundaries, and avoid overpromising.
            </p>
          </div>

          <div data-animate class="rounded-2xl border border-border bg-surface-raised/80 p-5 shadow-[0_20px_80px_-40px_rgba(0,0,0,0.75)]" style="transition-delay: 220ms">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.24em] text-text-dim">Last Updated</p>
            <p class="mt-3 text-xl text-text">{lastUpdated}</p>
            <p class="mt-4 text-sm leading-relaxed text-text-muted">
              Questions: <a class="text-primary hover:text-primary/80 transition-colors" href="mailto:manav@orionfold.com">manav@orionfold.com</a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-border bg-surface-raised px-6 py-10">
      <div class="mx-auto grid max-w-6xl gap-4 md:grid-cols-3" data-animate-stagger>
        {summaryCards.map((card) => (
          <article data-animate class="rounded-2xl border border-border/70 bg-surface/80 p-5">
            <p class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-primary">{card.title}</p>
            <p class="mt-4 text-sm leading-relaxed text-text-muted">{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="px-6 py-18">
      <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[15rem_minmax(0,1fr)]">
        <aside data-animate class="lg:sticky lg:top-28 h-fit rounded-2xl border border-border bg-surface-raised/70 p-5">
          <p class="font-mono text-[0.62rem] uppercase tracking-[0.24em] text-text-dim">Short version</p>
          <p class="mt-4 text-sm leading-relaxed text-text-muted">
            Orionfold is provided as open-source software, models, and related services, but you remain responsible for what you run, what you connect, and what you decide to rely on.
          </p>
        </aside>

        <div class="space-y-5" data-animate-stagger>
          {sections.map((section) => (
            <section data-animate class="rounded-2xl border border-border bg-surface-raised/70 p-6 sm:p-8">
              <h2 class="text-2xl">{section.title}</h2>
              <div class="mt-4 space-y-4">
                {section.paragraphs.map((paragraph) => (
                  <p class="text-base leading-relaxed text-text-muted">{paragraph}</p>
                ))}
                {section.bullets && (
                  <ul class="space-y-3 pt-2">
                    {section.bullets.map((bullet) => (
                      <li class="flex items-start gap-3 text-sm leading-relaxed text-text-muted">
                        <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-primary"></span>
                        <span>{bullet}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
