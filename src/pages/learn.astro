---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import { Image } from 'astro:assets';
import { books } from '../data/books';
import { ogMeta } from '../data/og';
import aiNativeBusinessCover from '../assets/book/ai-native-business-book.jpg';
import aiNativePlatformCover from '../assets/book/ai-native-platform-book.jpg';
import aiResearchSparkCover from '../assets/book/ai-research-dgx-spark-book.jpg';
import sparkHero from '../assets/dgx-spark/hero.jpg';
import storyHero from '../assets/story/building-in-public/hero.jpeg';

const og = ogMeta('/learn/');

// The three teaching paths, each led by the real art its destination leads with.
const learning = [
  { label: 'Books', href: '/books/', img: aiNativeBusinessCover, alt: 'AI Native Business book cover', body: 'Implementation playbooks for the business, the platform, and the DGX Spark research path.' },
  { label: 'Field lab', href: '/dgx-spark/', img: sparkHero, alt: 'A small desktop computer sending beams of light into a starry sky', body: 'The customer-controlled hardware story, grounded in the DGX Spark reference platform.' },
  { label: 'Stories', href: '/story/', img: storyHero, alt: 'Building in public story artwork', body: 'Build-log essays that show the decisions, failures, and working systems behind the stack.' },
];

const bookCovers: Record<string, ImageMetadata> = {
  'ai-native-business': aiNativeBusinessCover,
  'ai-native-platform': aiNativePlatformCover,
  'ai-research-on-nvidia-dgx-spark': aiResearchSparkCover,
};
---
<Layout
  title="Learn · Orionfold"
  description="Books, field notes, DGX Spark research, and story posts from Orionfold."
  ogImage={og.image}
  ogImageAlt={og.alt}
>
  <Nav />
  <main>
    <PageHeader
      eyebrow="Learn"
      title="The playbooks behind the stack."
      subtitle="Books, field notes, DGX Spark research, and build stories explain how the private AI capability is made. The teaching layer stays linked to the software, models, and roadmap."
    />

    <section class="px-6 pt-12">
      <div class="mx-auto max-w-6xl">
        <div data-animate-stagger class="grid gap-5 md:grid-cols-3">
          {learning.map((item) => (
            <a data-animate href={item.href} class="of-surface of-pressable group flex flex-col overflow-hidden rounded-2xl">
              <div class="aspect-[16/9] overflow-hidden border-b border-border">
                <Image
                  src={item.img}
                  alt={item.alt}
                  widths={[400, 640]}
                  sizes="(min-width: 768px) 33vw, 100vw"
                  loading="lazy"
                  decoding="async"
                  data-no-zoom
                  class="h-full w-full object-cover object-top"
                />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">{item.label}</span>
                <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">{item.body}</p>
                <span class="of-text-action of-compact mt-5 text-xs">Open →</span>
              </div>
            </a>
          ))}
        </div>

        <div class="mt-12">
          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">Current books</p>
          <div data-animate-stagger class="mt-4 grid grid-cols-1 gap-5 sm:grid-cols-3">
            {books.map((book) => (
              <a href={`/books/${book.slug}/`} data-animate class="of-surface of-pressable group flex flex-col overflow-hidden rounded-2xl">
                {bookCovers[book.slug] && (
                  <div class="aspect-[3/4] overflow-hidden border-b border-border">
                    <Image
                      src={bookCovers[book.slug]}
                      alt={`${book.title} book cover`}
                      widths={[300, 480]}
                      sizes="(min-width: 640px) 33vw, 100vw"
                      loading="lazy"
                      decoding="async"
                      data-no-zoom
                      class="h-full w-full object-cover object-top"
                    />
                  </div>
                )}
                <div class="p-5">
                  <span class="font-medium leading-snug text-text transition-colors group-hover:text-primary">{book.title}</span>
                  <span class="mt-1.5 block text-sm leading-snug text-text-muted">{book.body}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <div class="h-20"></div>
  </main>
  <Footer />
</Layout>
