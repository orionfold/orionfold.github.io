---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import BrowserFrame from '../components/ui/BrowserFrame.astro';
import OfferProofRail from '../components/flagship/OfferProofRail.astro';
import CapabilityStack from '../components/flagship/CapabilityStack.astro';
import NvidiaStackBand from '../components/flagship/NvidiaStackBand.astro';
import { flagshipById } from '../data/flagship-offers';
import { ogMeta } from '../data/og';
import arenaCockpit from '../assets/projects/arena/cockpit.png';

const offer = flagshipById.cockpit;
const og = ogMeta('/cockpit/');
---
<Layout
  title="Cockpit · Orionfold"
  description="The Orionfold Cockpit is Arena, Cortex, fieldkit, and supporting tools for comparing, remembering, evaluating, and shipping local AI work."
  ogImage={og.image}
  ogImageAlt={og.alt}
>
  <Nav />
  <main>
    <PageHeader
      eyebrow="Cockpit"
      title="The cockpit for private AI work."
      subtitle="Arena is the visible cockpit. Cortex gives it local memory and provenance. fieldkit carries the reusable patterns around it. Together they make private AI work inspectable instead of mysterious."
    >
      <div class="mt-7 flex flex-wrap gap-3">
        <a href="/software/arena/" class="inline-flex rounded-lg bg-primary px-5 py-3 font-mono text-sm font-semibold tracking-wider text-white transition-colors hover:bg-primary/90">Open Arena</a>
        <a href="/dgx-spark/" class="inline-flex rounded-lg border border-primary/30 px-5 py-3 font-mono text-sm font-semibold tracking-wider text-primary transition-colors hover:bg-primary/5">See the field lab</a>
      </div>
    </PageHeader>

    <!-- The cockpit itself: a real Arena screenshot, not a description of one. -->
    <section class="px-6 pt-12">
      <div class="mx-auto max-w-6xl">
        <BrowserFrame
          image={arenaCockpit}
          alt="The Orionfold Arena cockpit running local models side by side with live speed and memory telemetry."
          label="Orionfold Arena · cockpit"
          widths={[768, 1200, 1600]}
          sizes="(min-width: 1152px) 72rem, 100vw"
        />
        <p class="mx-auto mt-3 max-w-2xl text-center text-xs leading-relaxed text-text-muted">
          The Arena cockpit on a real run: local models side by side, with live speed and memory telemetry. Nothing you type leaves your machine.
        </p>
      </div>
    </section>

    <section class="px-6 pt-12">
      <div class="mx-auto max-w-6xl">
        <CapabilityStack
          items={[
            { label: 'Compare', body: 'Run models side by side, track speed and memory, and keep a local leaderboard.' },
            { label: 'Remember', body: 'Index notes and documents with source trails so recall can be tested, not guessed.' },
            { label: 'Evaluate', body: 'Score behavior, benchmarks, and regressions before a workflow is trusted.' },
            { label: 'Ship', body: 'Turn working local patterns into repeatable artifacts and playbooks.' },
          ]}
        />
      </div>
    </section>

    <section class="px-6 py-16">
      <div class="mx-auto max-w-6xl">
        <OfferProofRail title="The stack around the cockpit" links={offer.proof} />
      </div>
    </section>
    <NvidiaStackBand note="The Cockpit stack is proven on NVIDIA DGX Spark and supports NVIDIA GPU acceleration for inference, fine-tuning, and model evaluation workflows." />
  </main>
  <Footer />
</Layout>
