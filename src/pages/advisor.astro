---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import OfferProofRail from '../components/flagship/OfferProofRail.astro';
import CapabilityStack from '../components/flagship/CapabilityStack.astro';
import NvidiaPortalFit from '../components/flagship/NvidiaPortalFit.astro';
import { flagshipById } from '../data/flagship-offers';
import { nvidiaPortalProfiles } from '../data/nvidia-portal';
import { ogMeta } from '../data/og';

const offer = flagshipById.advisor;
const og = ogMeta('/advisor/');
---
<Layout
  title="Advisor · Orionfold"
  description="Orionfold Advisor is the private expert interface over the Orionfold corpus, starting with local retrieval over the books, stories, models, and implementation notes."
  ogImage={og.image}
  ogImageAlt={og.alt}
>
  <Nav />
  <main>
    <PageHeader
      eyebrow="Advisor"
      title="Ask Orionfold privately."
      subtitle="A private expert interface over the Orionfold corpus. The first useful version is local retrieval over the books, stories, product notes, model cards, and field notes. Fine-tuned small models come after the corpus and evals are stable."
    >
      <div class="mt-7 flex flex-wrap gap-3">
        <a href="/roadmap/#ask" class="inline-flex rounded-lg bg-primary px-5 py-3 font-mono text-sm font-semibold tracking-wider text-white transition-colors hover:bg-primary/90">Join the Advisor build</a>
        <a href="/learn/" class="inline-flex rounded-lg border border-primary/30 px-5 py-3 font-mono text-sm font-semibold tracking-wider text-primary transition-colors hover:bg-primary/5">Read the corpus</a>
      </div>
    </PageHeader>

    <section class="px-6 pt-12">
      <div class="mx-auto max-w-6xl">
        <CapabilityStack
          items={[
            { label: 'Corpus', body: 'Books, story posts, product detail pages, model cards, roadmap notes, and field lab material.' },
            { label: 'Private first', body: 'Runs against local or customer-controlled materials before anything becomes a hosted product.' },
            { label: 'Inspectable', body: 'Answers need sources, confidence, and a path back to the underlying material.' },
            { label: 'Roadmapped', body: 'The Advisor is a build path, not a finished public app. The roadmap tracks what is real.' },
          ]}
        />
      </div>
    </section>

    <section class="px-6 py-16">
      <div class="mx-auto max-w-6xl">
        <OfferProofRail links={offer.proof} />
      </div>
    </section>
    <NvidiaPortalFit profile={nvidiaPortalProfiles.advisor} />
  </main>
  <Footer />
</Layout>
