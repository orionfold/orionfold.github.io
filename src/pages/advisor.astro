---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import OfferProofRail from '../components/flagship/OfferProofRail.astro';
import CapabilityStack from '../components/flagship/CapabilityStack.astro';
import NvidiaStackBand from '../components/flagship/NvidiaStackBand.astro';
import { Image } from 'astro:assets';
import { flagshipById } from '../data/flagship-offers';
import { ogMeta } from '../data/og';
import aiNativeBusinessCover from '../assets/book/ai-native-business-book.jpg';
import aiNativePlatformCover from '../assets/book/ai-native-platform-book.jpg';
import aiResearchSparkCover from '../assets/book/ai-research-dgx-spark-book.jpg';
import patentStrategistCover from '../assets/models/patent-strategist/cover.png';
import buildingInPublicHero from '../assets/story/building-in-public/hero.jpeg';

const offer = flagshipById.advisor;
const og = ogMeta('/advisor/');

// The corpus shelf: the real material the first Advisor reads, shown with the
// covers the rest of the site already uses. Seeing the shelf makes "trained on
// the Orionfold corpus" concrete instead of abstract.
const corpus = [
  { img: aiNativeBusinessCover, href: '/books/ai-native-business/', label: 'AI Native Business', alt: 'AI Native Business book cover' },
  { img: aiNativePlatformCover, href: '/books/ai-native-platform/', label: 'AI Native Platform', alt: 'AI Native Platform book cover' },
  { img: aiResearchSparkCover, href: '/books/ai-research-on-nvidia-dgx-spark/', label: 'AI Research on NVIDIA DGX Spark', alt: 'AI Research on NVIDIA DGX Spark book cover' },
  { img: patentStrategistCover, href: '/models/patent-strategist/', label: 'Model cards + benchmarks', alt: 'Patent Strategist model cover' },
  { img: buildingInPublicHero, href: '/story/', label: 'Build stories + field notes', alt: 'Building in public story artwork' },
];
---
<Layout
  title="Advisor · Orionfold"
  description="Orionfold Advisor is the private expert interface over the Orionfold corpus, starting with local retrieval over the books, stories, models, and implementation notes."
  ogImage={og.image}
  ogImageAlt={og.alt}
>
  <Nav />
  <main>
    <PageHeader
      eyebrow="Advisor"
      title="Ask Orionfold privately."
      subtitle="A private expert interface over the Orionfold corpus. The first useful version is local retrieval over the books, stories, product notes, model cards, and field notes. Fine-tuned small models come after the corpus and evals are stable."
    >
      <div class="mt-7 flex flex-wrap gap-3">
        <a href="/adoption/#ask" class="inline-flex rounded-lg bg-primary px-5 py-3 font-mono text-sm font-semibold tracking-wider text-white transition-colors hover:bg-primary/90">Join the Advisor build</a>
        <a href="/learn/" class="inline-flex rounded-lg border border-primary/30 px-5 py-3 font-mono text-sm font-semibold tracking-wider text-primary transition-colors hover:bg-primary/5">Read the corpus</a>
      </div>
    </PageHeader>

    <!-- The corpus shelf: what the Advisor actually reads. -->
    <section class="px-6 pt-12">
      <div class="mx-auto max-w-6xl">
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">What the Advisor reads</p>
        <div data-animate-stagger class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
          {corpus.map((item) => (
            <a href={item.href} data-animate class="of-surface of-pressable group overflow-hidden rounded-2xl">
              <div class="aspect-[3/4] overflow-hidden border-b border-border">
                <Image
                  src={item.img}
                  alt={item.alt}
                  widths={[300, 480]}
                  sizes="(min-width: 1024px) 20vw, (min-width: 640px) 33vw, 50vw"
                  loading="lazy"
                  decoding="async"
                  data-no-zoom
                  class="h-full w-full object-cover object-top"
                />
              </div>
              <span class="block p-3 text-xs font-medium leading-snug text-text transition-colors group-hover:text-primary">{item.label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 pt-12">
      <div class="mx-auto max-w-6xl">
        <CapabilityStack
          items={[
            { label: 'Corpus', body: 'Books, story posts, product detail pages, model cards, roadmap notes, and field lab material.' },
            { label: 'Private first', body: 'Runs against local or customer-controlled materials before anything becomes a hosted product.' },
            { label: 'Inspectable', body: 'Answers need sources, confidence, and a path back to the underlying material.' },
            { label: 'Roadmapped', body: 'The Advisor is a build path, not a finished public app. The roadmap tracks what is real.' },
          ]}
        />
      </div>
    </section>

    <section class="px-6 py-16">
      <div class="mx-auto max-w-6xl">
        <OfferProofRail links={offer.proof} />
      </div>
    </section>
    <NvidiaStackBand note="Advisor targets customer-controlled hardware, with NVIDIA GPUs used for accelerated embedding, reranking, and local model inference where available." />
  </main>
  <Footer />
</Layout>
