---
// Adaptive product-detail engine (P1, spec §5.3). One layout drives all three
// types: a rich product gets the full Apple-style scroll, a thin one gets a tight
// honest page, because every section below renders ONLY when its data is present.
// The three routes (/software|/models|/books/[slug]/) join the .ts SSOT record to
// a productDetail entry (src/lib/product/detail.ts), then hand the normalized
// ProductView + the raw detail data + resolved hero/related here, with the
// rendered markdown body in the default slot. Wraps the shared Layout/Nav/Footer.
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroDetail from '../components/product/HeroDetail.astro';
import StickyCtaBar from '../components/product/StickyCtaBar.astro';
import CodeTabs from '../components/product/CodeTabs.astro';
import BookContents from '../components/product/BookContents.astro';
import Gallery from '../components/product/Gallery.astro';
import SpecTable from '../components/product/SpecTable.astro';
import BenchmarkTable from '../components/product/BenchmarkTable.astro';
import TrustBlock from '../components/product/TrustBlock.astro';
import BuyBox from '../components/product/BuyBox.astro';
import SponsorBlock from '../components/product/SponsorBlock.astro';
import FieldEditionBox from '../components/product/FieldEditionBox.astro';
import RelatedRail from '../components/product/RelatedRail.astro';
import ResourcesFooter from '../components/product/ResourcesFooter.astro';
import { getCatalogItem, formatUsd, FIELD_EDITION } from '../data/commerce';
import { ARENA_FIELD_EDITION_LIVE } from '../data/launch';
import { SITE, PERSON, PUBLISHER } from '../data/seo';
import { ogPath, productOgSlug } from '../data/og';
import type { ProductView, RelatedItem } from '../lib/product/detail';
import type { TrustStat } from '../lib/trust/source';
import type { CollectionEntry } from 'astro:content';

interface Props {
  view: ProductView;
  detail: CollectionEntry<'productDetail'>['data'];
  hero?: ImageMetadata;
  related: { relatedModels: RelatedItem[]; relatedBook?: RelatedItem; relatedReading: RelatedItem[] };
  /** Live HuggingFace trust tiles (P3) — empty when there's nothing real to show. */
  trustStats?: TrustStat[];
  hasBody: boolean;
}
const { view, detail, hero, related, trustStats = [], hasBody } = Astro.props;

// Book price (display only; CATALOG is the SSOT) for the hero + sticky CTA.
const item = view.lookupKey ? getCatalogItem(view.lookupKey) : undefined;
const priceLabel = item ? formatUsd(item.amount) : undefined;

// Edition split (Arena): the above-fold buy rail. When the page carries the
// Field Edition, the hero + sticky bar get a buy CTA instead of the sponsor
// anchor, so an already-convinced buyer never has to scroll to pay. The loud
// number is the founding price ($349, first 25); $499 is the standard behind it.
// Flag-aware: pre-launch the CTA scrolls to the full Field Edition block
// (#field-edition) where the "launching soon" state lives, so no charge fires
// before fulfillment exists.
const fieldEditionCta = detail.fieldEdition
  ? {
      live: ARENA_FIELD_EDITION_LIVE,
      lookupKey: FIELD_EDITION.founding.lookupKey,
      priceLabel: formatUsd(FIELD_EDITION.founding.amount),
      standardLabel: formatUsd(FIELD_EDITION.primary.amount),
      seats: FIELD_EDITION.foundingSeats,
      anchor: '#field-edition',
      itemId: view.roadmapItemId,
    }
  : undefined;

// Split related items by destination: internal Orionfold pages stay as full
// cards in "Keep exploring"; external links demote into the slim Resources rail.
const internalModels = related.relatedModels.filter((r) => !r.external);
const internalBook = related.relatedBook && !related.relatedBook.external ? related.relatedBook : undefined;
const internalReading = related.relatedReading.filter((r) => !r.external);
const externalRelated = [
  ...related.relatedModels.filter((r) => r.external),
  ...(related.relatedBook && related.relatedBook.external ? [related.relatedBook] : []),
  ...related.relatedReading.filter((r) => r.external),
];

// Classify each external related link the way the Resources rail tags links:
// HF data/weights + repos are "get it" resources; anything else is an article.
type ResourceKind = 'github' | 'huggingface' | 'docs' | 'site' | 'dataset' | 'reading';
const relatedResourceKind = (href: string): ResourceKind =>
  /huggingface\.co\/datasets/.test(href) ? 'dataset'
  : /huggingface\.co/.test(href) ? 'huggingface'
  : /github\.com/.test(href) ? 'github'
  : 'reading';

// Merge frontmatter outbound + external related, deduped by href, for the rail.
const resourceLinks: { label: string; href: string; kind: ResourceKind }[] = [
  ...(detail.outbound ?? []),
  ...externalRelated.map((r) => ({ label: r.title, href: r.href, kind: relatedResourceKind(r.href) })),
].filter((l, i, all) => all.findIndex((x) => x.href === l.href) === i);

// SEO / AEO (P8, spec §5.8). Per-product OG card (the P8 OG endpoint renders one
// at /og/<type>-<slug>.jpg) plus structured data: a Book + Offer for the paid
// books, a Product for the free/open software and models, and a BreadcrumbList
// (Home -> listing -> here) on every page. Layout still ships the global
// Organization node; these are the page-specific schemas it appends.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageRel = ogPath(productOgSlug(view.type, view.slug));
const ogImageAbs = `${SITE.url}${ogImageRel}`;

const LISTING: Record<ProductView['type'], { base: string; label: string }> = {
  software: { base: 'software', label: 'Software' },
  model: { base: 'models', label: 'Models' },
  book: { base: 'books', label: 'Books' },
};
const listing = LISTING[view.type];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: listing.label, item: `${SITE.url}/${listing.base}/` },
    { '@type': 'ListItem', position: 3, name: view.title, item: canonical },
  ],
};

// Merchant-listings completeness for EVERY priced Offer — the paid books AND
// the free software/models. GSC flagged both fields as missing in "offers".
// The catch: the price-0 Offer we add below (to make free products valid
// Product snippets) also makes them Merchant-listings-eligible, which then
// demands shipping + returns — so the same fields are needed on both branches;
// there's no way to be a valid Product snippet without entering that lane. All
// products here are instant digital/no-ship deliverables from a US-based LLC,
// so the honest values are uniform: free "shipping" (nothing physical ships)
// and no returns (a delivered file — or a free download — can't be returned).
const digitalMerchantFields = {
  hasMerchantReturnPolicy: {
    '@type': 'MerchantReturnPolicy',
    applicableCountry: 'US',
    returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
  },
  shippingDetails: {
    '@type': 'OfferShippingDetails',
    shippingRate: { '@type': 'MonetaryAmount', value: '0', currency: 'USD' },
    shippingDestination: { '@type': 'DefinedRegion', addressCountry: 'US' },
  },
};

const productSchema =
  view.cta === 'buy' && item
    ? {
        '@context': 'https://schema.org',
        '@type': 'Book',
        name: view.title,
        description: view.valueProp,
        url: canonical,
        image: ogImageAbs,
        inLanguage: 'en',
        author: PERSON,
        publisher: PUBLISHER,
        offers: {
          '@type': 'Offer',
          price: (item.amount / 100).toFixed(2),
          priceCurrency: 'USD',
          availability: 'https://schema.org/InStock',
          url: canonical,
          category: 'PDF + EPUB download',
          ...digitalMerchantFields,
        },
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'Product',
        name: view.title,
        description: view.valueProp,
        url: canonical,
        image: ogImageAbs,
        category: view.typeTag,
        brand: { '@type': 'Brand', name: 'Orionfold' },
        // A Product must carry at least one of offers/review/aggregateRating or
        // Google rejects the rich result ("1 invalid item"). The software and
        // open models are genuinely free, so a price-0 Offer is both the
        // documented fix for free products and truthful — no invented reviews
        // or ratings (consistent with the no-testimonials rule). Sponsorship is
        // a separate ask; this Offer just states the product costs nothing. The
        // merchant fields ride along because the price-0 Offer makes the page
        // Merchant-listings-eligible (see digitalMerchantFields above).
        offers: {
          '@type': 'Offer',
          price: '0',
          priceCurrency: 'USD',
          availability: 'https://schema.org/InStock',
          url: canonical,
          ...digitalMerchantFields,
        },
      };

// Edition split (Arena Field Edition): the page's primary Product node is the
// FREE, open Arena (price-0 Offer above). The paid edition is a DISTINCT Product
// in the same @graph so AEO/Merchant pick up a real priced offer without making
// the page a new product silo. Headline price is the $499 primary SKU; the
// founding price is the same product on a time-boxed offer, so it rides as a
// second Offer. Both carry the digital merchant fields the free node uses.
const fieldEditionSchema = detail.fieldEdition
  ? {
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: 'Arena Field Edition for DGX Spark',
      description:
        'A paid edition of the free Orionfold Arena: a one-pass installer that turns an NVIDIA DGX Spark into a private AI lab with an AI research teammate (agents, domain models, and tests). It proves itself on first boot with a verifiable receipt and stays proven for a year. You buy the assembled, proven, kept-proven AI team delivered turnkey.',
      url: `${canonical}#field-edition`,
      image: ogImageAbs,
      category: 'AI software license',
      brand: { '@type': 'Brand', name: 'Orionfold' },
      offers: [
        {
          '@type': 'Offer',
          name: 'One-time license',
          price: (FIELD_EDITION.primary.amount / 100).toFixed(2),
          priceCurrency: 'USD',
          availability: 'https://schema.org/InStock',
          url: `${canonical}#field-edition`,
          ...digitalMerchantFields,
        },
        {
          '@type': 'Offer',
          name: `Founding license (first ${FIELD_EDITION.foundingSeats})`,
          price: (FIELD_EDITION.founding.amount / 100).toFixed(2),
          priceCurrency: 'USD',
          availability: 'https://schema.org/LimitedAvailability',
          url: `${canonical}#field-edition`,
          ...digitalMerchantFields,
        },
      ],
    }
  : null;

const jsonLd = [productSchema, breadcrumbSchema, ...(fieldEditionSchema ? [fieldEditionSchema] : [])];
---
<Layout
  title={`${view.title} · Orionfold`}
  description={view.valueProp}
  ogImage={ogImageRel}
  ogImageAlt={detail.heroAlt ?? view.valueProp}
  jsonLd={jsonLd}
>
  <Nav />
  <main class="pb-24">
    <HeroDetail view={view} hero={hero} heroAlt={detail.heroAlt} chips={detail.chips} priceLabel={priceLabel} fieldEditionCta={fieldEditionCta} />
    <StickyCtaBar view={view} priceLabel={priceLabel} fieldEditionCta={fieldEditionCta} />

    {detail.chapters && <BookContents chapters={detail.chapters} />}

    {hasBody && (
      <section class="px-6 py-12">
        <div data-animate class="story-prose mx-auto max-w-3xl">
          <slot />
        </div>
      </section>
    )}

    {detail.gallery && <Gallery items={detail.gallery} />}

    {/* Install / Use-it commands follow the prose (the model pages' "How to run
        it" section) and sit just above the spec table. */}
    {detail.install && <CodeTabs heading="Install" tabs={detail.install} />}
    {detail.usage && <CodeTabs heading="Use it" tabs={detail.usage} />}

    {detail.specs && <SpecTable specs={detail.specs} />}
    {detail.benchmarks && <BenchmarkTable benchmarks={detail.benchmarks} />}

    <TrustBlock stats={trustStats} testimonials={detail.testimonials} />

    {/* Edition split: the paid Field Edition IS the conversion path on this page,
        so it replaces the sponsor/buy block rather than competing with it. The
        free install path stays as a quiet trust signal in the hero + the body's
        install section. Sponsor lives on /sponsor/ and the other product pages. */}
    {detail.fieldEdition
      ? <FieldEditionBox view={view} />
      : (view.cta === 'buy' ? <BuyBox view={view} /> : <SponsorBlock view={view} />)}

    <RelatedRail models={internalModels} book={internalBook} reading={internalReading} />

    {resourceLinks.length > 0 && <ResourcesFooter outbound={resourceLinks} />}
  </main>
  <Footer />
</Layout>

<!-- Wire Buy / Sponsor buttons to hosted Stripe Checkout (C4 pattern). The site
     holds no Stripe key; this POSTs the lookup key to the edge function and
     redirects to the returned URL. CORS-fails on localhost by design (L1 tests
     it live) — a network error surfaces the friendly "Could not connect". -->
<script>
  import { wireCheckoutButtons } from '../lib/checkout';
  wireCheckoutButtons();
  document.addEventListener('astro:after-swap', () => wireCheckoutButtons());
</script>
