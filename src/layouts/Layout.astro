---
import '../styles/global.css';
import { SITE, ORGANIZATION } from '../data/seo';
import { META_PIXEL_ID } from '../data/meta';
import { META_PIXEL_ENABLED } from '../data/launch';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean | 'follow';
  article?: {
    datePublished: string;
    dateModified: string;
    author: string;
    section?: string;
    tags?: string[];
  };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Orionfold · Prove which AI you can trust',
  description = SITE.description,
  ogImage = SITE.ogImage,
  ogImageAlt = SITE.ogImageAlt,
  ogType = 'website',
  noindex = false,
  article,
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// Global Organization node ships on every page so the whole site reads as one
// entity (Orionfold LLC); page-specific schemas (passed via jsonLd) come after.
const orgSchema = { '@context': 'https://schema.org', ...ORGANIZATION };
const pageSchemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdSchemas = [orgSchema, ...pageSchemas];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- Scroll-reveal gate. Without this class, [data-animate] elements paint
         visible by default — so if JS fails to load (CSP, network drop, CDN
         error), content is still readable instead of stuck at opacity:0. With
         JS, this runs synchronously before <body> paints, so the hide-then-
         reveal animation still plays on fast devices. -->
    <script is:inline>document.documentElement.classList.add('js-ready');</script>
    <!-- No-FOUC theme init. Sets BOTH data-theme-mode (the user's CHOICE:
         light | dark | system) and data-theme (the RESOLVED value) on <html>
         BEFORE first paint, so the dark remap + the toggle icon apply with no
         flash. Reads localStorage "of-theme"; a new user with no saved choice
         DEFAULTS TO DARK (not the OS preference). Only "system" follows the OS.
         The three-way toggle in the nav writes "of-theme". -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('of-theme'); // 'light' | 'dark' | 'system' | null
          var mode = (saved === 'light' || saved === 'dark' || saved === 'system') ? saved : 'dark';
          var resolved = mode === 'system'
            ? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : mode;
          document.documentElement.setAttribute('data-theme-mode', mode);
          document.documentElement.setAttribute('data-theme', resolved);
        } catch (e) {
          document.documentElement.setAttribute('data-theme-mode', 'dark');
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <!-- Relay screenshots start without a network URL. Assign only the active
         theme's responsive srcset as each node enters the parsed DOM; native
         loading="lazy" then defers below-fold figures. Watching data-theme keeps
         the site's explicit light/dark/system control authoritative. -->
    <script is:inline>
      (function () {
        function applyShot(img) {
          var theme = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
          if (img.getAttribute('data-shot-theme') === theme) return;
          var prefix = theme === 'light' ? 'data-shot-light-' : 'data-shot-dark-';
          var src = img.getAttribute(prefix + 'src');
          var srcset = img.getAttribute(prefix + 'srcset');
          if (!src || !srcset) return;
          img.setAttribute('srcset', srcset);
          img.setAttribute('src', src);
          img.setAttribute('data-shot-theme', theme);
        }
        function applyWithin(root) {
          if (root.nodeType !== 1) return;
          if (root.matches && root.matches('img[data-relay-shot]')) applyShot(root);
          if (root.querySelectorAll) root.querySelectorAll('img[data-relay-shot]').forEach(applyShot);
        }
        applyWithin(document.documentElement);
        new MutationObserver(function (mutations) {
          mutations.forEach(function (mutation) {
            if (mutation.type === 'attributes') applyWithin(document.documentElement);
            else mutation.addedNodes.forEach(applyWithin);
          });
        }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'], childList: true, subtree: true });
      })();
    </script>
    <!-- Warm DNS+TLS for the analytics origins so the post-load gtag.js fetch +
         beacons land quickly (Google Ads pulls a second tagmanager script when
         AW-... is configured below; the GA collect endpoint lives on
         google-analytics.com). -->
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
    <link rel="preconnect" href="https://www.google-analytics.com" crossorigin>
    <!-- Google tag queue for Orionfold GA4 + Ads. The runtime hostname check is
         the primary analytics boundary: Astro's production build also powers
         localhost Lighthouse, previews and CI, so build mode cannot distinguish
         real production traffic. Only the canonical apex gets a dataLayer,
         gtag shim, configuration calls or network loader; existing conversion
         callers already no-op when window.gtag is absent (G-042).

         On the canonical host, keep the queue/config inline and synchronous so
         page views and conversion calls preserve their ordering. Fetch gtag.js
         only AFTER the document's own load event: a parser-discovered async
         script does not block paint, but a degraded route to Google still holds
         document load completion open. That was the measured 6s mobile
         processing tail (G-043). The queued calls flush when the library arrives;
         on the normal path the fetch starts ~50–75ms after navigation rather
         than competing with page completion. -->
    <script is:inline>
      /* G-042 canonical analytics gate. */
      if (window.location.hostname === 'orionfold.com') {
        window.dataLayer = window.dataLayer || [];
        window.gtag = function gtag(){window.dataLayer.push(arguments);};
        window.gtag('js', new Date());
        window.gtag('config', 'G-04PH843W2C');
        // Google Ads (AW) shares the one gtag.js load. Drives the native
        // "Purchase" conversion fired on /thanks (MARKETING-HANDOFF.md, src/data/ads.ts).
        window.gtag('config', 'AW-18188052159');

        (function () {
          var loaded = false;
          function loadGoogleTag() {
            if (loaded) return;
            loaded = true;
            var tag = document.createElement('script');
            tag.async = true;
            tag.src = 'https://www.googletagmanager.com/gtag/js?id=G-04PH843W2C';
            document.head.appendChild(tag);
          }
          if (document.readyState === 'complete') loadGoogleTag();
          else window.addEventListener('load', loadGoogleTag, { once: true });
        })();
      }
      /* G-042 canonical analytics gate end. */
    </script>
    <!-- Meta Pixel (fbq) for the 2026-Q2 Meta Ads book test. Renders only once
         META_PIXEL_ID is set in src/data/meta.ts, so the site deploys safely
         before the Events Manager setup. PageView here; Purchase fires on
         /thanks via lib/conversion.ts with an eventID that pairs with the
         server-side CAPI event (stripe-webhook) for dedup.

         DEFERRED off the critical path (2026-06-13 perf pass — the eager pixel
         was the page's heaviest 3p main-thread cost). The loader fires on the
         FIRST of: a user interaction, requestIdleCallback, or a 3s timeout — so
         PageView still records for essentially every engaged session. The only
         loss is a hard-bounce (gone in <~3s, zero interaction), which is
         low-value for audience building. Purchase is NOT affected: reportPurchase
         in lib/conversion.ts force-loads the pixel (window.__ofLoadMetaPixel)
         before tracking, and CAPI (stripe-webhook) is the server-side backstop.
         Marketing can align or counter — see the strategy _RELAY.md entry.

         GATED OFF while both ad channels are paused (META_PIXEL_ENABLED, set in
         src/data/launch.ts; operator 2026-06-18). When false the loader below
         never renders, so fbevents.js never loads and no _fbp/_fbc cookies are
         set. window.__ofLoadMetaPixel stays undefined; reportPurchase() already
         no-ops it via ?.(), and the server-side CAPI Purchase still fires its
         eventID, so re-enabling is one flip back to true. -->
    {META_PIXEL_ID && META_PIXEL_ENABLED && (
      <script is:inline define:vars={{ META_PIXEL_ID }}>
        (function () {
          var loaded = false;
          var EVENTS = ['pointerdown', 'keydown', 'scroll', 'touchstart'];
          var OPTS = { once: true, passive: true, capture: true };
          function unbind() {
            EVENTS.forEach(function (ev) { window.removeEventListener(ev, load, OPTS); });
          }
          function load() {
            if (loaded) return;
            loaded = true;
            unbind();
            !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
            n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
            n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
            t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
            document,'script','https://connect.facebook.net/en_US/fbevents.js');
            fbq('init', META_PIXEL_ID);
            fbq('track', 'PageView');
          }
          // Exposed so reportPurchase() can force-load on the conversion page,
          // preserving the browser↔CAPI dedup pair even though PageView is lazy.
          window.__ofLoadMetaPixel = load;
          EVENTS.forEach(function (ev) { window.addEventListener(ev, load, OPTS); });
          if ('requestIdleCallback' in window) requestIdleCallback(load, { timeout: 3000 });
          else setTimeout(load, 3000);
        })();
      </script>
    )}
    <!-- Meta domain verification (Business Settings → Brand Safety → Domains,
         domain asset 1003335682186241). Deliberately UNGATED by META_PIXEL_ID:
         Meta polls for this tag independent of the pixel and re-checks it
         periodically after verification, so it must stay in static HTML on
         every deploy. Not a secret (visible in any verified site's source). -->
    <meta name="facebook-domain-verification" content="obnuck074w2envh4k4ksolj4djuoa6" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Orionfold" />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content={noindex === 'follow' ? 'noindex, follow' : 'noindex, nofollow'} />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content={/\.jpe?g$/i.test(ogImage) ? 'image/jpeg' : 'image/png'} />
    <meta property="og:site_name" content="Orionfold" />
    <meta property="og:locale" content="en_US" />

    {article && (
      <>
        <meta property="article:published_time" content={article.datePublished} />
        <meta property="article:modified_time" content={article.dateModified} />
        <meta property="article:author" content={article.author} />
        {article.section && <meta property="article:section" content={article.section} />}
        {article.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
      </>
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.twitter} />
    <meta name="twitter:creator" content={SITE.twitter} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- App icons — Orionfold 3D mark (variant B: origami paper star on a teal
         disc), from the design-system brand/logo/assets/logo-3d/ folder
         (2026-07-05). These are photographic RASTER renders, so there is no
         SVG favicon: browsers prefer type="image/svg+xml" over the PNGs, and a
         stale flat-mark SVG would keep showing the OLD logo in the tab — so the
         SVG <link> is intentionally dropped and browsers fall back to the
         purpose-sized PNG/ICO set. The ?v=4 query busts the favicon cache for
         visitors who saw the prior flat SC-01f mark. -->
    <link rel="icon" href="/favicon.ico?v=4" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=4" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png?v=4" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=4" />

    <!-- Manifest -->
    <link rel="manifest" href="/manifest.json" />

    <!-- Sitemap (generated by @astrojs/sitemap) -->
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/geist-sans-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/geist-sans-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin>

    <!-- Browser chrome paints to match the active surface (light + dark) -->
    <meta name="theme-color" content="#f9fafb" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#15171b" media="(prefers-color-scheme: dark)" />
    <meta name="application-name" content="Orionfold" />
    <meta name="apple-mobile-web-app-title" content="Orionfold" />
    <meta name="format-detection" content="telephone=no" />

    <!-- JSON-LD Structured Data -->
    {jsonLdSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Additional head content from child pages -->
    <slot name="head" />
  </head>
  <body class="bg-surface text-text min-h-screen">
    <slot />

    <!-- Capture ad attribution (utm_* / gclid / v) on landing, before any
         redirect to Stripe drops the query string (MARKETING-HANDOFF.md Task 4). -->
    <script>
      import { captureAttribution } from '../lib/attribution';
      captureAttribution();
      document.addEventListener('astro:after-swap', captureAttribution);
    </script>

    <!-- IntersectionObserver for scroll-reveal -->
    <script>
      function initScrollReveal() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                // Promote to its own compositing layer just before the reveal
                // animation starts. We don't set will-change in CSS because
                // doing so on every animated element at paint creates a layer
                // for each (137+ on the homepage) — a real cost on low-end mobile.
                const el = entry.target as HTMLElement;
                el.style.willChange = 'opacity, transform';
                el.classList.add('is-visible');
                el.addEventListener('transitionend', () => {
                  el.style.willChange = 'auto';
                }, { once: true });
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0, rootMargin: '0px 0px 33% 0px' }
        );

        document.querySelectorAll('[data-animate]').forEach((el) => {
          observer.observe(el);
        });

        // SVG child element reveals — toggles .visible on children
        // when a parent [data-svg-animate] enters the viewport
        const svgObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.querySelectorAll('.svg-reveal, .line-draw, .bar-grow, .ring-expand, .bar-grow-x, .dot-pop').forEach((child) => {
                  child.classList.add('visible');
                });
                svgObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0, rootMargin: '0px 0px 33% 0px' }
        );

        document.querySelectorAll('[data-svg-animate]').forEach((el) => {
          svgObserver.observe(el);
        });
      }

      initScrollReveal();
      document.addEventListener('astro:after-swap', initScrollReveal);
    </script>

    <!-- Copy-code for prose code blocks (.of-code, injected by
         rehype-code-block). One document-level delegated listener, so it covers
         blocks that arrive via astro:after-swap navigation with no re-init.
         Reads the sibling <pre> text at click time; flips the label to "Copied"
         for 1.5s on success. Prefers the async Clipboard API and falls back to
         execCommand('copy') via a hidden textarea when the API rejects (e.g. the
         document isn't focused or the permission is denied) so a real click
         always gives feedback. Same restraint as the product CodeTabs button. -->
    <script is:inline>
      document.addEventListener('click', function (e) {
        var btn = e.target && e.target.closest ? e.target.closest('.of-code__copy') : null;
        if (!btn) return;
        var fig = btn.closest('.of-code');
        var pre = fig && fig.querySelector('pre.astro-code');
        if (!pre) return;
        var label = btn.querySelector('.of-code__copy-label');
        var text = pre.innerText;
        var done = function () {
          btn.classList.add('is-copied');
          if (label) label.textContent = 'Copied';
          setTimeout(function () {
            btn.classList.remove('is-copied');
            if (label) label.textContent = 'Copy';
          }, 1500);
        };
        var legacyCopy = function () {
          try {
            var ta = document.createElement('textarea');
            ta.value = text;
            ta.setAttribute('readonly', '');
            ta.style.position = 'fixed';
            ta.style.top = '-9999px';
            document.body.appendChild(ta);
            ta.select();
            var ok = document.execCommand('copy');
            document.body.removeChild(ta);
            if (ok) done();
          } catch (err) {
            /* clipboard genuinely unavailable — leave the label alone */
          }
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(done).catch(legacyCopy);
        } else {
          legacyCopy();
        }
      });
    </script>

  </body>
</html>
