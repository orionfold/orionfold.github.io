---
// Orionfold footer. A "fat footer" directory (deep links to every product
// detail page + the 5 newest stories) sits above a slim meta row (wordmark ·
// explore · legal · social). The directory is data-driven from the SSOT and
// gated by detailKeySet() so it only links products that actually have a detail
// page; surfacing the latest stories puts a fresh internal link to new posts on
// every page (helps crawl discovery + AEO catalog mapping). Column headers link
// to the listing hubs; items link to the detail pages. NOTE: the productDetail
// `type` token is SINGULAR (software/model/book) even though the URL bases are
// plural (/software//models//books/).
import { getCollection } from 'astro:content';
import { software } from '../data/software';
import { models } from '../data/models';
import { books } from '../data/books';
import { detailKeySet, slugify } from '../lib/product/detail';

const detailKeys = await detailKeySet();

// Software, grouped (platform → apps → intel → devtools), detail-gated.
const SW_GROUPS = [
  { key: 'platform', label: 'Platform' },
  { key: 'apps', label: 'Apps' },
  { key: 'intel', label: 'Intel' },
  { key: 'devtools', label: 'Devtools' },
] as const;
const softwareLinks = software
  .filter((s) => detailKeys.has(`software:${s.slug}`))
  .map((s) => ({ href: `/software/${s.slug}/`, label: s.title, group: s.group }));

// Models: slug = slugify(title); dedupe build variants to one entry (first seen),
// then gate to those with a detail page (drops the dataset, which has none).
const modelBySlug = new Map<string, string>();
for (const m of models) {
  const slug = slugify(m.title);
  if (!modelBySlug.has(slug)) modelBySlug.set(slug, m.title);
}
const modelLinks = [...modelBySlug]
  .filter(([slug]) => detailKeys.has(`model:${slug}`))
  .map(([slug, label]) => ({ href: `/models/${slug}/`, label }));

// Books, detail-gated.
const bookLinks = books
  .filter((b) => detailKeys.has(`book:${b.slug}`))
  .map((b) => ({ href: `/books/${b.slug}/`, label: b.title }));

// The 5 newest stories (same sort as the /story index).
const latestStories = (await getCollection('story'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5)
  .map((p) => ({ href: `/story/${p.id}/`, label: p.data.title }));

// Slim meta-row nav: the listing hubs now live as directory column headers, so
// Explore keeps only the pages without a directory column.
const explore = [
  { href: '/story/', label: 'Story' },
  { href: '/about/', label: 'About' },
  { href: '/roadmap/', label: 'Roadmap' },
  { href: '/sponsor/', label: 'Sponsor' },
];
const legal = [
  { href: '/terms/', label: 'Terms' },
  { href: '/privacy/', label: 'Privacy' },
];
const year = new Date().getFullYear();
---
<footer class="border-t border-border">
  <!-- Directory band (tinted, full-bleed): deep links to every detail page +
       the latest stories. Software spans 2 columns, its 4 groups in a 2-col
       sub-grid, so the tall catalog reads as two balanced columns. -->
  <div class="bg-primary/[0.07] px-6 py-10">
    <div class="max-w-6xl mx-auto text-text-muted text-xs font-mono">
      <div class="grid grid-cols-2 gap-x-6 gap-y-8 md:flex md:justify-between text-center sm:text-left">
        <!-- Software (full width on mobile, first proportional col on desktop;
             its 4 groups sit in a 2-col sub-grid) -->
        <div class="col-span-2 md:col-span-1 flex flex-col gap-3">
          <a href="/software/" class="text-[0.65rem] uppercase tracking-[0.12em] text-text-dim hover:text-primary transition-colors">Software</a>
          <div class="grid grid-cols-2 gap-x-6 gap-y-3">
            {SW_GROUPS.map((g) => (
              <div class="flex flex-col gap-1.5">
                <span class="text-[0.6rem] uppercase tracking-[0.1em] text-text-dim">{g.label}</span>
                {softwareLinks.filter((s) => s.group === g.key).map((s) => (
                  <a href={s.href} class="hover:text-primary transition-colors">{s.label}</a>
                ))}
              </div>
            ))}
          </div>
        </div>

        <!-- Models -->
        <div class="flex flex-col gap-2">
          <a href="/models/" class="text-[0.65rem] uppercase tracking-[0.12em] text-text-dim hover:text-primary transition-colors">Models</a>
          {modelLinks.map((m) => (
            <a href={m.href} class="hover:text-primary transition-colors">{m.label}</a>
          ))}
        </div>

        <!-- Books -->
        <div class="flex flex-col gap-2">
          <a href="/books/" class="text-[0.65rem] uppercase tracking-[0.12em] text-text-dim hover:text-primary transition-colors">Books</a>
          {bookLinks.map((b) => (
            <a href={b.href} class="hover:text-primary transition-colors">{b.label}</a>
          ))}
        </div>

        <!-- Latest stories (full width on mobile, widest col on desktop so the
             post titles sit on one line) -->
        <div class="col-span-2 md:col-span-1 flex flex-col gap-2">
          <a href="/story/" class="text-[0.65rem] uppercase tracking-[0.12em] text-text-dim hover:text-primary transition-colors">Latest stories</a>
          {latestStories.map((s) => (
            <a href={s.href} class="hover:text-primary transition-colors text-balance">{s.label}</a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Meta band (default surface): wordmark · explore · legal · connect -->
  <div class="px-6 py-10">
    <div class="max-w-6xl mx-auto text-text-muted text-xs font-mono">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 text-center sm:text-left">
      <!-- Wordmark -->
      <div class="col-span-2 sm:col-span-1 flex flex-col items-center sm:items-start gap-3">
        <a href="/" class="inline-flex items-center gap-1.5 text-text hover:text-primary transition-colors" aria-label="Orionfold home">
          <img src="/logos/orionfold-logo.png" alt="" width="28" height="28" class="h-7 w-7 shrink-0" />
          <span class="text-lg font-semibold tracking-tight leading-none">
            <span class="text-text">Orion</span><span class="text-primary">fold</span>
          </span>
        </a>
        <p class="max-w-[16rem] text-[0.7rem] leading-relaxed text-text-dim text-balance">
          We build open AI software, custom models, and the playbooks to run them.
        </p>
      </div>

      <!-- Explore -->
      <div class="flex flex-col gap-2">
        <span class="text-[0.65rem] uppercase tracking-[0.12em] text-text-dim">Explore</span>
        {explore.map((link) => (
          <a href={link.href} class="hover:text-primary transition-colors">{link.label}</a>
        ))}
      </div>

      <!-- Legal -->
      <div class="flex flex-col gap-2">
        <span class="text-[0.65rem] uppercase tracking-[0.12em] text-text-dim">Legal</span>
        {legal.map((link) => (
          <a href={link.href} class="hover:text-primary transition-colors">{link.label}</a>
        ))}
      </div>

      <!-- Connect -->
      <div class="flex flex-col gap-3">
        <span class="text-[0.65rem] uppercase tracking-[0.12em] text-text-dim">Connect</span>
        <div class="flex items-center justify-center sm:justify-start gap-4">
          <a
            href="https://youtube.com/@ainativebusiness"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-primary transition-colors"
            aria-label="YouTube"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
          <a
            href="https://x.com/manavsehgal"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-primary transition-colors"
            aria-label="X (Twitter)"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a
            href="https://github.com/manavsehgal"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-primary transition-colors"
            aria-label="GitHub"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

      <div class="pt-6 mt-8 border-t border-border text-center sm:text-left">
        <span>&copy; {year} Orionfold LLC. Apache 2.0.</span>
      </div>
    </div>
  </div>
</footer>
