---
// /proof/ — "What Orionfold Proof does." The product section that sits right after
// the capability matrix: the cockpit hero, the configure→run→decide loop as an
// animated flow (ProofLoopFlow, not screenshots), the inside-the-cockpit rails as
// full-width showcases, and the flagship 18/21 governance bench reproduced on a Mac.
// Every number cites the receipt it came from (receipt-honesty); the clean wins
// lead, the honest misses stay in. Voice grade 3-5, no em-dashes (website-copy-style).
// Assets are website-owned copies of secret-free captures from the orionfold-proof repo.
//
// All cockpit stills are the 0.2.0 Arena-shape redesign (relay orionfold-proof
// 2026-06-27): top app bar (Prove · Datasets · Receipts · Settings) + always-on
// telemetry rail + full-width canvas + tabbed L3 receipt detail. The hero + rail
// stills are keyless mock runs; the flagship 18/21 GIF + full-results still are the
// operator's REAL Advisor bench run re-captured in the new UI (config 552d0060f782,
// 18/21, $0.00 local). Source: samples/screenshots in the orionfold-proof repo,
// dark theme, no key material.
import { Image } from 'astro:assets';
import ProofLoopFlow from './ProofLoopFlow.astro';
import moneyShot from '../../assets/proof/cockpit-results.png';
import railDatasets from '../../assets/proof/rail-datasets.png';
import railCandidates from '../../assets/proof/rail-candidates.png';
import railReceipts from '../../assets/proof/rail-receipts.png';
import flagshipResults from '../../assets/proof/flagship-results.png';
// Animated GIF served straight from public/ so the animation survives and the file
// is actually emitted. Importing a .gif through the asset pipeline rewrites the URL
// to a hashed /_astro/ path but never copies the file into dist (Astro 5 / Vite
// raw-asset gap) -> a 404 on the deployed page. public/ assets are copied verbatim
// at a stable path. Intrinsic size kept inline (the source is 1568x718) to reserve
// layout space without a JS import. astro:assets <Image> is intentionally NOT used
// (it would flatten the animation to a still frame).
const flagshipGifSrc = '/proof/flagship-18of21.gif';
const flagshipGifW = 1568;
const flagshipGifH = 718;

const rails = [
  {
    title: 'Your datasets',
    body: 'Bring your own task rows. Proof scores against the answers you decide are right.',
    image: railDatasets,
    alt: 'The Datasets screen in the Proof cockpit: the frozen example sets, the governance bench, and the corpus.',
  },
  {
    title: 'Any candidate',
    body: 'Local models through Ollama or cloud models through their API, side by side in one run.',
    image: railCandidates,
    alt: 'The candidate picker listing local models through Ollama and cloud models across providers, side by side.',
  },
  {
    title: 'Signed receipts',
    body: 'Every run exports a receipt as Markdown, HTML, or JSON. Same inputs, same receipt, every time.',
    image: railReceipts,
    alt: 'The Receipts screen: the bento masthead over the Runs table, each run exportable as Markdown, HTML, or JSON.',
  },
];
---
<section id="what-it-does" class="scroll-mt-24 px-6 py-16">
  <div class="mx-auto max-w-6xl">
    <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">What Orionfold Proof does</p>
    <h2 class="font-display text-2xl leading-tight sm:text-3xl">The tool behind these receipts</h2>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-text-muted">
      Orionfold Proof runs on your own machine. You point it at your own task, run the AI models or
      setups you are weighing, and it hands back a signed receipt: which one won, at what cost, with
      what failures. One command to install, a cockpit in your browser, and you are proving in
      minutes. Nothing phones home.
    </p>

    <!-- Hero: the populated Prove page (DS .of-showcase + browser-frame chrome; natural
         height so the full cockpit shows — cover-cropping would hide the leaderboard.
         This is a tall full-page capture: verdict band + leaderboard + cost-vs-quality
         scatter + run-cost ledger on one scrolling canvas) -->
    <figure data-animate data-treatment="scroll" class="of-showcase proof-hero mt-12">
      <div class="of-frame">
        <div class="of-frame-bar">
          <span class="of-frame-dots"><i></i><i></i><i></i></span>
          <span class="of-frame-label">Orionfold Proof — cockpit</span>
        </div>
        <div class="of-shot">
          <Image
            src={moneyShot}
            alt="The Orionfold Proof cockpit after a run: the always-on telemetry rail across the top, the recommended winner, the leaderboard, the cost-vs-quality chart, and the failure cases on one scrolling canvas."
            widths={[720, 1080, 1440]}
            sizes="(min-width: 1024px) 1024px, 100vw"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <figcaption class="of-showcase-cap">
        One canvas, the whole proof: the live telemetry rail up top, then the recommended winner, the
        leaderboard with cost and speed, the cost-vs-quality chart, and every failure case. Scroll
        inside the frame to read it all.
      </figcaption>
    </figure>

    <!-- How it works: configure -> run -> decide, as one animated flow line
         (ProofLoopFlow) instead of cramped screenshot thumbnails. Same metro-line
         idiom as the homepage CapabilitySystemMap; the Run station streams rows and
         the Decide station stamps a pass tick -- motion a static still can't show. -->
    <div class="mt-14">
      <p class="mb-6 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">How it works</p>
      <ProofLoopFlow />
    </div>

    <!-- Inside the cockpit: each rail as a full-width browser-frame showcase so the
         real Arena UI is readable (the old 3-up thumbnails squished it). Image and
         text alternate sides on desktop for rhythm. -->
    <div class="mt-14">
      <p class="mb-8 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-text-dim">Inside the cockpit</p>
      <div class="flex flex-col gap-10">
        {rails.map((r, i) => (
          <div data-animate class="grid items-center gap-6 lg:grid-cols-2 lg:gap-10">
            <div class={`of-showcase ${i % 2 === 1 ? 'lg:order-2' : ''}`} data-treatment="natural">
              <div class="of-frame">
                <div class="of-frame-bar">
                  <span class="of-frame-dots"><i></i><i></i><i></i></span>
                  <span class="of-frame-label">Orionfold Proof — {r.title.toLowerCase()}</span>
                </div>
                <div class="of-shot">
                  <Image
                    src={r.image}
                    alt={r.alt}
                    widths={[640, 960, 1280]}
                    sizes="(min-width: 1024px) 50vw, 100vw"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              </div>
            </div>
            <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
              <p class="font-display text-xl leading-snug sm:text-2xl">{r.title}</p>
              <p class="mt-3 max-w-md text-base leading-relaxed text-text-muted">{r.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Flagship proof: the 18/21 governance bench, reproduced on a Mac -->
    <div class="mt-14 rounded-3xl border border-primary/30 bg-surface-raised/70 p-6 sm:p-8">
      <p class="mb-2 font-mono text-[0.65rem] uppercase tracking-[0.24em] text-primary">The flagship proof</p>
      <h3 class="font-display text-xl leading-snug sm:text-2xl">
        Reproduce a published model result on your own laptop, turnkey
      </h3>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-text-muted">
        We took our Advisor 4B model and ran its governance bench again, this time on an Apple M3 Max
        laptop instead of the lab box. It scored <strong class="text-text">18 of 21</strong>,
        matching the published baseline answer for answer: the same 9 of 9 refusals, and the same 3
        misses. It cost <strong class="text-text">$0.00</strong> because it ran fully local. Every
        line of that is in the receipt, down to the config hash
        <code class="rounded bg-surface px-1.5 py-0.5 font-mono text-xs text-primary">552d0060f782</code>.
      </p>

      <figure data-animate data-treatment="natural" class="of-showcase mt-6">
        <div class="of-frame">
          <div class="of-frame-bar">
            <span class="of-frame-dots"><i></i><i></i><i></i></span>
            <span class="of-frame-label">Orionfold Proof — the run, end to end</span>
          </div>
          <div class="of-shot">
            <img
              src={flagshipGifSrc}
              width={flagshipGifW}
              height={flagshipGifH}
              alt="The full Orionfold Proof workflow: configure the Advisor governance bench, run 21 rows locally, and reach an 18 of 21 result."
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <figcaption class="of-showcase-cap">
          The whole run in one take: configure, generate all 21 rows locally, reach 18 of 21.
        </figcaption>
      </figure>

      <p class="mt-6 text-sm leading-relaxed text-text-muted">
        It does not hide the losses. The result misses 3 of the 21 and shows exactly which checks
        failed and why. A trust tool that only ever shows a perfect score is the one you should not
        trust.
      </p>

      <!-- The full results page (a tall 1:2.2 full-page capture): DS .of-showcase[scroll]
           — browser-frame chrome + scrolls in place + a soft "more below" fade, never an overlay -->
      <figure data-animate data-treatment="scroll" class="of-showcase mt-6">
        <div class="of-frame">
          <div class="of-frame-bar">
            <span class="of-frame-dots"><i></i><i></i><i></i></span>
            <span class="of-frame-label">Orionfold Proof — full results</span>
          </div>
          <div class="of-shot">
            <Image
              src={flagshipResults}
              alt="The full Orionfold Proof results page: the recommended 18 of 21 verdict, the leaderboard with tokens per second and zero cost, the run cost ledger, and the three honest failure cases with per-check detail."
              widths={[480, 720, 960]}
              sizes="(min-width: 1024px) 960px, 100vw"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <figcaption class="of-showcase-cap">
          The full results page: the recommended verdict, the leaderboard, the cost ledger, and the
          three honest misses laid out check by check. Scroll inside the frame to read it all.
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  /* The hero capture (cockpit-arena-populated) starts with an empty grid band
     above "Proof Run". The scroll-treatment frame clips overflow, so pull the
     image up to crop that dead whitespace under the chrome bar. The negative
     margin scales with the rendered width (% of the image's own width) so the
     crop holds across breakpoints instead of clipping differently. */
  .proof-hero :global(.of-shot) > :global(img) {
    margin-top: -10.5%;
  }
</style>
