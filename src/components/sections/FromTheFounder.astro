---
// Homepage "From the founder" band. Auto-features the newest founder letter (so
// the homepage refreshes with new content each month) next to a proof callout.
// Both are reason-to-believe surfaces beneath the capability headline, never the
// company headline itself (strategy hierarchy). Lazy/no eager images, no
// data-animate on an LCP candidate (mobile-perf-hygiene).
import { getCollection } from 'astro:content';
import SectionLabel from '../ui/SectionLabel.astro';

const letters = (await getCollection('letters')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const latest = letters[0];
---
{latest && (
  <section class="px-6 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl">
      <SectionLabel text="From the founder" />
      <div class="mt-6 grid gap-5 lg:grid-cols-3">
        <!-- Latest letter -->
        <a href="/letter/" class="of-surface of-pressable group flex flex-col rounded-3xl p-7 sm:p-9 lg:col-span-2">
          <div class="flex flex-wrap items-center gap-3 font-mono text-[10px] uppercase tracking-[0.18em] text-text-dim">
            <span class="text-primary">A letter every month</span>
            <span aria-hidden="true">·</span>
            <span>{latest.data.edition}</span>
          </div>
          <p class="mt-4 font-display text-2xl leading-snug text-text transition-colors group-hover:text-primary sm:text-3xl">{latest.data.title}</p>
          <p class="mt-3 max-w-xl text-base leading-relaxed text-text-muted">{latest.data.dek}</p>
          <span class="of-text-action mt-6">Read the letter</span>
        </a>
        <!-- Proof callout -->
        <a href="/proof/" class="of-surface of-pressable group flex flex-col justify-between rounded-3xl p-7 sm:p-9">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-primary">Receipts</p>
            <p class="mt-4 font-display text-xl leading-snug text-text transition-colors group-hover:text-primary">Proof you can rerun.</p>
            <p class="mt-3 text-sm leading-relaxed text-text-muted">Every starred claim has a frozen test you can run yourself. We never say "trust us." We say "rerun it."</p>
          </div>
          <span class="of-text-action mt-6">See the receipts</span>
        </a>
      </div>
    </div>
  </section>
)}
