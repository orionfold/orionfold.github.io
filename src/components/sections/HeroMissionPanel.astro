---
const layers = [
  { label: 'Data boundary', value: 'Customer controlled', state: 'locked' },
  { label: 'Workflow state', value: 'Human approved runs', state: 'audited' },
  { label: 'Evaluation layer', value: 'Benchmarks before rollout', state: 'measured' },
  { label: 'Model path', value: 'Cloud, local, or tuned', state: 'flexible' },
];

const proof = [
  'Corpus indexed',
  'Eval rubric attached',
  'Runbook shipped',
];
---
<div class="of-surface hero-mission-panel rounded-3xl p-4 sm:p-5">
  <div class="relative z-10 rounded-2xl border border-white/55 bg-surface-raised/80 p-4 shadow-[inset_0_1px_0_oklch(1_0_0/0.75)] sm:p-5">
    <div class="flex items-start justify-between gap-4 border-b border-border pb-4">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted">Orionfold control plane</p>
        <p class="mt-2 text-[1.55rem] font-bold leading-tight text-text sm:text-[1.95rem]">Private AI, mapped to business control.</p>
      </div>
      <span class="of-chip shrink-0">AI visible</span>
    </div>

    <div class="grid gap-4 pt-4">
      <div class="relative min-h-[10.5rem] overflow-hidden rounded-2xl border border-border bg-[oklch(0.18_0.06_260)] p-5 text-white">
        <div class="absolute inset-0 opacity-80 hero-mission-map" aria-hidden="true"></div>
        <div class="relative z-10 flex h-full flex-col justify-between gap-8">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-white/62">Capability route</p>
            <p class="mt-3 max-w-xs text-3xl font-semibold leading-tight">Ask → Run → Know → Build</p>
          </div>
          <div class="grid grid-cols-2 gap-2 font-mono text-[8px] uppercase tracking-[0.08em] text-white/72 sm:grid-cols-4">
            {proof.map((item) => (
              <span class="rounded-full border border-white/12 bg-white/[0.07] px-3 py-2">{item}</span>
            ))}
            <span class="rounded-full border border-[oklch(0.70_0.14_82/0.34)] bg-[oklch(0.70_0.14_82/0.12)] px-3 py-2 text-[oklch(0.86_0.10_82)]">Ready for review</span>
          </div>
        </div>
      </div>

      <div class="grid content-start gap-3 sm:grid-cols-2">
        {layers.map((layer, index) => (
          <div class="relative grid grid-cols-[auto_1fr] items-center gap-3 rounded-2xl border border-border bg-surface/70 p-3 pr-4">
            <span class="flex h-8 w-8 items-center justify-center rounded-full border border-primary/20 bg-primary/5 font-mono text-[10px] text-primary">
              {String(index + 1).padStart(2, '0')}
            </span>
            <span>
              <span class="block font-mono text-[10px] uppercase tracking-[0.16em] text-text-muted">{layer.label}</span>
              <span class="mt-0.5 block text-sm font-medium leading-snug text-text">{layer.value}</span>
            </span>
            <span class="absolute right-3 top-3 font-mono text-[9px] uppercase tracking-[0.1em] text-primary">{layer.state}</span>
          </div>
        ))}

        <div class="rounded-2xl border border-primary/15 bg-primary/[0.045] p-3 sm:col-span-2">
          <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-primary">Trust posture</p>
          <p class="mt-1 text-sm leading-relaxed text-text-muted">
            Explainability, approval, and evaluation sit inside the workflow.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hero-mission-panel {
    box-shadow:
      0 32px 80px -52px oklch(0.18 0.08 260 / 0.72),
      inset 0 1px 0 oklch(1 0 0 / 0.54);
  }
  .hero-mission-map {
    background:
      radial-gradient(circle at 24% 28%, white 0 2px, transparent 2.5px),
      radial-gradient(circle at 55% 42%, white 0 2px, transparent 2.5px),
      radial-gradient(circle at 75% 22%, white 0 1.5px, transparent 2px),
      radial-gradient(circle at 38% 74%, white 0 1.5px, transparent 2px),
      radial-gradient(circle at 82% 76%, white 0 2px, transparent 2.5px),
      linear-gradient(26deg, transparent 0 24%, oklch(0.70 0.14 82 / 0.32) 24.2% 24.6%, transparent 24.8% 100%),
      linear-gradient(145deg, transparent 0 39%, oklch(0.62 0.16 205 / 0.26) 39.2% 39.55%, transparent 39.8% 100%),
      radial-gradient(110% 120% at 12% 0%, oklch(0.55 0.18 260 / 0.74), transparent 42%),
      linear-gradient(135deg, oklch(0.16 0.05 260), oklch(0.25 0.08 246));
  }
</style>
