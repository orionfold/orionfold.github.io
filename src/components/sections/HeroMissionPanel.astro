---
const stack = [
  { label: 'Corpus', note: 'Docs + context', y: 118, accent: 'violet', icon: 'docs' },
  { label: 'Agents', note: 'Tools + roles', y: 218, accent: 'blue', icon: 'agent' },
  { label: 'Evals', note: 'Score + gate', y: 318, accent: 'cyan', icon: 'eval' },
  { label: 'Ship', note: 'Runbook + owner', y: 418, accent: 'gold', icon: 'ship' },
];

---
<div class="of-surface hero-mission-panel rounded-3xl p-3 sm:p-4">
  <div class="hero-mission-inner relative z-10 rounded-[1.45rem] border border-white/60 bg-surface-raised/85 p-4 shadow-[inset_0_1px_0_oklch(1_0_0/0.74)] sm:p-5">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted">Owned AI route</p>
        <p class="mt-2 max-w-md text-[1.55rem] font-bold leading-tight text-text sm:text-[1.95rem]">One private workflow, visible end to end.</p>
      </div>
      <span class="of-chip shrink-0">Traceable</span>
    </div>

    <div class="hero-route-card mt-5 overflow-hidden rounded-[1.35rem] border border-border bg-[oklch(0.985_0.012_255)] p-2 shadow-[0_22px_60px_-44px_oklch(0.18_0.08_260/0.52)]">
      <svg class="mx-auto block h-auto w-full sm:w-[82%] sm:max-w-[27rem]" viewBox="0 0 520 545" role="img" aria-labelledby="hero-route-title hero-route-desc">
        <title id="hero-route-title">Orionfold private AI workflow stack</title>
        <desc id="hero-route-desc">A workflow moves from brief to runbook through corpus, agents, evals, and shipping, with approval and trace rails visible on the sides.</desc>

        <defs>
          <linearGradient id="routePanel" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="oklch(1 0 0)" />
            <stop offset="1" stop-color="oklch(0.955 0.018 255)" />
          </linearGradient>
          <linearGradient id="navRail" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="oklch(0.18 0.075 250)" />
            <stop offset="1" stop-color="oklch(0.28 0.10 255)" />
          </linearGradient>
          <linearGradient id="mainRoute" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="oklch(0.48 0.16 260)" />
            <stop offset="0.52" stop-color="oklch(0.58 0.16 210)" />
            <stop offset="1" stop-color="oklch(0.70 0.14 82)" />
          </linearGradient>
          <filter id="softShadow" x="-20%" y="-20%" width="140%" height="150%">
            <feDropShadow dx="0" dy="16" stdDeviation="16" flood-color="oklch(0.20 0.07 250)" flood-opacity="0.14" />
          </filter>
          <filter id="routeGlow" x="-60%" y="-60%" width="220%" height="220%">
            <feGaussianBlur stdDeviation="6" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>

        <rect x="10" y="10" width="500" height="525" rx="34" fill="url(#routePanel)" stroke="oklch(0.72 0.028 250)" />
        <path d="M10 48C10 27 27 10 48 10H78V535H48C27 535 10 518 10 497Z" fill="url(#navRail)" />
        <path d="M54 82V440" stroke="oklch(0.70 0.14 82)" stroke-width="3" stroke-linecap="round" stroke-dasharray="1 10" />
        <circle cx="54" cy="68" r="7" fill="oklch(0.72 0.15 82)" />
        <circle cx="54" cy="454" r="10" fill="none" stroke="oklch(1 0 0 / 0.86)" stroke-width="3" />
        <path d="M54 486l6 14 14 6-14 6-6 14-6-14-14-6 14-6Z" fill="oklch(0.72 0.15 82)" />

        <g class="route-field">
          <path d="M276 66V495" stroke="oklch(0.20 0.065 250 / 0.26)" stroke-width="2" />
          <path class="route-flow" d="M276 66V495" stroke="url(#mainRoute)" stroke-width="4" stroke-linecap="round" stroke-dasharray="64 360" filter="url(#routeGlow)" />

          <g transform="translate(276 58)">
            <circle r="29" fill="oklch(1 0 0 / 0.9)" stroke="oklch(0.74 0.035 250)" />
            <path d="M0 -17l6 12 13 5-13 5-6 12-6-12-13-5 13-5Z" fill="oklch(0.17 0.075 250)" />
            <circle r="4.5" fill="oklch(1 0 0)" />
          </g>

          <g transform="translate(276 512)">
            <circle r="28" fill="oklch(1 0 0 / 0.95)" stroke="oklch(0.72 0.15 82)" stroke-width="2" />
            <path d="M-10 1l7 8 15-18" fill="none" stroke="oklch(0.67 0.15 82)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
          </g>

          {stack.map((item, index) => (
            <g class={`stack-node stack-node-${index + 1} stack-node-${item.accent}`} transform={`translate(276 ${item.y})`}>
              <rect x="-72" y="-44" width="144" height="88" rx="19" fill="oklch(1 0 0 / 0.94)" stroke="oklch(0.72 0.035 250)" filter="url(#softShadow)" />
              <rect class="node-accent" x="-72" y="-44" width="5" height="88" rx="3" />
              <circle cx="-28" cy="-7" r="21" fill="oklch(0.965 0.018 255)" stroke="oklch(0.76 0.04 250)" />

              {item.icon === 'docs' && (
                <g fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" transform="translate(-28 -7)">
                  <path d="M-8 -11h12l8 8v16H-8Z" />
                  <path d="M4 -11v8h8" />
                  <path d="M-2 3h8M-2 10h8" />
                </g>
              )}
              {item.icon === 'agent' && (
                <g fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" transform="translate(-28 -7)">
                  <circle cx="0" cy="-10" r="5" />
                  <path d="M0 -5v9M0 4l-10 8M0 4l10 8" />
                  <circle cx="-12" cy="14" r="4" />
                  <circle cx="12" cy="14" r="4" />
                </g>
              )}
              {item.icon === 'eval' && (
                <g fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" transform="translate(-28 -7)">
                  <path d="M-13 15V2h8v13M-1 15v-22h8v22M11 15V-14h8v29" />
                  <path d="M-16 15h38" />
                </g>
              )}
              {item.icon === 'ship' && (
                <g fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" transform="translate(-28 -7)">
                  <path d="M-15 -4 0 -13 15 -4 0 5Z" />
                  <path d="M-15 -4v17L0 22l15-9V-4M0 5v17" />
                </g>
              )}

              <text x="14" y="-8" fill="oklch(0.18 0.055 250)" font-family="var(--font-sans)" font-size="21" font-weight="700">{item.label}</text>
              <text x="14" y="17" fill="oklch(0.42 0.035 250)" font-family="var(--font-mono)" font-size="10">{item.note}</text>
              {index < stack.length - 1 && (
                <g transform="translate(0 58)">
                  <circle r="13" fill="oklch(0.17 0.075 250)" />
                  <path d="M-5 -2 0 4l5-6" fill="none" stroke="white" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" />
                </g>
              )}
            </g>
          ))}

          <g class="approval-rail">
            <path d="M116 138H182" stroke="oklch(0.70 0.14 82)" stroke-width="2" stroke-linecap="round" stroke-dasharray="1 9" />
            <path d="M116 238H182" stroke="oklch(0.70 0.14 82)" stroke-width="2" stroke-linecap="round" stroke-dasharray="1 9" />
            <path d="M116 338H182" stroke="oklch(0.70 0.14 82)" stroke-width="2" stroke-linecap="round" stroke-dasharray="1 9" />
            <path d="M116 138C92 138 92 238 116 238C92 238 92 338 116 338C92 338 92 438 116 438" fill="none" stroke="oklch(0.70 0.14 82)" stroke-width="2" stroke-linecap="round" />
            <circle cx="116" cy="438" r="22" fill="oklch(1 0 0 / 0.92)" stroke="oklch(0.75 0.13 82 / 0.55)" />
            <path d="M105 438l7 8 15-17" fill="none" stroke="oklch(0.68 0.15 82)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
            <text x="88" y="482" fill="oklch(0.20 0.055 250)" font-family="var(--font-mono)" font-size="11">APPROVE</text>
          </g>

          <g class="trace-rail">
            <path d="M370 138H414C438 138 438 238 414 238H370" fill="none" stroke="oklch(0.58 0.16 210)" stroke-width="2" stroke-linecap="round" />
            <path d="M370 338H414C438 338 438 438 414 438H370" fill="none" stroke="oklch(0.58 0.16 210)" stroke-width="2" stroke-linecap="round" />
            <path d="M370 138H414M370 238H414M370 338H414M370 438H414" stroke="oklch(0.58 0.16 210)" stroke-width="2" stroke-linecap="round" stroke-dasharray="1 9" />
            <circle cx="434" cy="288" r="24" fill="oklch(1 0 0 / 0.92)" stroke="oklch(0.62 0.14 210 / 0.55)" />
            <circle cx="429" cy="283" r="9" fill="none" stroke="oklch(0.52 0.15 210)" stroke-width="4" />
            <path d="M437 290l10 10" stroke="oklch(0.52 0.15 210)" stroke-width="4" stroke-linecap="round" />
            <text x="414" y="326" fill="oklch(0.20 0.055 250)" font-family="var(--font-mono)" font-size="11">TRACE</text>
          </g>
        </g>
      </svg>
    </div>
  </div>
</div>

<style>
  .hero-mission-panel {
    box-shadow:
      0 34px 84px -54px oklch(0.18 0.08 260 / 0.72),
      inset 0 1px 0 oklch(1 0 0 / 0.54);
  }
  .hero-mission-inner {
    background:
      radial-gradient(circle at 18% 6%, oklch(0.62 0.16 205 / 0.12), transparent 18rem),
      radial-gradient(circle at 86% 12%, oklch(0.70 0.14 82 / 0.10), transparent 16rem),
      color-mix(in oklch, var(--color-surface-raised) 88%, white 12%);
  }
  .hero-route-card {
    background:
      linear-gradient(135deg, oklch(0.995 0.004 250), oklch(0.955 0.018 255));
  }
  .stack-node {
    color: oklch(0.48 0.16 260);
  }
  .stack-node-blue {
    color: oklch(0.46 0.15 235);
  }
  .stack-node-cyan {
    color: oklch(0.52 0.15 205);
  }
  .stack-node-gold {
    color: oklch(0.66 0.14 82);
  }
  .stack-node-violet .node-accent {
    fill: oklch(0.56 0.18 260);
  }
  .stack-node-blue .node-accent {
    fill: oklch(0.50 0.16 235);
  }
  .stack-node-cyan .node-accent {
    fill: oklch(0.58 0.16 205);
  }
  .stack-node-gold .node-accent {
    fill: oklch(0.70 0.14 82);
  }
  .route-flow {
    animation: routeTravel 5.8s linear infinite;
  }
  .stack-node {
    animation: stackBreathe 6s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  .stack-node-2 { animation-delay: 0.3s; }
  .stack-node-3 { animation-delay: 0.6s; }
  .stack-node-4 { animation-delay: 0.9s; }
  @keyframes routeTravel {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -494; }
  }
  @keyframes stackBreathe {
    0%, 100% { opacity: 0.93; }
    45% { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .route-flow,
    .stack-node {
      animation: none;
    }
  }
</style>
