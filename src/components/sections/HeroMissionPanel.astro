---
const layers = [
  { label: 'Input', value: 'Corpus + workflow brief', state: 'scoped' },
  { label: 'Orchestrate', value: 'Agent run with approvals', state: 'guarded' },
  { label: 'Evaluate', value: 'Benchmarks before rollout', state: 'measured' },
  { label: 'Ship', value: 'Runbook, trace, and owner', state: 'owned' },
];

const proof = ['No data drift', 'Human gate', 'Eval trace'];

const routeNodes = [
  { label: 'Ask', x: 70, y: 194, tone: 'primary' },
  { label: 'Run', x: 205, y: 130, tone: 'cyan' },
  { label: 'Know', x: 340, y: 194, tone: 'gold' },
  { label: 'Build', x: 250, y: 270, tone: 'primary' },
];
---
<div class="of-surface hero-mission-panel rounded-3xl p-3 sm:p-5">
  <div class="relative z-10 rounded-2xl border border-white/55 bg-surface-raised/80 p-4 shadow-[inset_0_1px_0_oklch(1_0_0/0.75)] sm:p-5">
    <div class="flex items-start justify-between gap-4 border-b border-border pb-4">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted">Orionfold control plane</p>
        <p class="mt-2 text-[1.55rem] font-bold leading-tight text-text sm:text-[1.95rem]">Private AI, mapped as a working system.</p>
      </div>
      <span class="of-chip shrink-0">Traceable</span>
    </div>

    <div class="grid gap-4 pt-4">
      <div class="hero-system relative overflow-hidden rounded-2xl border border-border bg-[oklch(0.17_0.055_260)] p-4 text-white sm:p-5">
        <div class="relative z-10 flex items-start justify-between gap-4">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-white/62">Capability machine</p>
            <p class="mt-2 max-w-xs text-2xl font-semibold leading-tight sm:text-3xl">Ask → Run → Know → Build</p>
          </div>
          <div class="hidden rounded-xl border border-white/12 bg-white/[0.06] px-3 py-2 text-right font-mono text-[9px] uppercase leading-relaxed tracking-[0.12em] text-white/68 sm:block">
            <span class="block text-[oklch(0.86_0.10_82)]">live route</span>
            <span class="block">04 gates</span>
          </div>
        </div>

        <svg class="relative z-10 mt-2 h-auto w-full" viewBox="0 0 420 330" role="img" aria-labelledby="hero-system-title hero-system-desc">
          <title id="hero-system-title">Isometric Orionfold capability machine</title>
          <desc id="hero-system-desc">A route from Ask to Run to Know to Build moves through a controlled AI workflow with data, approval, evaluation, and shipping layers.</desc>

          <defs>
            <linearGradient id="heroDeck" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="oklch(0.38 0.13 250)" />
              <stop offset="1" stop-color="oklch(0.20 0.05 260)" />
            </linearGradient>
            <linearGradient id="heroTop" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="oklch(0.98 0.01 260 / 0.23)" />
              <stop offset="1" stop-color="oklch(0.62 0.16 205 / 0.18)" />
            </linearGradient>
            <filter id="heroGlow" x="-40%" y="-40%" width="180%" height="180%">
              <feGaussianBlur stdDeviation="7" result="blur" />
              <feMerge>
                <feMergeNode in="blur" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
          </defs>

          <g class="iso-shadow" aria-hidden="true">
            <ellipse cx="220" cy="274" rx="155" ry="42" fill="oklch(0.05 0.02 260 / 0.38)" />
          </g>

          <g class="iso-deck">
            <polygon points="70,176 218,104 374,180 226,258" fill="url(#heroDeck)" stroke="oklch(1 0 0 / 0.18)" stroke-width="1.3" />
            <polygon points="70,176 226,258 226,286 70,204" fill="oklch(0.12 0.04 260)" stroke="oklch(1 0 0 / 0.10)" />
            <polygon points="226,258 374,180 374,207 226,286" fill="oklch(0.10 0.035 246)" stroke="oklch(1 0 0 / 0.10)" />
            <path d="M118 183L220 132L323 181M158 205L260 154M205 230L308 176" fill="none" stroke="oklch(1 0 0 / 0.09)" stroke-width="1" />
          </g>

          <path class="route-line" d="M91 194L205 130L340 194L250 270L91 194" fill="none" stroke="oklch(0.62 0.16 205 / 0.82)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
          <path class="route-pulse" d="M91 194L205 130L340 194L250 270L91 194" fill="none" stroke="oklch(0.86 0.10 82)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" />

          {routeNodes.map((node, index) => (
            <g class={`iso-node iso-node-${index + 1} iso-node-${node.tone}`}>
              <polygon points={`${node.x - 34},${node.y - 8} ${node.x},${node.y - 25} ${node.x + 35},${node.y - 8} ${node.x},${node.y + 11}`} fill="url(#heroTop)" stroke="oklch(1 0 0 / 0.24)" />
              <polygon points={`${node.x - 34},${node.y - 8} ${node.x},${node.y + 11} ${node.x},${node.y + 31} ${node.x - 34},${node.y + 11}`} fill="oklch(0.14 0.045 260)" stroke="oklch(1 0 0 / 0.12)" />
              <polygon points={`${node.x},${node.y + 11} ${node.x + 35},${node.y - 8} ${node.x + 35},${node.y + 12} ${node.x},${node.y + 31}`} fill="oklch(0.11 0.038 246)" stroke="oklch(1 0 0 / 0.12)" />
              <circle cx={node.x} cy={node.y - 7} r="7" filter="url(#heroGlow)" />
              <text x={node.x} y={node.y + 54} text-anchor="middle" fill="oklch(1 0 0 / 0.76)" font-size="10" font-family="var(--font-mono)" letter-spacing="1.5">{node.label}</text>
            </g>
          ))}

          <g class="agent-card">
            <rect x="146" y="58" width="118" height="54" rx="12" fill="oklch(0.98 0.01 260 / 0.12)" stroke="oklch(1 0 0 / 0.22)" />
            <path d="M161 78h48M161 93h76" stroke="oklch(1 0 0 / 0.58)" stroke-width="3" stroke-linecap="round" />
            <circle cx="241" cy="82" r="8" fill="oklch(0.70 0.14 82)" />
          </g>
        </svg>

        <div class="relative z-10 grid grid-cols-3 gap-2 font-mono text-[8px] uppercase tracking-[0.08em] text-white/72 sm:text-[9px]">
          {proof.map((item) => (
            <span class="rounded-full border border-white/12 bg-white/[0.07] px-2.5 py-2 text-center">{item}</span>
          ))}
        </div>
      </div>

      <div class="grid content-start gap-3 sm:grid-cols-2">
        {layers.map((layer, index) => (
          <div class="relative grid grid-cols-[auto_1fr] items-center gap-3 rounded-2xl border border-border bg-surface/70 p-3 pr-4">
            <span class="flex h-8 w-8 items-center justify-center rounded-full border border-primary/20 bg-primary/5 font-mono text-[10px] text-primary">
              {String(index + 1).padStart(2, '0')}
            </span>
            <span>
              <span class="block font-mono text-[10px] uppercase tracking-[0.16em] text-text-muted">{layer.label}</span>
              <span class="mt-0.5 block text-sm font-medium leading-snug text-text">{layer.value}</span>
            </span>
            <span class="absolute right-3 top-3 font-mono text-[9px] uppercase tracking-[0.1em] text-primary">{layer.state}</span>
          </div>
        ))}

        <div class="rounded-2xl border border-primary/15 bg-primary/[0.045] p-3 sm:col-span-2">
          <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-primary">Operating posture</p>
          <p class="mt-1 text-sm leading-relaxed text-text-muted">
            The diagram is the product promise: data, tools, approvals, evals, and output stay visible as one route.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hero-mission-panel {
    box-shadow:
      0 32px 80px -52px oklch(0.18 0.08 260 / 0.72),
      inset 0 1px 0 oklch(1 0 0 / 0.54);
  }
  .hero-system {
    background:
      radial-gradient(circle at 16% 18%, oklch(0.62 0.16 205 / 0.28), transparent 20rem),
      radial-gradient(circle at 86% 16%, oklch(0.70 0.14 82 / 0.22), transparent 18rem),
      linear-gradient(135deg, transparent 0 48%, oklch(1 0 0 / 0.045) 48.2% 48.55%, transparent 48.8% 100%),
      linear-gradient(135deg, oklch(0.16 0.05 260), oklch(0.25 0.08 246));
  }
  .iso-node-primary circle { fill: oklch(0.60 0.18 260); }
  .iso-node-cyan circle { fill: oklch(0.62 0.16 205); }
  .iso-node-gold circle { fill: oklch(0.70 0.14 82); }
  .route-line {
    opacity: 0.72;
  }
  .route-pulse {
    stroke-dasharray: 58 420;
    animation: missionRoute 5.4s linear infinite;
    filter: drop-shadow(0 0 10px oklch(0.70 0.14 82 / 0.35));
  }
  .iso-node {
    animation: nodeBreathe 5.4s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  .iso-node-2 { animation-delay: 0.45s; }
  .iso-node-3 { animation-delay: 0.9s; }
  .iso-node-4 { animation-delay: 1.35s; }
  .agent-card {
    animation: agentAudit 6.2s ease-in-out infinite;
  }
  @keyframes missionRoute {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -478; }
  }
  @keyframes nodeBreathe {
    0%, 100% { transform: translateY(0); opacity: 0.88; }
    45% { transform: translateY(-3px); opacity: 1; }
  }
  @keyframes agentAudit {
    0%, 100% { transform: translateY(0); opacity: 0.84; }
    50% { transform: translateY(5px); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .route-pulse,
    .iso-node,
    .agent-card {
      animation: none;
    }
  }
</style>
