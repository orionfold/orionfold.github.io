---
// Catalog doorway (spec _SPECS/2026-06-09-catalog-doorway.md): the homepage
// shelf that opens the three hub pages. Counts come from the SSOT arrays and
// door art reuses the proof-art resolver, so a new product shows up here with
// zero edits. Model count is DISTINCT non-dataset slugs: build variants share
// one detail page and the bench dataset is not a model (6 today, not 9).
import { Image } from 'astro:assets';
import { software } from '../../data/software';
import { models } from '../../data/models';
import { books } from '../../data/books';
import { slugify } from '../../lib/product/detail';
import { resolveProofArt } from '../../lib/flagship/proof-art';

const modelSlugs = [...new Set(models.filter((m) => m.group !== 'dataset').map((m) => slugify(m.title)))];

const artFor = (hrefs: string[], max: number) =>
  hrefs
    .map((href) => resolveProofArt(href))
    .filter((img): img is NonNullable<typeof img> => Boolean(img))
    .slice(0, max);

const doors = [
  {
    href: '/software/',
    label: 'Software',
    count: software.length,
    unit: 'apps',
    gloss: 'The platform, the cockpit tools, and the apps that run private AI work.',
    art: artFor(software.map((s) => `/software/${s.slug}/`), 4),
  },
  {
    href: '/models/',
    label: 'Models',
    count: modelSlugs.length,
    unit: 'models',
    gloss: 'Domain experts for patents, security, law, money, health, and space math.',
    art: artFor(modelSlugs.map((slug) => `/models/${slug}/`), 4),
  },
  {
    href: '/books/',
    label: 'Books',
    count: books.length,
    unit: 'books',
    gloss: 'Playbooks from the build. Read free on the site.',
    art: artFor(books.map((b) => `/books/${b.slug}/`), 3),
  },
];
---
<section class="px-6 pb-10 pt-4">
  <div class="mx-auto max-w-6xl">
    <div class="mb-6 flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">The full catalog</p>
        <h2 class="mt-2 text-3xl sm:text-4xl">Browse everything we have shipped.</h2>
      </div>
      <p class="max-w-md text-sm leading-relaxed text-text-muted">
        The featured products above are a sample. Every app, model, and book lives in the open
        catalog, free to inspect.
      </p>
    </div>
    <div data-animate-stagger class="grid gap-4 lg:grid-cols-3">
      {doors.map((door) => (
        <a
          href={door.href}
          data-animate
          aria-label={`Browse all ${door.label.toLowerCase()}`}
          class="of-surface of-pressable block overflow-hidden rounded-2xl p-6"
        >
          {/* Cover fan: height-constrained so covers never overlap the text below. */}
          <div class="relative h-32 sm:h-36" aria-hidden="true">
            {door.art.map((img, i) => (
              <Image
                src={img}
                alt=""
                widths={[160, 320]}
                sizes="120px"
                loading="lazy"
                decoding="async"
                data-no-zoom
                class="absolute top-0 h-full w-auto rounded-lg border border-border shadow-lg"
                style={`left:${i * 18}%;transform:rotate(${(i - (door.art.length - 1) / 2) * 3}deg);aspect-ratio:3/4;object-fit:cover;object-position:top;z-index:${i};`}
              />
            ))}
          </div>
          <div class="mt-4"><span class="of-chip">{door.count} {door.unit}</span></div>
          <span class="mt-3 block text-2xl leading-tight text-text">{door.label}</span>
          <span class="mt-2 block text-sm leading-relaxed text-text-muted">{door.gloss}</span>
          <span class="of-text-action of-compact mt-4 inline-block text-xs">Browse all →</span>
        </a>
      ))}
    </div>
  </div>
</section>
