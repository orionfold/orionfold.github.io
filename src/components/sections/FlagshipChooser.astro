---
import FlagshipPathCard from '../flagship/FlagshipPathCard.astro';
import { flagshipOffers } from '../../data/flagship-offers';
---
<section class="px-6 pb-10 pt-12">
  <div class="mx-auto max-w-6xl">
    <div class="mb-6 flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">Choose the adoption path</p>
        <h2 class="mt-2 text-3xl sm:text-4xl">Ask, run, know, then build.</h2>
      </div>
      <p class="max-w-md text-sm leading-relaxed text-text-muted">
        Every product on this site feeds one of these four paths. Pick the one that matches the work your team needs to own.
      </p>
    </div>
    <div data-animate-stagger class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {flagshipOffers.map((offer) => <FlagshipPathCard offer={offer} />)}
    </div>
  </div>
</section>
