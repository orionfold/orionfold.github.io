---
// CapabilityMatrix — the signature "proof" element for /proof/. It turns a flat
// comparison table into a flex with three moves:
//   1. The star legend is the hero: every star has a frozen test you can rerun.
//   2. Progressive disclosure: you first see OUR small models shine on their own,
//      then choose to bring in the big open base models for scale. Discovery beats
//      declaration. (No-JS fallback: the "ours" view is the default and always shows.)
//   3. A starred ROW is clickable and deep-links to the receipt that carries its
//      frozen test; hovering a row glows its star and shows a taster on the right.
// The table is left-aligned (readability), and the freed right-side space holds
// the hover taster: in "ours" view a receipt preview + rerun CTA; in "all" view,
// an honest "vendor-claimed, no rerunnable receipt" note for the big base models.
// Themed with the existing tokens; the only new color is the gold star, scoped below.
import { cols, matrix, speedRows, speedCaveat, receiptHref, rowReceiptSlug } from '../../data/proof';
import type { Mark } from '../../data/proof';

interface Props {
  // Receipt slug -> { metric, claim } for the hover taster. Passed from the page
  // (read off the receipts collection there) so this component stays decoupled
  // from the content layer.
  tasters?: Record<string, { metric: string; claim: string }>;
}
const { tasters = {} } = Astro.props;

const glyph: Record<Mark, string> = { star: '★', strong: '●', maybe: '◐', none: '○' };
const meaning: Record<Mark, string> = {
  star: 'Proved on a locked test you can rerun',
  strong: 'Yes, strong',
  maybe: 'Possible, but not guaranteed',
  none: 'Not built for this',
};
---
<section data-matrix data-view="ours" class="px-6 py-4">
  <div class="mx-auto max-w-6xl">
    <!-- Star legend as the hero line -->
    <div class="of-surface rounded-2xl p-6 sm:p-7">
      <p class="font-display text-2xl leading-snug sm:text-3xl">
        Every <span class="mark mark-star align-middle">★</span> has a frozen test you can rerun.
      </p>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-text-muted">
        We write the hard test and lock it before we train, so we cannot cheat. A
        <span class="mark mark-star">★</span> means we proved it and published the receipts, and it links to the page where you can check our numbers. The rest of the marks read like this:
      </p>
      <ul class="mt-4 flex flex-wrap gap-x-6 gap-y-2 font-mono text-xs text-text-muted">
        <li><span class="mark mark-star">★</span> proved on a locked test</li>
        <li><span class="mark mark-strong">●</span> yes, strong</li>
        <li><span class="mark mark-maybe">◐</span> possible, not guaranteed</li>
        <li><span class="mark mark-none">○</span> not built for it</li>
      </ul>
    </div>

    <!-- View toggle: ours first, then add the big open models -->
    <div class="mt-6 flex flex-wrap items-center gap-3">
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-text-dim">Show</span>
      <div class="inline-flex rounded-full border border-border bg-surface-raised p-1 text-xs font-medium">
        <button data-view-btn="ours" type="button" class="rounded-full px-4 py-1.5 transition">Our models</button>
        <button data-view-btn="all" type="button" class="rounded-full px-4 py-1.5 transition">Add the big open models</button>
      </div>
    </div>

    <!-- Guiding subtext: tell the reader the rows are doors to the receipts. -->
    <p data-matrix-hint class="mt-4 flex items-center gap-2 text-sm text-text-muted">
      <span class="mark mark-star">★</span>
      Click a row with a star to open its receipt, the frozen test you can rerun.
    </p>

    <!-- Left: the matrix (left-aligned for readability). Right: the hover taster
         that fills the freed space. They sit side by side on wide screens; the
         taster drops below on small screens. -->
    <div data-matrix-grid class="mt-4 flex flex-col gap-6 lg:items-start">
      <!-- The matrix (DS .of-table.sticky-col.matrix). Scrolls sideways on small
           screens; the capability column is sticky so the labels stay put. -->
      <div class="min-w-0 lg:flex-1">
        <table class="of-table sticky-col matrix" style="min-width:30rem;">
          <thead>
            <tr>
              <th scope="col">What it can do</th>
              {cols.map((c) => (
                <th scope="col" data-base={!c.ours ? 'true' : undefined}>
                  {c.href ? (
                    <a href={c.href} class="block leading-tight text-text transition-colors hover:text-primary">{c.label}</a>
                  ) : (
                    <span class="block leading-tight text-text">{c.label}</span>
                  )}
                  <span class={`mt-0.5 block font-mono text-[9px] tracking-[0.12em] ${c.ours ? 'text-primary' : 'text-text-dim'}`}>{c.sub}</span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {matrix.map((row) => {
              const slug = rowReceiptSlug(row);
              const href = receiptHref(slug);
              const taster = slug ? tasters[slug] : undefined;
              return (
                <tr
                  data-row
                  data-receipt-href={href}
                  data-taster-metric={taster?.metric}
                  data-taster-claim={taster?.claim}
                  class:list={[href && 'has-receipt']}
                >
                  <th scope="row">
                    {href ? (
                      <a href={href} class="row-cap-link">{row.capability}</a>
                    ) : (
                      row.capability
                    )}
                  </th>
                  {row.cells.map((cell, i) => (
                    <td data-base={!cols[i].ours ? 'true' : undefined}>
                      <span title={meaning[cell.mark]} class={`mark mark-${cell.mark}`} aria-label={`${cols[i].label}: ${meaning[cell.mark]}`}>{glyph[cell.mark]}</span>
                    </td>
                  ))}
                </tr>
              );
            })}
          </tbody>
        </table>
        <p class="mt-3 text-xs leading-relaxed text-text-dim">
          Base-model marks (Qwen3, Llama, DeepSeek-R1) are general, vendor-documented capability, not our measurement. Only the <span class="mark mark-star">★</span> cells come with a frozen test anyone can rerun.
        </p>
      </div>

      <!-- The taster rail. Sticky on wide screens so it tracks as you scan rows.
           Two faces, swapped by JS: the receipt preview (ours view) and the
           vendor-claimed note (all view). The idle face invites the hover. -->
      <aside data-taster class="lg:sticky lg:top-24">
        <div class="of-surface rounded-2xl p-5 min-h-[11rem] flex flex-col justify-center">
          <!-- Idle -->
          <div data-taster-face="idle">
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-text-dim">The receipt</p>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">
              Hover a row with a <span class="mark mark-star">★</span> to preview the receipt behind it. Click to open and rerun it.
            </p>
          </div>
          <!-- Receipt preview (ours view) -->
          <a data-taster-face="receipt" href="#" hidden class="group block">
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">Proved on a locked test</p>
            <p data-taster-metric class="mt-2 font-display text-2xl leading-none text-primary"></p>
            <p data-taster-claim class="mt-3 text-sm leading-relaxed text-text-muted"></p>
            <span class="mt-4 inline-block text-sm text-primary transition-colors group-hover:text-primary/80">See the receipt &rarr;</span>
          </a>
          <!-- Vendor-claimed note (all view, base model) -->
          <div data-taster-face="vendor" hidden>
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-text-dim">No receipt here</p>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">
              The big open models' marks are vendor-documented capability, not a test we ran. Only our <span class="mark mark-star">★</span> come with a frozen test you can rerun.
            </p>
          </div>
        </div>
      </aside>
    </div>

    <!-- Speed: a model on your own desk, keeping pace with the big hosted ones -->
    <div class="mt-10 of-surface rounded-2xl p-6 sm:p-7">
      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">Typing speed, words a second</p>
      <p class="mt-2 font-display text-xl leading-snug sm:text-2xl">A model on your own desk keeps pace with the big hosted ones.</p>
      <div class="mt-5 grid gap-2.5">
        {speedRows.map((s) => {
          const n = parseFloat(s.wps.replace('~', '')) || 0;
          const pct = Math.min(100, Math.round((n / 166.8) * 100));
          return (
            <div class={`flex items-center gap-4 rounded-xl px-4 py-3 ${s.ours ? 'of-win-row' : 'bg-surface-raised'}`}>
              <div class="w-40 shrink-0">
                <p class={`text-sm font-medium ${s.ours ? 'text-primary' : 'text-text'}`}>{s.model}</p>
                <p class="text-xs text-text-dim">{s.where}</p>
              </div>
              <div class="h-2 flex-1 overflow-hidden rounded-full bg-border/40">
                <div class={`h-full rounded-full ${s.ours ? 'bg-primary' : 'bg-text-muted/45'}`} style={`width:${pct}%`}></div>
              </div>
              <span class="w-14 shrink-0 text-right font-mono text-sm text-text">{s.wps}</span>
            </div>
          );
        })}
      </div>
      <p class="mt-4 text-xs leading-relaxed text-text-dim">{speedCaveat}</p>
    </div>
  </div>
</section>

<style>
  /* Mark colors. The gold star is the brand in one glyph. */
  .mark { font-size: 1.05em; line-height: 1; }
  .mark-star { color: oklch(0.70 0.14 82); }
  .mark-strong { color: var(--color-primary); }
  .mark-maybe { color: var(--color-text-muted); opacity: 0.85; }
  .mark-none { color: var(--color-text-muted); opacity: 0.3; }

  /* Left-align the table cells (readability) instead of the DS-centered glyphs.
     The capability column already left-aligns; this pulls the model columns in
     so they sit tight to the labels and free the right side for the taster. */
  .of-table.matrix th[scope='col'],
  .of-table.matrix td { text-align: left; }
  .of-table.matrix th[scope='col']:first-child,
  .of-table.matrix th[scope='row'] { text-align: left; }

  /* The capability cell is a plain-looking link (the whole row is the affordance). */
  .row-cap-link { color: inherit; text-decoration: none; }
  tr.has-receipt { cursor: pointer; }
  tr.has-receipt:hover th[scope='row'] .row-cap-link,
  tr.has-receipt:hover th[scope='row'] { color: var(--color-primary); }
  tr.has-receipt:hover { background: color-mix(in oklab, var(--color-primary) 7%, transparent); }

  /* Star glow + expand on row hover: signals the row is "about the star". */
  tr.has-receipt:hover .mark-star {
    transform: scale(1.35);
    filter: drop-shadow(0 0 7px oklch(0.70 0.14 82 / 0.75));
  }
  .mark-star { display: inline-block; transition: transform 150ms ease, filter 150ms ease; }

  /* Progressive disclosure: hide the base-model columns until the reader asks. */
  [data-matrix][data-view='ours'] [data-base] { display: none; }

  /* Layout: in "ours" view (3 narrow columns) the table is compact, so the
     taster sits beside it on the right and fills the freed space. In "all" view
     (6 columns) the table needs the full width, so the taster drops below as a
     full-width strip. Mobile always stacks. */
  @media (min-width: 1024px) {
    [data-matrix][data-view='ours'] [data-matrix-grid] { flex-direction: row; }
    [data-matrix][data-view='ours'] [data-matrix-grid] > div:first-child { flex: 1 1 auto; min-width: 0; }
    [data-matrix][data-view='ours'] [data-taster] { width: 18rem; flex: 0 0 18rem; }

    [data-matrix][data-view='all'] [data-matrix-grid] { flex-direction: column; }
    [data-matrix][data-view='all'] [data-taster] { position: static; width: 100%; }
    [data-matrix][data-view='all'] [data-taster] .of-surface { min-height: 0; }
  }

  /* In "all" view the receipt-hover hint is less central (base cols have no
     receipt), so soften the guiding line. */
  [data-matrix][data-view='all'] [data-matrix-hint] { opacity: 0.7; }

  /* Toggle active state, set by the inline script via aria-pressed. The active
     pill uses the theme-aware accent triad — a bare #fff on the bright dark-theme
     cyan fails WCAG (≈1.6:1); accent-text resolves to a legible ink per theme. */
  [data-view-btn][aria-pressed='true'] { background: var(--color-accent); color: var(--color-accent-text); }
  [data-view-btn][aria-pressed='false'] { color: var(--color-text-muted); }
</style>

<script>
  // Progressive disclosure toggle + clickable rows + hover taster. No framework:
  // flip a data attribute on the section, reflect it on the buttons, wire row
  // hover/click to the taster panel on the right.
  document.querySelectorAll('[data-matrix]').forEach((section) => {
    const btns = section.querySelectorAll<HTMLButtonElement>('[data-view-btn]');
    const rows = section.querySelectorAll<HTMLTableRowElement>('[data-row]');
    const taster = section.querySelector('[data-taster]');
    const faces = {
      idle: taster?.querySelector<HTMLElement>('[data-taster-face="idle"]') ?? null,
      receipt: taster?.querySelector<HTMLAnchorElement>('[data-taster-face="receipt"]') ?? null,
      vendor: taster?.querySelector<HTMLElement>('[data-taster-face="vendor"]') ?? null,
    };
    const metricEl = taster?.querySelector<HTMLElement>('[data-taster-metric]') ?? null;
    const claimEl = taster?.querySelector<HTMLElement>('[data-taster-claim]') ?? null;

    const showFace = (which: 'idle' | 'receipt' | 'vendor') => {
      (Object.keys(faces) as Array<keyof typeof faces>).forEach((k) => {
        if (faces[k]) faces[k]!.hidden = k !== which;
      });
    };

    const apply = (view: string) => {
      section.setAttribute('data-view', view);
      btns.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.viewBtn === view)));
      showFace('idle');
    };

    btns.forEach((b) => b.addEventListener('click', () => apply(b.dataset.viewBtn || 'ours')));

    rows.forEach((row) => {
      const href = row.dataset.receiptHref;
      const metric = row.dataset.tasterMetric;
      const claim = row.dataset.tasterClaim;

      const enter = () => {
        const view = section.getAttribute('data-view');
        if (href && faces.receipt) {
          // A starred row in either view previews its receipt.
          faces.receipt.href = href;
          if (metricEl) metricEl.textContent = metric ?? '';
          if (claimEl) claimEl.textContent = claim ?? '';
          showFace('receipt');
        } else if (view === 'all') {
          // A row with no receipt, while the big models are shown: explain why.
          showFace('vendor');
        } else {
          showFace('idle');
        }
      };
      row.addEventListener('mouseenter', enter);
      row.addEventListener('focusin', enter);

      // Whole-row click opens the receipt (the capability cell also holds a real
      // <a> for no-JS + keyboard; this makes the rest of the row clickable too).
      if (href) {
        row.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).closest('a')) return; // let real links work
          window.location.href = href;
        });
      }
    });

    // Reset to idle only when the pointer leaves the WHOLE table+taster region,
    // not the tbody alone — otherwise moving the cursor toward the taster (to
    // click "See the receipt") would wipe the preview before you reach it. The
    // last-hovered receipt sticks while you travel across the gap into the panel.
    section.querySelector('[data-matrix-grid]')?.addEventListener('mouseleave', () => showFace('idle'));

    apply('ours');
  });
</script>
