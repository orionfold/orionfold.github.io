---
// Homepage NVIDIA DGX Spark band (G2/G3, spec 2026-06-02). A compelling, hero-style
// two-column section — featured art on one side, eyebrow + title + blurb + CTA on the
// other — that sits just below the homepage Hero and points to the /dgx-spark/ hub
// where the NVIDIA-stack body of work is gathered. The image is lazy (it is below the
// Hero, which owns the homepage LCP) and not data-animate (perf invariants). Copy reads
// grade 3-5, no em-dashes (website-copy-style).
import { Image } from 'astro:assets';
import sparkHero from '../../assets/dgx-spark/hero.jpg';
---
<section class="px-6 py-12 sm:py-16">
  <div class="mx-auto grid max-w-6xl items-stretch overflow-hidden rounded-3xl border border-primary/15 bg-primary/[0.06] lg:grid-cols-2">
    <!-- Featured art -->
    <a href="/dgx-spark/" aria-label="Built on the NVIDIA DGX Spark" class="block">
      <Image
        src={sparkHero}
        alt="A small gold desktop computer glows on a plain desk at night, sending bright beams of light up into a wide sky full of stars and constellations."
        widths={[480, 720, 960]}
        sizes="(min-width: 1024px) 36rem, 100vw"
        loading="lazy"
        data-no-zoom
        class="h-full min-h-[16rem] w-full object-cover"
      />
    </a>

    <!-- Pitch -->
    <div class="flex flex-col justify-center p-8 sm:p-10 lg:p-12">
      <p class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-primary">Built on the NVIDIA stack</p>
      <h2 class="mt-4 text-3xl leading-[1.1] sm:text-4xl">Real AI research, run on one desk.</h2>
      <p class="mt-5 max-w-xl text-base leading-relaxed text-text-muted">
        Our reference machine is the NVIDIA DGX Spark, a small AI supercomputer that fits on a desk. The
        book, the open models, and the tools were all proven on it first, with no cloud. See the whole
        body of work gathered in one place.
      </p>
      <div class="mt-7">
        <a
          href="/dgx-spark/"
          class="inline-flex items-center gap-1.5 rounded-full bg-primary px-6 py-3 text-sm font-medium text-white transition hover:bg-primary/90"
        >
          See the NVIDIA-stack work
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
