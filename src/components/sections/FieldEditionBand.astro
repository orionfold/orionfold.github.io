---
// Homepage Arena Field Edition band (IA refocus, 2026-06). Sits immediately below
// the Hero as the site's single primary commercial CTA. Positioning (operator
// 2026-06-13, capability/velocity-led): "Get an AI team without hiring one, in the
// DGX Spark you already own"; velocity (one builder's output on this stack) is the
// hero proof, the receipt is the reason-to-believe. A focused two-column band with
// a primary border so it reads as the page's focal point. It is the HOOK, not the
// checkout — it deep-links to the Field Edition buy block on the /arena/ landing
// (#get-arena), the single canonical Arena buy surface since the /software/arena/
// detail page was retired (2026-07-01).
//
// Flag-aware: while ARENA_FIELD_EDITION_LIVE is false the CTA says "launching
// this weekend"; when it flips, the same band points at the live buy. Price comes
// from the catalog SSOT (FIELD_EDITION) so it can never drift. The image is lazy
// and not data-animate (the Hero owns the homepage LCP — perf invariants hold).
// Copy is grade 3-5, no em-dashes (website-copy-style).
import { Image } from 'astro:assets';
import arenaPoster from '../../assets/projects/arena-poster.png';
import { FIELD_EDITION, formatUsd } from '../../data/commerce';

const primary = formatUsd(FIELD_EDITION.primary.amount);
const founding = formatUsd(FIELD_EDITION.founding.amount);
---
<section id="arena-field-edition" class="scroll-mt-24 px-6 py-12 sm:py-16">
  <div class="of-surface mx-auto grid max-w-6xl items-stretch overflow-hidden rounded-3xl border border-primary/40 shadow-lg shadow-primary/5 lg:grid-cols-2">
    <!-- Featured art (lazy; the Hero owns the homepage LCP) -->
    <a href="/arena/#get-arena" aria-label="Arena Field Edition for DGX Spark" class="block">
      <Image
        src={arenaPoster}
        alt="Movie-poster key art for Orionfold Arena, the eval cockpit you run on your own desktop."
        widths={[480, 720, 960]}
        sizes="(min-width: 1024px) 36rem, 100vw"
        loading="lazy"
        data-no-zoom
        class="h-full min-h-[16rem] w-full object-cover"
      />
    </a>

    <!-- Pitch -->
    <div class="flex flex-col justify-center p-8 sm:p-10 lg:p-12">
      <p class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-primary">
        Arena Field Edition for DGX Spark
      </p>
      <h2 class="mt-4 text-3xl leading-[1.1] sm:text-4xl">Get an AI team without hiring one, in the Spark you own.</h2>
      <p class="mt-5 max-w-xl text-base leading-relaxed text-text-muted">
        One installer turns your NVIDIA DGX Spark into a private AI lab with an AI research
        teammate, and proves itself on first boot. The proof of what it unlocks: one builder,
        solo on this exact stack, shipped 15 tools, 7 open models, 3 books, and 2 production
        sites. What you buy is the assembled, proven team, delivered turnkey.
      </p>

      <div class="mt-6 flex flex-wrap items-baseline gap-x-3 gap-y-1">
        <span class="font-display text-3xl font-bold text-primary">{founding}</span>
        <span class="rounded-full bg-primary/10 px-2.5 py-1 font-mono text-[0.65rem] tracking-wider text-primary">
          Founding, first {FIELD_EDITION.foundingSeats}
        </span>
        <span class="font-mono text-xs tracking-wider text-text-muted">then {primary} one time</span>
      </div>

      <div class="mt-7 flex flex-wrap items-center gap-4">
        <a href="/arena/#get-arena" class="of-primary-action">
          Get Arena Field Edition
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
        <a href="/arena/demo/" class="of-secondary-action">
          Watch the demo
        </a>
      </div>
    </div>
  </div>
</section>
