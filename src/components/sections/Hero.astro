---
// Homepage hero ("split + constellation"). Left: the capability-ownership pitch
// and offer CTAs. Right: a quieter enterprise mission panel that turns the
// constellation motif into trust, control, and evaluation signals. The homepage
// newsletter form lives on the Story pages (H3).
import { Image } from 'astro:assets';
import heroImage from '../../assets/proof/orionfold-proof-poster.jpeg';
import { magnetHref } from '../../data/magnet.ts';
// Magnet secondary CTA (relay latest+21): a quieter free-book rung BELOW the two
// Proof anchor CTAs, so the magnet sits under the anchor offer without competing
// with it. The free book captures the email before the visitor weighs the paid
// product.
const magnetHeroHref = magnetHref('hero-secondary');
---
<section class="relative overflow-x-clip">
  <!-- Soft atmospheric light, kept below the operational surfaces. -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute left-[8%] top-1/2 h-[640px] w-[640px] -translate-y-1/2 rounded-full bg-primary/[0.08] blur-[170px]"></div>
    <div class="absolute right-[4%] top-[18%] h-[420px] w-[420px] rounded-full bg-[oklch(0.70_0.14_82/0.10)] blur-[120px]"></div>
  </div>

  <!-- Bottom gradient fade into the narrative -->
  <div class="pointer-events-none absolute bottom-0 left-0 right-0 z-10 h-32" style="background: linear-gradient(to bottom, transparent, var(--color-surface));"></div>

  <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 pb-16 pt-24 sm:pt-28 lg:min-h-[calc(100dvh-120px)] lg:grid-cols-[0.95fr_1.05fr] lg:gap-12 lg:pb-16 lg:pt-24">
    <!-- Left: the pitch. The pitch column used to stagger-reveal via [data-animate]
         + IntersectionObserver, but that made the subtitle P the page's LCP element
         at ~7.5s on mobile (Lighthouse won't count an opacity:0 element as painted).
         Painting the pitch immediately is the bigger UX win than the stagger polish. -->
    <div class="relative z-10 text-center lg:text-left">
      <p class="mx-auto mb-6 max-w-[18rem] text-wrap font-mono text-[11px] uppercase leading-relaxed tracking-[0.18em] text-text-muted lg:mx-0 lg:max-w-none lg:text-xs">
        Prove it yourself, on your own machine
      </p>

      <h1 class="hero-gradient-text mx-auto max-w-[21rem] text-balance font-display text-[2.45rem] font-bold leading-[1.08] sm:max-w-2xl sm:text-6xl lg:mx-0 lg:max-w-none lg:text-[clamp(2.9rem,4.2vw,4.2rem)]">
        Prove which AI you can trust.
      </h1>

      <p class="mx-auto mt-6 max-w-[22rem] text-balance text-base leading-relaxed text-text-muted sm:max-w-xl sm:text-lg lg:mx-0">
        Orionfold Proof runs on your own machine. Point it at your own task, run the AI models or setups you are weighing, and get a signed receipt: which one won, at what cost, with what failures. Nothing phones home, and you can rerun the proof any time.
      </p>

      <div class="mx-auto mt-9 flex w-full max-w-[24rem] flex-col items-stretch gap-3 lg:mx-0">
        <a
          href="/proof/#get-proof"
          class="of-primary-action group w-full justify-center !text-sm sm:!text-base"
        >
          Get Orionfold Proof
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href="/proof/"
          class="of-secondary-action w-full justify-center !text-sm sm:!text-base"
        >
          See the receipts
        </a>
        <a
          href={magnetHeroHref}
          class="group mt-1 inline-flex items-center justify-center gap-1.5 self-center font-mono text-xs tracking-wider text-text-muted transition-colors hover:text-primary lg:self-start"
        >
          Or get the free AI Native Business book
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </a>
      </div>

    </div>

    <!-- Right: the Orionfold Proof poster, optimized through Astro. On desktop
         it floats on the slowly drifting isometric plane carried over from
         HeroConstellation3D (753bbc6), softened (21° vs 26°) so the art stays
         readable; mobile gets the flat card. The poster is the LCP image
         (eager + fetchpriority), so the swap keeps the hero's paint timing. -->
    <div class="hero3d-stage relative lg:pl-2">
      <div class="hero3d-plane of-surface relative overflow-hidden rounded-3xl p-2 shadow-[0_32px_90px_-58px_oklch(0.18_0.08_260/0.62)]">
        <Image
          src={heroImage}
          alt="Orionfold Proof poster: a signed receipt rising from a MacBook on a working desk into the Orion constellation."
          widths={[640, 960, 1280]}
          sizes="(min-width: 1024px) 54vw, calc(100vw - 3rem)"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          data-no-zoom
          class="block aspect-[16/9] w-full rounded-[1.25rem] object-cover"
        />
        <!-- The chip clicks through to the Orionfold Proof product page (the
             single CTA the hero drives toward). -->
        <a
          href="/proof/#get-proof"
          class="group absolute bottom-5 left-5 z-10 inline-flex items-center gap-1.5 rounded-full border border-white/20 bg-[oklch(0.18_0.06_260/0.62)] px-3.5 py-1.5 font-mono text-xs tracking-[0.04em] text-white backdrop-blur-md transition-colors duration-300 hover:border-white/40 hover:bg-[oklch(0.22_0.07_260/0.75)]"
        >
          Get Orionfold Proof
          <span class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Desktop-only isometric drift. Transform animates on ONE element so the
     compositor owns the loop (no main-thread paint); the LCP image inside
     still paints immediately. Mobile keeps the flat card, same as the old
     constellation hero's desktop/mobile split. */
  @media (min-width: 1024px) {
    .hero3d-stage {
      perspective: 1500px;
    }
    .hero3d-plane {
      transform: rotateX(21deg) rotateZ(-4deg) scale(0.94);
      animation: hero3d-drift 14s ease-in-out infinite alternate;
      will-change: transform;
    }
    @keyframes hero3d-drift {
      from { transform: rotateX(21deg) rotateZ(-4deg) scale(0.94); }
      to   { transform: rotateX(27deg) rotateZ(3deg) scale(0.98); }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero3d-plane {
      animation: none;
    }
  }
</style>
