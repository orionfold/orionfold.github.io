---
// Homepage hero (company-router rebuild, 2026-07-03). Left: the company promise
// ("Get an AI team without hiring one") + a plain company paragraph + a Relay-led
// CTA stack (Relay primary, demo text link). Right: the hero
// product UI on a restrained floating plane. The homepage no longer sells Proof
// from the hero; it routes to the product that matches each visitor's question,
// with Relay led for the $10K paid-test window. The newsletter form lives on
// Story (H3).
import relayShots from '../../data/relay-shots.json';
import { themedShotProps } from '../relay/themed-shot.logic.mjs';

const relayHeroShot = themedShotProps(relayShots, {
  id: 'agents-list',
  alt: 'Orionfold Relay Agents library showing the AI teammates available to run specialized work.',
});
---
<section class="home-hero relative overflow-x-clip">
  <!-- The Relay Host section's blueprint field becomes the homepage stage: one
       technical surface, one cyan action color, and localized light around the
       two things a visitor can act on. -->
  <div class="home-hero__blueprint pointer-events-none absolute inset-0" aria-hidden="true"></div>
  <div class="home-hero__glow home-hero__glow--cta" aria-hidden="true"></div>
  <div class="home-hero__glow home-hero__glow--shot" aria-hidden="true"></div>

  <!-- Bottom gradient fade into the narrative -->
  <div class="pointer-events-none absolute bottom-0 left-0 right-0 z-10 h-32" style="background: linear-gradient(to bottom, transparent, var(--color-surface));"></div>

  <div class="relative z-20 mx-auto grid max-w-[90rem] items-center gap-12 px-6 pb-20 pt-24 sm:pt-28 lg:min-h-[calc(100dvh-120px)] lg:grid-cols-[0.72fr_1.28fr] lg:gap-10 lg:pb-20 lg:pt-28">
    <!-- Left: the pitch. The pitch column used to stagger-reveal via [data-animate]
         + IntersectionObserver, but that made the subtitle P the page's LCP element
         at ~7.5s on mobile (Lighthouse won't count an opacity:0 element as painted).
         Painting the pitch immediately is the bigger UX win than the stagger polish. -->
    <div class="relative z-10 text-center lg:text-left">
      <p class="mx-auto mb-6 max-w-[18rem] text-wrap font-mono text-[11px] uppercase leading-relaxed tracking-[0.18em] text-[#79e8e4]/80 lg:mx-0 lg:max-w-none lg:text-xs">
        Private AI you own, on your own machine
      </p>

      <h1 class="mx-auto max-w-[21rem] font-display text-[2.45rem] font-bold leading-[1.08] tracking-[-0.035em] text-white sm:max-w-2xl sm:text-6xl lg:mx-0 lg:max-w-none lg:text-[clamp(2.75rem,4vw,4.15rem)]">
        <span class="sm:whitespace-nowrap">Get an <span class="text-[#38e2de]">AI team</span></span><br /><span class="sm:whitespace-nowrap">without hiring one.</span>
      </h1>

      <p class="mx-auto mt-6 max-w-[22rem] text-balance text-base leading-relaxed text-white/65 sm:max-w-xl sm:text-lg lg:mx-0">
        Orionfold takes the AI scattered across your work and runs it through one path you own, see, test, and approve. Agents that do the real work, models that know your field, and tests that prove it. All on your own machine.
      </p>

      <!-- Relay stays the single action in the pitch column. The demo moves onto
           the product shot so it becomes a quiet fallback after the visitor has
           considered the main CTA instead of competing with it. -->
      <div class="mx-auto mt-9 flex w-full max-w-[24rem] flex-col items-stretch lg:mx-0">
        <a
          href="/relay/"
          class="home-hero__cta of-primary-action group w-full flex-col !items-start justify-center gap-0.5 !rounded-xl !py-3.5"
        >
          <span class="font-mono text-[0.62rem] uppercase tracking-[0.18em] opacity-80">Control AI team</span>
          <span class="flex items-center gap-1.5 font-display text-lg font-bold tracking-normal normal-case">
            Get Orionfold Relay
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      </div>

    </div>

    <!-- Right: the current Agents library gets the larger cinematic product frame
         already proven by Relay Host. It stays dark in either site theme so the
         blueprint canvas, cyan glows and high-fidelity UI read as one scene. -->
    <a
      href="/relay/demo/"
      class="home-hero-shot group relative block min-w-0"
      aria-label="View the interactive Orionfold Relay demo"
    >
      <div class="home-hero-shot__frame">
        <div class="home-hero-shot__bar" aria-hidden="true">
          <span class="home-hero-shot__dot bg-[#ff5f57]"></span>
          <span class="home-hero-shot__dot bg-[#febc2e]"></span>
          <span class="home-hero-shot__dot bg-[#28c840]"></span>
          <span class="home-hero-shot__tab">orionfold relay · agents</span>
          <span class="home-hero-shot__live"><span class="home-hero-shot__livedot"></span>RELAY</span>
        </div>
        <div class="home-hero-shot__view">
          <img
            class="absolute inset-0 block h-full w-full object-cover object-top"
            width={relayHeroShot.width}
            height={relayHeroShot.height}
            alt={relayHeroShot.alt}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            src={relayHeroShot.dark.src}
            srcset={relayHeroShot.dark.srcset}
            sizes="(min-width: 1280px) 850px, (min-width: 1024px) 61vw, calc(100vw - 3rem)"
            data-no-zoom
          />
          <span class="home-hero-shot__sheen" aria-hidden="true"></span>
        </div>

      </div>
      <span class="home-hero-shot__demo-link mt-4 flex items-center justify-end gap-1.5 font-mono text-xs font-semibold tracking-[0.04em] text-[#79e8e4]/80 transition-colors group-hover:text-[#79e8e4]">
        View the interactive demo
        <span class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">&rarr;</span>
      </span>
    </a>
  </div>
</section>

<style>
  .home-hero {
    isolation: isolate;
    border-bottom: 1px solid rgb(77 222 219 / 0.22);
    background: #061117;
  }

  .home-hero__blueprint {
    background:
      linear-gradient(rgb(39 213 210 / 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgb(39 213 210 / 0.055) 1px, transparent 1px);
    background-size: 42px 42px;
  }

  .home-hero__glow {
    position: absolute;
    border-radius: 999px;
    background: rgb(23 210 205 / 0.12);
    filter: blur(100px);
    pointer-events: none;
  }

  .home-hero__glow--cta {
    bottom: 8%;
    left: -8rem;
    width: 30rem;
    height: 20rem;
  }

  .home-hero__glow--shot {
    top: 12%;
    right: -7rem;
    width: 44rem;
    height: 34rem;
  }

  .home-hero__cta {
    background: #2ad6d2;
    color: #03201f;
    box-shadow: 0 22px 52px -28px rgb(42 214 210 / 0.9), 0 0 0 1px rgb(101 241 237 / 0.18);
  }

  .home-hero__cta:hover {
    background: #4ce3df;
    box-shadow: 0 26px 58px -28px rgb(42 214 210 / 1), 0 0 0 4px rgb(42 214 210 / 0.12);
  }

  .home-hero-shot {
    width: 100%;
    animation: home-hero-shot-float 8s ease-in-out infinite;
    will-change: transform;
  }

  .home-hero-shot::after {
    content: '';
    position: absolute;
    inset: -3.5rem;
    z-index: -1;
    background: radial-gradient(ellipse at center, rgb(33 211 208 / 0.18), transparent 68%);
    pointer-events: none;
  }

  .home-hero-shot__frame {
    position: relative;
    overflow: hidden;
    border: 1px solid rgb(96 221 219 / 0.48);
    border-radius: 0.9rem;
    background: #071219;
    box-shadow: 0 38px 82px -30px rgb(0 0 0 / 0.92), 0 0 0 1px rgb(66 232 228 / 0.12);
    transform: perspective(1400px) rotateY(-1.6deg) rotateX(0.8deg);
    transition: transform 400ms ease, box-shadow 400ms ease;
  }

  .home-hero-shot:hover .home-hero-shot__frame {
    transform: perspective(1400px) rotateY(0) rotateX(0) translateY(-3px);
    box-shadow: 0 48px 92px -30px rgb(0 0 0 / 0.96), 0 0 0 1px rgb(74 238 234 / 0.42);
  }

  .home-hero-shot:focus-visible {
    border-radius: 0.9rem;
    outline: 2px solid #6ff0ed;
    outline-offset: 4px;
  }

  .home-hero-shot__bar {
    display: flex;
    align-items: center;
    gap: 0.38rem;
    min-width: 0;
    border-bottom: 1px solid rgb(71 112 120 / 0.42);
    background: #09171e;
    padding: 0.62rem 0.8rem;
  }

  .home-hero-shot__dot {
    width: 0.55rem;
    height: 0.55rem;
    flex: none;
    border-radius: 999px;
  }

  .home-hero-shot__tab {
    min-width: 0;
    overflow: hidden;
    margin-left: 0.45rem;
    color: rgb(220 239 241 / 0.58);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .home-hero-shot__live {
    display: inline-flex;
    flex: none;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
    color: #4de7e3;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
  }

  .home-hero-shot__livedot {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: #32dcd8;
    animation: home-hero-live 2.2s ease-in-out infinite;
  }

  .home-hero-shot__view {
    position: relative;
    aspect-ratio: 1.31 / 1;
    overflow: hidden;
  }

  .home-hero-shot__sheen {
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 38%, rgb(202 255 253 / 0.1) 50%, transparent 62%);
    transform: translateX(-130%);
    animation: home-hero-sheen 10s ease-in-out 2.5s infinite;
    pointer-events: none;
  }

  @keyframes home-hero-shot-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-9px); }
  }

  @keyframes home-hero-live {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgb(50 220 216 / 0.28); }
    50% { opacity: 0.45; box-shadow: 0 0 0 4px transparent; }
  }

  @keyframes home-hero-sheen {
    0% { transform: translateX(-130%); }
    28%, 100% { transform: translateX(130%); }
  }

  @media (max-width: 639px) {
    .home-hero-shot__frame {
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-hero-shot,
    .home-hero-shot__livedot,
    .home-hero-shot__sheen {
      animation: none;
    }

    .home-hero-shot__sheen {
      display: none;
    }

    .home-hero__cta,
    .home-hero-shot__frame {
      transition: none;
    }
  }
</style>
