---
// Homepage hero ("split + constellation"). Left: the capability-ownership pitch
// and offer CTAs. Right: the trust signal — the studio's products drawn as the
// Orion constellation on a slowly drifting 3D card (HeroConstellation3D).
// It replaced the old animated poster rail (2026-06-05): zero image requests
// instead of ~21 posters rendered twice, a single GPU-only transform loop
// instead of two infinite scroll animations, every star a real inward link,
// and mobile finally gets the proof-of-shipping band the rail never gave it.
// The bottom fade carries into the narrative. The homepage newsletter form
// lives on the Story pages (H3).
import HeroConstellation from './HeroConstellation.astro';
import HeroConstellation3D from './HeroConstellation3D.astro';

const whyUs = [
  'Use cloud AI where it fits.',
  'Own the workflows, data boundaries, and evals where it matters.',
];
---
<section class="relative overflow-x-clip">
  <!-- Dual atmospheric glow, weighted toward the pitch side -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute left-[10%] top-1/2 h-[700px] w-[700px] -translate-y-1/2 rounded-full bg-primary/[0.10] blur-[180px]"></div>
    <div class="absolute left-[20%] top-1/3 h-[380px] w-[380px] rounded-full bg-primary/[0.14] blur-[100px]"></div>
  </div>

  <!-- Bottom gradient fade into the narrative -->
  <div class="pointer-events-none absolute bottom-0 left-0 right-0 z-10 h-32" style="background: linear-gradient(to bottom, transparent, var(--color-surface));"></div>

  <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 pb-16 pt-28 sm:pt-32 lg:min-h-[calc(100dvh-150px)] lg:grid-cols-[1.05fr_0.95fr] lg:gap-16 lg:pb-20">
    <!-- Left: the pitch. The pitch column used to stagger-reveal via [data-animate]
         + IntersectionObserver, but that made the subtitle P the page's LCP element
         at ~7.5s on mobile (Lighthouse won't count an opacity:0 element as painted).
         Painting the pitch immediately is the bigger UX win than the stagger polish. -->
    <div class="relative z-10 text-center lg:text-left">
      <p class="mx-auto mb-6 max-w-[18rem] text-wrap font-mono text-[11px] uppercase leading-relaxed tracking-[0.18em] text-text-muted lg:mx-0 lg:max-w-none lg:text-xs">
        Private AI capability for small teams
      </p>

      <h1 class="hero-gradient-text mx-auto max-w-[21rem] text-balance font-display text-[2.45rem] font-bold leading-[1.08] sm:max-w-2xl sm:text-6xl lg:mx-0 lg:max-w-none lg:text-[clamp(3.5rem,5.4vw,5.6rem)]">
        Own the AI skills your company needs before you can hire the team.
      </h1>

      <p class="mx-auto mt-6 max-w-[22rem] text-balance text-base leading-relaxed text-text-muted sm:max-w-xl sm:text-lg lg:mx-0">
        Orionfold packages private agents, domain models, benchmarks, and playbooks that run on customer-controlled hardware.
      </p>

      <div class="mt-9 flex flex-col items-center gap-3 sm:flex-row sm:justify-center lg:justify-start">
        <a
          href="/workflows/"
          class="group inline-flex items-center gap-2 rounded-lg bg-primary px-7 py-3.5 font-mono text-sm font-semibold tracking-wider text-white transition-colors hover:bg-primary/90"
        >
          Run a private workflow
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href="/domain-packs/"
          class="inline-flex items-center gap-2 rounded-lg border border-primary/30 px-7 py-3.5 font-mono text-sm font-semibold tracking-wider text-primary transition-colors hover:border-primary/50 hover:bg-primary/5"
        >
          Explore domain packs
        </a>
        <a
          href="/workbench/"
          class="inline-flex items-center gap-2 py-3.5 font-mono text-sm font-semibold tracking-wider text-primary transition-colors hover:underline"
        >
          Open the Workbench
        </a>
      </div>

      <p class="mx-auto mt-8 max-w-[20rem] font-mono text-[11px] leading-relaxed tracking-wider text-primary lg:mx-0 lg:max-w-lg">
        {whyUs.map((line) => <span class="block">{line}</span>)}
      </p>
    </div>

    <!-- Right: the hero visual — the studio's products drawn as the Orion
         constellation on a slowly drifting 3D card (replaced the poster rail:
         zero images, GPU-only animation, every star a real link). Mobile gets
         a flat compact band below the pitch instead of the tilted card. -->
    <div class="relative hidden h-[calc(100dvh-80px)] max-h-[760px] lg:block">
      <HeroConstellation3D />
    </div>
    <div class="relative h-[26rem] lg:hidden">
      <HeroConstellation compact />
    </div>
  </div>
</section>
