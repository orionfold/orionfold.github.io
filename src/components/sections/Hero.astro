---
// Homepage hero ("split + constellation"). Left: the capability-ownership pitch
// and offer CTAs. Right: a quieter enterprise mission panel that turns the
// constellation motif into trust, control, and evaluation signals. The homepage
// newsletter form lives on the Story pages (H3).
import { Image } from 'astro:assets';
import heroImage from '../../assets/home/orionfold-hero-gemini.jpeg';
---
<section class="relative overflow-x-clip">
  <!-- Soft atmospheric light, kept below the operational surfaces. -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute left-[8%] top-1/2 h-[640px] w-[640px] -translate-y-1/2 rounded-full bg-primary/[0.08] blur-[170px]"></div>
    <div class="absolute right-[4%] top-[18%] h-[420px] w-[420px] rounded-full bg-[oklch(0.70_0.14_82/0.10)] blur-[120px]"></div>
  </div>

  <!-- Bottom gradient fade into the narrative -->
  <div class="pointer-events-none absolute bottom-0 left-0 right-0 z-10 h-32" style="background: linear-gradient(to bottom, transparent, var(--color-surface));"></div>

  <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 pb-16 pt-24 sm:pt-28 lg:min-h-[calc(100dvh-120px)] lg:grid-cols-[0.95fr_1.05fr] lg:gap-12 lg:pb-16 lg:pt-24">
    <!-- Left: the pitch. The pitch column used to stagger-reveal via [data-animate]
         + IntersectionObserver, but that made the subtitle P the page's LCP element
         at ~7.5s on mobile (Lighthouse won't count an opacity:0 element as painted).
         Painting the pitch immediately is the bigger UX win than the stagger polish. -->
    <div class="relative z-10 text-center lg:text-left">
      <p class="mx-auto mb-6 max-w-[18rem] text-wrap font-mono text-[11px] uppercase leading-relaxed tracking-[0.18em] text-text-muted lg:mx-0 lg:max-w-none lg:text-xs">
        Enterprise AI capability for small teams
      </p>

      <h1 class="hero-gradient-text mx-auto max-w-[21rem] text-balance font-display text-[2.45rem] font-bold leading-[1.08] sm:max-w-2xl sm:text-6xl lg:mx-0 lg:max-w-none lg:text-[clamp(2.9rem,4.2vw,4.2rem)]">
        Own the AI skills your company needs before you can hire the team.
      </h1>

      <p class="mx-auto mt-6 max-w-[22rem] text-balance text-base leading-relaxed text-text-muted sm:max-w-xl sm:text-lg lg:mx-0">
        Orionfold packages private agents, domain models, evaluations, and playbooks for teams that need AI capability with clear ownership.
      </p>

      <div class="mx-auto mt-9 flex w-full max-w-[24rem] flex-col items-stretch gap-3 lg:mx-0">
        <a
          href="/workflows/"
          class="of-primary-action group w-full justify-center !text-sm sm:!text-base"
        >
          Run a private workflow
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href="/workbench/"
          class="of-secondary-action w-full justify-center !text-sm sm:!text-base"
        >
          Open the Workbench
        </a>
      </div>

    </div>

    <!-- Right: generated Orionfold hero image, optimized through Astro. -->
    <div class="relative lg:pl-2">
      <div class="of-surface overflow-hidden rounded-3xl p-2 shadow-[0_32px_90px_-58px_oklch(0.18_0.08_260/0.62)]">
        <Image
          src={heroImage}
          alt="Illustration of a founder at a desk projecting an Orion constellation workflow from a small private AI device."
          widths={[640, 960, 1280]}
          sizes="(min-width: 1024px) 54vw, calc(100vw - 3rem)"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          data-no-zoom
          class="block aspect-[16/9] w-full rounded-[1.25rem] object-cover"
        />
      </div>
    </div>
  </div>
</section>
