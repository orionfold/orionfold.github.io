---
// Homepage highlights (spec §5.4–5.6): curated picks that deep-link straight to
// their on-site detail page instead of the listing page, fixing the "click a
// product, get a catalog" leak (spec §3).
// 2026-06-13 (IA refocus): the flagship Arena Highlight was REMOVED — Arena now
// leads via the hero + the Field Edition band above.
// 2026-06-13 (payload pass): the "The software / Orionfold Advisor" and
// "The models / Patent Strategist" highlights were REMOVED too — each rendered a
// ~880px movie-poster on first load, and product discovery is already carried by
// the CatalogShelf doorway + the /software and /models listing pages below.
// 2026-06-22: the CapabilityProof "Inspectable proof" slot was removed from the
// homepage. What remains: the book highlight. The <slot/> stays for reuse.
import Highlight from '../ui/Highlight.astro';
import BookCover from '../ui/BookCover.astro';
import nativeBusinessCover from '../../assets/book/ai-native-business-book.jpg';
---
<!-- ── Highlight: the book ── -->
<Highlight
  eyebrow="The book"
  title="AI Native Business"
  body="A book on running a business with AI agents (software helpers that do the work for you). Fourteen short chapters in four parts take you from the first idea to a working system. About a two hour read, open to all."
  pills={['14 chapters', '4 parts', '~2h read']}
  href="/books/ai-native-business/"
  ctaText="Explore the book"
  reverse
>
  <a slot="media" href="/books/ai-native-business/" aria-label="Explore the book" class="block">
    <BookCover title="AI Native Business" subtitle="Build with AI agents." tag="Open" image={nativeBusinessCover} />
  </a>
</Highlight>

<slot />
