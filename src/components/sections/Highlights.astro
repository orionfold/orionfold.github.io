---
// Homepage highlights (spec §5.4–5.6): one curated pick from each pillar —
// the book, the software, a model — each linking to its showcase page (built
// in S6–S8, routes already stubbed). Layout sides alternate via Highlight's
// `reverse`. Visuals are placeholders (real artwork is a later spec); they're
// CSS-only and aria-hidden so they add texture without misleading a reader.
import Highlight from '../ui/Highlight.astro';
---
<!-- ── Highlight: the book ── -->
<Highlight
  eyebrow="The book"
  title="AI Native Business"
  body="A free book on running a business with AI agents (software helpers that do the work for you). Fourteen short chapters, about a two hour read."
  pills={['14 chapters', '4 parts', '~2h read', 'Free to read']}
  href="/books/"
  ctaText="See the book"
>
  <div slot="media" data-animate class="relative mx-auto w-[220px] sm:w-[250px]">
    <div class="absolute -inset-10 -z-10 rounded-full bg-primary/[0.10] blur-[90px]"></div>
    <div
      class="relative flex aspect-[2/3] flex-col justify-between overflow-hidden rounded-l-sm rounded-r-lg border border-border bg-surface-raised p-6 shadow-2xl shadow-primary/10"
      style="transform: perspective(900px) rotateY(-6deg) rotateX(2deg);"
      aria-hidden="true"
    >
      <span class="absolute inset-y-0 left-0 w-1.5 bg-primary/70"></span>
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-text-muted">Orionfold</span>
      <div>
        <div class="font-display text-2xl font-bold leading-tight">AI Native Business</div>
        <p class="mt-2 text-xs leading-relaxed text-text-muted">Build with AI agents.</p>
      </div>
      <span class="font-mono text-[10px] tracking-wider text-primary">Free · open</span>
    </div>
  </div>
</Highlight>

<!-- ── Highlight: the software ── -->
<Highlight
  eyebrow="The software"
  title="AI Native Platform"
  body="Run AI agents on your own computer. Hand them tasks, set schedules, watch the work, and track what it costs. One place, no cloud needed."
  pills={['Runs local', 'Open', 'Agents', 'Workflows']}
  href="/software/"
  ctaText="See the software"
  reverse
>
  <div slot="media" data-animate class="relative mx-auto w-full max-w-md">
    <div class="absolute -inset-10 -z-10 rounded-full bg-primary/[0.08] blur-[90px]"></div>
    <div class="overflow-hidden rounded-xl border border-border bg-surface-raised shadow-2xl shadow-primary/10" aria-hidden="true">
      <!-- title bar -->
      <div class="flex items-center gap-2 border-b border-border px-4 py-3">
        <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
        <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
        <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
      </div>
      <!-- skeleton workspace -->
      <div class="flex gap-4 p-5">
        <div class="hidden w-28 shrink-0 flex-col gap-2 sm:flex">
          <span class="h-2.5 w-full rounded bg-primary/20"></span>
          <span class="h-2.5 w-3/4 rounded bg-border"></span>
          <span class="h-2.5 w-5/6 rounded bg-border"></span>
          <span class="h-2.5 w-2/3 rounded bg-border"></span>
        </div>
        <div class="flex flex-1 flex-col gap-3">
          <div class="flex items-center gap-2 rounded-lg border border-primary/20 bg-primary/[0.04] px-3 py-2">
            <span class="h-2 w-2 rounded-full bg-success"></span>
            <span class="font-mono text-[11px] text-text-muted">task running…</span>
          </div>
          <span class="h-2.5 w-full rounded bg-border"></span>
          <span class="h-2.5 w-11/12 rounded bg-border"></span>
          <span class="h-2.5 w-4/5 rounded bg-border"></span>
          <span class="h-2.5 w-2/3 rounded bg-border"></span>
        </div>
      </div>
    </div>
  </div>
</Highlight>

<!-- ── Highlight: a model ── -->
<Highlight
  eyebrow="The models"
  title="Patent Strategist"
  body="An AI built to reason about patents (legal cover for inventions). It runs fully offline on a small desktop, so your ideas and filings never leave the room."
  pills={['Patents', 'Runs offline', 'Open weights']}
  href="/models/"
  ctaText="See the models"
>
  <div slot="media" data-animate class="relative mx-auto w-full max-w-md">
    <div class="absolute -inset-10 -z-10 rounded-full bg-primary/[0.08] blur-[90px]"></div>
    <div class="overflow-hidden rounded-xl border border-border bg-surface-raised shadow-2xl shadow-primary/10" aria-hidden="true">
      <div class="flex items-center gap-2 border-b border-border px-4 py-3">
        <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
        <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
        <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
        <span class="ml-2 font-mono text-[10px] tracking-wider text-text-muted">patent-strategist</span>
      </div>
      <div class="space-y-2 p-5 font-mono text-[12px] leading-relaxed">
        <p class="text-text-muted"><span class="text-primary">$</span> run --offline</p>
        <p class="text-text-muted">reading claim 1 of 12…</p>
        <p class="text-text-muted">prior art found: 3 close matches</p>
        <p class="text-success">ok · answered on this desktop</p>
      </div>
    </div>
  </div>
</Highlight>
