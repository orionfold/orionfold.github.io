---
// ProofLoopFlow — the "How it works" loop as one animated line, replacing the
// cramped 3-up screenshot thumbnails. Same metro-line idiom as the homepage
// CapabilitySystemMap (track + moving dash overlay, icon stations ON the line,
// data-animate reveal, reduced-motion safe) so /proof/ reads as the same product
// family. Themed to the proof loop: Configure -> Run -> Decide, with proof-only
// motion the static screenshots could never show -- rows streaming through the
// Run station, a receipt "stamping" at Decide, and a pass tick landing.
//
// Decorative SVG carries the motion; the <ol> stations carry the semantics
// (screen-reader path). Horizontal on desktop, vertical-stacked on mobile, the
// same responsive flip as the metro line. Voice grade 3-5, em-dash-free
// (website-copy-style).
const stations = [
  {
    label: 'Configure',
    detail: 'task + candidates',
    icon: 'configure',
    body: 'Point Proof at your own task. Pick the models or setups you are weighing, local or cloud, and the rubric to score them by.',
  },
  {
    label: 'Run',
    detail: 'local, row by row',
    icon: 'run',
    body: 'Proof runs every candidate on your machine, row by row, with a live rail showing the host, the runtime, and the result as it lands. Nothing leaves your desk.',
  },
  {
    label: 'Decide',
    detail: 'a signed receipt',
    icon: 'decide',
    body: 'You get a clear winner, a leaderboard with cost and speed, the failures laid out, and a signed receipt you can rerun any time.',
  },
];
---
<div class="loop-wrap">
  <div data-animate class="loop-panel">
    <!-- The flow line. Track + animated dash; horizontal desktop, vertical mobile.
         Decorative — the station list below carries the semantics. -->
    <svg class="loop-line loop-line-h" aria-hidden="true">
      <line x1="0" y1="50%" x2="100%" y2="50%" class="loop-track" />
      <line x1="0" y1="50%" x2="100%" y2="50%" class="loop-dash" />
    </svg>
    <svg class="loop-line loop-line-v" aria-hidden="true">
      <line x1="50%" y1="0" x2="50%" y2="100%" class="loop-track" />
      <line x1="50%" y1="0" x2="50%" y2="100%" class="loop-dash" />
    </svg>

    <ol class="loop-stations" aria-label="How Orionfold Proof works: configure, run, decide">
      {stations.map((s, i) => (
        <li class="loop-station">
          <span class="loop-dot" data-icon={s.icon}>
            <!-- Configure: sliders -->
            {s.icon === 'configure' && (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 7h10 M18 7h2 M4 12h2 M10 12h10 M4 17h7 M15 17h5" />
                <circle cx="16" cy="7" r="2.1" />
                <circle cx="8" cy="12" r="2.1" />
                <circle cx="13" cy="17" r="2.1" />
              </svg>
            )}
            <!-- Run: animated streaming rows filling in -->
            {s.icon === 'run' && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="run-icon">
                <rect x="4" y="5" width="16" height="2.4" rx="1.2" class="run-row run-row-1" />
                <rect x="4" y="10.8" width="16" height="2.4" rx="1.2" class="run-row run-row-2" />
                <rect x="4" y="16.6" width="16" height="2.4" rx="1.2" class="run-row run-row-3" />
              </svg>
            )}
            <!-- Decide: a receipt with a pass tick that lands -->
            {s.icon === 'decide' && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="decide-icon">
                <path d="M6 3h9l3 3v15l-2.2-1.4L13.6 21l-2.2-1.4L9.2 21 7 19.6 4 21V6z" class="decide-receipt" />
                <path d="M8.5 12.5l2.3 2.3 4.7-5" class="decide-tick" />
              </svg>
            )}
          </span>
          <span class="loop-step">Step {i + 1}</span>
          <span class="loop-label">{s.label}</span>
          <span class="loop-detail">{s.detail}</span>
          <span class="loop-body">{s.body}</span>
        </li>
      ))}
    </ol>
  </div>
</div>

<style>
  .loop-wrap { margin-top: 1.5rem; }

  .loop-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    background: linear-gradient(180deg, var(--color-surface-raised), var(--color-surface));
    box-shadow: var(--shadow-of-pop);
    padding: 1.75rem 1.25rem;
  }

  /* ── the flowing line (identical engine to the homepage metro line) ── */
  .loop-line { position: absolute; pointer-events: none; }
  .loop-track {
    stroke: color-mix(in oklch, var(--color-primary) 22%, var(--color-border));
    stroke-width: 5;
  }
  .loop-dash {
    stroke: var(--color-primary);
    stroke-width: 2.2;
    stroke-opacity: 0.85;
    stroke-dasharray: 7 6;
    animation: loop-dash-move 1.4s linear infinite;
  }
  @keyframes loop-dash-move { to { stroke-dashoffset: -26; } }

  /* ── stations ── */
  .loop-stations {
    position: relative;
    z-index: 1;
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .loop-station {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-areas:
      'dot step'
      'dot label'
      'dot detail'
      'body body';
    column-gap: 1rem;
    row-gap: 0.1rem;
    align-items: center;
  }
  .loop-dot {
    grid-area: dot;
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    border: 3px solid var(--color-primary);
    background: var(--color-surface-raised);
    box-shadow: 0 0 0 5px color-mix(in oklch, var(--color-primary) 13%, transparent);
  }
  .loop-dot svg {
    width: 1.5rem;
    height: 1.5rem;
    fill: none;
    stroke: var(--color-primary);
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .loop-step {
    grid-area: step;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
  }
  .loop-label {
    grid-area: label;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .loop-detail {
    grid-area: detail;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .loop-body {
    grid-area: body;
    margin-top: 0.6rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }

  /* ── Run: rows stream in (fill left-to-right, staggered) ── */
  .run-row {
    fill: var(--color-primary);
    transform-box: fill-box;
    transform-origin: left center;
    animation: run-fill 2.1s ease-in-out infinite;
  }
  .run-row-1 { animation-delay: 0s; }
  .run-row-2 { animation-delay: 0.32s; }
  .run-row-3 { animation-delay: 0.64s; }
  @keyframes run-fill {
    0%, 12% { transform: scaleX(0); opacity: 0.35; }
    40%, 72% { transform: scaleX(1); opacity: 1; }
    92%, 100% { transform: scaleX(0); opacity: 0.35; }
  }

  /* ── Decide: the receipt sits, the pass tick draws on ── */
  .decide-receipt { stroke: var(--color-primary); }
  .decide-tick {
    stroke: var(--color-primary);
    stroke-width: 2.4;
    stroke-dasharray: 14;
    stroke-dashoffset: 14;
    animation: decide-stamp 2.4s ease-in-out infinite;
  }
  @keyframes decide-stamp {
    0%, 30% { stroke-dashoffset: 14; }
    55%, 88% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: 14; }
  }

  @media (prefers-reduced-motion: reduce) {
    .loop-dash,
    .run-row,
    .decide-tick { animation: none; }
    /* hold the meaningful end-state when motion is off */
    .run-row { transform: scaleX(1); opacity: 1; }
    .decide-tick { stroke-dashoffset: 0; }
  }

  /* ── Mobile: vertical line down the left, stations stacked along it ── */
  .loop-line-h { display: none; }
  .loop-line-v {
    left: 2.75rem;
    top: 1.75rem;
    bottom: 1.75rem;
    width: 12px;
    height: calc(100% - 3.5rem);
  }

  /* ── Desktop: horizontal line, three stations across ── */
  @media (min-width: 768px) {
    .loop-panel { padding: 2.5rem 2rem 2.25rem; }
    .loop-line-v { display: none; }
    .loop-line-h {
      display: block;
      left: 0;
      top: 4.25rem;        /* runs through the dot centers */
      width: 100%;
      height: 12px;
    }
    .loop-stations {
      flex-direction: row;
      gap: 1.5rem;
      align-items: start;
    }
    .loop-station {
      flex: 1;
      grid-template-columns: 1fr;
      grid-template-areas:
        'dot'
        'step'
        'label'
        'detail'
        'body';
      justify-items: center;
      text-align: center;
      row-gap: 0.18rem;
    }
    .loop-step { margin-top: 0.6rem; }
    .loop-body { margin-top: 0.7rem; max-width: 22rem; }
  }
</style>
