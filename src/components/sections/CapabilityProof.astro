---
const proof = [
  { eyebrow: 'Cockpit', title: 'Arena, Cortex, and fieldkit make the stack inspectable.', href: '/cockpit/' },
  { eyebrow: 'Field lab', title: 'NVIDIA DGX Spark is the reference machine behind the local stack.', href: '/dgx-spark/' },
  { eyebrow: 'Playbooks', title: 'Books and field notes turn the implementation into a repeatable path.', href: '/learn/' },
];
---
<section class="px-6 pb-20 pt-10">
  <div class="mx-auto max-w-6xl">
    <div class="mb-6 flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">Inspectable proof</p>
        <h2 class="mt-2 text-3xl sm:text-4xl">Proof that the stack is real.</h2>
      </div>
      <p class="max-w-md text-sm leading-relaxed text-text-muted">
        The Cockpit, Spark field lab, and playbooks make Orionfold visible as running software, local infrastructure, and repeatable operating knowledge.
      </p>
    </div>
    <div data-animate-stagger class="grid gap-4 lg:grid-cols-3">
      {proof.map((item) => (
        <a data-animate href={item.href} class="of-surface of-pressable rounded-2xl p-6">
          <span class="of-chip w-fit">{item.eyebrow}</span>
          <h3 class="mt-3 text-2xl leading-tight">{item.title}</h3>
          <span class="of-text-action of-compact mt-5 text-xs">Explore →</span>
        </a>
      ))}
    </div>
  </div>
</section>
