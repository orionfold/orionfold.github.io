---
// CapabilitySystemMap — "the metro line". One animated line carries the whole
// argument: scattered AI (dashed red-tinted pills straddling the line, the
// problem state) enters one controlled path — the Orionfold product suite as
// three stations, Arena (train) -> Proof (prove) -> Relay (run) — with a green
// approval gate before Relay, and the line terminates at a raised suite card
// whose last element is the section CTA (Get Relay). Desktop draws the line
// horizontally; mobile rotates it vertical.
// Redesigned 2026-07-03 (operator review): the generic Data/Agent/Eval/Output
// stations became the real end-to-end suite flow; scattered badges retinted to
// the theme danger color; approval gate retinted to the theme success color;
// stations spaced wider so the gate never crowds a station.
//
// Sprawl jitter (rotate/shift) is hand-placed static offsets, the same idiom
// as the old hero constellation's hand-placed stars — no runtime PRNG.
const sprawl = [
  { label: 'Chat tabs', detail: 'ad hoc prompts', r: -3, x: 0 },
  { label: 'Loose scripts', detail: 'one-off glue', r: 2, x: 26 },
  { label: 'Cloud tools', detail: 'external state', r: -1, x: 6 },
  { label: 'Private files', detail: 'sensitive context', r: 3, x: 34 },
  { label: 'No evals', detail: 'unclear quality', r: -2, x: 12 },
  { label: 'Manual review', detail: 'slow approval', r: 1, x: -4 },
];

// Stations sit ON the line at hand-placed x positions (% of the stations zone).
// The three suite products ARE the controlled path: Arena trains the models,
// Proof proves which one fits the use case, Relay runs it for real. Spread wide
// (14 / 50 / 86) so the green approval gate between Proof and Relay never
// crowds a station. Labels alternate above/below so neighbors never collide.
const stages = [
  { label: 'Arena', detail: 'train models', icon: 'arena', x: 14, above: true },
  { label: 'Proof', detail: 'prove the fit', icon: 'proof', x: 50, above: false },
  { label: 'Relay', detail: 'run for real', icon: 'relay', x: 86, above: true },
];

// The terminus card = the product suite, in flow order.
const proof = [
  { label: 'Arena', value: 'Train + compare' },
  { label: 'Proof', value: 'Prove the fit' },
  { label: 'Relay', value: 'Run the work' },
];

const icons: Record<string, string> = {
  // Arena — training / dumbbell-on-target (models trained in the arena)
  arena: 'M6.5 6.5l11 11 M17.5 6.5l-11 11 M4 9v6 M20 9v6 M2 11v2 M22 11v2',
  // Proof — check-badge (proven / verified fit)
  proof: 'M12 2l2.4 1.8 3 .1 1 2.8 2.4 1.8-.9 2.9.9 2.9-2.4 1.8-1 2.8-3 .1L12 22l-2.4-1.8-3-.1-1-2.8L3.2 15.5l.9-2.9-.9-2.9 2.4-1.8 1-2.8 3-.1Z M9 12l2 2 4-4',
  // Relay — play / run the work
  relay: 'M5 3v18l15-9L5 3Z',
};
---
<section class="px-6 pb-12 pt-4 sm:pb-16">
  <div class="mx-auto max-w-6xl">
    <div class="mb-7 flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">From AI sprawl to one clear flow</p>
        <!-- Explicit break: the hook may only wrap at the sentence boundary. -->
        <h2 class="mt-2 font-display text-[2.2rem] font-extrabold leading-[1.05] text-text sm:text-5xl">
          AI everywhere.<br />Control nowhere.
        </h2>
      </div>
      <p class="max-w-md text-[0.95rem] leading-relaxed text-text-muted">
        Sound familiar? Orionfold turns the scatter into one flow. Train your models in Arena, prove which one fits your job in Proof, then run it for real in Relay. You approve before it ships.
      </p>
    </div>

    <div data-animate class="flow-panel">
      <!-- The line. Track + animated dash overlay; horizontal on desktop,
           vertical on mobile. Decorative — the zones carry the semantics. -->
      <svg class="flow-line flow-line-h" aria-hidden="true">
        <line x1="0" y1="50%" x2="100%" y2="50%" class="flow-track" />
        <line x1="0" y1="50%" x2="100%" y2="50%" class="flow-dash" />
      </svg>
      <svg class="flow-line flow-line-v" aria-hidden="true">
        <line x1="50%" y1="0" x2="50%" y2="100%" class="flow-track" />
        <line x1="50%" y1="0" x2="50%" y2="100%" class="flow-dash" />
      </svg>

      <div class="flow-grid">
        <!-- Today: the mess, loosely scattered across the line -->
        <div class="flow-sprawl">
          <p class="flow-zone-label">Today · scattered</p>
          <ul aria-label="Scattered AI tools before Orionfold">
            {sprawl.map((item) => (
              <li style={`--r:${item.r}deg; --x:${item.x}px;`}>
                <span class="sprawl-label">{item.label}</span>
                <span class="sprawl-detail">{item.detail}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- The controlled path: stations on the line, approval gate before output -->
        <div class="flow-stations">
          <p class="flow-zone-label flow-zone-label-center text-primary">One clear flow</p>
          <ol aria-label="The Orionfold suite flow: Arena trains, Proof proves, you approve, Relay runs">
            {stages.map((s) => (
              <li class:list={['station', s.above ? 'station-above' : 'station-below']} style={`--sx:${s.x}%;`}>
                <span class="station-dot">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d={icons[s.icon]} /></svg>
                </span>
                <span class="station-text">
                  <span class="station-label">{s.label}</span>
                  <span class="station-detail">{s.detail}</span>
                </span>
              </li>
            ))}
          </ol>
          <span class="approval-gate">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12l4 4L19 6" /></svg>
            Approve
          </span>
        </div>

        <!-- Terminus: the product suite in flow order, then the one CTA -->
        <div class="flow-proof">
          <p class="flow-zone-label">One suite you own</p>
          <ul aria-label="The Orionfold product suite">
            {proof.map((item) => (
              <li>
                <span class="proof-label">{item.label}</span>
                <span class="proof-value">{item.value}</span>
              </li>
            ))}
          </ul>
          <a href="/relay/" class="of-primary-action flow-cta">Get Orionfold Relay →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .flow-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    background: linear-gradient(180deg, var(--color-surface-raised), var(--color-surface));
    box-shadow: var(--shadow-of-pop);
    padding: 1.5rem 1.25rem;
  }
  .flow-line {
    position: absolute;
    pointer-events: none;
  }
  .flow-track {
    stroke: color-mix(in oklch, var(--color-primary) 22%, var(--color-border));
    stroke-width: 5;
  }
  .flow-dash {
    stroke: var(--color-primary);
    stroke-width: 2.2;
    stroke-opacity: 0.8;
    stroke-dasharray: 7 6;
    animation: flow-dash-move 1.4s linear infinite;
  }
  @keyframes flow-dash-move {
    to { stroke-dashoffset: -26; }
  }
  @media (prefers-reduced-motion: reduce) {
    .flow-dash { animation: none; }
  }

  .flow-zone-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .flow-sprawl ul,
  .flow-proof ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  /* Scattered = the problem state, tinted with the theme danger color so the
     "before" mess reads as red against the calm cyan of the controlled flow. */
  .flow-sprawl li {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    transform: rotate(var(--r)) translateX(var(--x));
    border: 1px dashed color-mix(in oklch, var(--color-danger) 45%, var(--color-border));
    border-radius: 999px;
    background: color-mix(in oklch, var(--color-danger) 10%, var(--color-surface-raised));
    padding: 0.32rem 0.75rem;
    opacity: 0.9;
  }
  .sprawl-label {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 700;
    color: color-mix(in oklch, var(--color-danger) 55%, var(--color-text));
    white-space: nowrap;
  }
  .sprawl-detail {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .station-dot {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    border: 3px solid var(--color-primary);
    background: var(--color-surface-raised);
    box-shadow: 0 0 0 4px color-mix(in oklch, var(--color-primary) 14%, transparent);
  }
  .station-dot svg {
    width: 1.05rem;
    height: 1.05rem;
    fill: none;
    stroke: var(--color-primary);
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .station-label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .station-detail {
    display: block;
    margin-top: 0.15rem;
    font-family: var(--font-mono);
    font-size: 0.53rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  /* The approval gate is the human-in-the-loop step, tinted with the theme
     success color (green) so "you approve" reads as the go signal before Relay
     runs the work for real. */
  .approval-gate {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid color-mix(in oklch, var(--color-success) 45%, var(--color-border));
    border-radius: 999px;
    background: var(--color-success-dim);
    padding: 0.4rem 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-success);
    white-space: nowrap;
  }
  .approval-gate svg {
    width: 0.85rem;
    height: 0.85rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .flow-proof {
    position: relative;
    z-index: 1; /* the card terminates the line by covering it */
    border: 1px solid color-mix(in oklch, var(--color-border) 70%, var(--color-primary) 30%);
    border-radius: 1rem;
    background: linear-gradient(135deg, var(--color-surface-raised), color-mix(in oklch, var(--color-surface-raised) 92%, var(--color-primary) 8%));
    box-shadow: var(--shadow-of-pop);
    padding: 1.1rem;
  }
  .flow-proof li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem;
    padding: 0.42rem 0;
    border-bottom: 1px solid color-mix(in oklch, var(--color-border) 60%, transparent);
  }
  .proof-label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .proof-value {
    font-family: var(--font-display);
    font-size: 0.84rem;
    font-weight: 700;
    color: var(--color-text);
    text-align: right;
  }
  .flow-cta {
    width: 100%;
    justify-content: center;
    margin-top: 1rem;
    font-size: 0.85rem !important;
  }

  /* ── Mobile: the line rotates vertical, zones stack along it ── */
  .flow-line-h { display: none; }
  .flow-line-v {
    left: 2.1rem;
    top: 1.25rem;
    bottom: 1.25rem;
    width: 12px;
    height: calc(100% - 2.5rem);
  }
  .flow-grid {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .flow-sprawl .flow-zone-label,
  .flow-stations .flow-zone-label {
    margin-bottom: 0.9rem;
    margin-left: 2.6rem;
  }
  .flow-sprawl ul {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    margin-left: 2.6rem;
  }
  .flow-sprawl li {
    /* keep the jitter feel but tame the horizontal shift on small screens */
    transform: rotate(var(--r)) translateX(calc(var(--x) / 2));
  }
  .flow-stations ol {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .station {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    /* center the dot on the vertical line: 2.1rem line center − 1.25rem panel
       padding − half a 2.2rem dot */
    margin-left: calc(2.1rem - 1.25rem - 1.1rem);
  }
  .station-text { text-align: left; }
  .approval-gate {
    margin-top: 1rem;
    margin-left: 2.6rem;
  }
  .flow-proof { margin-top: 0.25rem; }

  /* ── Desktop: horizontal metro line ── */
  @media (min-width: 1024px) {
    .flow-panel { padding: 2rem; }
    .flow-line-v { display: none; }
    .flow-line-h {
      display: block;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      /* stop under the proof card (grid col 3 starts ~75%) — the terminus
         covers the line's end; it must not re-emerge on the card's right */
      width: 80%;
      height: 12px;
    }
    .flow-grid {
      display: grid;
      grid-template-columns: 1fr 2fr 1.1fr;
      gap: 1.5rem;
      align-items: center;
    }
    .flow-sprawl,
    .flow-stations {
      position: relative;
      height: 300px;
    }
    .flow-sprawl .flow-zone-label,
    .flow-stations .flow-zone-label {
      position: absolute;
      top: 0;
      margin: 0;
    }
    .flow-sprawl .flow-zone-label { left: 0; }
    .flow-zone-label-center {
      left: 50%;
      transform: translateX(-50%);
      white-space: nowrap;
    }
    .flow-sprawl ul {
      position: absolute;
      /* nudged past center so the jittered first pill clears the zone label */
      top: calc(50% + 12px);
      left: 0;
      transform: translateY(-50%);
      margin-left: 0;
      gap: 0.45rem;
    }
    .flow-sprawl li {
      transform: rotate(var(--r)) translateX(var(--x));
    }
    .flow-stations ol {
      position: absolute;
      inset: 0;
      display: block;
    }
    .station {
      position: absolute;
      left: var(--sx);
      top: 50%;
      transform: translate(-50%, -50%);
      display: block;
      margin-left: 0;
    }
    .station-dot { margin: 0 auto; }
    .station-text {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      text-align: center;
      white-space: nowrap;
    }
    .station-above .station-text { bottom: calc(100% + 0.55rem); }
    .station-below .station-text { top: calc(100% + 0.55rem); }
    .approval-gate {
      position: absolute;
      /* centered in the Proof(50%)->Relay(86%) gap so it never crowds a station,
         and lifted ABOVE the animating pipeline (with padding) so it floats off
         the line as the human-in-the-loop step rather than sitting on it */
      left: 68%;
      top: calc(50% - 2.4rem);
      transform: translate(-50%, -50%);
      margin: 0;
    }
    /* thin connector pointing the floating gate toward the pipeline it gates;
       it stops just short of the line (a small gap) rather than crossing it */
    .approval-gate::after {
      content: '';
      position: absolute;
      top: 100%;
      left: 50%;
      width: 2px;
      height: 0.95rem;
      transform: translateX(-50%);
      background: color-mix(in oklch, var(--color-success) 55%, transparent);
    }
    .flow-proof { align-self: center; }
  }
</style>
