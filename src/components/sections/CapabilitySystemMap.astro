---
const before = [
  { label: 'Chat tabs', detail: 'ad hoc prompts' },
  { label: 'Loose scripts', detail: 'one-off glue' },
  { label: 'Cloud tools', detail: 'external state' },
  { label: 'Private files', detail: 'sensitive context' },
  { label: 'No evals', detail: 'unclear quality' },
  { label: 'Manual review', detail: 'slow approval' },
];

const after = [
  { label: 'Data', detail: 'Boundary' },
  { label: 'Agent', detail: 'Tools + gate' },
  { label: 'Eval', detail: 'Benchmark' },
  { label: 'Output', detail: 'Runbook' },
];

const proof = [
  { label: 'Arena', value: 'Model comparison' },
  { label: 'Cortex', value: 'Local memory' },
  { label: 'fieldkit', value: 'Reusable runs' },
];

const icons = {
  data: 'M5 6c0-1.7 3.1-3 7-3s7 1.3 7 3-3.1 3-7 3-7-1.3-7-3Z M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6 M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6',
  agent: 'M12 3v4 M12 17v4 M4.9 4.9l2.8 2.8 M16.3 16.3l2.8 2.8 M3 12h4 M17 12h4 M4.9 19.1l2.8-2.8 M16.3 7.7l2.8-2.8 M9 9h6v6H9z',
  eval: 'M5 12l4 4 10-10 M5 20h14 M5 4h14',
  output: 'M5 4h14v16H5z M8 8h8 M8 12h8 M8 16h5',
};
---
<section class="px-6 pb-12 pt-4 sm:pb-16">
  <div class="mx-auto max-w-6xl">
    <div class="mb-6 flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">From AI sprawl to operating system</p>
        <h2 class="mt-2 max-w-3xl text-3xl leading-tight sm:text-4xl">The work is not another chatbot. It is making invisible AI machinery legible.</h2>
      </div>
      <p class="max-w-md text-sm leading-relaxed text-text-muted">
        The design language follows the product: map the messy stack, route it through controlled capability, then prove it with real tools.
      </p>
    </div>

    <div class="grid gap-4 lg:grid-cols-[0.88fr_1.24fr_0.88fr]">
      <div data-animate class="of-surface rounded-2xl p-5">
        <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted">Before</p>
        <h3 class="map-card-title mt-2">Scattered AI sprawl.</h3>
        <ul class="issue-list mt-5" aria-label="Scattered tools before Orionfold">
          {before.map((item) => (
            <li>
              <span class="issue-marker" aria-hidden="true"></span>
              <span>
                <span class="issue-label">{item.label}</span>
                <span class="issue-detail">{item.detail}</span>
              </span>
            </li>
          ))}
        </ul>
      </div>

      <div data-animate class="of-surface rounded-2xl p-5">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-primary">After</p>
            <h3 class="map-card-title mt-2">Controlled capability route.</h3>
          </div>
          <span class="of-chip shrink-0">Mapped</span>
        </div>

        <div class="icon-route icon-route-after mt-5" aria-label="Orionfold controlled AI capability route">
          {after.map((item, index) => (
            <span class={`icon-node icon-node-after route-step-${index + 1}`}>
              <span class="icon-badge">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d={icons[item.label.toLowerCase()] ?? icons.output} />
                </svg>
              </span>
              <span>
                <span class="icon-node-label">{item.label}</span>
                <span class="icon-node-detail">{item.detail}</span>
              </span>
            </span>
          ))}
          <span class="approval-pill">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12l4 4L19 6" /></svg>
            Approval
          </span>
        </div>
      </div>

      <div data-animate class="of-surface rounded-2xl p-5">
        <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-primary">Proof</p>
        <h3 class="map-card-title mt-2">Real proof surfaces.</h3>
        <div class="mt-5 space-y-3">
          {proof.map((item) => (
            <div class="rounded-xl border border-border bg-surface/70 p-3">
              <p class="font-mono text-[10px] uppercase tracking-[0.16em] text-text-muted">{item.label}</p>
              <p class="mt-1 text-sm font-medium leading-snug text-text">{item.value}</p>
            </div>
          ))}
        </div>
        <a href="/workbench/" class="of-text-action of-compact mt-5 text-xs">Open the Workbench →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .map-card-title {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.65vw, 1.5rem);
    font-weight: 700;
    line-height: 1.05;
    white-space: nowrap;
  }
  .icon-route {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background:
      radial-gradient(circle at 18% 14%, oklch(0.55 0.18 260 / 0.13), transparent 12rem),
      radial-gradient(circle at 82% 86%, oklch(0.70 0.14 82 / 0.11), transparent 11rem),
      linear-gradient(180deg, color-mix(in oklch, var(--color-surface-raised) 94%, white 6%), var(--color-surface));
  }
  .issue-list {
    display: grid;
    gap: 0.65rem;
    min-height: 15rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .issue-list li {
    display: flex;
    min-height: 3.1rem;
    align-items: flex-start;
    gap: 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 0.85rem;
    background: color-mix(in oklch, var(--color-surface-raised) 84%, white 16%);
    padding: 0.72rem 0.82rem;
  }
  .issue-marker {
    margin-top: 0.42rem;
    height: 0.42rem;
    width: 0.42rem;
    flex: 0 0 auto;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-orbit-gold));
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--color-primary) 12%, transparent);
  }
  .issue-label,
  .issue-detail {
    display: block;
  }
  .issue-label {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.1;
  }
  .issue-detail {
    margin-top: 0.22rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }
  .icon-route-after {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-content: center;
    gap: 0.8rem;
    min-height: 15rem;
    padding: 1.25rem;
  }
  .icon-node {
    position: relative;
    z-index: 1;
    display: flex;
    min-height: 4.2rem;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid color-mix(in oklch, var(--color-border) 76%, var(--color-primary) 24%);
    border-radius: 0.85rem;
    background:
      linear-gradient(135deg, oklch(1 0 0 / 0.84), oklch(0.94 0.02 252 / 0.9)),
      color-mix(in oklch, var(--color-surface-raised) 82%, white 18%);
    padding: 0.75rem;
    box-shadow:
      inset 0 1px 0 oklch(1 0 0 / 0.72),
      0 18px 36px -32px oklch(0.18 0.08 260 / 0.34);
  }
  .icon-node-after {
    position: relative;
    width: auto;
    min-height: 6.6rem;
    flex-direction: column;
    justify-content: center;
    gap: 0.6rem;
    text-align: center;
  }
  .icon-badge {
    display: grid;
    height: 2.55rem;
    width: 2.55rem;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid oklch(1 0 0 / 0.48);
    border-radius: 0.75rem;
    background:
      linear-gradient(135deg, var(--color-primary), color-mix(in oklch, var(--color-primary) 54%, var(--color-orbit-gold))),
      var(--color-primary);
    color: white;
    box-shadow: 0 12px 26px -18px var(--color-primary);
  }
  .icon-badge svg {
    height: 1.15rem;
    width: 1.15rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }
  .icon-node-label,
  .icon-node-detail {
    display: block;
  }
  .icon-node-label {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.1;
  }
  .icon-node-detail {
    margin-top: 0.22rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }
  .approval-pill {
    position: relative;
    z-index: 2;
    display: inline-flex;
    grid-column: 1 / -1;
    justify-self: center;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid color-mix(in oklch, var(--color-primary) 26%, var(--color-border));
    border-radius: 999px;
    background: color-mix(in oklch, var(--color-surface-raised) 88%, white 12%);
    padding: 0.48rem 0.75rem;
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    box-shadow: inset 0 1px 0 oklch(1 0 0 / 0.72);
  }
  .approval-pill svg {
    height: 0.9rem;
    width: 0.9rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.5;
  }
  @media (max-width: 640px) {
    .issue-list {
      min-height: 0;
    }
    .icon-route-after {
      display: grid;
      gap: 0.75rem;
      min-height: 0;
    }
    .approval-pill {
      justify-content: center;
    }
  }
</style>
