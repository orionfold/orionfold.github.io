---
// Homepage stories bento (spec §5.7): the three newest Story posts in a bento
// layout — the lead story as a full-width hero (image left, text right), then
// the next two side by side. Reads the live `story` collection (S9), top 3 by
// date, linking to real /story/<slug>/ routes; cards are the shared StoryCard
// (same teaser used by the /story/ index), with the lead using its `featured`
// variant. Pure layout, no JS.
import { getCollection } from 'astro:content';
import SectionLabel from '../ui/SectionLabel.astro';
import StoryCard from '../ui/StoryCard.astro';

const stories = (await getCollection('story'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
const [lead, ...rest] = stories;
---
<section class="px-6 py-20 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-6">
      <div>
        <SectionLabel text="Story" />
        <h2 class="mt-4">From the build log.</h2>
      </div>
      <a
        href="/story/"
        class="rounded-md border border-primary/30 px-5 py-2.5 font-mono text-xs uppercase tracking-[0.15em] text-primary transition-colors hover:bg-primary/10"
      >
        All stories →
      </a>
    </div>

    {lead && (
      <StoryCard
        href={`/story/${lead.id}/`}
        title={lead.data.title}
        date={lead.data.date}
        tag={lead.data.tags[0]}
        summary={lead.data.summary}
        seed={lead.data.accent}
        cover={lead.data.hero}
        coverAlt={lead.data.heroAlt}
        featured
        animate
      />
    )}

    {rest.length > 0 && (
      <div data-animate-stagger class="mt-6 grid gap-6 sm:grid-cols-2">
        {rest.map((post) => (
          <StoryCard
            href={`/story/${post.id}/`}
            title={post.data.title}
            date={post.data.date}
            tag={post.data.tags[0]}
            summary={post.data.summary}
            seed={post.data.accent}
            cover={post.data.hero}
            coverAlt={post.data.heroAlt}
            animate
          />
        ))}
      </div>
    )}
  </div>
</section>
