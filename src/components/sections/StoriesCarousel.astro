---
// Homepage stories bento (spec §5.7): the three newest Story posts. The LEAD
// keeps the full-width featured hero (image left, text right). The next two are
// compact HORIZONTAL THUMBNAIL cards — same visual vocabulary as the end-of-
// article StoryPrevNext navigator (80px image left + eyebrow/title/summary),
// so their images ship at ~80px instead of the old ~400-640px card covers
// (2026-06-13 payload pass). Pure layout, no JS.
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import SectionLabel from '../ui/SectionLabel.astro';
import StoryCard from '../ui/StoryCard.astro';
import ConstellationCover from '../ui/ConstellationCover.astro';

const stories = (await getCollection('story'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
const [lead, ...rest] = stories;
---
<section class="px-6 py-20 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-6">
      <div>
        <SectionLabel text="Story" />
        <h2 class="mt-4">From the build log.</h2>
      </div>
      <a
        href="/story/"
        class="of-secondary-action"
      >
        All stories →
      </a>
    </div>

    {lead && (
      <StoryCard
        href={`/story/${lead.id}/`}
        title={lead.data.title}
        date={lead.data.date}
        tag={lead.data.tags[0]}
        summary={lead.data.summary}
        seed={lead.data.accent}
        cover={lead.data.hero}
        coverAlt={lead.data.heroAlt}
        featured
        animate
      />
    )}

    {rest.length > 0 && (
      <ul data-animate-stagger class="mt-6 grid gap-6 sm:grid-cols-2">
        {rest.map((post) => (
          <li>
            <a
              href={`/story/${post.id}/`}
              aria-label={post.data.title}
              data-animate
              class="group flex h-full gap-4 rounded-xl border border-border bg-surface-raised/50 p-4 transition-colors hover:border-primary/40 hover:bg-primary/[0.03]"
            >
              <div class="h-20 w-20 shrink-0 overflow-hidden rounded-lg">
                {post.data.hero ? (
                  <Image
                    src={post.data.hero}
                    alt={post.data.heroAlt ?? post.data.title}
                    widths={[160, 240]}
                    sizes="80px"
                    loading="lazy"
                    decoding="async"
                    data-no-zoom
                    class="h-full w-full object-cover object-top"
                  />
                ) : (
                  <ConstellationCover seed={post.data.accent ?? `/story/${post.id}/`} ratio="square" rounded="rounded-none" class="h-full w-full" />
                )}
              </div>
              <div class="flex min-w-0 flex-1 flex-col">
                <span class="mb-1 inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted">
                  {post.data.tags[0]}
                </span>
                <h3 class="mb-1 line-clamp-2 text-sm font-semibold leading-snug transition-colors group-hover:text-primary">
                  {post.data.title}
                </h3>
                <p class="line-clamp-2 text-xs leading-relaxed text-text-muted">{post.data.summary}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>
