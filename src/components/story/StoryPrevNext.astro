---
// StoryPrevNext — end-of-article chronological-arc navigator on /story/<slug>/.
// Two horizontal cards on one row: left = older (Previous story), right = newer
// (Next story). Each card is image-LEFT + (eyebrow + title + one-line summary)
// on the RIGHT, capped narrower than half the article width so a visible gap
// sits between the pair. Stacks on mobile. End-of-arc: the missing neighbor's
// card just doesn't render — the remaining card anchors to its correct side
// (prev flush-left, next flush-right via sm:ml-auto).
//
// Visual vocabulary matches StoryCard / RelatedRail (rounded-xl, border,
// bg-surface-raised/50, primary-tinted hover, group-hover title color).
// Constellation fallback uses the same seed format as StoryCard so a post
// without a curated hero shows the SAME pattern here as on the index.
//
// Caller passes the full, date-ascending-sorted collection so we don't
// re-fetch per page and the component stays portable (any collection that
// has id/title/summary/hero/heroAlt + a stable order would work).
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import ConstellationCover from '../ui/ConstellationCover.astro';

interface Props {
  current: CollectionEntry<'story'>;
  posts: CollectionEntry<'story'>[]; // ascending by date (oldest → newest)
}

const { current, posts } = Astro.props;

// Index in an asc-sorted list IS the arc position. prev = older, next = newer.
const i = posts.findIndex((p) => p.id === current.id);
const prev = i > 0 ? posts[i - 1] : undefined;
const next = i >= 0 && i < posts.length - 1 ? posts[i + 1] : undefined;

// Belt-and-braces: a story not found in `posts` (shouldn't happen) leaves
// both neighbors undefined → render nothing instead of an empty border bar.
const showSection = Boolean(prev || next);
---
{showSection && (
  <nav aria-label="More stories in the arc" class="border-t border-border px-6 py-14">
    <ul
      data-animate-stagger
      class="mx-auto flex max-w-2xl flex-col gap-6 sm:flex-row sm:items-stretch sm:justify-between"
    >
      {prev && (
        <li class="sm:w-[19rem] sm:max-w-[calc(50%-1rem)]">
          <a
            href={`/story/${prev.id}/`}
            aria-label={`Previous story: ${prev.data.title}`}
            data-animate
            class="group flex h-full gap-4 rounded-xl border border-border bg-surface-raised/50 p-4 transition-colors hover:border-primary/40 hover:bg-primary/[0.03]"
          >
            <div class="h-20 w-20 shrink-0 overflow-hidden rounded-lg">
              {prev.data.hero ? (
                <Image
                  src={prev.data.hero}
                  alt={prev.data.heroAlt ?? prev.data.title}
                  widths={[160, 240]}
                  sizes="80px"
                  loading="lazy"
                  decoding="async"
                  data-no-zoom
                  class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]"
                />
              ) : (
                <ConstellationCover seed={`/story/${prev.id}/`} ratio="square" rounded="rounded-none" class="h-full w-full" />
              )}
            </div>
            <div class="flex min-w-0 flex-1 flex-col">
              <span class="mb-1 inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
                Previous story
              </span>
              <h3 class="mb-1 line-clamp-2 text-sm font-semibold leading-snug transition-colors group-hover:text-primary">
                {prev.data.title}
              </h3>
              <p class="line-clamp-2 text-xs leading-relaxed text-text-muted">{prev.data.summary}</p>
            </div>
          </a>
        </li>
      )}
      {next && (
        <li class="sm:ml-auto sm:w-[19rem] sm:max-w-[calc(50%-1rem)]">
          <a
            href={`/story/${next.id}/`}
            aria-label={`Next story: ${next.data.title}`}
            data-animate
            class="group flex h-full gap-4 rounded-xl border border-border bg-surface-raised/50 p-4 transition-colors hover:border-primary/40 hover:bg-primary/[0.03]"
          >
            <div class="h-20 w-20 shrink-0 overflow-hidden rounded-lg">
              {next.data.hero ? (
                <Image
                  src={next.data.hero}
                  alt={next.data.heroAlt ?? next.data.title}
                  widths={[160, 240]}
                  sizes="80px"
                  loading="lazy"
                  decoding="async"
                  data-no-zoom
                  class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]"
                />
              ) : (
                <ConstellationCover seed={`/story/${next.id}/`} ratio="square" rounded="rounded-none" class="h-full w-full" />
              )}
            </div>
            <div class="flex min-w-0 flex-1 flex-col">
              <span class="mb-1 inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted">
                Next story
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6-6 6" /></svg>
              </span>
              <h3 class="mb-1 line-clamp-2 text-sm font-semibold leading-snug transition-colors group-hover:text-primary">
                {next.data.title}
              </h3>
              <p class="line-clamp-2 text-xs leading-relaxed text-text-muted">{next.data.summary}</p>
            </div>
          </a>
        </li>
      )}
    </ul>
  </nav>
)}
