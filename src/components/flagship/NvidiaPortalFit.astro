---
import { nvidiaBrand, type NvidiaPortalProfile } from '../../data/nvidia-portal';

interface Props {
  profile: NvidiaPortalProfile;
}

const { profile } = Astro.props;
const facts = [
  { label: 'Name', value: profile.productServiceName },
  { label: 'Type', value: profile.type },
  { label: 'Stage', value: profile.developmentStage },
  { label: 'Runtime acceleration', value: profile.runtimeAcceleratedByNvidia },
];
---
<section class="px-6 py-12">
  <div class="mx-auto max-w-6xl">
    <div data-animate class="overflow-hidden rounded-2xl border border-border bg-surface-raised">
      <div class="flex flex-col gap-5 border-b border-border p-6 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <p class="font-mono text-[10px] uppercase tracking-[0.2em]" style={`color: ${nvidiaBrand.color}`}>
            Enterprise listing fit
          </p>
          <h2 class="mt-2 text-3xl">NVIDIA Partner Portal alignment</h2>
          <p class="mt-3 max-w-2xl text-sm leading-relaxed text-text-muted">
            This page uses the same public name, stage, value proposition, and technical posture that customers should see through NVIDIA channels.
          </p>
        </div>
        <span class="inline-flex self-start rounded-full border px-3 py-1 font-mono text-[10px] uppercase tracking-[0.16em]" style={`border-color: ${nvidiaBrand.color}55; color: ${nvidiaBrand.color}; background: ${nvidiaBrand.color}10`}>
          {nvidiaBrand.program}
        </span>
      </div>
      <div class="grid gap-0 lg:grid-cols-[0.9fr_1.1fr]">
        <dl class="grid border-b border-border lg:border-b-0 lg:border-r">
          {facts.map((fact) => (
            <div class="grid grid-cols-[8rem_1fr] gap-4 border-b border-border px-6 py-4 last:border-b-0">
              <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-dim">{fact.label}</dt>
              <dd class="text-sm font-medium text-text">{fact.value}</dd>
            </div>
          ))}
        </dl>
        <div class="space-y-5 p-6">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-primary">Value proposition</p>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">{profile.valueProposition}</p>
          </div>
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-primary">Technical posture</p>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">{profile.technicalDetails}</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-3">
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-primary">NVIDIA used</p>
              <p class="mt-2 text-sm leading-snug text-text-muted">{profile.nvidiaTechnologiesUsed.join(', ')}</p>
            </div>
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-primary">Considering</p>
              <p class="mt-2 text-sm leading-snug text-text-muted">{profile.nvidiaTechnologiesConsidered.join(', ')}</p>
            </div>
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-primary">Also used</p>
              <p class="mt-2 text-sm leading-snug text-text-muted">{profile.nonNvidiaTechnologies.join(', ')}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
