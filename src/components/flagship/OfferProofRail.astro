---
import type { ProofLink } from '../../data/flagship-offers';

interface Props {
  title?: string;
  links: ProofLink[];
}

const { title = 'Proof in the current portfolio', links } = Astro.props;
---
<div data-animate class="rounded-2xl border border-primary/20 bg-primary/[0.045] p-5 sm:p-6">
  <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">{title}</p>
  <div class="mt-4 grid gap-3 sm:grid-cols-3">
    {links.map((link) => (
      <a href={link.href} class="rounded-xl border border-border bg-surface-raised p-4 transition-colors hover:border-primary/30">
        <span class="font-medium text-text">{link.label}</span>
        <span class="mt-1 block text-sm leading-snug text-text-muted">{link.note}</span>
      </a>
    ))}
  </div>
</div>
