---
// Proof rail for flagship offer pages: real product art instead of text tiles,
// so each offer page shows the shipped portfolio it stands on (spec rescue:
// "reuse existing product cards, covers, and proof rails").
import type { ProofLink } from '../../data/flagship-offers';
import ProofCard from './ProofCard.astro';

interface Props {
  title?: string;
  links: ProofLink[];
  /** Optional header-right action, e.g. the catalog-hub doorway link. */
  action?: { label: string; href: string };
}

const { title = 'Proof in the current portfolio', links, action } = Astro.props;
---
<div>
  <div class="flex flex-wrap items-baseline justify-between gap-4">
    <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">{title}</p>
    {action && <a href={action.href} class="of-text-action of-compact text-xs">{action.label}</a>}
  </div>
  <div data-animate-stagger class="mt-4 grid gap-5 sm:grid-cols-3">
    {links.map((link) => (
      <ProofCard link={link} />
    ))}
  </div>
</div>
