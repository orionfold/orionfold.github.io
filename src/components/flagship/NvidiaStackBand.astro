---
// Compact NVIDIA partner band for the flagship offer pages: the approved
// membership sentence, one page-specific stack note, the official member badge,
// and the required legal attribution. The full per-offer stack profiles live on
// /dgx-spark/ (and in src/data/nvidia-portal.ts for portal submissions) so the
// offer pages stay buyer-first.
import NvidiaLegalLine from './NvidiaLegalLine.astro';

interface Props {
  note?: string;
}

const {
  note = 'This work is proven on NVIDIA DGX Spark, with CUDA-capable local inference where deployments support it.',
} = Astro.props;
---
<section class="px-6 py-12">
  <div class="mx-auto max-w-6xl">
    <div data-animate class="flex flex-col gap-6 rounded-2xl border border-border bg-surface-raised p-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="min-w-0 max-w-2xl">
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-text-dim">Built on the NVIDIA stack</p>
        <p class="mt-2 text-sm leading-relaxed text-text-muted">
          Orionfold is a member of the NVIDIA Inception program. {note}
        </p>
        <a href="/dgx-spark/" class="of-text-action of-compact mt-3 inline-flex text-xs">See the DGX Spark field lab →</a>
        <div class="mt-4">
          <NvidiaLegalLine />
        </div>
      </div>
      <img
        src="/logos/nvidia-inception/nvidia-inception-program-badge-rgb-for-screen.svg"
        alt="NVIDIA Inception program member badge"
        loading="lazy"
        class="h-auto w-36 shrink-0 sm:w-40"
      />
    </div>
  </div>
</section>
