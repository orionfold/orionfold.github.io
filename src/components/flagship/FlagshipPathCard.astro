---
import type { FlagshipOffer } from '../../data/flagship-offers';

interface Props {
  offer: FlagshipOffer;
}

const { offer } = Astro.props;
---
<a
  href={offer.route}
  data-animate
  class="of-surface of-pressable group flex h-full flex-col rounded-2xl p-6"
>
  <span class="of-chip w-fit">{offer.eyebrow}</span>
  <h3 class="mt-3 text-2xl leading-tight group-hover:text-primary">{offer.title}</h3>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">{offer.outcome}</p>
  <div class="mt-5 border-t border-border pt-4">
    <p class="text-xs font-medium leading-snug text-text">{offer.status}</p>
    <span class="of-text-action of-compact mt-3 text-xs">Open →</span>
  </div>
</a>
