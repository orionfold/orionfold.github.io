---
import type { FlagshipOffer } from '../../data/flagship-offers';

interface Props {
  offer: FlagshipOffer;
}

const { offer } = Astro.props;
---
<a
  href={offer.route}
  data-animate
  class="group flex h-full flex-col rounded-2xl border border-border bg-surface-raised p-6 transition-colors hover:border-primary/35 hover:bg-primary/[0.035]"
>
  <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">{offer.eyebrow}</span>
  <h3 class="mt-3 text-2xl leading-tight group-hover:text-primary">{offer.title}</h3>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">{offer.outcome}</p>
  <div class="mt-5 flex items-center justify-between gap-4 border-t border-border pt-4">
    <span class="rounded-full bg-primary/[0.08] px-3 py-1 font-mono text-[10px] uppercase tracking-[0.16em] text-primary">{offer.status}</span>
    <span class="font-mono text-xs tracking-wider text-primary">Open →</span>
  </div>
</a>
