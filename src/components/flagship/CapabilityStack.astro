---
interface Item {
  label: string;
  body: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---
<div data-animate-stagger class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
  {items.map((item) => (
    <div data-animate class="rounded-2xl border border-border bg-surface-raised p-5">
      <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-primary">{item.label}</p>
      <p class="mt-3 text-sm leading-relaxed text-text-muted">{item.body}</p>
    </div>
  ))}
</div>
