---
// TrustPage — the shared renderer for the on-site /trust/ pages (2026-07-03).
// One data-driven layout (mirrors promise.astro): a hero with a plain summary +
// a "short version" card, a sticky aside pointing at the canonical repo, then
// the sections (prose, bullets, tables, and muted notes). Content comes from
// src/data/trust-pages.ts; each route file passes one TrustPageData in. Voice
// keeps the technical specifics; the plain framing follows website-copy-style.
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';
import { SITE, PUBLISHER } from '../../data/seo';
import { RELAY_REPO, trustPagesInOrder, type TrustPageData } from '../../data/trust-pages';

interface Props {
  page: TrustPageData;
}
const { page } = Astro.props;

// Sibling trust pages for the "more trust pages" tail (everything but this one).
const others = trustPagesInOrder().filter((p) => p.slug !== page.slug);
const canonical = `${RELAY_REPO}/blob/main/docs/trust/${page.slug}.md`;
---
<Layout
  title={`${page.title} · Orionfold`}
  description={page.summary}
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: `${page.title} · Orionfold`,
      url: `${SITE.url}/trust/${page.slug}/`,
      inLanguage: 'en',
      publisher: PUBLISHER,
      description: page.summary,
      dateModified: page.lastUpdated,
    },
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'Trust', item: `${SITE.url}/trust/` },
        { '@type': 'ListItem', position: 3, name: page.title, item: `${SITE.url}/trust/${page.slug}/` },
      ],
    },
  ]}
>
  <Nav />
  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden px-6 pt-32 pb-14">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute left-1/2 top-14 h-[26rem] w-[26rem] -translate-x-1/2 rounded-full bg-primary/[0.10] blur-[150px]"></div>
        <div class="absolute inset-x-0 bottom-0 h-40" style="background: linear-gradient(to bottom, transparent, var(--color-surface-raised));"></div>
      </div>

      <div class="relative z-10 mx-auto max-w-5xl">
        <div data-animate class="flex items-center gap-2">
          <a href="/trust/" class="font-mono text-xs uppercase tracking-[0.2em] text-text-muted transition-colors hover:text-primary">Trust</a>
          <span class="text-text-dim" aria-hidden="true">/</span>
          <SectionLabel text={page.eyebrow} />
        </div>
        <div class="mt-5 grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_20rem] lg:items-end">
          <div>
            <h1 data-animate class="font-display text-[clamp(2rem,5vw,3.6rem)] leading-[1.04]" style="transition-delay: 80ms">
              {page.title}
            </h1>
            <p data-animate class="mt-5 max-w-3xl text-lg leading-relaxed text-text-muted" style="transition-delay: 160ms">
              {page.summary}
            </p>
          </div>

          <div data-animate class="rounded-2xl border border-primary/30 bg-primary/[0.06] p-5 shadow-[0_20px_80px_-40px_rgba(0,0,0,0.75)]" style="transition-delay: 220ms">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.24em] text-primary/70">The short version</p>
            <p class="mt-3 text-sm leading-relaxed text-text">{page.shortVersion}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Body -->
    <section class="px-6 py-16">
      <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[16rem_minmax(0,1fr)]">
        <aside data-animate class="lg:sticky lg:top-28 h-fit rounded-2xl border border-border bg-surface-raised/70 p-5">
          <p class="font-mono text-[0.62rem] uppercase tracking-[0.24em] text-text-dim">Check it yourself</p>
          <p class="mt-4 text-sm leading-relaxed text-text-muted">
            Every claim here is backed by open-source code you can read. This page mirrors the canonical trust doc in the Relay repository.
          </p>
          <a href={canonical} target="_blank" rel="noopener" class="of-text-action of-compact mt-4 inline-flex text-xs">
            Read it in the repo →
          </a>
          <p class="mt-5 font-mono text-[0.58rem] uppercase tracking-[0.18em] text-text-dim">Last updated {page.lastUpdated}</p>
        </aside>

        <div class="space-y-5">
          {page.sections.map((section) => (
            <section class="rounded-2xl border border-border bg-surface-raised/70 p-6 sm:p-8">
              <h2 class="text-2xl">{section.title}</h2>
              <div class="mt-4 space-y-4">
                {section.lead && (
                  <p class="text-base leading-relaxed text-text">{section.lead}</p>
                )}
                {section.paragraphs?.map((paragraph) => (
                  <p class="text-base leading-relaxed text-text-muted">{paragraph}</p>
                ))}
                {section.bullets && (
                  <ul class="space-y-3 pt-1">
                    {section.bullets.map((bullet) => (
                      <li class="flex items-start gap-3 text-sm leading-relaxed text-text-muted">
                        <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-primary"></span>
                        <span>{bullet}</span>
                      </li>
                    ))}
                  </ul>
                )}
                {section.table && (
                  <div class="mt-2 overflow-x-auto rounded-xl border border-border">
                    <table class="w-full min-w-[38rem] border-collapse text-left text-sm">
                      <thead>
                        <tr class="bg-surface/70">
                          {section.table.head.map((h) => (
                            <th class="whitespace-nowrap border-b border-border px-3.5 py-2.5 font-mono text-[0.62rem] uppercase tracking-[0.14em] text-text-muted">{h}</th>
                          ))}
                        </tr>
                      </thead>
                      <tbody>
                        {section.table.rows.map((row) => (
                          <tr class="align-top">
                            {row.map((cell, i) => (
                              <td class={`border-b border-border/60 px-3.5 py-2.5 leading-relaxed ${i === 0 ? 'font-semibold text-text' : 'text-text-muted'}`}>{cell}</td>
                            ))}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
                {section.note && (
                  <p class="border-l-2 border-primary/40 pl-4 text-sm italic leading-relaxed text-text-muted">{section.note}</p>
                )}
              </div>
            </section>
          ))}

          <!-- Tail: the other trust pages + the buy nudge -->
          <div class="rounded-2xl border border-primary/30 bg-primary/[0.06] p-6 sm:p-8">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.24em] text-primary/70">More trust pages</p>
            <ul class="mt-4 grid gap-2 sm:grid-cols-2">
              {others.map((o) => (
                <li>
                  <a href={`/trust/${o.slug}/`} class="group flex items-center gap-2 text-sm text-text transition-colors hover:text-primary">
                    <span class="text-primary" aria-hidden="true">→</span>
                    {o.title}
                  </a>
                </li>
              ))}
            </ul>
            <p class="mt-6 text-base leading-relaxed text-text">
              Ready to run it? <a href="/relay/" class="text-primary transition-colors hover:text-primary/80">Get Orionfold Relay</a>. The engine is free and open; a license only adds the premium packs you own.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
