---
// Related rail (P1, spec §4/§5.4). Turns the leak into a funnel: instead of one
// outbound trapdoor, point readers at related models, the documenting book, and
// field-notes articles. Each item renders as a full card in the listing idiom
// (16:9 cover, mono eyebrow, title, blurb) — the same look as the software/models
// grids — so "Keep exploring" reads as a shelf, not a link list. Covers + blurbs
// are resolved in resolveRelated (src/lib/product/detail.ts); a reading link with
// no asset falls back to the seeded constellation motif. Internal targets link
// to their on-site detail page, external ones open the canonical home in a new
// tab. Renders only when there is at least one related item.
import { Image } from 'astro:assets';
import ConstellationCover from '../ui/ConstellationCover.astro';
import type { RelatedItem } from '../../lib/product/detail';

interface Props {
  models?: RelatedItem[];
  book?: RelatedItem;
  reading?: RelatedItem[];
}
const { models = [], book, reading = [] } = Astro.props;

const EYEBROW: Record<RelatedItem['kind'], string> = {
  software: 'Software',
  model: 'Model',
  book: 'Book',
  story: 'Story',
  reading: 'Reading',
};

const cards: RelatedItem[] = [...models, ...(book ? [book] : []), ...reading];
const sizes = '(min-width: 1024px) 22rem, (min-width: 640px) 50vw, 100vw';
---
{cards.length > 0 && (
  <section class="border-t border-border px-6 py-14">
    <div class="mx-auto max-w-5xl">
      <h2 data-animate class="font-display text-2xl font-bold">Keep exploring</h2>
      <div data-animate-stagger class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {cards.map((item) => (
          <a
            href={item.href}
            data-animate
            aria-label={item.title}
            {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class="group flex flex-col overflow-hidden rounded-2xl border border-border bg-surface-raised transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-primary/[0.03] hover:shadow-xl hover:shadow-primary/10"
          >
            {/* Cover: landscape art is cropped 16:9; a portrait book cover sits
                contained over a blurred fill (RoadmapCard idiom); no asset -> motif. */}
            {item.cover ? (
              <div class="relative aspect-[16/9] overflow-hidden border-b border-border">
                {item.kind === 'book' ? (
                  <>
                    <Image src={item.cover} alt="" aria-hidden="true" widths={[400, 640]} sizes={sizes} loading="lazy" decoding="async" data-no-zoom class="absolute inset-0 h-full w-full scale-110 object-cover blur-2xl" />
                    <div class="absolute inset-0 bg-black/20"></div>
                    <Image src={item.cover} alt={`${item.title} cover`} widths={[240, 400]} sizes="240px" loading="lazy" decoding="async" data-no-zoom class="relative z-[1] mx-auto h-full w-auto object-contain p-3 transition-transform duration-500 group-hover:scale-[1.03]" />
                  </>
                ) : (
                  <Image src={item.cover} alt={`${item.title} cover`} widths={[400, 640]} sizes={sizes} loading="lazy" decoding="async" data-no-zoom class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]" />
                )}
              </div>
            ) : (
              <ConstellationCover seed={item.seed} rounded="rounded-none" label={item.title} class="border-b border-border" />
            )}

            {/* Body */}
            <div class="flex flex-1 flex-col p-6">
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">{EYEBROW[item.kind]}</span>
              <h3 class="mt-2 flex items-start gap-1.5 font-display text-lg font-bold leading-tight transition-colors group-hover:text-primary">
                <span class="flex-1">{item.title}</span>
                {item.external && (
                  <svg class="mt-1 shrink-0 text-text-muted transition-colors group-hover:text-primary" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" /></svg>
                )}
              </h3>
              {item.blurb && <p class="mt-2 line-clamp-3 flex-1 text-sm leading-relaxed text-text-muted">{item.blurb}</p>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
