---
// AsciinemaCasts — client island that turns every `.asciinema-cast` mount point
// (emitted by remark-asciinema) into a real asciinema-player on scroll-into-view.
//
// Adapted from ainative-business.github.io src/components/products/AsciinemaCasts.astro
// (d091567). Deviation for orionfold.com mobile-perf-hygiene: the ~250 KB player
// bundle + CSS are dynamic-import()ed INSIDE mount(), so they fetch only on
// scroll-into-view, never at page-load. The component is itself included only
// when the body has a cast (hasCast gate in the layout), so the chunk is absent
// from every other page. The poster <img> is the no-JS / pre-play fallback.
---
<script>
  // Co-located styles for the cast figure/poster (the literal class names the
  // remark-asciinema plugin emits). Injected from JS instead of a `<style
  // is:global>` block on purpose: an `is:global` style in this island is
  // hoisted by Astro into the SHARED stylesheet of every page that uses the
  // ProductDetail layout (the layout imports this island unconditionally), which
  // defeats the hasCast gate and ships ~0.6 KB of cast CSS + a `<link>` to the
  // ~30 KB player CSS onto all 24 product pages. Injecting here keeps the styles
  // bound to this island's chunk, which is gated to the Arena page. The poster
  // <img> still styles correctly before play because this runs at init().
  const CAST_CSS = `
  figure.asciinema-figure { margin: 2rem auto 0.75rem; max-width: 100%; }
  .asciinema-cast {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border, #2a2d35);
    background: #16181d;
    line-height: 0;
    /* Reserve the box before the lazy poster paints to avoid CLS. Ratio matches
       the onboard preflight poster SVG's viewBox (1043x587). */
    aspect-ratio: 1043 / 587;
  }
  .asciinema-cast__poster {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    margin: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    transition: opacity 0.4s ease;
  }
  .asciinema-cast__poster--hidden { opacity: 0; pointer-events: none; }
  .asciinema-cast__player { position: absolute; inset: 0; z-index: 1; }
  .asciinema-cast__player:empty { display: none; }
  .asciinema-cast .ap-player { border-radius: 0; }
  @media (max-width: 640px) {
    .asciinema-cast { border-radius: 0; border-inline: none; }
  }`;

  function injectCss() {
    if (document.getElementById('asciinema-cast-css')) return;
    const style = document.createElement('style');
    style.id = 'asciinema-cast-css';
    style.textContent = CAST_CSS;
    document.head.appendChild(style);
  }

  // Inject the player stylesheet and resolve only once it has actually loaded,
  // so create() never paints against an empty palette / wrong metrics.
  function ensurePlayerCss(href: string): Promise<void> {
    let link = document.getElementById('asciinema-player-css') as HTMLLinkElement | null;
    if (link && link.sheet) return Promise.resolve();
    if (!link) {
      link = document.createElement('link');
      link.id = 'asciinema-player-css';
      link.rel = 'stylesheet';
      link.href = href;
      document.head.appendChild(link);
    }
    const el = link;
    return new Promise<void>((resolve) => {
      if (el.sheet) { resolve(); return; }
      el.addEventListener('load', () => resolve(), { once: true });
      el.addEventListener('error', () => resolve(), { once: true });
    });
  }

  async function mount(el: HTMLElement) {
    if (el.dataset.mounted) return;
    el.dataset.mounted = '1';
    const slot = el.querySelector<HTMLElement>('.asciinema-cast__player');
    const poster = el.querySelector<HTMLElement>('.asciinema-cast__poster');
    if (!slot) return;
    const castSrc = el.dataset.cast;
    if (!castSrc) return;
    // Deviation: lazy-load the player bundle + CSS only now (on scroll-into-view).
    // The player CSS is imported as a URL (?url) and injected as a <link> at
    // mount, NOT as a CSS module import. A module `import('...css')` makes Vite
    // extract a static CSS asset that Astro then associates with this island's
    // layout and emits as a `<link rel=stylesheet>` on EVERY page using
    // ProductDetail (all 24 product pages) even where the island never renders.
    // Importing the URL and creating the <link> here keeps the player CSS inside
    // the gated dynamic-import path, so it ships only when a cast actually mounts.
    const [{ create }, { default: playerCssUrl }] = await Promise.all([
      import('asciinema-player'),
      import('asciinema-player/dist/bundle/asciinema-player.css?url'),
    ]);
    // The player reads its ANSI palette (CSS custom props --term-color-*) and
    // computes font metrics from the stylesheet at create() time. Because we
    // inject the CSS as a <link> (to keep it inside the gated chunk rather than
    // a static import that Astro would hoist onto all product pages), we MUST
    // wait for the sheet to load before create() — otherwise the first paint
    // reads an empty palette (renders black-on-black) and wrong cell metrics
    // (short box, stranded control bar). Upstream sidesteps this with a static
    // import; awaiting the link load gives the same guarantee without the leak.
    await ensurePlayerCss(playerCssUrl);
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const player = create(castSrc, slot, {
      cols: Number(el.dataset.cols) || 100,
      rows: Number(el.dataset.rows) || 18,
      autoPlay: !reduce,
      preload: true,
      loop: false,
      idleTimeLimit: Number(el.dataset.idle) || 2,
      speed: Number(el.dataset.speed) || 1,
      theme: 'asciinema',
      fit: 'width',
      controls: true,
    });
    const hidePoster = () => {
      if (poster) poster.classList.add('asciinema-cast__poster--hidden');
    };
    player.addEventListener('play', hidePoster);
    // Belt-and-suspenders: hide once the first frame should be up (skip when
    // reduced-motion, where we keep the poster + the player's own controls).
    if (!reduce) setTimeout(hidePoster, 600);
  }

  function init() {
    const casts = Array.from(
      document.querySelectorAll<HTMLElement>('.asciinema-cast'),
    );
    if (!casts.length) return;
    injectCss();
    if (!('IntersectionObserver' in window)) {
      casts.forEach(mount);
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            mount(e.target as HTMLElement);
            io.unobserve(e.target);
          }
        }
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.25 },
    );
    casts.forEach((c) => io.observe(c));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  // Match the repo island convention (Nav/Layout/StickyCtaBar): re-init after a
  // View Transitions swap. VT is off today so this is dormant, but init() is
  // idempotent (data-mounted + id-guarded injectCss) so it's safe to bind.
  document.addEventListener('astro:after-swap', init);
</script>
