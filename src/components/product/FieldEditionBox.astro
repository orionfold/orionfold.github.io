---
// Field Edition box (Arena Field Edition launch, 2026-06). The edition-split
// conversion point: the FREE, open Arena stays the page's spine (its "License:
// Free and local" chip is true verbatim), and this block sits beside it as the
// paid edition. Positioning (operator 2026-06-13, CAPABILITY/VELOCITY-led —
// supersedes the earlier "Free and open: the machine. Paid: the evidence." line):
// "Get an AI team without hiring one, in the DGX Spark you already own." Velocity
// is the hero proof (one builder's output on this stack); the first-boot receipt +
// 12-month kept-proven window are the reason-to-believe, not the headline. What
// the buyer gets is the assembled, proven, kept-proven AI team delivered turnkey.
// Receipt-honesty rule: "verifiable receipt" / "report=reality", never "all gates
// green" (the launch receipt is honest-partial). See memory arena-field-edition-launch.
//
// Price + the founding cap + the window come from the catalog SSOT (FIELD_EDITION
// in commerce.ts), so the chips, the buy button, and the JSON-LD Offer can never
// drift. The charging buttons render ONLY when ARENA_FIELD_EDITION_LIVE is true
// (launch flag) — before the flag flips, the full pitch shows with a "tell me at
// launch" path instead, so no one can pay before fulfillment exists.
import { FIELD_EDITION, formatUsd } from '../../data/commerce';
import { ARENA_FIELD_EDITION_LIVE } from '../../data/launch';
import type { ProductView } from '../../lib/product/detail';

interface Props {
  view: ProductView;
}
const { view } = Astro.props;

const primary = formatUsd(FIELD_EDITION.primary.amount);
const founding = formatUsd(FIELD_EDITION.founding.amount);
const renewal = formatUsd(FIELD_EDITION.renewal.amount);

// Honest proof ladder — the evidence the buyer pays to have kept proven. Every
// link is a real first-party surface, except the first-boot receipt, which Spark
// delivers at launch (rendered as a pending item, never a dead link).
const proof = [
  { label: '7 published model builds, scored on frozen tests', href: '/models/' },
  { label: 'fieldkit v0.31.0, 1,576 tests green', href: '/software/fieldkit/' },
  { label: 'Cortex grounded eval pack', href: '/software/cortex/' },
  { label: 'The 54-article DGX Spark corpus', href: '/dgx-spark/' },
];
const enquiryHref = `/adoption/?item=${view.roadmapItemId}`;
---
<section id="field-edition" class="scroll-mt-24 px-6 py-16">
  <div class="mx-auto max-w-3xl">
    <div data-animate class="rounded-2xl border border-primary/40 bg-surface-raised p-8 shadow-lg shadow-primary/5">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-primary">
        Get an AI team without hiring one, in the Spark you own
      </p>

      <div class="mt-4 flex flex-wrap items-end justify-between gap-4">
        <div>
          <h2 class="font-display text-2xl font-bold sm:text-3xl">Arena Field Edition</h2>
          <p class="mt-2 max-w-xl text-text-muted">
            Arena Field Edition turns the Spark you own into a private AI lab with an AI research
            teammate: agents that do real work, models that know your field, and tests that prove
            it. You go from running demos to shipping AI research and engineering beyond your solo
            skills.
          </p>
        </div>
        {!ARENA_FIELD_EDITION_LIVE && (
          <span class="rounded-full border border-primary/40 px-3 py-1 font-mono text-xs tracking-wider text-primary">
            Launching soon
          </span>
        )}
      </div>

      <p class="mt-5 text-sm text-text-muted">
        The proof is what one builder already did with this exact stack. Solo, on a single Spark
        running Arena: 15 software tools, 7 open models, 3 books, a 54-article research corpus,
        and 2 production sites. That is the velocity the box unlocks.
      </p>

      <p class="mt-4 text-sm text-text-muted">
        It installs in one pass, proves itself on first boot with a verifiable receipt, and stays
        proven for a year, every update re-gated and re-receipted. What you buy is the assembled,
        proven, kept-proven AI team delivered turnkey, not a pile of parts you wire together and
        babysit.
      </p>

      <!-- Price: lead with the founding hook ($349, first 25), $499 standard behind it -->
      <div class="mt-6 flex flex-wrap items-end justify-between gap-4 border-t border-border/60 pt-6">
        <p class="flex items-baseline gap-2">
          <span class="font-display text-4xl font-bold text-primary">{founding}</span>
          <span class="font-mono text-xs tracking-wider text-text-muted">
            founding, first {FIELD_EDITION.foundingSeats} licenses
          </span>
        </p>
        <p class="rounded-lg bg-primary/10 px-3 py-2 font-mono text-xs tracking-wider text-primary">
          then {primary} one time, {FIELD_EDITION.windowMonths}-month window included
        </p>
      </div>

      {ARENA_FIELD_EDITION_LIVE ? (
        <div class="mt-6 flex flex-wrap items-center gap-4">
          <button
            type="button"
            data-checkout={FIELD_EDITION.founding.lookupKey}
            data-item={view.roadmapItemId}
            data-error-target="fe-err"
            class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-accent px-5 py-3 font-mono text-sm tracking-wider text-accent-text transition-colors hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-60"
          >
            Buy now, founding · {founding}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </button>
          <button
            type="button"
            data-checkout={FIELD_EDITION.primary.lookupKey}
            data-item={view.roadmapItemId}
            data-error-target="fe-err"
            class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-primary/40 px-5 py-3 font-mono text-sm tracking-wider text-primary transition-colors hover:bg-primary/10 disabled:cursor-not-allowed disabled:opacity-60"
          >
            Buy at {primary}
          </button>
        </div>
      ) : (
        <div class="mt-6 flex flex-wrap items-center gap-4">
          <a
            href={enquiryHref}
            class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-accent px-5 py-3 font-mono text-sm tracking-wider text-accent-text transition-colors hover:bg-accent-hover"
          >
            Tell me when it launches
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </a>
          <span class="font-mono text-xs tracking-wider text-text-muted">
            Founding price holds for the first {FIELD_EDITION.foundingSeats} licenses.
          </span>
        </div>
      )}
      <p id="fe-err" role="alert" hidden class="mt-2 font-mono text-xs text-red-500"></p>
      <p class="mt-4 text-sm text-text-muted">
        After the first year, {renewal}/yr keeps it proven: the updates, the re-run gate, and a
        fresh receipt. Skip it and your box keeps working, you just stop getting new proof.
      </p>

      <!-- The evidence ladder: what "kept proven" points at -->
      <div class="mt-6 border-t border-border/60 pt-6">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-text-muted">Why you can trust it</p>
        <ul class="mt-3 grid gap-2 sm:grid-cols-2">
          {proof.map((p) => (
            <li>
              <a href={p.href} class="text-sm text-primary underline-offset-2 hover:underline">{p.label}</a>
            </li>
          ))}
          <li class="text-sm text-text-muted">An example first-boot receipt (at launch)</li>
        </ul>
      </div>
    </div>
  </div>
</section>
