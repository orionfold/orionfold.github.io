---
// ProductBand — the cross-sell band that appears on non-flagship pages (software,
// models, stories, receipts, about, thanks) and SELLS one of the three products,
// picked by context via bandForPage() (strong topical match wins; loose pages
// hash to a roughly-even Proof/Arena/Relay split, accepted skew ~39/38/23 since
// Relay has fewer natural homes today). Replaces the old link-only ProofCta /
// ProofBand / story ProofCTA.
//
// Two modes (the operator's hybrid, 2026-07-01; GA4 arbitrates which converts):
//   checkout — high-intent product-evaluation pages (software + model detail):
//              real in-page Buy buttons (data-checkout -> Stripe), like the
//              flagship LicenseBand. "See full details" links to the landing page.
//   link     — lower-intent pages (stories, about, thanks, receipts): the same
//              band chrome, but one CTA routing to the product's landing page
//              (where the canonical buy block lives), carrying a cross-sell UTM.
//
// Shares the blueprint-grid + cyan-glow + drifting-poster look of LicenseBand so
// the whole site reads as one band family. The flagship LicenseBand is NOT
// touched (its 3 usages stay as-is). errId is unique per band instance so two
// bands could coexist without clashing checkout error targets. Voice: grade 3-5,
// no em-dashes (website-copy-style).
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { PROOF, RELAY, FIELD_EDITION, formatUsd } from '../../data/commerce';
import { ORIONFOLD_PROOF_LIVE, ORIONFOLD_RELAY_LIVE, ARENA_FIELD_EDITION_LIVE } from '../../data/launch';
import { bandForPage, type PageType, type BandProduct } from '../../lib/product/band-for-page';
import proofPoster from '../../assets/proof/orionfold-proof-poster.jpeg';
import relayPoster from '../../assets/projects/orionfold-relay-poster.jpeg';
import arenaPoster from '../../assets/projects/arena-poster.png';

interface Props {
  /** Page type — drives the mode (software/model = checkout, else link). */
  type: PageType;
  /** Page slug — the stable key for strong-match + loose hashing. */
  slug: string;
  /** Story tags (for the topical strong-match). */
  tags?: string[];
  /** Proven-product flag (advisor/kepler/patent) — forces Proof. */
  proven?: boolean;
  /** Receipt source origin (proof|arena) for receipt pages. */
  receiptProduct?: BandProduct;
  /** Extra classes. */
  class?: string;
}

const { type, slug, tags, proven, receiptProduct, class: className } = Astro.props;

const { product, mode } = bandForPage({ type, slug, tags, proven, receiptProduct });

// Per-product config: family (price SSOT), live flag, poster, landing page,
// display name, roadmap attribution id, and the drift class prefix.
const CONFIG: Record<BandProduct, {
  family: typeof PROOF;
  live: boolean;
  poster: ImageMetadata;
  posterAlt: string;
  landing: string;
  name: string;
  itemId: string;
  eyebrow: string;
  heading: string;
  body: string;
}> = {
  proof: {
    family: PROOF, live: ORIONFOLD_PROOF_LIVE, poster: proofPoster,
    posterAlt: 'Orionfold Proof poster: an art-deco receipt rising from a laptop into the Orion stars.',
    landing: '/proof/', name: 'Orionfold Proof', itemId: 'software:orionfold-proof',
    eyebrow: 'Prove which AI you can trust',
    heading: 'Prove it on your own machine.',
    body: 'Orionfold Proof runs on your own machine, tries the models you are weighing, and hands back a signed receipt you can rerun. Which one won, at what cost, with what failures.',
  },
  arena: {
    family: FIELD_EDITION, live: ARENA_FIELD_EDITION_LIVE, poster: arenaPoster,
    posterAlt: 'Orionfold Arena poster: the eval cockpit you run on your own DGX Spark.',
    landing: '/arena/', name: 'Orionfold Arena', itemId: 'software:arena',
    eyebrow: 'See which AI wins, on your own desk',
    heading: 'Run, compare, and score on your own Spark.',
    body: 'Orionfold Arena is the cockpit that runs, compares, scores, and trains local AI models on one DGX Spark. The model, the tests, and the results in one place you control.',
  },
  relay: {
    family: RELAY, live: ORIONFOLD_RELAY_LIVE, poster: relayPoster,
    posterAlt: 'Orionfold Relay poster: one operator running a whole AI agency from one board.',
    landing: '/relay/', name: 'Orionfold Relay', itemId: 'software:orionfold-relay',
    eyebrow: 'Run your agents from one place',
    heading: 'Put your trusted AI to work.',
    body: 'Orionfold Relay is the free and open engine that runs your AI agents and workflows from one board. Own a license and add the premium packs that save you the setup.',
  },
};

const c = CONFIG[product];
const primary = formatUsd(c.family.primary.amount);
const founding = formatUsd(c.family.founding.amount);

// A stable, unique-ish error target + a class prefix per instance. slug keeps it
// unique across a page; product keeps the drift-class namespaced.
const errId = `pband-${type}-${slug}-err`.replace(/[^a-z0-9-]/gi, '');

// Cross-sell UTM for the link mode (so GA4 can compare link vs checkout bands).
const utm = `utm_source=orionfold&utm_medium=cross-sell&utm_campaign=product-band&utm_content=${type}-${slug}-${product}`;
const landingHref = `${c.landing}?${utm}`;
---
<section
  class:list={['product-band relative overflow-hidden border-y border-primary/25 px-6 py-12', className]}
  aria-label={`Get ${c.name}`}
>
  <!-- Blueprint grid + cyan glow, the shared band-family surface. -->
  <div class="product-band__grid pointer-events-none absolute inset-0 -z-10" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute -left-[6%] top-1/2 h-[380px] w-[380px] -translate-y-1/2 rounded-full bg-primary/[0.12] blur-[130px]"></div>
  </div>

  <div class="mx-auto grid max-w-5xl items-center gap-8 md:grid-cols-[1.1fr_auto] md:gap-10">
    <!-- LEFT: pitch + CTA -->
    <div>
      <p class="font-mono text-[0.62rem] uppercase tracking-[0.24em] text-primary">{c.eyebrow}</p>
      <h2 class="mt-2 font-display text-2xl font-bold leading-tight sm:text-3xl">{c.heading}</h2>
      <p class="mt-3 max-w-xl text-sm leading-relaxed text-text-muted">{c.body}</p>

      <div class="mt-5 flex flex-wrap items-baseline gap-x-3 gap-y-1">
        <span class="font-display text-3xl font-bold text-primary">{founding}</span>
        <span class="rounded-full bg-primary/10 px-2.5 py-1 font-mono text-[0.62rem] tracking-wider text-primary">
          founding, first {c.family.foundingSeats}
        </span>
        <span class="font-mono text-xs tracking-wider text-text-muted">then {primary} one time</span>
      </div>

      {mode === 'checkout' && c.live ? (
        <div class="mt-5 flex flex-wrap items-center gap-3">
          <button
            type="button"
            data-checkout={c.family.founding.lookupKey}
            data-item={c.itemId}
            data-error-target={errId}
            class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-accent px-5 py-2.5 font-mono text-sm tracking-wider text-accent-text transition-colors hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-60"
          >
            Buy founding · {founding}
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </button>
          <button
            type="button"
            data-checkout={c.family.primary.lookupKey}
            data-item={c.itemId}
            data-error-target={errId}
            class="inline-flex items-center justify-center rounded-lg border border-primary/40 px-5 py-2.5 font-mono text-sm tracking-wider text-primary transition-colors hover:bg-primary/10 disabled:cursor-not-allowed disabled:opacity-60"
          >
            Buy at {primary}
          </button>
          <a href={c.landing} class="font-mono text-[0.7rem] tracking-wider text-text-muted underline underline-offset-2 hover:text-primary">
            or see the full details
          </a>
        </div>
      ) : (
        <div class="mt-5 flex flex-wrap items-center gap-3">
          <a
            href={landingHref}
            class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-accent px-5 py-2.5 font-mono text-sm tracking-wider text-accent-text transition-colors hover:bg-accent-hover"
          >
            See {c.name}
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </a>
        </div>
      )}
      <p id={errId} role="alert" hidden class="mt-2 font-mono text-xs text-red-500"></p>
    </div>

    <!-- RIGHT: the product poster, drifting on the isometric plane. -->
    <div class="pband3d-stage relative order-first mx-auto w-full max-w-sm shrink-0 self-center md:order-none md:w-[22rem]">
      <div class="pband3d-plane block overflow-hidden rounded-xl ring-1 ring-primary/20 shadow-[0_22px_60px_-32px_oklch(0.18_0.08_260/0.7)]">
        <Image
          src={c.poster}
          alt={c.posterAlt}
          widths={[352, 704]}
          sizes="22rem"
          loading="lazy"
          decoding="async"
          data-no-zoom
          class="block aspect-[16/9] w-full object-cover object-top"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .product-band { background-color: oklch(0.97 0.012 200); }
  :global([data-theme='dark']) .product-band { background-color: oklch(0.20 0.022 235); }
  .product-band__grid {
    background-image:
      linear-gradient(to right, oklch(0.55 0.10 220 / 0.10) 1px, transparent 1px),
      linear-gradient(to bottom, oklch(0.55 0.10 220 / 0.10) 1px, transparent 1px);
    background-size: 26px 26px;
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 30% 50%, black, transparent);
    mask-image: radial-gradient(ellipse 80% 70% at 30% 50%, black, transparent);
  }
  :global([data-theme='dark']) .product-band__grid {
    background-image:
      linear-gradient(to right, oklch(0.70 0.12 210 / 0.09) 1px, transparent 1px),
      linear-gradient(to bottom, oklch(0.70 0.12 210 / 0.09) 1px, transparent 1px);
  }
  @media (min-width: 1024px) {
    .pband3d-stage { perspective: 1400px; }
    .pband3d-plane {
      transform: rotateX(14deg) rotateZ(-3deg) scale(0.97) translateY(6px);
      animation: pband3d-drift 15s ease-in-out infinite alternate;
      will-change: transform;
    }
    @keyframes pband3d-drift {
      from { transform: rotateX(14deg) rotateZ(-3deg) scale(0.97) translateY(6px); }
      to   { transform: rotateX(19deg) rotateZ(3deg) scale(1) translateY(2px); }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .pband3d-plane { animation: none; }
  }
</style>
