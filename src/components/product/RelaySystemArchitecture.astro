    </g>
    <text x="544" y="42" fill="var(--svg-accent-purple)" font-family="var(--font-mono)" font-size="11" font-weight="700" letter-spacing="1">GOVERN</text>

    <!-- Converse -->
    <rect x="682" y="18" width="160" height="38" rx="6" fill="var(--svg-accent-orange)" fill-opacity="0.2" stroke="var(--svg-accent-orange)" stroke-width="1" stroke-opacity="0.4" />
    <g transform="translate(696, 28) scale(0.7)" fill="none" stroke="var(--svg-accent-orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
    </g>
    <text x="724" y="42" fill="var(--svg-accent-orange)" font-family="var(--font-mono)" font-size="11" font-weight="700" letter-spacing="1">CONVERSE</text>
  </g>

  <!-- ═══ ROW LABELS ═══ -->
  <g class="svg-reveal svg-reveal-d1">
