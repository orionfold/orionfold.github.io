      <circle cx="12" cy="12" r="10" /><path d="M16 12H8M12 16V8" />
    </g>
    <text x="156" y="42" fill="var(--svg-accent-blue)" font-family="var(--font-mono)" font-size="11" font-weight="700" letter-spacing="1">ORCHESTRATE</text>

    <!-- Automate -->
    <rect x="306" y="18" width="160" height="38" rx="6" fill="var(--svg-accent-teal)" fill-opacity="0.2" stroke="var(--svg-accent-teal)" stroke-width="1" stroke-opacity="0.4" />
    <g transform="translate(320, 28) scale(0.7)" fill="none" stroke="var(--svg-accent-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
