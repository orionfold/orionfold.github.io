---
/**
 * Relay full system architecture: 4 pillars (Orchestrate, Automate, Govern,
 * Converse) across 3 layers (Surfaces, Services, Infrastructure) plus a tech
 * stack bar. Ported from the legacy ainative.business SystemArchitecture.astro
 * (the ai-transformation field note's Figure 4, on the property now known as
 * Orionfold Relay), 2026-07-01.
 *
 * This is the "full" diagram that the compact RelayArchitectureGlance expands to
 * (inline progressive disclosure, wired in RelayUnderTheHood). Geometry carried
 * over verbatim: both repos share the SVG-var contract + svg-reveal/sa-flow
 * classes, so it themes to Orionfold's palette and animates unchanged. Only the
 * LABELS were refreshed to current Relay reality from the peer SSOT
 * (~/orionfold/relay README + features/stats/snapshot.json, 2026-06-23):
 *   - "Profiles (21+)" -> "Agents (21)" (Profiles renamed to Agents 2026-07-05)
 *   - Converse/Surfaces "Slack · Telegram" -> "Apps · Palette" (chat-built apps)
 *   - Infra/Automate "SQLite (45+ tables)" -> "SQLite (43 tables)"
 *   - Infra/Automate "~/.ainative/ workspace" -> "Local workspace"
 *   - Infra/Converse "Slack · Telegram APIs" -> "Multi-vendor APIs"
 *   - the two unsourced surface/API counts ("39 screens" / "169 APIs") were
 *     replaced with un-numbered labels (no current SSOT figure to back them).
 * The tech-stack bar matches the peer README badges (TypeScript, Next.js 16,
 * React 19, Tailwind v4, shadcn/ui, Apache 2.0).
 */
---
<svg
  viewBox="0 0 880 560"
  xmlns="http://www.w3.org/2000/svg"
  class="mx-auto w-full"
  data-svg-animate
  role="img"
  aria-label="Relay system architecture: four pillars — Orchestrate, Automate, Govern, Converse — each spanning three layers of surfaces, services, and infrastructure, on a TypeScript, Next.js 16, React 19 stack"
>
  <defs>
    <linearGradient id="rsa-orch-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--svg-accent-blue)" stop-opacity="0.12" />
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.03" />
    </linearGradient>
    <linearGradient id="rsa-auto-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--svg-accent-teal)" stop-opacity="0.12" />
      <stop offset="100%" stop-color="var(--svg-accent-teal)" stop-opacity="0.03" />
    </linearGradient>
    <linearGradient id="rsa-gov-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--svg-accent-purple)" stop-opacity="0.12" />
      <stop offset="100%" stop-color="var(--svg-accent-purple)" stop-opacity="0.03" />
    </linearGradient>
    <linearGradient id="rsa-conv-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--svg-accent-orange)" stop-opacity="0.12" />
      <stop offset="100%" stop-color="var(--svg-accent-orange)" stop-opacity="0.03" />
    </linearGradient>
  </defs>
  <style>
    @keyframes rsa-dash { to { stroke-dashoffset: -14; } }
    .rsa-flow { stroke-dasharray: 4 3; animation: rsa-dash 0.8s linear infinite; }
    @media (prefers-reduced-motion: reduce) { .rsa-flow { animation: none; } }
  </style>

  <!-- ═══ COLUMN BACKGROUNDS ═══ -->
  <g class="svg-reveal">
    <rect x="108" y="8" width="180" height="504" rx="8" fill="url(#rsa-orch-grad)" stroke="var(--svg-stroke)" stroke-width="0.5" />
    <rect x="296" y="8" width="180" height="504" rx="8" fill="url(#rsa-auto-grad)" stroke="var(--svg-stroke)" stroke-width="0.5" />
    <rect x="484" y="8" width="180" height="504" rx="8" fill="url(#rsa-gov-grad)" stroke="var(--svg-stroke)" stroke-width="0.5" />
    <rect x="672" y="8" width="180" height="504" rx="8" fill="url(#rsa-conv-grad)" stroke="var(--svg-stroke)" stroke-width="0.5" />
  </g>

  <!-- ═══ COLUMN HEADERS ═══ -->
  <g class="svg-reveal">
    <!-- Orchestrate -->
    <rect x="118" y="18" width="160" height="38" rx="6" fill="var(--svg-accent-blue)" fill-opacity="0.2" stroke="var(--svg-accent-blue)" stroke-width="1" stroke-opacity="0.4" />
