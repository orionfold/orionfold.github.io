---
// Orionfold Relay purchase block (relay ask orionfold-relay 2026-06-30). Sits on
// the /relay/ page and turns "the engine is free" into "own the premium packs".
// Mirrors ProofBox.astro: price + founding cap + window come from the catalog
// SSOT (RELAY in commerce.ts), so the chips and the buy buttons can never drift.
// The charging buttons render ONLY when ORIONFOLD_RELAY_LIVE is true (launch
// flag) — before the flip, the full pitch shows with a "tell me at launch" path
// instead, so no one can pay before fulfillment (the signed
// `product:orionfold-relay` license) is proven live.
//
// Self-contained: /relay/ is a plain page, so the roadmap attribution id is a
// literal here. Voice: grade 3-5, jargon explained, no em-dashes
// (website-copy-style).
import { Image } from 'astro:assets';
import { RELAY, formatUsd } from '../../data/commerce';
import { ORIONFOLD_RELAY_LIVE } from '../../data/launch';
import relayPoster from '../../assets/projects/orionfold-relay-poster.jpeg';

const ROADMAP_ITEM_ID = 'software:orionfold-relay';

const primary = formatUsd(RELAY.primary.amount);
const founding = formatUsd(RELAY.founding.amount);
const renewal = formatUsd(RELAY.renewal.amount);

const enquiryHref = `/adoption/?item=${ROADMAP_ITEM_ID}`;
---
<section id="get-relay" class="scroll-mt-24 px-6 py-16">
  <div class="mx-auto max-w-3xl">
    <div data-animate class="overflow-hidden rounded-2xl border border-primary/40 bg-surface-raised shadow-lg shadow-primary/5">
      <!-- Poster header: the same sci-fi key art that drifts in the mid-page band,
           here as a full-width banner so the block and band read as one product. -->
      <div class="relay-poster relative overflow-hidden border-b border-primary/20">
        <Image
          src={relayPoster}
          alt="Orionfold Relay poster: one operator at a wide command wall of glowing client panels, running a whole AI agency from one board."
          widths={[640, 960]}
          sizes="(min-width: 768px) 48rem, 100vw"
          loading="lazy"
          decoding="async"
          data-no-zoom
          class="relay-poster__img block aspect-[16/7] w-full object-cover object-top"
        />
      </div>

      <div class="p-8">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-primary">
        Own the premium packs
      </p>

      <div class="mt-4 flex flex-wrap items-end justify-between gap-4">
        <div>
          <h2 class="font-display text-2xl font-bold sm:text-3xl">Get Orionfold Relay</h2>
          <p class="mt-2 max-w-xl text-text-muted">
            The Relay engine is free and open. You install it with one command and run your agents
            and workflows from one place. A license unlocks the premium packs you own: ready-made
            agents, blueprints, and customer setups you drop in instead of building from scratch,
            starting with the agency pack for real-estate and nonprofit work.
          </p>
        </div>
        {!ORIONFOLD_RELAY_LIVE && (
          <span class="rounded-full border border-primary/40 px-3 py-1 font-mono text-xs tracking-wider text-primary">
            Launching soon
          </span>
        )}
      </div>

      <p class="mt-5 text-sm text-text-muted">
        The engine stays free forever. Your license is the key that adds a premium pack: run
        <span class="font-mono text-primary">relay pack add</span> with your own private link and
        the pack installs. One license, every pack you own, no re-buying when new packs ship.
      </p>

      <!-- Price: lead with the founding hook, standard behind it -->
      <div class="mt-6 flex flex-wrap items-end justify-between gap-4 border-t border-border/60 pt-6">
        <p class="flex items-baseline gap-2">
          <span class="font-display text-4xl font-bold text-primary">{founding}</span>
          <span class="font-mono text-xs tracking-wider text-text-muted">
            founding, first {RELAY.foundingSeats} licenses
          </span>
        </p>
        <p class="rounded-lg bg-primary/10 px-3 py-2 font-mono text-xs tracking-wider text-primary">
          then {primary} one time, {RELAY.windowMonths}-month window included
        </p>
      </div>

      {ORIONFOLD_RELAY_LIVE ? (
        <div class="mt-6 flex flex-wrap items-center gap-4">
          <button
            type="button"
            data-checkout={RELAY.founding.lookupKey}
            data-item={ROADMAP_ITEM_ID}
            data-error-target="relay-err"
            class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-accent px-5 py-3 font-mono text-sm tracking-wider text-accent-text transition-colors hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-60"
          >
            Buy now, founding · {founding}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </button>
          <button
            type="button"
            data-checkout={RELAY.primary.lookupKey}
            data-item={ROADMAP_ITEM_ID}
            data-error-target="relay-err"
            class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-primary/40 px-5 py-3 font-mono text-sm tracking-wider text-primary transition-colors hover:bg-primary/10 disabled:cursor-not-allowed disabled:opacity-60"
          >
            Buy at {primary}
          </button>
        </div>
      ) : (
        <div class="mt-6 flex flex-wrap items-center gap-4">
          <a
            href={enquiryHref}
            class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-accent px-5 py-3 font-mono text-sm tracking-wider text-accent-text transition-colors hover:bg-accent-hover"
          >
            Tell me when it launches
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </a>
          <span class="font-mono text-xs tracking-wider text-text-muted">
            Founding price holds for the first {RELAY.foundingSeats} licenses.
          </span>
        </div>
      )}
      <p id="relay-err" role="alert" hidden class="mt-2 font-mono text-xs text-red-500"></p>
      <p class="mt-4 text-sm text-text-muted">
        Your packs are yours forever. Renewal gets you the year's new and updated packs and priority
        support.
      </p>
      <p class="mt-2 text-sm text-text-muted">
        After the first year, renewal is {renewal}/yr. It is optional.
      </p>

      <div class="mt-6 border-t border-border/60 pt-5">
        <p class="text-sm text-text-muted">
          Buying for a team? We take purchase orders and can work under your MSA. Email
          <a href="mailto:manav@orionfold.com" class="text-primary hover:text-primary/80 transition-colors">manav@orionfold.com</a>.
        </p>
        <p class="mt-3 text-sm text-text-muted">
          Read the
          <a
            href="/trust/license-terms/"
            class="text-primary hover:text-primary/80 transition-colors"
          >full license terms, in plain language</a>: seats, transfer, and exactly what renewal does and does not change.
        </p>
      </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* A slow ambient float on the poster banner (subtler than the band's isometric
     tilt, since this is a flat full-width banner not a tilted thumbnail). Desktop
     only, reduced-motion safe. */
  @media (min-width: 1024px) {
    .relay-poster__img {
      animation: relay-poster-float 16s ease-in-out infinite alternate;
      will-change: transform;
    }
    @keyframes relay-poster-float {
      from { transform: scale(1.02) translateY(0); }
      to   { transform: scale(1.06) translateY(-6px); }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .relay-poster__img { animation: none; }
  }
</style>
