---
import { RELAY_HOST, formatUsd } from '../../data/commerce';
import relayHostTopology from '../../assets/relay/relay-host-topology.svg';
import relayShots from '../../data/relay-shots.json';
import { themedShotProps } from '../relay/themed-shot.logic.mjs';

interface Props {
  placement?: 'home' | 'relay';
}

const { placement = 'relay' } = Astro.props;
const isHome = placement === 'home';
const price = formatUsd(RELAY_HOST.amount);
const sectionId = isHome ? 'relay-host' : 'get-relay-host';
const headingId = `${sectionId}-heading`;
const deploymentShot = themedShotProps(relayShots, {
  id: 'settings-host-deployment',
  alt: 'Relay Host deployment screen showing local and cloud placement, administrator trust, managed automation licensing and Host configuration',
});
---

<section id={sectionId} aria-labelledby={headingId} class="relay-host-feature scroll-mt-24 px-6 py-12 sm:py-16">
  <div data-animate class="relay-host-feature__canvas mx-auto max-w-6xl overflow-hidden rounded-3xl">
    <div class="relay-host-feature__glow" aria-hidden="true"></div>
    <div class="relative z-10 grid items-center gap-9 p-7 sm:p-10 lg:grid-cols-[0.78fr_1.22fr] lg:gap-12 lg:p-12">
      <div class="relay-host-feature__copy">
        <p class="relay-host-feature__eyebrow font-mono text-[0.62rem] uppercase tracking-[0.25em]">
          Managed customer operations
        </p>
        <h2 id={headingId} class="relay-host-feature__title mt-3 text-balance font-display text-[clamp(2.65rem,5.4vw,5.35rem)] font-bold leading-[0.94] tracking-[-0.045em]">
          Relay <span class="relay-host-feature__title-accent">Host</span>
        </h2>
        <p class="relay-host-feature__tagline mt-5 text-balance font-display text-[clamp(1.15rem,2vw,1.65rem)] leading-tight">
          One Host. <span class="relay-host-feature__tagline-accent">Ten managed Cells.</span>
        </p>

        <img
          src={relayHostTopology.src}
          alt="One Relay Host branching to ten isolated managed customer Cells"
          width="620"
          height="300"
          loading="lazy"
          decoding="async"
          class="relay-host-feature__topology mt-6 h-auto w-full max-w-[31rem]"
          data-no-zoom
        />

        <p class="relay-host-feature__description mt-5 max-w-lg text-sm leading-relaxed sm:text-base">
          {isHome
            ? 'Run customer work through one Host while each customer keeps a complete, isolated Relay Cell.'
            : 'Run one licensed Host for managed customer work while every customer keeps a complete, isolated Relay Cell.'}
        </p>

        <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-3">
          <a href="/relay/host/" class="relay-host-feature__cta">
            Explore Relay Host
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <p class="relay-host-feature__price font-mono text-xs uppercase tracking-[0.15em]">{price}/year</p>
        </div>
      </div>

      <a href="/relay/host/" class="relay-host-shot block" aria-label="Explore Relay Host and its managed Cell deployment workflow">
        <div class="relay-host-shot__frame">
          <div class="relay-host-shot__bar" aria-hidden="true">
            <span class="relay-host-shot__dot bg-[#ff5f57]"></span>
            <span class="relay-host-shot__dot bg-[#febc2e]"></span>
            <span class="relay-host-shot__dot bg-[#28c840]"></span>
            <span class="relay-host-shot__tab">orionfold relay · host deployment</span>
            <span class="relay-host-shot__live"><span class="relay-host-shot__livedot"></span>HOST</span>
          </div>
          <div class="relay-host-shot__view">
            <img
              width={deploymentShot.width}
              height={deploymentShot.height}
              alt={deploymentShot.alt}
              sizes={deploymentShot.sizes}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover object-top"
              data-relay-shot
              data-shot-light-src={deploymentShot.light.src}
              data-shot-light-srcset={deploymentShot.light.srcset}
              data-shot-dark-src={deploymentShot.dark.src}
              data-shot-dark-srcset={deploymentShot.dark.srcset}
              data-no-zoom
            />
            <noscript>
              <img
                src={deploymentShot.light.src}
                srcset={deploymentShot.light.srcset}
                sizes={deploymentShot.sizes}
                width={deploymentShot.width}
                height={deploymentShot.height}
                alt={deploymentShot.alt}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover object-top"
                data-no-zoom
              />
            </noscript>
            <span class="relay-host-shot__sheen" aria-hidden="true"></span>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .relay-host-feature__canvas {
    --host-canvas-border: rgb(14 158 152 / 0.28);
    --host-grid-line: rgb(14 158 152 / 0.08);
    --host-canvas-radial: rgb(14 158 152 / 0.13);
    --host-canvas-bg: #eff9f8;
    --host-canvas-shadow: 0 34px 82px -42px rgb(24 74 78 / 0.38), 0 0 0 1px rgb(14 158 152 / 0.08);
    --host-glow: rgb(14 158 152 / 0.14);
    --host-eyebrow: #087c77;
    --host-title: #142126;
    --host-title-accent: #0b8d87;
    --host-tagline: #34484e;
    --host-tagline-accent: #0b8d87;
    --host-description: #53666c;
    --host-price: #65777c;
    --host-cta-bg: #0e9e98;
    --host-cta-hover: #0b8b86;
    --host-cta-text: #ffffff;
    --host-cta-ring: rgb(14 158 152 / 0.12);
    --host-focus: #0e9e98;
    --host-shot-glow: rgb(14 158 152 / 0.14);
    --host-frame-border: rgb(14 158 152 / 0.34);
    --host-frame-bg: #ffffff;
    --host-frame-shadow: 0 34px 70px -32px rgb(24 74 78 / 0.45), 0 0 0 1px rgb(14 158 152 / 0.08);
    --host-frame-hover-shadow: 0 42px 82px -32px rgb(24 74 78 / 0.5), 0 0 0 1px rgb(14 158 152 / 0.28);
    --host-bar-border: rgb(87 132 137 / 0.24);
    --host-bar-bg: #f5fafa;
    --host-tab: rgb(60 83 88 / 0.68);
    --host-live: #0b8d87;
    --host-live-dot: #0e9e98;
    --host-sheen: rgb(255 255 255 / 0.3);
    position: relative;
    isolation: isolate;
    border: 1px solid var(--host-canvas-border);
    background:
      linear-gradient(var(--host-grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--host-grid-line) 1px, transparent 1px),
      radial-gradient(circle at 82% 18%, var(--host-canvas-radial), transparent 38%),
      var(--host-canvas-bg);
    background-size: 42px 42px, 42px 42px, auto, auto;
    box-shadow: var(--host-canvas-shadow);
    transition: background-color 180ms ease, border-color 180ms ease;
  }

  :global(html[data-theme='dark']) .relay-host-feature__canvas {
    --host-canvas-border: rgb(77 222 219 / 0.32);
    --host-grid-line: rgb(39 213 210 / 0.055);
    --host-canvas-radial: rgb(28 203 199 / 0.12);
    --host-canvas-bg: #061117;
    --host-canvas-shadow: 0 34px 90px -42px rgb(0 0 0 / 0.85), 0 0 0 1px rgb(20 200 192 / 0.07);
    --host-glow: rgb(23 210 205 / 0.13);
    --host-eyebrow: #57e9e5;
    --host-title: #ffffff;
    --host-title-accent: #21d3d0;
    --host-tagline: rgb(255 255 255 / 0.9);
    --host-tagline-accent: #38e2de;
    --host-description: rgb(255 255 255 / 0.65);
    --host-price: rgb(255 255 255 / 0.55);
    --host-cta-bg: #2ad6d2;
    --host-cta-hover: #4ce3df;
    --host-cta-text: #03201f;
    --host-cta-ring: rgb(42 214 210 / 0.15);
    --host-focus: #6ff0ed;
    --host-shot-glow: rgb(33 211 208 / 0.19);
    --host-frame-border: rgb(96 221 219 / 0.48);
    --host-frame-bg: #071219;
    --host-frame-shadow: 0 34px 70px -28px rgb(0 0 0 / 0.9), 0 0 0 1px rgb(66 232 228 / 0.12);
    --host-frame-hover-shadow: 0 46px 86px -28px rgb(0 0 0 / 0.95), 0 0 0 1px rgb(74 238 234 / 0.45);
    --host-bar-border: rgb(71 112 120 / 0.42);
    --host-bar-bg: #09171e;
    --host-tab: rgb(220 239 241 / 0.58);
    --host-live: #4de7e3;
    --host-live-dot: #32dcd8;
    --host-sheen: rgb(202 255 253 / 0.11);
  }

  .relay-host-feature__glow {
    position: absolute;
    inset: auto -8rem -11rem 35%;
    height: 28rem;
    border-radius: 999px;
    background: var(--host-glow);
    filter: blur(100px);
    pointer-events: none;
  }

  .relay-host-feature__copy,
  .relay-host-shot {
    min-width: 0;
  }

  .relay-host-feature__eyebrow { color: var(--host-eyebrow); }
  .relay-host-feature__title { color: var(--host-title); }
  .relay-host-feature__title-accent { color: var(--host-title-accent); }
  .relay-host-feature__tagline { color: var(--host-tagline); }
  .relay-host-feature__tagline-accent { color: var(--host-tagline-accent); }
  .relay-host-feature__description { color: var(--host-description); }
  .relay-host-feature__price { color: var(--host-price); }

  .relay-host-feature__topology {
    filter: drop-shadow(0 16px 28px rgb(14 88 86 / 0.12));
  }

  :global(html[data-theme='dark']) .relay-host-feature__topology {
    filter: none;
  }

  .relay-host-feature__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border-radius: 0.5rem;
    background: var(--host-cta-bg);
    padding: 0.78rem 1.05rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--host-cta-text);
    transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
  }

  .relay-host-feature__cta:hover {
    transform: translateY(-2px);
    background: var(--host-cta-hover);
    box-shadow: 0 0 0 4px var(--host-cta-ring);
  }

  .relay-host-feature__cta:focus-visible,
  .relay-host-shot:focus-visible {
    outline: 2px solid var(--host-focus);
    outline-offset: 4px;
  }

  .relay-host-shot {
    position: relative;
    width: 100%;
    animation: relay-host-float 8s ease-in-out infinite;
  }

  .relay-host-shot::after {
    content: '';
    position: absolute;
    inset: -3.5rem;
    z-index: -1;
    background: radial-gradient(ellipse at center, var(--host-shot-glow), transparent 68%);
    pointer-events: none;
  }

  .relay-host-shot__frame {
    overflow: hidden;
    border: 1px solid var(--host-frame-border);
    border-radius: 0.85rem;
    background: var(--host-frame-bg);
    box-shadow: var(--host-frame-shadow);
    transform: perspective(1200px) rotateY(-2deg) rotateX(1deg);
    transition: transform 400ms ease, box-shadow 400ms ease;
  }

  .relay-host-shot:hover .relay-host-shot__frame {
    transform: perspective(1200px) rotateY(0) rotateX(0) translateY(-4px);
    box-shadow: var(--host-frame-hover-shadow);
  }

  .relay-host-shot__bar {
    display: flex;
    align-items: center;
    gap: 0.38rem;
    min-width: 0;
    border-bottom: 1px solid var(--host-bar-border);
    background: var(--host-bar-bg);
    padding: 0.62rem 0.8rem;
  }

  .relay-host-shot__dot {
    width: 0.55rem;
    height: 0.55rem;
    flex: none;
    border-radius: 999px;
  }

  .relay-host-shot__tab {
    min-width: 0;
    overflow: hidden;
    margin-left: 0.45rem;
    color: var(--host-tab);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .relay-host-shot__live {
    display: inline-flex;
    flex: none;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
    color: var(--host-live);
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
  }

  .relay-host-shot__livedot {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--host-live-dot);
    animation: relay-host-live 2.2s ease-in-out infinite;
  }

  .relay-host-shot__view {
    position: relative;
    aspect-ratio: 1.31 / 1;
    overflow: hidden;
  }

  .relay-host-shot__sheen {
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 38%, var(--host-sheen) 50%, transparent 62%);
    transform: translateX(-130%);
    animation: relay-host-sheen 9s ease-in-out 2s infinite;
    pointer-events: none;
  }

  @keyframes relay-host-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @keyframes relay-host-live {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgb(50 220 216 / 0.28); }
    50% { opacity: 0.45; box-shadow: 0 0 0 4px transparent; }
  }

  @keyframes relay-host-sheen {
    0% { transform: translateX(-130%); }
    30%, 100% { transform: translateX(130%); }
  }

  @media (max-width: 639px) {
    .relay-host-feature__copy > img {
      max-width: 27rem;
    }

    .relay-host-shot__frame {
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .relay-host-shot,
    .relay-host-shot__livedot,
    .relay-host-shot__sheen {
      animation: none;
    }

    .relay-host-shot__sheen {
      display: none;
    }

    .relay-host-feature__cta,
    .relay-host-shot__frame {
      transition: none;
    }
  }
</style>
