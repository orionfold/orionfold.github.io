---
import { Image } from 'astro:assets';
import { RELAY_HOST, formatUsd } from '../../data/commerce';
import relayHostTopology from '../../assets/relay/relay-host-topology.svg';
import relayHostDeployment from '../../assets/relay/relay-host-deployment.webp';

interface Props {
  placement?: 'home' | 'relay';
}

const { placement = 'relay' } = Astro.props;
const isHome = placement === 'home';
const price = formatUsd(RELAY_HOST.amount);
const sectionId = isHome ? 'relay-host' : 'get-relay-host';
const headingId = `${sectionId}-heading`;
---

<section id={sectionId} aria-labelledby={headingId} class="relay-host-feature scroll-mt-24 px-6 py-12 sm:py-16">
  <div data-animate class="relay-host-feature__canvas mx-auto max-w-6xl overflow-hidden rounded-3xl">
    <div class="relay-host-feature__glow" aria-hidden="true"></div>
    <div class="relative z-10 grid items-center gap-9 p-7 sm:p-10 lg:grid-cols-[0.78fr_1.22fr] lg:gap-12 lg:p-12">
      <div class="relay-host-feature__copy">
        <p class="font-mono text-[0.62rem] uppercase tracking-[0.25em] text-[#57e9e5]">
          Managed customer operations
        </p>
        <h2 id={headingId} class="mt-3 text-balance font-display text-[clamp(2.65rem,5.4vw,5.35rem)] font-bold leading-[0.94] tracking-[-0.045em] text-white">
          Relay <span class="text-[#21d3d0]">Host</span>
        </h2>
        <p class="mt-5 text-balance font-display text-[clamp(1.15rem,2vw,1.65rem)] leading-tight text-white/90">
          One Host. <span class="text-[#38e2de]">Ten managed Cells.</span>
        </p>

        <img
          src={relayHostTopology.src}
          alt="One Relay Host branching to ten isolated managed customer Cells"
          width="620"
          height="300"
          loading="lazy"
          decoding="async"
          class="mt-6 h-auto w-full max-w-[31rem]"
          data-no-zoom
        />

        <p class="mt-5 max-w-lg text-sm leading-relaxed text-white/65 sm:text-base">
          {isHome
            ? 'Run customer work through one Host while each customer keeps a complete, isolated Relay Cell.'
            : 'Run one licensed Host for managed customer work while every customer keeps a complete, isolated Relay Cell.'}
        </p>

        <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-3">
          <a href="/relay/host/" class="relay-host-feature__cta">
            Explore Relay Host
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <p class="font-mono text-xs uppercase tracking-[0.15em] text-white/55">{price}/year</p>
        </div>
      </div>

      <a href="/relay/host/" class="relay-host-shot block" aria-label="Explore Relay Host and its managed Cell deployment workflow">
        <div class="relay-host-shot__frame">
          <div class="relay-host-shot__bar" aria-hidden="true">
            <span class="relay-host-shot__dot bg-[#ff5f57]"></span>
            <span class="relay-host-shot__dot bg-[#febc2e]"></span>
            <span class="relay-host-shot__dot bg-[#28c840]"></span>
            <span class="relay-host-shot__tab">orionfold relay · host deployment</span>
            <span class="relay-host-shot__live"><span class="relay-host-shot__livedot"></span>HOST</span>
          </div>
          <div class="relay-host-shot__view">
            <Image
              src={relayHostDeployment}
              alt="Relay Host deployment screen showing local and cloud placement, administrator trust, managed automation licensing and Host configuration"
              widths={[560, 760, 960, 1280]}
              sizes="(min-width: 1024px) 650px, calc(100vw - 5rem)"
              format="webp"
              quality={78}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover object-top"
              data-no-zoom
            />
            <span class="relay-host-shot__sheen" aria-hidden="true"></span>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .relay-host-feature__canvas {
    position: relative;
    isolation: isolate;
    border: 1px solid rgb(77 222 219 / 0.32);
    background:
      linear-gradient(rgb(39 213 210 / 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgb(39 213 210 / 0.055) 1px, transparent 1px),
      radial-gradient(circle at 82% 18%, rgb(28 203 199 / 0.12), transparent 38%),
      #061117;
    background-size: 42px 42px, 42px 42px, auto, auto;
    box-shadow: 0 34px 90px -42px rgb(0 0 0 / 0.85), 0 0 0 1px rgb(20 200 192 / 0.07);
  }

  .relay-host-feature__glow {
    position: absolute;
    inset: auto -8rem -11rem 35%;
    height: 28rem;
    border-radius: 999px;
    background: rgb(23 210 205 / 0.13);
    filter: blur(100px);
    pointer-events: none;
  }

  .relay-host-feature__copy,
  .relay-host-shot {
    min-width: 0;
  }

  .relay-host-feature__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border-radius: 0.5rem;
    background: #2ad6d2;
    padding: 0.78rem 1.05rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #03201f;
    transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
  }

  .relay-host-feature__cta:hover {
    transform: translateY(-2px);
    background: #4ce3df;
    box-shadow: 0 0 0 4px rgb(42 214 210 / 0.15);
  }

  .relay-host-feature__cta:focus-visible,
  .relay-host-shot:focus-visible {
    outline: 2px solid #6ff0ed;
    outline-offset: 4px;
  }

  .relay-host-shot {
    position: relative;
    width: 100%;
    animation: relay-host-float 8s ease-in-out infinite;
  }

  .relay-host-shot::after {
    content: '';
    position: absolute;
    inset: -3.5rem;
    z-index: -1;
    background: radial-gradient(ellipse at center, rgb(33 211 208 / 0.19), transparent 68%);
    pointer-events: none;
  }

  .relay-host-shot__frame {
    overflow: hidden;
    border: 1px solid rgb(96 221 219 / 0.48);
    border-radius: 0.85rem;
    background: #071219;
    box-shadow: 0 34px 70px -28px rgb(0 0 0 / 0.9), 0 0 0 1px rgb(66 232 228 / 0.12);
    transform: perspective(1200px) rotateY(-2deg) rotateX(1deg);
    transition: transform 400ms ease, box-shadow 400ms ease;
  }

  .relay-host-shot:hover .relay-host-shot__frame {
    transform: perspective(1200px) rotateY(0) rotateX(0) translateY(-4px);
    box-shadow: 0 46px 86px -28px rgb(0 0 0 / 0.95), 0 0 0 1px rgb(74 238 234 / 0.45);
  }

  .relay-host-shot__bar {
    display: flex;
    align-items: center;
    gap: 0.38rem;
    min-width: 0;
    border-bottom: 1px solid rgb(71 112 120 / 0.42);
    background: #09171e;
    padding: 0.62rem 0.8rem;
  }

  .relay-host-shot__dot {
    width: 0.55rem;
    height: 0.55rem;
    flex: none;
    border-radius: 999px;
  }

  .relay-host-shot__tab {
    min-width: 0;
    overflow: hidden;
    margin-left: 0.45rem;
    color: rgb(220 239 241 / 0.58);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .relay-host-shot__live {
    display: inline-flex;
    flex: none;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
    color: #4de7e3;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
  }

  .relay-host-shot__livedot {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: #32dcd8;
    animation: relay-host-live 2.2s ease-in-out infinite;
  }

  .relay-host-shot__view {
    position: relative;
    aspect-ratio: 1.31 / 1;
    overflow: hidden;
  }

  .relay-host-shot__sheen {
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 38%, rgb(202 255 253 / 0.11) 50%, transparent 62%);
    transform: translateX(-130%);
    animation: relay-host-sheen 9s ease-in-out 2s infinite;
    pointer-events: none;
  }

  @keyframes relay-host-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @keyframes relay-host-live {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgb(50 220 216 / 0.28); }
    50% { opacity: 0.45; box-shadow: 0 0 0 4px transparent; }
  }

  @keyframes relay-host-sheen {
    0% { transform: translateX(-130%); }
    30%, 100% { transform: translateX(130%); }
  }

  @media (max-width: 639px) {
    .relay-host-feature__copy > img {
      max-width: 27rem;
    }

    .relay-host-shot__frame {
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .relay-host-shot,
    .relay-host-shot__livedot,
    .relay-host-shot__sheen {
      animation: none;
    }

    .relay-host-shot__sheen {
      display: none;
    }

    .relay-host-feature__cta,
    .relay-host-shot__frame {
      transition: none;
    }
  }
</style>
