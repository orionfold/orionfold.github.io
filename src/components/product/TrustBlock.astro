---
// Trust block (P1 + P3, spec §4 "trust for an unknown studio"). Shows the live
// HuggingFace social proof — download/like counts pulled at build time
// (src/lib/trust/source.ts) — as stat tiles, plus attributed quotes if any are
// ever authored (none today: invented quotes are a trust risk on a selling site,
// so P2 dropped them and P3 fills the slot with real numbers). Renders only when
// there is something real to show.
interface Props {
  stats?: { label: string; value: string }[];
  testimonials?: { quote: string; author: string; role?: string }[];
}
const { stats = [], testimonials = [] } = Astro.props;
const hasStats = stats.length > 0;
const hasQuotes = testimonials.length > 0;
---
{(hasStats || hasQuotes) && (
  <section class="px-6 py-12">
    <div class="mx-auto max-w-3xl">
      {hasStats && (
        <div>
          <h2 data-animate class="font-display text-2xl font-bold">Used in the open</h2>
          <p data-animate class="mt-2 text-text-muted">
            Live counts from HuggingFace, refreshed when the site builds. Built and maintained in
            the open by Orionfold.
          </p>
          <dl data-animate-stagger class="mt-6 flex flex-wrap gap-4">
            {stats.map((s) => (
              <div data-animate class="flex-1 rounded-xl border border-border bg-surface-raised px-5 py-5" style="min-width: 9rem">
                <dd class="font-display text-3xl font-bold leading-none text-text">{s.value}</dd>
                <dt class="mt-2 font-mono text-[10px] uppercase tracking-wider text-text-muted">{s.label}</dt>
              </div>
            ))}
          </dl>
        </div>
      )}

      {hasQuotes && (
        <div class={hasStats ? 'mt-10' : ''}>
          <h2 data-animate class="font-display text-2xl font-bold">What people say</h2>
          <div data-animate-stagger class="mt-6 grid gap-5 sm:grid-cols-2">
            {testimonials.map((t) => (
              <figure data-animate class="rounded-xl border border-border bg-surface-raised p-5">
                <blockquote class="text-text">“{t.quote}”</blockquote>
                <figcaption class="mt-4 font-mono text-xs tracking-wider text-text-muted">
                  {t.author}{t.role && <span class="text-text-muted/70"> · {t.role}</span>}
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
)}
