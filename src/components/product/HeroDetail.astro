---
// Product detail hero (P1, spec §4 "10-second hero"). Type tag, name, one-line
// value prop, ONE role-correct primary CTA, the key visual, and a metadata-chip
// strip. The primary CTA is a Buy button (books, wired by wireCheckoutButtons)
// or a "Sponsor" anchor that scrolls to the SponsorBlock (#sponsor). A product
// with a hosted demo (view.demo) gets a prominent outlined "try it" button next
// to it; the demoted canonical/outbound link sits beside them as a ghost
// secondary. Always renders.
import { Image } from 'astro:assets';
import type { ProductView } from '../../lib/product/detail';

interface Props {
  view: ProductView;
  hero?: ImageMetadata;
  heroAlt?: string;
  chips?: { label: string; value: string }[];
  /** Display price for the Buy CTA, e.g. "$20" (books). */
  priceLabel?: string;
}
const { view, hero, heroAlt, chips, priceLabel } = Astro.props;
const buyLabel = priceLabel ? `Buy PDF + EPUB · ${priceLabel}` : 'Buy now';
---
<section class="px-6 pt-32 sm:pt-36">
  <div class="mx-auto grid max-w-6xl items-center gap-10 lg:grid-cols-2">
    <div>
      <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-primary">{view.typeTag}</p>
      <h1 class="mt-3 leading-tight" style="font-size: clamp(2.25rem, 5vw, 3.5rem);">{view.title}</h1>
      <p class="mt-5 text-lg leading-relaxed text-text-muted">{view.valueProp}</p>

      {view.pills.length > 0 && (
        <ul class="mt-6 flex flex-wrap gap-1.5" aria-label="Highlights">
          {view.pills.map((pill) => (
            <li>
              <span class="rounded-full border border-primary/20 bg-primary/5 px-2.5 py-1 font-mono text-[10px] tracking-wider text-primary">{pill}</span>
            </li>
          ))}
        </ul>
      )}

      <div id="hero-cta-sentinel" class="mt-8 flex flex-wrap items-center gap-4">
        {view.cta === 'buy' ? (
          <button
            type="button"
            data-checkout={view.lookupKey}
            data-error-target="hero-cta-err"
            class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-primary px-5 py-3 font-mono text-sm tracking-wider text-white transition-colors hover:bg-primary/90 disabled:cursor-not-allowed disabled:opacity-60"
          >
            {buyLabel}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </button>
        ) : (
          <a
            href="#sponsor"
            class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-primary px-5 py-3 font-mono text-sm tracking-wider text-white transition-colors hover:bg-primary/90"
          >
            Sponsor this work
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </a>
        )}

        {view.demo && (
          <a
            href={view.demo.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-primary/40 bg-primary/10 px-5 py-3 font-mono text-sm tracking-wider text-primary transition-colors hover:bg-primary/15"
          >
            {view.demo.label}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" /></svg>
          </a>
        )}

        {view.outboundPrimary && (
          <a
            href={view.outboundPrimary.href}
            target="_blank"
            rel="noopener noreferrer"
            class="ml-auto inline-flex items-center gap-1.5 font-mono text-sm tracking-wider text-text-muted transition-colors hover:text-primary"
          >
            {view.outboundPrimary.label}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" /></svg>
          </a>
        )}
      </div>
      <p id="hero-cta-err" role="alert" hidden class="mt-2 font-mono text-xs text-red-500"></p>
    </div>

    {hero && (
      <div class="order-first lg:order-last">
        <Image
          src={hero}
          alt={heroAlt ?? view.title}
          widths={[480, 768, 1024]}
          sizes="(min-width: 1024px) 32rem, 100vw"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          data-no-zoom
          class="aspect-[16/10] w-full rounded-2xl border border-border object-cover shadow-lg shadow-primary/5"
        />
      </div>
    )}
  </div>

  {chips && chips.length > 0 && (
    <div data-animate class="mx-auto mt-12 max-w-6xl">
      <dl class="grid grid-cols-2 gap-px overflow-hidden rounded-xl border border-border bg-border sm:grid-cols-4">
        {chips.map((chip) => (
          <div class="bg-surface-raised px-4 py-3">
            <dt class="font-mono text-[10px] uppercase tracking-wider text-text-muted">{chip.label}</dt>
            <dd class="mt-1 text-sm font-medium text-text">{chip.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  )}
</section>
