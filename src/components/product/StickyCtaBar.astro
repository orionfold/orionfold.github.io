---
// Sticky Buy/Sponsor bar (P1, spec §4 "Apple sticky CTA"). A compact bottom bar
// that fades in once the hero CTA scrolls out of view, so the conversion action
// is always one tap away. Progressive enhancement: hidden by default, revealed by
// an IntersectionObserver watching the #hero-cta-sentinel; reduced-motion just
// snaps it in. The Buy variant reuses data-checkout (wired by the layout); the
// Sponsor variant anchors to #sponsor.
import type { ProductView, FieldEditionCta } from '../../lib/product/detail';

interface Props {
  view: ProductView;
  priceLabel?: string;
  fieldEditionCta?: FieldEditionCta;
}
const { view, priceLabel, fieldEditionCta } = Astro.props;
const buyLabel = priceLabel ? `Buy · ${priceLabel}` : 'Buy now';
---
<div
  id="sticky-cta"
  class="fixed inset-x-0 bottom-0 z-40 translate-y-full border-t border-border bg-surface/95 backdrop-blur transition-transform duration-300 [&.is-visible]:translate-y-0 motion-reduce:transition-none"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-3">
    <p class="truncate font-display text-sm font-bold">{view.title}</p>
    <div class="flex shrink-0 items-center gap-2">
    {view.demo && (
      <a
        href={view.demo.href}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex shrink-0 items-center gap-1.5 rounded-lg border border-primary/40 bg-primary/10 px-4 py-2 font-mono text-xs tracking-wider text-primary transition-colors hover:bg-primary/15"
      >
        {view.demo.label}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" /></svg>
      </a>
    )}
    {fieldEditionCta ? (
      fieldEditionCta.live ? (
        <button
          type="button"
          data-checkout={fieldEditionCta.lookupKey}
          data-item={fieldEditionCta.itemId}
          class="inline-flex shrink-0 items-center gap-1.5 rounded-lg bg-accent px-4 py-2 font-mono text-xs tracking-wider text-accent-text transition-colors hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-60"
        >
          Buy now · {fieldEditionCta.priceLabel}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </button>
      ) : (
        <a
          href={fieldEditionCta.anchor}
          class="inline-flex shrink-0 items-center gap-1.5 rounded-lg bg-accent px-4 py-2 font-mono text-xs tracking-wider text-accent-text transition-colors hover:bg-accent-hover"
        >
          Field Edition · {fieldEditionCta.priceLabel}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </a>
      )
    ) : view.cta === 'buy' ? (
      <button
        type="button"
        data-checkout={view.lookupKey}
        class="inline-flex shrink-0 items-center gap-1.5 rounded-lg bg-accent px-4 py-2 font-mono text-xs tracking-wider text-accent-text transition-colors hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-60"
      >
        {buyLabel}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </button>
    ) : (
      <a
        href="#sponsor"
        class="inline-flex shrink-0 items-center gap-1.5 rounded-lg bg-accent px-4 py-2 font-mono text-xs tracking-wider text-accent-text transition-colors hover:bg-accent-hover"
      >
        Sponsor
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>
    )}
    </div>
  </div>
</div>

<script>
  function initStickyCta() {
    const bar = document.getElementById('sticky-cta');
    const sentinel = document.getElementById('hero-cta-sentinel');
    if (!bar || !sentinel) return;
    const io = new IntersectionObserver(
      ([entry]) => bar.classList.toggle('is-visible', !entry.isIntersecting),
      { rootMargin: '0px 0px -80% 0px' },
    );
    io.observe(sentinel);
  }
  initStickyCta();
  document.addEventListener('astro:after-swap', initStickyCta);
</script>
