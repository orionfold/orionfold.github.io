---
// Gallery (P1, spec §4/§5.5; showcase pass 2026-06-10). Real product screenshots
// are the key conversion hook, so items that carry a `detail` explainer render as
// LARGE showcase rows: the shot at its natural aspect ratio (never cropped, so an
// odd-shaped capture stays sharp) beside an explainer block sourced from the
// product's upstream article. Rows alternate image-left/image-right; an ultra-wide
// capture (a banner-shaped rail or strip) stacks full-width with its text below,
// since squeezing it into a half column would shrink it to a sliver. Items without
// `detail` keep the compact two-up grid, also uncropped. Every image is a button
// that opens the shared native <dialog> lightbox (Esc, focus trap, and click-out
// come free from the element); a high-res source per item is pre-generated at
// build time, capped to the source width so Astro never upscales.
import { Image, getImage } from 'astro:assets';

interface Item {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  detail?: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;

// One optimized large source per item for the expanded view.
const full = await Promise.all(
  items.map((it) => getImage({ src: it.src, width: Math.min(1920, it.src.width), format: 'webp' })),
);

const showcase = items
  .map((item, i) => ({ item, i }))
  .filter(({ item }) => Boolean(item.detail));
const compact = items
  .map((item, i) => ({ item, i }))
  .filter(({ item }) => !item.detail);

// A banner-shaped capture (e.g. a telemetry rail) is too short for a side column.
const isUltraWide = (it: Item) => it.src.width / it.src.height >= 2.2;
---
{items.length > 0 && (
  <Fragment>
  <section class="px-6 py-12">
    <div class="mx-auto max-w-6xl">
      <h2 data-animate class="font-display text-2xl font-bold">A closer look</h2>

      {showcase.length > 0 && (
        <div class="mt-8 space-y-14 lg:space-y-20">
          {showcase.map(({ item, i }, n) => (
            <figure
              data-animate
              class:list={[
                'gap-6 lg:gap-10',
                isUltraWide(item)
                  ? 'flex flex-col'
                  : 'grid items-center lg:grid-cols-12',
              ]}
            >
              <button
                type="button"
                data-lightbox-trigger
                data-full={full[i].src}
                data-alt={item.alt}
                aria-label={`Expand image: ${item.alt}`}
                class:list={[
                  'group relative block w-full cursor-zoom-in overflow-hidden rounded-2xl border border-border bg-surface-raised shadow-sm',
                  !isUltraWide(item) && 'lg:col-span-7',
                  !isUltraWide(item) && n % 2 === 1 && 'lg:order-2',
                ]}
              >
                <Image
                  src={item.src}
                  alt={item.alt}
                  widths={[768, 1200, 1600]}
                  sizes={isUltraWide(item) ? '(min-width: 1280px) 72rem, 100vw' : '(min-width: 1024px) 42rem, 100vw'}
                  loading="lazy"
                  decoding="async"
                  data-no-zoom
                  class="h-auto w-full"
                />
                <span class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/0 opacity-0 transition-all duration-300 group-hover:bg-black/15 group-hover:opacity-100">
                  <span class="rounded-full bg-black/55 p-2.5 text-white shadow-lg backdrop-blur">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6M14 10l7-7M9 21H3v-6M10 14l-7 7" /></svg>
                  </span>
                </span>
              </button>
              <figcaption
                class:list={[
                  isUltraWide(item) ? 'max-w-3xl' : 'lg:col-span-5',
                  !isUltraWide(item) && n % 2 === 1 && 'lg:order-1',
                ]}
              >
                <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">{String(n + 1).padStart(2, '0')}</p>
                {item.caption && (
                  <p class="mt-2 font-display text-lg font-semibold leading-snug text-text">{item.caption}</p>
                )}
                <p class="mt-3 leading-relaxed text-text-muted">{item.detail}</p>
              </figcaption>
            </figure>
          ))}
        </div>
      )}

      {compact.length > 0 && (
        <div data-animate-stagger class:list={['grid gap-5 sm:grid-cols-2', showcase.length > 0 ? 'mt-14' : 'mt-6']}>
          {compact.map(({ item, i }) => (
            <figure data-animate class="overflow-hidden rounded-xl border border-border bg-surface-raised">
              <button
                type="button"
                data-lightbox-trigger
                data-full={full[i].src}
                data-alt={item.alt}
                aria-label={`Expand image: ${item.alt}`}
                class="group relative block w-full cursor-zoom-in overflow-hidden"
              >
                <Image
                  src={item.src}
                  alt={item.alt}
                  widths={[600, 960]}
                  sizes="(min-width: 640px) 33rem, 100vw"
                  loading="lazy"
                  decoding="async"
                  data-no-zoom
                  class="h-auto w-full"
                />
                <span class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/0 opacity-0 transition-all duration-300 group-hover:bg-black/15 group-hover:opacity-100">
                  <span class="rounded-full bg-black/55 p-2.5 text-white shadow-lg backdrop-blur">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6M14 10l7-7M9 21H3v-6M10 14l-7 7" /></svg>
                  </span>
                </span>
              </button>
              {item.caption && (
                <figcaption class="border-t border-border px-4 py-2.5 text-sm text-text-muted">{item.caption}</figcaption>
              )}
            </figure>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Lightbox: one native dialog per page; the trigger fills #lightbox-img. -->
  <dialog
    id="gallery-lightbox"
    class="m-auto max-h-[92vh] max-w-[94vw] overflow-visible bg-transparent p-0 backdrop:bg-black/80 backdrop:backdrop-blur-sm"
  >
    <img id="lightbox-img" alt="" class="max-h-[90vh] w-auto max-w-full rounded-xl border border-white/10 object-contain shadow-2xl" />
    <button
      type="button"
      data-lightbox-close
      aria-label="Close"
      class="fixed right-4 top-4 z-10 rounded-full bg-white/90 p-2.5 text-black shadow-lg backdrop-blur transition-colors hover:bg-white"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
    </button>
  </dialog>
  </Fragment>
)}

<script>
  function initGalleryLightbox() {
    const dialog = document.getElementById('gallery-lightbox') as HTMLDialogElement | null;
    if (!dialog) return;
    const img = dialog.querySelector('#lightbox-img') as HTMLImageElement;
    const closeBtn = dialog.querySelector('[data-lightbox-close]') as HTMLButtonElement;

    document.querySelectorAll<HTMLButtonElement>('[data-lightbox-trigger]').forEach((btn) => {
      btn.addEventListener('click', () => {
        img.src = btn.dataset.full ?? '';
        img.alt = btn.dataset.alt ?? '';
        dialog.showModal();
      });
    });

    closeBtn?.addEventListener('click', () => dialog.close());
    // Click on the backdrop (the dialog element itself, outside the content) closes.
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  }

  initGalleryLightbox();
  document.addEventListener('astro:after-swap', initGalleryLightbox);
</script>
