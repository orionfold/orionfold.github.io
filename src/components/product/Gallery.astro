---
// Gallery — product screenshots are the conversion hook. Showcase items (those
// with a `detail`) render FULL-BLEED: the shot spans the full browser width at
// its natural height, with the explainer in a centered readable column below.
// No lightbox — full-bleed at the high source resolution IS the full-glory view
// (operator decision 2026-06-15). Dense/tall shots (e.g. the 2850x7284
// leaderboard) render long-and-strong and read by scrolling. Items without a
// `detail` keep the compact two-up grid.
//
// Perf: the gallery is below the fold and every image is lazy, so it does not
// affect LCP/initial paint. `sizes="100vw"` + a capped width ladder means each
// viewport downloads only the rung it needs (a phone gets ~1024, not 2560). The
// Image's intrinsic width/height reserves layout space so CLS stays ~0.
import { Image } from 'astro:assets';

interface Item {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  detail?: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;

const showcase = items.filter((it) => Boolean(it.detail));
const compact = items.filter((it) => !it.detail);
---
{items.length > 0 && (
  <section class="py-12">
    <div class="mx-auto max-w-6xl px-6">
      <h2 data-animate class="font-display text-2xl font-bold">A closer look</h2>
    </div>

    {showcase.length > 0 && (
      <div class="mt-8 space-y-16 lg:space-y-24">
        {showcase.map((item, n) => (
          <figure data-animate>
            <Image
              src={item.src}
              alt={item.alt}
              widths={[1024, 1440, 1920, 2560]}
              sizes="100vw"
              loading="lazy"
              decoding="async"
              class="h-auto w-full max-w-none border-y border-border bg-surface-raised"
            />
            <figcaption class="mx-auto mt-5 max-w-3xl px-6">
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">{String(n + 1).padStart(2, '0')}</p>
              {item.caption && (
                <p class="mt-2 font-display text-lg font-semibold leading-snug text-text">{item.caption}</p>
              )}
              <p class="mt-3 leading-relaxed text-text-muted">{item.detail}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    )}

    {compact.length > 0 && (
      <div data-animate-stagger class:list={['mx-auto grid max-w-6xl gap-5 px-6 sm:grid-cols-2', showcase.length > 0 ? 'mt-16' : 'mt-6']}>
        {compact.map((item) => (
          <figure data-animate class="overflow-hidden rounded-xl border border-border bg-surface-raised">
            <Image
              src={item.src}
              alt={item.alt}
              widths={[600, 960]}
              sizes="(min-width: 640px) 33rem, 100vw"
              loading="lazy"
              decoding="async"
              class="h-auto w-full"
            />
            {item.caption && (
              <figcaption class="border-t border-border px-4 py-2.5 text-sm text-text-muted">{item.caption}</figcaption>
            )}
          </figure>
        ))}
      </div>
    )}
  </section>
)}
