---
// Gallery (P1, spec §4/§5.5). Real product screenshots, reused DGX figures, or
// posters shown on-page under "A closer look". Items carry resolved ImageMetadata
// (the productDetail schema uses image() so each gets WebP/AVIF + responsive
// sizes). Each snapshot is a button: it lifts/scales on hover (cursor-zoom-in +
// an expand badge) and opens a native <dialog> lightbox on click — Esc, focus
// trap, and a click-out backdrop come free from the element. A high-res source
// per item is pre-generated at build time (capped to the source width so Astro
// never upscales) and swapped into the single lightbox <img> on open.
import { Image, getImage } from 'astro:assets';

interface Props {
  items: { src: ImageMetadata; alt: string; caption?: string }[];
}
const { items } = Astro.props;

// One optimized large source per item for the expanded view.
const full = await Promise.all(
  items.map((it) => getImage({ src: it.src, width: Math.min(1600, it.src.width), format: 'webp' })),
);
---
{items.length > 0 && (
  <Fragment>
  <section class="px-6 py-12">
    <div class="mx-auto max-w-5xl">
      <h2 data-animate class="font-display text-2xl font-bold">A closer look</h2>
      <div data-animate-stagger class="mt-6 grid gap-5 sm:grid-cols-2">
        {items.map((item, i) => (
          <figure data-animate class="overflow-hidden rounded-xl border border-border bg-surface-raised">
            <button
              type="button"
              data-lightbox-trigger
              data-full={full[i].src}
              data-alt={item.alt}
              aria-label={`Expand image: ${item.alt}`}
              class="group relative block w-full cursor-zoom-in overflow-hidden"
            >
              <Image
                src={item.src}
                alt={item.alt}
                widths={[400, 768]}
                sizes="(min-width: 640px) 24rem, 100vw"
                loading="lazy"
                decoding="async"
                data-no-zoom
                class="aspect-video w-full object-cover"
              />
              <span class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/0 opacity-0 transition-all duration-300 group-hover:bg-black/15 group-hover:opacity-100">
                <span class="rounded-full bg-black/55 p-2.5 text-white shadow-lg backdrop-blur">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6M14 10l7-7M9 21H3v-6M10 14l-7 7" /></svg>
                </span>
              </span>
            </button>
            {item.caption && (
              <figcaption class="border-t border-border px-4 py-2.5 text-sm text-text-muted">{item.caption}</figcaption>
            )}
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox: one native dialog per page; the trigger fills #lightbox-img. -->
  <dialog
    id="gallery-lightbox"
    class="m-auto max-h-[92vh] max-w-[94vw] overflow-visible bg-transparent p-0 backdrop:bg-black/80 backdrop:backdrop-blur-sm"
  >
    <img id="lightbox-img" alt="" class="max-h-[90vh] w-auto max-w-full rounded-xl border border-white/10 object-contain shadow-2xl" />
    <button
      type="button"
      data-lightbox-close
      aria-label="Close"
      class="fixed right-4 top-4 z-10 rounded-full bg-white/90 p-2.5 text-black shadow-lg backdrop-blur transition-colors hover:bg-white"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
    </button>
  </dialog>
  </Fragment>
)}

<script>
  function initGalleryLightbox() {
    const dialog = document.getElementById('gallery-lightbox') as HTMLDialogElement | null;
    if (!dialog) return;
    const img = dialog.querySelector('#lightbox-img') as HTMLImageElement;
    const closeBtn = dialog.querySelector('[data-lightbox-close]') as HTMLButtonElement;

    document.querySelectorAll<HTMLButtonElement>('[data-lightbox-trigger]').forEach((btn) => {
      btn.addEventListener('click', () => {
        img.src = btn.dataset.full ?? '';
        img.alt = btn.dataset.alt ?? '';
        dialog.showModal();
      });
    });

    closeBtn?.addEventListener('click', () => dialog.close());
    // Click on the backdrop (the dialog element itself, outside the content) closes.
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  }

  initGalleryLightbox();
  document.addEventListener('astro:after-swap', initGalleryLightbox);
</script>
