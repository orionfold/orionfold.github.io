---
// src/components/relay/RelayMemoInterstitial.astro
// The ONE mid-essay CTA for a Relay Packs memo (Rail B, _RELAY #17). The publish
// contract says a memo is an editorial read, so it gets the story treatment: a
// single quiet interstitial mid-read + a footer CTA, and NO sticky strip. This
// is the mid-read half — a soft inline band, lighter than the footer's
// RelayDocsCta, that routes to /relay/ where the canonical buy block lives.
// Relay ships no CTA HTML; the website owns this chrome. The route mounts this
// component into the [data-memo-interstitial-slot] div that the
// rehype-memo-interstitial plugin auto-inserts at the section boundary.
import { RELAY, formatUsd } from '../../data/commerce';

interface Props {
  class?: string;
}
const { class: className } = Astro.props;
const price = formatUsd(RELAY.founding.amount);
---
<aside class:list={['memo-interstitial not-prose my-12 sm:my-14', className]} aria-label="Get Relay">
  <div class="rounded-2xl border border-border/70 bg-surface/40 px-6 py-6 sm:px-8 sm:py-7">
    <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-primary">Orionfold Relay</p>
    <p class="mt-2 text-lg leading-snug sm:text-xl">
      Every pack in this series is one you install and own, offline.
    </p>
    <p class="mt-2 max-w-xl text-sm leading-relaxed text-text-muted">
      The engine is free and open. A license unlocks the premium packs and keeps them yours. Founding seats from {price}.
    </p>
    <a
      href="/relay/#get-relay"
      class="mt-4 inline-flex items-center gap-1.5 font-mono text-sm text-primary transition-colors hover:text-primary/80"
    >
      See pricing &amp; get Relay
      <span class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">&rarr;</span>
    </a>
  </div>
</aside>
