---
// src/components/relay/ThemedShot.astro
// Theme-aware Relay screenshot. The head bootstrap in Layout assigns only the
// active theme's responsive srcset, and native loading="lazy" keeps below-fold
// shots off the initial network path. Exact viewport dimensions from the corpus
// reserve layout for zero CLS. Never use this for an above-fold LCP hero. See
// docs/superpowers/specs/2026-07-09-relay-themed-screenshot-component-design.md
import index from '../../data/relay-shots.json';
import { themedShotProps } from './themed-shot.logic.mjs';

interface Props {
  id: string;
  alt?: string;
  class?: string;
}
const { id, alt, class: className } = Astro.props;
const shot = themedShotProps(index, { id, alt });
---

<div class:list={['relay-shot', className]} style={shot.style}>
  <img
    class="relay-shot__image"
    width={shot.width}
    height={shot.height}
    alt={shot.alt}
    loading="lazy"
    decoding="async"
    sizes={shot.sizes}
    data-relay-shot
    data-shot-light-src={shot.light.src}
    data-shot-light-srcset={shot.light.srcset}
    data-shot-dark-src={shot.dark.src}
    data-shot-dark-srcset={shot.dark.srcset}
    data-no-zoom
  />
  <noscript>
    <img
      class="relay-shot__image"
      src={shot.light.src}
      srcset={shot.light.srcset}
      sizes={shot.sizes}
      width={shot.width}
      height={shot.height}
      alt={shot.alt}
      loading="lazy"
      decoding="async"
      data-no-zoom
    />
  </noscript>
</div>
