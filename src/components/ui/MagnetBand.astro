---
// MagnetBand (2026-Q3 magnet-traffic, relay latest+21; redesigned latest+23) —
// the "get the free book" band on Story footers. Deliberately styled to look
// DIFFERENT from its sibling ProofBand so the two next-step bands don't read as
// duplicates: this one is WARM (paper/amber), with the real book cover floating
// as an upright portrait thumbnail on the LEFT (mirror of ProofBand's poster on
// the right). The cover drifts on the same compositor-owned, reduced-motion-safe
// isometric recipe as ProofCTA/Hero (desktop only; flat on mobile).
// Value-first framing, message-matched to the magnet page. Voice: grade 3-5,
// no em-dashes, no invented claims (website-copy-style).
import { Image } from 'astro:assets';
import { magnetHref, type MagnetPlacement } from '../../data/magnet.ts';
import bookCover from '../../assets/book/ai-native-business-book.jpg';

interface Props {
  placement: MagnetPlacement;
  eyebrow?: string;
  line?: string;
  linkText?: string;
  class?: string;
}
const {
  placement,
  eyebrow = 'Free book',
  line = 'Get the $20 AI Native Business book free, in PDF and EPUB. Just your email.',
  linkText = 'Get the free book',
  class: className,
} = Astro.props;
const href = magnetHref(placement);
---
<section
  class:list={['magnet-band relative overflow-hidden border-y border-[oklch(0.70_0.14_82/0.25)] px-6 py-12', className]}
  aria-label="Get the free book"
>
  <!-- Warm paper-dot texture + an amber reading-lamp glow, both behind content.
       This is the "paper / book" surface that sets the band apart from Proof. -->
  <div class="magnet-band__paper pointer-events-none absolute inset-0 -z-10" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute -left-[6%] top-1/2 h-[340px] w-[340px] -translate-y-1/2 rounded-full bg-[oklch(0.72_0.15_82/0.16)] blur-[120px]"></div>
  </div>

  <div class="mx-auto grid max-w-4xl items-center gap-7 sm:grid-cols-[auto_1fr] sm:gap-9">
    <!-- LEFT: the book cover, upright, drifting on the isometric plane (desktop). -->
    <div class="magnet3d-stage relative mx-auto w-32 shrink-0 sm:mx-0 sm:w-36">
      <a href={href} tabindex="-1" aria-hidden="true" class="magnet3d-plane block">
        <Image
          src={bookCover}
          alt="The AI Native Business book cover"
          widths={[160, 288]}
          sizes="9rem"
          loading="lazy"
          decoding="async"
          data-no-zoom
          class="block w-full rounded-lg shadow-[0_22px_50px_-22px_oklch(0.30_0.10_60/0.65)] ring-1 ring-black/10"
        />
      </a>
    </div>

    <!-- RIGHT: the pitch + CTA. -->
    <div class="text-center sm:text-left">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-[oklch(0.58_0.13_70)]">{eyebrow}</p>
      <p class="mt-2.5 max-w-xl text-lg leading-relaxed text-text">{line}</p>
      <a
        href={href}
        class="mt-5 inline-flex items-center justify-center gap-1.5 rounded-lg bg-[oklch(0.62_0.15_72)] px-5 py-3 font-mono text-sm tracking-wider text-white transition-colors hover:bg-[oklch(0.56_0.15_70)]"
      >
        {linkText}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* Warm "paper" surface: a faint warm wash + a dot grid that reads as a page,
     distinct from ProofBand's cool blueprint lines. Both themes get a tuned
     tint so the band stands apart from the page without fighting the cover. */
  .magnet-band {
    background-color: oklch(0.97 0.012 80);
  }
  :global([data-theme='dark']) .magnet-band {
    background-color: oklch(0.205 0.018 70);
  }
  .magnet-band__paper {
    background-image: radial-gradient(oklch(0.60 0.10 70 / 0.16) 1px, transparent 1.4px);
    background-size: 16px 16px;
  }
  :global([data-theme='dark']) .magnet-band__paper {
    background-image: radial-gradient(oklch(0.78 0.12 80 / 0.10) 1px, transparent 1.4px);
  }

  /* Desktop-only isometric drift, same compositor-owned recipe as ProofCTA/Hero,
     tuned so the upright book "leans" rather than tilting like a screen. Mobile
     keeps the flat cover. */
  @media (min-width: 1024px) {
    .magnet3d-stage { perspective: 1200px; }
    .magnet3d-plane {
      transform: rotateY(14deg) rotateZ(-2deg);
      animation: magnet3d-lean 13s ease-in-out infinite alternate;
      will-change: transform;
      transform-style: preserve-3d;
    }
    @keyframes magnet3d-lean {
      from { transform: rotateY(14deg) rotateZ(-2deg) translateY(0); }
      to   { transform: rotateY(6deg) rotateZ(2deg) translateY(-6px); }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .magnet3d-plane { animation: none; }
  }
</style>
