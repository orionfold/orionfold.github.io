---
// Post-confirmation banner (H3). The confirm-email edge function redirects to
// /?confirmed=1 (or =already / =error&error=...). H1 removed the homepage form
// that used to surface that state (its watchConfirmed handler), so this small
// standalone banner reads the query param, shows a short acknowledgment, cleans
// the URL, then self-dismisses. It only renders when ?confirmed= is present, so
// it never clutters a normal homepage visit. Capture itself lives on /story
// (StorySubscribe); this is only the landing acknowledgment.
---
<div
  id="confirm-banner"
  role="status"
  aria-live="polite"
  class="fixed inset-x-0 top-20 z-50 mx-auto hidden w-[calc(100%-2rem)] max-w-md px-0"
>
  <div class="flex items-start gap-3 rounded-xl border border-primary/30 bg-surface-raised px-4 py-3 shadow-lg">
    <span id="confirm-banner-dot" class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>
    <p id="confirm-banner-text" class="flex-1 font-mono text-xs leading-relaxed text-text"></p>
    <button
      id="confirm-banner-close"
      type="button"
      aria-label="Dismiss"
      class="-mr-1 -mt-1 shrink-0 cursor-pointer rounded p-1 text-text-dim transition-colors hover:text-text"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12" />
      </svg>
    </button>
  </div>
</div>

<script>
  (function () {
    const params = new URLSearchParams(location.search);
    const state = params.get('confirmed');
    if (!state) return;

    const banner = document.getElementById('confirm-banner');
    const text = document.getElementById('confirm-banner-text');
    const dot = document.getElementById('confirm-banner-dot');
    const close = document.getElementById('confirm-banner-close');
    if (!banner || !text) return;

    let msg = '';
    let isError = false;
    if (state === '1') {
      msg = "You're subscribed. New stories are on the way.";
    } else if (state === 'already') {
      msg = "You're already subscribed to our stories.";
    } else if (state === 'error') {
      msg = params.get('error') || "That link didn't work. Please try again.";
      isError = true;
    }
    if (!msg) return;

    text.textContent = msg;
    if (isError && dot) dot.classList.replace('bg-primary', 'bg-red-500');
    banner.classList.remove('hidden');
    // Clean the URL so a reload doesn't re-show the banner.
    history.replaceState({}, '', location.pathname);

    const dismiss = () => banner.classList.add('hidden');
    close?.addEventListener('click', dismiss);
    if (!isError) setTimeout(dismiss, 8000);
  })();
</script>
