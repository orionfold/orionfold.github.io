---
// Story card (S9, cover added V6) — one post teaser, shared by the /story/ index
// and the homepage carousel (StoriesCarousel) so both stay in sync. Now leads
// with a cover (a curated hero image if the post has one, else a full-bleed
// constellation seeded off the post so each post still gets a distinct-but-on-
// brand cover), then the tag/date row, title, and summary. The outer <a> takes a
// `class` for context sizing (carousel adds snap/width); `animate` opts into the
// scroll-reveal grid.
import { Image } from 'astro:assets';
import ConstellationCover from './ConstellationCover.astro';

interface Props {
  href: string;
  title: string;
  date: Date;
  tag?: string;
  summary: string;
  seed?: string; // constellation seed (defaults to href slug)
  cover?: ImageMetadata; // curated hero (I-series); falls back to constellation
  coverAlt?: string;
  class?: string;
  animate?: boolean;
}

const { href, title, date, tag, summary, seed, cover, coverAlt, class: className = '', animate = false } = Astro.props;
// timeZone:'UTC' so a date-only value (UTC midnight) shows the authored day, not
// the day before in a behind-UTC timezone.
const dateFmt = new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'UTC' }).format(date);
const dateIso = date.toISOString().slice(0, 10);
const coverSeed = seed ?? href;
---
<a
  href={href}
  data-animate={animate ? '' : undefined}
  class:list={[
    'group flex flex-col overflow-hidden rounded-xl border border-border bg-surface-raised/50 transition-colors hover:border-primary/40 hover:bg-primary/[0.03]',
    className,
  ]}
>
  {cover ? (
    <div class="aspect-[16/9] overflow-hidden">
      <Image
        src={cover}
        alt={coverAlt ?? title}
        widths={[400, 640]}
        sizes="(min-width: 1024px) 22rem, 100vw"
        loading="lazy"
        decoding="async"
        data-no-zoom
        class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]"
      />
    </div>
  ) : (
    <ConstellationCover seed={coverSeed} rounded="rounded-none" />
  )}
  <div class="flex flex-1 flex-col p-6">
    <div class="mb-3 flex items-center gap-3 font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted">
      {tag && <span class="text-primary">{tag}</span>}
      <span class="h-px flex-1 bg-border"></span>
      <time datetime={dateIso}>{dateFmt}</time>
    </div>
    <h3 class="mb-2 font-semibold leading-snug transition-colors group-hover:text-primary" style="font-size: 1.1rem;">
      {title}
    </h3>
    <p class="mt-auto text-sm leading-relaxed text-text-muted">{summary}</p>
  </div>
</a>
