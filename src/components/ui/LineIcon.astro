---
// Tiny inline line-icon set (H-series). Hand-drawn 24x24 stroke paths in the
// site's existing convention (fill=none, stroke=currentColor, width 2, round
// caps) so callers set size + color via classes — no icon dependency, no extra
// build weight. Add a name here when a section needs a new glyph.
interface Props {
  name: string;
  class?: string;
  strokeWidth?: number;
}
const { name, class: className = '', strokeWidth = 2 } = Astro.props;

const icons: Record<string, string> = {
  // "new tools every week" — refresh cycle
  refresh:
    '<path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/>',
  // "skill, not staff" — spark / bolt
  spark: '<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>',
  // "open tools caught up" — unlock
  unlock: '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/>',
  // "expert playbooks" — open book
  book: '<path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/>',
  // "open software" — code brackets
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  // "custom models" — cpu / chip
  chip: '<rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M9 2v2"/><path d="M15 2v2"/><path d="M9 20v2"/><path d="M15 20v2"/><path d="M2 9h2"/><path d="M2 15h2"/><path d="M20 9h2"/><path d="M20 15h2"/>',
  // "personal devices" — monitor
  monitor: '<rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/>',
};

const inner = icons[name] ?? '';
---
<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class:list={[className]}
  set:html={inner}
></svg>
