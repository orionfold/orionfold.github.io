---
// Roadmap card (R1, spec §5). One offering on the /roadmap status lanes. Reuses
// the ProductCard visual idiom (rounded-2xl border bg-surface-raised, full-bleed
// 16:9 cover, mono eyebrow, primary pills) but adds the roadmap-specific bits:
// a status pill, an optional Gold/Platinum sponsor badge, a select checkbox (for
// the R2 enquiry drawer), and — on active items — a no-JS <details> expansion
// listing individually selectable features. Covers resolve in roadmap.astro and
// arrive as ImageMetadata; books have none and fall back to ConstellationCover.
import { Image } from 'astro:assets';
import ConstellationCover from './ConstellationCover.astro';
import type { RoadmapItem } from '../../lib/roadmap/source';
import { SPONSOR_TIERS, getCatalogItem, sponsorLookupKey, formatUsd } from '../../data/commerce';

interface Props {
  item: RoadmapItem;
  cover?: ImageMetadata;
  // On-site detail page for this offering (P-series). Set by roadmap.astro only
  // when an entry exists, so a "Details ->" link shows beside the CTA. Absent ->
  // no link (planned stages / sub-features have no detail page).
  detailHref?: string;
}
const { item, cover, detailHref } = Astro.props;

const TYPE_LABEL: Record<RoadmapItem['type'], string> = { book: 'Book', software: 'Software', model: 'Model' };

// Status presentation stays inside the brand palette: active is the primary
// blue-indigo with a pulsing dot, shipped is calm/neutral, planned is dashed.
const STATUS: Record<RoadmapItem['status'], { label: string; pill: string; dot: string }> = {
  released: { label: 'Shipped', pill: 'border-white/40 bg-black/25 text-white', dot: 'bg-white/70' },
  active: { label: 'Building now', pill: 'border-primary/50 bg-primary/90 text-white', dot: 'bg-white animate-pulse' },
  planned: { label: 'Planned', pill: 'border-dashed border-white/50 bg-black/25 text-white', dot: 'bg-white/40' },
};
const status = STATUS[item.status];

const SPONSOR_BADGE: Record<NonNullable<RoadmapItem['sponsorTier']>, string> = {
  gold: '🥇 Gold sponsor',
  platinum: '🏅 Platinum sponsor',
};

const isBuy = item.cta === 'buy';
// getElementById tolerates any string, but keep the id selector-clean (item.id has a colon).
const errId = `rm-err-${item.id.replace(/[^a-z0-9]+/gi, '-')}`;
const sponsorTiers = SPONSOR_TIERS.map((tier) => {
  const c = getCatalogItem(sponsorLookupKey(tier))!;
  return { tier, lookupKey: c.lookupKey, price: c.amount };
});

const features = item.features ?? [];
const featureDot: Record<RoadmapItem['status'], string> = {
  released: 'bg-text-muted/40',
  active: 'bg-primary',
  planned: 'border border-text-muted/40',
};
---
<article
  data-animate
  data-roadmap-item={item.id}
  class="group/card flex flex-col overflow-hidden rounded-2xl border border-border bg-surface-raised transition-colors hover:border-primary/30"
>
  <!-- Cover + overlays -->
  <div class="relative aspect-[16/9] overflow-hidden border-b border-border">
    {cover ? (
      item.type === 'book' ? (
        // Books are portrait covers: show the whole cover (full title + subtitle),
        // vertically centered, over a blurred fill so the 16:9 frame reads as art.
        <>
          <Image
            src={cover}
            alt=""
            aria-hidden="true"
            widths={[400, 640]}
            sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
            loading="lazy"
            decoding="async"
            data-no-zoom
            class="absolute inset-0 h-full w-full scale-110 object-cover blur-2xl"
          />
          <div class="absolute inset-0 bg-black/20"></div>
          <Image
            src={cover}
            alt={`${item.title} cover`}
            widths={[240, 400]}
            sizes="240px"
            loading="lazy"
            decoding="async"
            data-no-zoom
            class="relative z-[1] mx-auto h-full w-auto object-contain p-3"
          />
        </>
      ) : (
        <Image
          src={cover}
          alt={`${item.title} key art`}
          widths={[400, 640]}
          sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
          loading="lazy"
          decoding="async"
          data-no-zoom
          class="h-full w-full object-cover object-top"
        />
      )
    ) : (
      <ConstellationCover seed={item.id} rounded="rounded-none" label={item.title} />
    )}

    <!-- Select for enquiry (R2 reads [data-roadmap-select]) -->
    <label class="absolute left-3 top-3 z-10 cursor-pointer">
      <input type="checkbox" data-roadmap-select value={item.id} data-label={item.title} class="peer sr-only" />
      <span
        class="flex h-7 w-7 items-center justify-center rounded-md border border-white/50 bg-black/30 text-white backdrop-blur transition peer-checked:border-primary peer-checked:bg-primary peer-checked:[&>svg]:opacity-100 peer-focus-visible:ring-2 peer-focus-visible:ring-white/80"
      >
        <svg class="opacity-0 transition" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 6 9 17l-5-5" />
        </svg>
      </span>
      <span class="sr-only">Select {item.title} for an enquiry</span>
    </label>

    <!-- Status pill -->
    <span class:list={['absolute right-3 top-3 inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 font-mono text-[10px] uppercase tracking-wider backdrop-blur', status.pill]}>
      <span class:list={['h-1.5 w-1.5 rounded-full', status.dot]}></span>{status.label}
    </span>

    <!-- Sponsor badge (gold/platinum only) -->
    {item.sponsorTier && (
      <span class="absolute bottom-3 left-3 rounded-full border border-white/30 bg-black/40 px-2.5 py-1 font-mono text-[10px] tracking-wider text-white backdrop-blur">
        {SPONSOR_BADGE[item.sponsorTier]}
      </span>
    )}
  </div>

  <!-- Body -->
  <div class="flex flex-1 flex-col p-6">
    <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">{TYPE_LABEL[item.type]}</span>
    <h3 class="mt-2 font-display text-xl font-bold leading-tight">
      {item.href ? (
        <a href={item.href} target="_blank" rel="noopener noreferrer" class="hover:text-primary">{item.title}</a>
      ) : (
        item.title
      )}
    </h3>
    <p class="mt-2 line-clamp-3 flex-1 text-sm leading-relaxed text-text-muted">{item.blurb}</p>

    <!-- Active items expand into selectable features (no JS needed to open) -->
    {features.length > 0 && (
      <details class="mt-4 border-t border-border pt-3">
        <summary class="flex cursor-pointer list-none items-center gap-1.5 font-mono text-[11px] uppercase tracking-wider text-primary marker:hidden">
          <svg class="transition-transform [details[open]_&]:rotate-90" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6" />
          </svg>
          {features.length} features you can sponsor
        </summary>
        <ul class="mt-3 space-y-1">
          {features.map((f) => (
            <li>
              <label class="flex cursor-pointer items-center gap-2.5 rounded-lg px-2 py-1.5 transition-colors hover:bg-primary/5">
                <input
                  type="checkbox"
                  data-roadmap-select
                  value={f.id}
                  data-label={`${item.title}: ${f.label}`}
                  class="peer sr-only"
                />
                <span class="flex h-4.5 w-4.5 shrink-0 items-center justify-center rounded border border-border bg-surface text-primary transition peer-checked:border-primary peer-checked:bg-primary/10 peer-checked:[&>svg]:opacity-100 peer-focus-visible:ring-2 peer-focus-visible:ring-primary/40">
                  <svg class="opacity-0 transition" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                </span>
                <span class:list={['h-1.5 w-1.5 shrink-0 rounded-full', featureDot[f.status ?? item.status]]}></span>
                <span class="text-sm leading-snug text-text">{f.label}</span>
              </label>
            </li>
          ))}
        </ul>
      </details>
    )}

    <!-- Commerce CTA: books Buy straight to Checkout; everything else opens an
         in-flow Sponsor menu of the four tiers (deep-links to each tier's
         subscription Checkout, carrying this item id into Stripe metadata). The
         menu is in-flow, not absolute, so the card's overflow-hidden can't clip it. -->
    <div class="mt-5 flex flex-wrap items-start justify-between gap-x-4 gap-y-2">
      {isBuy ? (
        <div>
        <button
          type="button"
          data-checkout={item.lookupKey}
          data-item={item.id}
          data-error-target={errId}
          class="inline-flex items-center gap-1.5 self-start rounded-lg bg-accent px-4 py-2 font-mono text-sm tracking-wider text-accent-text transition-colors hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-60"
        >
          Get the book
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </button>
        <p id={errId} role="alert" hidden class="mt-2 font-mono text-xs text-red-500"></p>
      </div>
    ) : (
        <details>
        <summary class="inline-flex cursor-pointer list-none items-center gap-1.5 self-start rounded-lg border border-primary/30 px-4 py-2 font-mono text-sm tracking-wider text-primary transition-colors hover:bg-primary/5 marker:hidden">
          Sponsor this
          <svg class="transition-transform [details[open]_&]:rotate-180" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </summary>
        <div class="mt-3 space-y-1 rounded-xl border border-border bg-surface p-2">
          {sponsorTiers.map((t) => (
            <button
              type="button"
              data-checkout={t.lookupKey}
              data-item={item.id}
              data-error-target={errId}
              class="flex w-full items-center justify-between rounded-lg px-3 py-2 text-left text-sm capitalize text-text transition-colors hover:bg-primary/5 disabled:cursor-not-allowed disabled:opacity-60"
            >
              {t.tier}
              <span class="font-mono text-xs tracking-wider text-text-muted">{formatUsd(t.price)}/mo</span>
            </button>
          ))}
          <a href={`/sponsor/?item=${encodeURIComponent(item.id)}`} class="block rounded-lg px-3 py-2 text-center font-mono text-xs tracking-wider text-text-muted transition-colors hover:text-primary">
            Compare tiers →
          </a>
        </div>
        <p id={errId} role="alert" hidden class="mt-2 font-mono text-xs text-red-500"></p>
      </details>
      )}
      {detailHref && (
        <a
          href={detailHref}
          class="inline-flex items-center gap-1 self-start py-2 font-mono text-sm tracking-wider text-primary transition-colors hover:underline"
        >
          Details
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      )}
    </div>
  </div>
</article>
