---
// Orionfold brand mark — 3D variant B (design-system brand/logo/assets/logo-3d/,
// 2026-07-05): a matte white origami paper star on a filled teal disc. This
// REPLACES the former inline theme-aware SVG (a flat cyan disc + white star
// knockout, SC-01f). The 3D render is a photographic raster, so it is NOT
// theme-aware (the disc stays the same teal on light + dark) and NOT a vector —
// per the operator's "full swap everywhere" decision (2026-07-05), which trades
// the flat mark's theme-recolor + vector crispness for the richer 3D look.
//
// EXACT-SIZE sources (no browser resampling): the design-system ships the mark
// pre-rendered at the exact CSS sizes the app embeds it (app-embed/), each a
// single Lanczos downscale from the 1710px master — sharper at 24-32px than
// letting the browser bilinear-scale one big master. We ship the DS's 1x + 2x
// pairs and pick the nearest 1x for the requested `size`, with a 2x `srcset` for
// retina. Served from public/ so a plain <img> is correct (public bypasses the
// Astro image pipeline). aria-hidden: the adjacent "Orionfold" wordmark carries
// the accessible name.
interface Props {
  size?: number;
  class?: string;
}
const { size = 30, class: className = '' } = Astro.props;

// DS exact-size marks in public/logos (24/28/32/48/56/64/72). Map the requested
// CSS size to its nearest 1x source and a 2x retina source; if a size falls
// between exacts, round UP to the next exact so we never upscale. The two live
// call sites hit exact pairs: nav size=32 -> 32(1x)+64(2x); footer/magnet
// size=28 -> 28(1x)+56(2x).
const BASE = '/logos/orionfold-mark-3d';
const EXACTS = [24, 28, 32, 48, 56, 64, 72];
const pick = (target: number) => EXACTS.find((s) => s >= target) ?? EXACTS[EXACTS.length - 1];
const one = pick(size);
const two = pick(size * 2);
const src1x = `${BASE}-${one}.png`;
const src2x = `${BASE}-${two}.png`;
---
<img
  src={src1x}
  srcset={`${src1x} 1x, ${src2x} 2x`}
  width={size}
  height={size}
  class:list={["of-mark shrink-0", className]}
  alt=""
  aria-hidden="true"
  decoding="async"
  loading="eager"
/>
