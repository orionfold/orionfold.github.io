---
// Sponsor tier card (C4, spec §2/§5). One monthly tier on /sponsor. Reuses the
// ProductCard/RoadmapCard surface (rounded-2xl border bg-surface-raised) and adds
// the pricing-page bits: a price header, a benefit list, and a Buy button that
// starts a subscription Checkout via the shared checkout helper. The featured
// tier (Gold) gets a primary frame + a "Most popular" tag. When an `itemId` is
// passed (the visitor came from a roadmap item via ?item=), it rides into Stripe
// metadata so a sponsorship can be traced back to the line of work it backs.
import { formatUsd, type SponsorTierDisplay } from '../../data/commerce';

interface Props {
  tier: SponsorTierDisplay;
  /** Roadmap item id the visitor arrived from, carried into checkout metadata. */
  itemId?: string;
}
const { tier, itemId } = Astro.props;
const errorId = `sponsor-err-${tier.tier}`;
---
<article
  data-animate
  class:list={[
    'relative flex flex-col rounded-2xl border bg-surface-raised p-6 transition-colors',
    tier.featured ? 'border-primary/60 ring-1 ring-primary/30 shadow-lg shadow-primary/5' : 'border-border hover:border-primary/30',
  ]}
>
  {tier.featured && (
    <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary px-3 py-1 font-mono text-[10px] uppercase tracking-wider text-white">
      Most popular
    </span>
  )}

  <!-- Header -->
  <div class="border-b border-border pb-5">
    <h2 class="font-display text-xl font-bold leading-tight">{tier.name}</h2>
    <p class="mt-1 text-sm text-text-muted">{tier.tagline}</p>
    <p class="mt-4 flex items-baseline gap-1">
      <span class="font-display text-4xl font-bold text-primary">{formatUsd(tier.price)}</span>
      <span class="font-mono text-xs tracking-wider text-text-muted">/ month</span>
    </p>
  </div>

  <!-- Benefits -->
  <ul class="flex flex-1 flex-col gap-3 py-5">
    {tier.benefits.map((benefit, i) => (
      <li class="flex items-start gap-2.5 text-sm leading-snug">
        {i === 0 && benefit.startsWith('Everything in') ? (
          <span class="text-text">{benefit}</span>
        ) : (
          <>
            <svg class="mt-0.5 shrink-0 text-primary" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" />
            </svg>
            <span class="text-text">{benefit}</span>
          </>
        )}
      </li>
    ))}
  </ul>

  <!-- Sponsor CTA (Sponsor family; a tier is a subscription, not a one-off buy) -->
  <button
    type="button"
    data-checkout={tier.lookupKey}
    data-item={itemId}
    data-error-target={errorId}
    class:list={[
      'inline-flex w-full items-center justify-center gap-1.5 rounded-lg px-4 py-3 font-mono text-sm tracking-wider transition-colors disabled:opacity-60 disabled:cursor-not-allowed',
      tier.featured ? 'bg-primary text-white hover:bg-primary/90' : 'border border-primary/30 text-primary hover:bg-primary/5',
    ]}
  >
    Sponsor as {tier.name}
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  </button>
  <p id={errorId} role="alert" hidden class="mt-2 text-center font-mono text-xs text-red-500"></p>
</article>
