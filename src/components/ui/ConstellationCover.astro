---
// ConstellationCover (V3) — the site's signature visual motif, rendered as a
// seeded star-field over a deep blue-indigo gradient. It echoes the AI Native
// Business book cover (dark panel, blue constellation) and the hero glow, so it
// reads as Orionfold even with no photo. Used for: story-card covers, the
// /models/ header band, software cards with no screenshot (Marketer, fieldkit,
// AI Native API), and as the panel behind logo-only cards (OpenVolo, Sentinel)
// via the default <slot/>.
//
// Deterministic from `seed` (a slug/tag): the same post always draws the same
// constellation, but each one differs. Purely decorative -> aria-hidden. No JS.

interface Props {
  seed: string;
  label?: string; // faint mono caption, bottom-left
  ratio?: 'card' | 'band' | 'wide'; // 16:9 | 3:1 | 5:2
  rounded?: string; // tailwind rounding; use 'rounded-none' when embedded full-bleed
  class?: string;
}

const { seed, label, ratio = 'card', rounded = 'rounded-xl', class: className = '' } = Astro.props;

// ── deterministic PRNG (string hash -> mulberry32) ──
function hash(str: string): number {
  let h = 1779033703 ^ str.length;
  for (let i = 0; i < str.length; i++) {
    h = Math.imul(h ^ str.charCodeAt(i), 3432918353);
    h = (h << 13) | (h >>> 19);
  }
  return h >>> 0;
}
function mulberry32(a: number) {
  return function () {
    a |= 0;
    a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rnd = mulberry32(hash(seed));

const W = 400;
const H = 225; // 16:9 viewBox; slice-scaled for other ratios
const COUNT = 14;
type Node = { x: number; y: number; r: number; bright: boolean };
const nodes: Node[] = Array.from({ length: COUNT }, () => ({
  x: Math.round(rnd() * W),
  y: Math.round(rnd() * H),
  r: 0.8 + rnd() * 1.7,
  bright: rnd() > 0.76,
}));

// connect each node to its 1-2 nearest neighbours (skip far pairs)
const edges: [Node, Node][] = [];
nodes.forEach((a, i) => {
  const near = nodes
    .map((b, j) => ({ b, d: (a.x - b.x) ** 2 + (a.y - b.y) ** 2, j }))
    .filter((o) => o.j !== i)
    .sort((u, v) => u.d - v.d);
  const links = 1 + Math.floor(rnd() * 2);
  for (let k = 0; k < links && k < near.length; k++) {
    if (near[k].d < 13000) edges.push([a, near[k].b]);
  }
});

// seeded hue drift, kept inside the blue-indigo band (250-274)
const hue = 250 + Math.floor(rnd() * 24);
const glowX = 18 + Math.round(rnd() * 64);
const uid = 'cc' + hash(seed).toString(36);

const aspect = ratio === 'wide' ? 'aspect-[5/2]' : ratio === 'band' ? 'aspect-[3/1]' : 'aspect-[16/9]';
---
<div
  class:list={['relative overflow-hidden', aspect, rounded, className]}
  aria-hidden="true"
  style={`background: radial-gradient(120% 130% at ${glowX}% -10%, oklch(0.36 0.11 ${hue}) 0%, oklch(0.25 0.09 ${hue + 6}) 52%, oklch(0.17 0.06 ${hue + 10}) 100%);`}
>
  <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="xMidYMid slice" class="absolute inset-0 h-full w-full">
    <defs>
      <radialGradient id={`${uid}-g`} cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="white" stop-opacity="0.95"></stop>
        <stop offset="100%" stop-color="white" stop-opacity="0"></stop>
      </radialGradient>
    </defs>
    {edges.map(([a, b]) => (
      <line x1={a.x} y1={a.y} x2={b.x} y2={b.y} stroke="white" stroke-width="0.4" stroke-opacity="0.16"></line>
    ))}
    {nodes.map((n) =>
      n.bright ? (
        <g>
          <circle cx={n.x} cy={n.y} r={n.r * 3.4} fill={`url(#${uid}-g)`} opacity="0.55"></circle>
          <circle cx={n.x} cy={n.y} r={n.r} fill="white"></circle>
        </g>
      ) : (
        <circle cx={n.x} cy={n.y} r={n.r} fill="white" opacity="0.5"></circle>
      ),
    )}
  </svg>

  <!-- optional overlay (e.g. a product logo) -->
  <div class="absolute inset-0 flex items-center justify-center p-6">
    <slot />
  </div>

  {label && (
    <span class="absolute bottom-3 left-3 font-mono text-[10px] uppercase tracking-[0.2em] text-white/70">{label}</span>
  )}
  <span class="pointer-events-none absolute inset-0 rounded-[inherit] ring-1 ring-inset ring-white/[0.06]"></span>
</div>
