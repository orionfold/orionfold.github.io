---
// Orionfold top nav: parent mark + "Orionfold" wordmark ("fold" in primary),
// a product-led link set, mobile hamburger, and a scroll-triggered blur.
// Ported from the donor Nav, minus ThemeToggle and the in-nav social icon
// (social links live in the Footer per the spec).
// IA refocus 2026-06-22: the top nav is product-led — Proof · Arena,
// then a vertical divider, then the catalog entries Models · Books. Operator kept
// the link targets unchanged while relabelling: Arena → /cockpit/ (SEO equity
// retained), Models → /experts/, Books → /learn/. Workflows + Adoption dropped
// from the top nav but stay footer-linked for SEO/AEO.
// 2026-06-24: Advisor removed from the top nav (still reachable at /advisor/ and
// footer-linked); the nav leads with the flagship products.
// 2026-07-01: Relay (/relay/) added as the third flagship. Story (/story/) stays
// after Books behind its own divider. Flagship order was Proof · Arena · Relay
// until the 2026-07-03 Relay-led reorder below.
// 2026-07-01 (later): Arena repointed /cockpit/ -> /arena/ (the new flagship
// landing page, parallel to /proof/ + /relay/). /cockpit/ stays live + footer-
// linked (keeps its SEO equity); the /software/arena/ detail page was retired the
// same day and 301s to /arena/ (the single canonical Arena surface).
// 2026-07-03: nav reordered Proof·Arena·Relay -> Relay·Proof·Arena so the nav
// hierarchy matches the Relay-led homepage suite router.
import BrandMark from './ui/BrandMark.astro';
import { magnetHref } from '../data/magnet.ts';
// Persistent magnet sticky bar (2026-Q3 magnet-traffic, relay latest+21): a slim,
// dismissible "free book" bar pinned ABOVE the nav, site-wide. It lives inside
// #nav-wrapper (like #confirm-bar) so it joins the pinned overlay and the hero's
// nav-clearance adjusts for it automatically. It is auto-suppressed on the magnet
// page itself because that page (and /thanks/) render their own bare header, NOT
// this Nav. The controller hides it once dismissed (localStorage, persists across
// sessions) and yields to #confirm-bar for users who already converted.
const magnetBarHref = magnetHref('nav-cta');
// `divider: true` renders a separator immediately BEFORE that link.
const links = [
  { href: '/relay/', label: 'Relay' },
  { href: '/proof/', label: 'Proof' },
  { href: '/arena/', label: 'Arena' },
  { href: '/experts/', label: 'Models', divider: true },
  { href: '/learn/', label: 'Books' },
  { href: '/training/', label: 'Training' },
  { href: '/story/', label: 'Story', divider: true },
];
---
<div id="nav-wrapper" class="fixed top-0 left-0 right-0 z-40 transition-[background-color,backdrop-filter] duration-300">
  <!-- Persistent magnet sticky bar (relay latest+21). Hidden by default; the
       controller script reveals it unless dismissed (localStorage) or the
       post-confirm welcome bar is active. Value-first, message-matched to the
       magnet page's "$20 book free" copy. -->
  <div id="magnet-bar" class="hidden border-b border-primary/20 bg-primary/[0.07] text-text">
    <div class="mx-auto flex max-w-7xl items-center justify-center gap-3 px-6 py-1.5">
      <a
        href={magnetBarHref}
        class="group inline-flex items-center gap-2 text-center text-sm leading-tight transition-colors hover:text-primary"
      >
        <svg class="shrink-0 text-primary" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        <span><span class="font-semibold">Get the $20 AI Native Business book free</span> <span class="text-text-muted">(PDF + EPUB)</span></span>
        <span class="font-mono text-primary transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">&rarr;</span>
      </a>
      <button
        id="magnet-bar-close"
        type="button"
        aria-label="Dismiss"
        class="-mr-1 shrink-0 cursor-pointer rounded p-0.5 text-text-dim transition-colors hover:text-text"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
      </button>
    </div>
  </div>
  <nav id="main-nav" aria-label="Main navigation" class="border-b border-transparent transition-[border-color] duration-300">
  <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
    <a
      href="/"
      class="group inline-flex items-center gap-1.5 text-text transition-colors hover:text-primary -ml-1"
      aria-label="Orionfold home"
    >
      <BrandMark size={32} class="h-8 w-8" />
      <span class="text-2xl font-semibold tracking-tight leading-none">
        <span class="text-text">Orion</span><span class="text-primary">fold</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      {links.map((link) => (
        <Fragment>
          {link.divider && <span class="h-4 w-px bg-border" aria-hidden="true"></span>}
          <a
            href={link.href}
            class="font-mono text-xs tracking-widest text-text-muted hover:text-primary transition-colors"
            data-astro-prefetch
          >
            {link.label}
          </a>
        </Fragment>
      ))}
    </div>

    <!-- Right cluster: theme toggle (all sizes) + mobile hamburger -->
    <div class="flex items-center gap-4">
      <button
        id="theme-toggle"
        type="button"
        class="theme-toggle text-text-muted hover:text-primary transition-colors"
        aria-label="Theme"
      >
        <svg class="ic-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2.5M12 19.5V22M4.2 4.2l1.8 1.8M18 18l1.8 1.8M2 12h2.5M19.5 12H22M4.2 19.8l1.8-1.8M18 6l1.8-1.8"/></svg>
        <svg class="ic-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="ic-system" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
      </button>

      <!-- Mobile hamburger — CSS-only disclosure. A visually-hidden checkbox is
           the real control; the <label> below toggles it. The menu open/close and
           the icon swap are driven purely by `#main-nav:has(...:checked)` CSS
           (style block at the bottom), so tapping works the instant the HTML
           paints — no wait for the deferred module bundle to execute, which is
           what made the menu feel laggy to open on slow mobile. JS is no longer
           required for the menu. -->
      <input id="mobile-menu-toggle" type="checkbox" class="sr-only" aria-label="Toggle menu" />
      <label
        for="mobile-menu-toggle"
        id="mobile-menu-btn"
        class="md:hidden text-text-muted hover:text-primary transition-colors cursor-pointer"
      >
        <svg id="hamburger-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="hidden">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </label>
    </div>
  </div>

  <!-- Mobile menu — opaque bg (no backdrop-blur). The blur was a GPU cost paid
       on every paint of the dropdown, which made it feel slow to open on real
       phones; a solid surface paints instantly. Shadow restores the depth the
       translucency used to give. Opened by the CSS at the bottom. -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface shadow-xl">
    <div class="px-6 py-4 flex flex-col gap-3">
      {links.map((link) => (
        <Fragment>
          {link.divider && <span class="h-px w-full bg-border my-1" aria-hidden="true"></span>}
          <a href={link.href} class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2" data-astro-prefetch>{link.label}</a>
        </Fragment>
      ))}
    </div>
  </div>
</nav>
  <!-- Post-confirm welcome bar (success state). Lives inside the fixed nav-wrapper
       so it joins the pinned overlay and the hero's existing nav-clearance adjusts
       for it automatically. Hidden by default; ConfirmBanner's script reveals it
       (session-persistent via sessionStorage). See src/components/ui/ConfirmBanner.astro. -->
  <div id="confirm-bar" role="status" aria-live="polite" class="hidden border-t border-accent/25 bg-accent-soft text-text">
    <div class="mx-auto flex max-w-7xl items-center justify-end gap-2.5 px-6 py-1.5">
      <svg class="shrink-0 text-accent" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
      <p class="text-sm leading-tight">
        <span class="font-semibold">You're in.</span> Welcome to the real build log.
      </p>
      <a
        id="confirm-bar-cta"
        href="/proof/"
        class="shrink-0 rounded-md bg-accent px-2.5 py-1 text-sm font-semibold text-accent-text transition-colors hover:bg-accent-hover"
      >See the proof →</a>
      <button
        id="confirm-bar-close"
        type="button"
        aria-label="Dismiss"
        class="-mr-1 shrink-0 cursor-pointer rounded p-0.5 text-text-dim transition-colors hover:text-text"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
      </button>
    </div>
  </div>
</div>

<style is:global>
  /* CSS-only mobile menu (see the markup above). The hidden checkbox's state
     opens the dropdown and swaps the hamburger/close icons with no JavaScript,
     so the menu responds the moment the page paints. Scoped to the mobile
     breakpoint so the desktop nav (md: and up) is never affected even if the
     checkbox is left checked when the viewport is resized. */
  @media (max-width: 767.98px) {
    #main-nav:has(#mobile-menu-toggle:checked) #mobile-menu { display: block; }
    #main-nav:has(#mobile-menu-toggle:checked) #hamburger-icon { display: none; }
    #main-nav:has(#mobile-menu-toggle:checked) #close-icon { display: block; }
  }
</style>

<script>
  function initNav() {
    // The mobile menu is now a pure-CSS disclosure (hidden checkbox + :has()),
    // so this script only handles the theme toggle and the scroll-blur — neither
    // of which the menu depends on. That keeps the menu working even before this
    // module executes.
    const nav = document.getElementById('main-nav');
    const navWrapper = document.getElementById('nav-wrapper');
    if (!nav || !navWrapper) return;

    // Three-way theme toggle — cycles light → dark → system → light, writing the
    // CHOICE to localStorage 'of-theme'. The no-FOUC script in <head> reads it
    // pre-paint and defaults new users to dark. data-theme-mode (the choice)
    // drives the icon (pure CSS); data-theme (resolved) drives the dark remap.
    const themeToggle = document.getElementById('theme-toggle');
    if (themeToggle) {
      const order = ['light', 'dark', 'system'];
      const mql = window.matchMedia('(prefers-color-scheme: dark)');
      const resolve = (mode) => (mode === 'system' ? (mql.matches ? 'dark' : 'light') : mode);
      const currentMode = () => document.documentElement.getAttribute('data-theme-mode') || 'dark';
      const apply = (mode) => {
        document.documentElement.setAttribute('data-theme-mode', mode);
        document.documentElement.setAttribute('data-theme', resolve(mode));
        const label = mode === 'system' ? 'System' : mode[0].toUpperCase() + mode.slice(1);
        themeToggle.setAttribute('aria-label', `Theme: ${label} (click to change)`);
        themeToggle.setAttribute('title', `Theme: ${label}`);
      };
      apply(currentMode());
      themeToggle.addEventListener('click', () => {
        const next = order[(order.indexOf(currentMode()) + 1) % order.length];
        try { localStorage.setItem('of-theme', next); } catch (e) {}
        apply(next);
      });
      // While in System mode, follow live OS theme changes.
      mql.addEventListener('change', () => {
        if (currentMode() === 'system') {
          document.documentElement.setAttribute('data-theme', resolve('system'));
        }
      });
    }

    // Scroll-triggered blur
    let scrolled = false;
    function onScroll() {
      const isScrolled = window.scrollY > 40;
      if (isScrolled !== scrolled) {
        scrolled = isScrolled;
        if (scrolled) {
          navWrapper.classList.add('bg-surface/80', 'backdrop-blur-md');
          nav.classList.add('border-border');
          nav.classList.remove('border-transparent');
        } else {
          navWrapper.classList.remove('bg-surface/80', 'backdrop-blur-md');
          nav.classList.remove('border-border');
          nav.classList.add('border-transparent');
        }
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Persistent magnet bar: reveal unless the user dismissed it (localStorage,
    // persists across sessions) or the post-confirm welcome bar is showing (they
    // already converted, so don't stack two bars). Dismissal is one click and
    // sticky, so the bar never nags a returning visitor.
    const magnetBar = document.getElementById('magnet-bar');
    if (magnetBar) {
      const DISMISSED = 'of-magnet-bar-dismissed';
      let dismissed = false;
      try { dismissed = localStorage.getItem(DISMISSED) === '1'; } catch (e) {}
      const confirmShowing =
        (() => { try { return sessionStorage.getItem('of-confirm-welcome') === '1'
          && sessionStorage.getItem('of-confirm-welcome-dismissed') !== '1'; } catch (e) { return false; } })();
      if (!dismissed && !confirmShowing) {
        magnetBar.classList.remove('hidden');
        const closeBtn = document.getElementById('magnet-bar-close');
        closeBtn && closeBtn.addEventListener('click', () => {
          try { localStorage.setItem(DISMISSED, '1'); } catch (e) {}
          magnetBar.classList.add('hidden');
        });
      }
    }
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
