---
// Orionfold top nav: parent mark + "Orionfold" wordmark ("fold" in primary),
// six section links (Sponsor reads as a plain link like the rest), mobile
// hamburger, and a scroll-triggered blur.
// Ported from the donor Nav, minus ThemeToggle and the in-nav social icon
// (social links live in the Footer per the spec).
// IA refocus 2026-06-13: nav leads with Arena (the Arena Field Edition home).
// "Cockpit" relabelled to "Arena" — the /cockpit/ URL is kept (no redirect churn,
// SEO equity retained) and the page leads with Arena + the Field Edition. Advisor
// dropped from the top nav (its /advisor/ page stays live + footer-linked for
// SEO/AEO). Arena takes pole position.
import BrandMark from './ui/BrandMark.astro';
const links = [
  { href: '/cockpit/', label: 'Arena' },
  { href: '/workflows/', label: 'Workflows' },
  { href: '/experts/', label: 'Experts' },
  { href: '/learn/', label: 'Learn' },
  { href: '/adoption/', label: 'Adoption' },
];
---
<div id="nav-wrapper" class="fixed top-0 left-0 right-0 z-40 transition-[background-color,backdrop-filter] duration-300">
  <nav id="main-nav" aria-label="Main navigation" class="border-b border-transparent transition-[border-color] duration-300">
  <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
    <a
      href="/"
      class="group inline-flex items-center gap-1.5 text-text transition-colors hover:text-primary -ml-1"
      aria-label="Orionfold home"
    >
      <BrandMark size={32} class="h-8 w-8" />
      <span class="text-2xl font-semibold tracking-tight leading-none">
        <span class="text-text">Orion</span><span class="text-primary">fold</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      {links.map((link) => (
        <a
          href={link.href}
          class="font-mono text-xs tracking-widest text-text-muted hover:text-primary transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Right cluster: theme toggle (all sizes) + mobile hamburger -->
    <div class="flex items-center gap-4">
      <button
        id="theme-toggle"
        type="button"
        class="theme-toggle text-text-muted hover:text-primary transition-colors"
        aria-label="Switch to dark theme"
        aria-pressed="false"
      >
        <svg class="ic-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="ic-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2.5M12 19.5V22M4.2 4.2l1.8 1.8M18 18l1.8 1.8M2 12h2.5M19.5 12H22M4.2 19.8l1.8-1.8M18 6l1.8-1.8"/></svg>
      </button>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-text-muted hover:text-primary transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="hamburger-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="hidden">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface/95 backdrop-blur-md">
    <div class="px-6 py-4 flex flex-col gap-3">
      {links.map((link) => (
        <a href={link.href} class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2">{link.label}</a>
      ))}
    </div>
  </div>
</nav>
</div>

<script>
  function initNav() {
    const nav = document.getElementById('main-nav');
    const navWrapper = document.getElementById('nav-wrapper');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');
    if (!nav || !navWrapper || !menuBtn || !mobileMenu || !hamburgerIcon || !closeIcon) return;

    // Theme toggle — writes localStorage 'of-theme'; the no-FOUC script in
    // <head> reads it pre-paint. Icon swap (sun/moon) is pure CSS off data-theme.
    const themeToggle = document.getElementById('theme-toggle');
    if (themeToggle) {
      const syncTheme = () => {
        const dark = document.documentElement.getAttribute('data-theme') === 'dark';
        themeToggle.setAttribute('aria-pressed', String(dark));
        themeToggle.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme');
      };
      syncTheme();
      themeToggle.addEventListener('click', () => {
        const dark = document.documentElement.getAttribute('data-theme') === 'dark';
        const next = dark ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('of-theme', next); } catch (e) {}
        syncTheme();
      });
    }

    // Scroll-triggered blur
    let scrolled = false;
    function onScroll() {
      const isScrolled = window.scrollY > 40;
      if (isScrolled !== scrolled) {
        scrolled = isScrolled;
        if (scrolled) {
          navWrapper.classList.add('bg-surface/80', 'backdrop-blur-md');
          nav.classList.add('border-border');
          nav.classList.remove('border-transparent');
        } else {
          navWrapper.classList.remove('bg-surface/80', 'backdrop-blur-md');
          nav.classList.remove('border-border');
          nav.classList.add('border-transparent');
        }
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Mobile menu toggle
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      hamburgerIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    // Close mobile menu on link click
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
