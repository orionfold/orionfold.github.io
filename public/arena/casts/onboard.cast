[9.45, "o", "\u001b[33m\u256d\u2500\u001b[0m\u001b[33m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[33m NGC API key needed \u001b[0m\u001b[33m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[33m\u2500\u256e\u001b[0m\r\n\u001b[33m\u2502\u001b[0m                                                                                                  \u001b[33m\u2502\u001b[0m\r\n\u001b[33m\u2502\u001b[0m  Your Cortex embedder needs a free NVIDIA NGC key (one-time).                                    \u001b[33m\u2502\u001b[0m\r\n\u001b[33m\u2502\u001b[0m                                                                                                  \u001b[33m\u2502\u001b[0m\r\n\u001b[33m\u2502\u001b[0m  Get one here: \u001b[4;36mhttps://org.ngc.nvidia.com/setup/api-keys\u001b[0m                                         \u001b[33m\u2502\u001b[0m\r\n\u001b[33m\u2502\u001b[0m                                                                                                  \u001b[33m\u2502\u001b[0m\r\n\u001b[33m\u2502\u001b[0m  Then paste it below. It is saved to ~/.nim/secrets.env on this box and never leaves it.         \u001b[33m\u2502\u001b[0m\r\n\u001b[33m\u2502\u001b[0m                                                                                                  \u001b[33m\u2502\u001b[0m\r\n\u001b[33m\u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[0m\r\n"]
