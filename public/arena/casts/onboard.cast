[3.2, "o", "\u001b[36m\u256d\u2500\u001b[0m\u001b[36m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[36m \u2726 Orionfold Arena \u00b7 Field Edition \u001b[0m\u001b[36m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[36m\u2500\u256e\u001b[0m\r\n\u001b[36m\u2502\u001b[0m                                                                                                  \u001b[36m\u2502\u001b[0m\r\n\u001b[36m\u2502\u001b[0m  \u001b[1mWelcome to your Arena.\u001b[0m                                                                          \u001b[36m\u2502\u001b[0m\r\n\u001b[36m\u2502\u001b[0m                                                                                                  \u001b[36m\u2502\u001b[0m\r\n\u001b[36m\u2502\u001b[0m  You are about to bring up your AI Researcher \u2014 a local model that reads your corpus and         \u001b[36m\u2502\u001b[0m\r\n\u001b[36m\u2502\u001b[0m  answers only from it, every time with sources. This guide will get a free key if you need one,  \u001b[36m\u2502\u001b[0m\r\n\u001b[36m\u2502\u001b[0m  download your model, and open the cockpit warm.                                                 \u001b[36m\u2502\u001b[0m\r\n\u001b[36m\u2502\u001b[0m                                                                                                  \u001b[36m\u2502\u001b[0m\r\n\u001b[36m\u2502\u001b[0m  \u001b[3mNothing leaves your box.\u001b[0m                                                                        \u001b[36m\u2502\u001b[0m\r\n\u001b[36m\u2502\u001b[0m                                                                                                  \u001b[36m\u2502\u001b[0m\r\n\u001b[36m\u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[0m\r\n"]
[5.95, "o", "\u001b[3m     Preflight \u2014 does this box match the tested matrix?     \u001b[0m\r\n\u250f\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2533\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2533\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2533\u2501\u2501\u2501\u2513\r\n\u2503\u001b[1m \u001b[0m\u001b[1mcheck                   \u001b[0m\u001b[1m \u001b[0m\u2503\u001b[1m \u001b[0m\u001b[1mfound     \u001b[0m\u001b[1m \u001b[0m\u2503\u001b[1m \u001b[0m\u001b[1mtested      \u001b[0m\u001b[1m \u001b[0m\u2503\u001b[1m \u001b[0m\u001b[1m \u001b[0m\u001b[1m \u001b[0m\u2503\r\n\u2521\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2547\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2547\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2547\u2501\u2501\u2501\u2529\r\n\u2502 DGX OS                   \u2502 7.4.0      \u2502 7.4.0        \u2502 \u001b[32m\u2713\u001b[0m \u2502\r\n\u2502 NVIDIA driver            \u2502 580.159.03 \u2502 580.159.03   \u2502 \u001b[32m\u2713\u001b[0m \u2502\r\n\u2502 CUDA runtime             \u2502 13.0       \u2502 13.0         \u2502 \u001b[32m\u2713\u001b[0m \u2502\r\n\u2502 Docker CE                \u2502 28.1.1     \u2502 preinstalled \u2502 \u001b[32m\u2713\u001b[0m \u2502\r\n\u2502 NVIDIA Container Toolkit \u2502 1.17.8     \u2502 preinstalled \u2502 \u001b[32m\u2713\u001b[0m \u2502\r\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u